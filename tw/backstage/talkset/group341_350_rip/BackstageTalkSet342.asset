{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet342","backstageTalkSetId":342,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet342-1","talkText":"奧澤同學，你會做羊毛氈對吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet342-2","talkText":"我會唷～。難道說\n燐子學姊，你有興趣嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet342-3","talkText":"對、對……不過……好像很難對吧……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet342-4","talkText":"不會不會，如果會做衣服\n我覺得這根本超簡單的唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}