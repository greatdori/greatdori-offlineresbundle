{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet344","backstageTalkSetId":344,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet344-1","talkText":"紗夜，你真早呢。\n練習是更晚才對吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet344-2","talkText":"我是在做自主練習。\n這麼說的湊同學你呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet344-3","talkText":"呵呵，我們想的事情\n是一樣的呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}