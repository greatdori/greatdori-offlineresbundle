{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet569","backstageTalkSetId":569,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet569-1","talkText":"明天是薰同學的\n生日呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet569-2","talkText":"生日禮物已經OK了\n還有要做其他準備嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet569-3","talkText":"就只剩用最棒的笑臉\n迎接薰的生日了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet569-4","talkText":"也對。驚喜成功的話\n就太好了呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}