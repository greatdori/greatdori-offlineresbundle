{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet570","backstageTalkSetId":570,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet570-1","talkText":"薰，生日快樂！\n我們來慶祝吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet570-2","talkText":"有好好記得我的生日呢，\n小貓咪們","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet570-3","talkText":"當然唷！\n請收下生日禮物！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet570-4","talkText":"是鮮花禮盒唷。\n感覺非常適合你","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet570-5","talkText":"順帶一提，\n米歇爾也有參與挑選過程唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet570-6","talkText":"多麼虛幻的生日禮物呀！\n我會好好珍惜的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}