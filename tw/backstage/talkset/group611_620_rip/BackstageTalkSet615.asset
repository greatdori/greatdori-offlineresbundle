{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet615","backstageTalkSetId":615,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet615-1","talkText":"来週、数学のテストだね～\n全然わかんないや","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet615-2","talkText":"私も。一緒に有咲に\n教えてもらおう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet615-3","talkText":"ついでに蔵で\nお泊まりしたいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet615-4","talkText":"うわーっ！　楽しみすぎて\n勉強どころじゃないよ〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}