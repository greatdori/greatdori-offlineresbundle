{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet697","backstageTalkSetId":697,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet697-1","talkText":"温かいチョココロネが\n食べたくなっちゃった……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet697-2","talkText":"なにそれ！？\nはぐみも食べたいなー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet697-3","talkText":"あ、揚げたらもーーっと\n美味しくなるかも！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet697-4","talkText":"揚げたてチョココロネ……\nめっちゃ美味しそう……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet697-5","talkText":"りみりん、今日帰りに家で\n揚げてみよー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}