{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet540","backstageTalkSetId":540,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet540-1","talkText":"小彩，生日快樂。\n這是要給你的禮物唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet540-2","talkText":"是髮圈耶～！\n亮晶晶的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet540-3","talkText":"欸嘿嘿，\n因為覺得很適合彩學姊所以！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet540-4","talkText":"除了可愛之外\n而且還亮晶晶的♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet540-5","talkText":"欸嘿嘿，好害羞哦～。\n謝謝你們兩位！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}