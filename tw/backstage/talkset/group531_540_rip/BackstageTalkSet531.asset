{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet531","backstageTalkSetId":531,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet531-1","talkText":"よーし、今年のクリスマス\nみんなの担当決めるよー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet531-2","talkText":"はーい、モカちゃんは\n食べるの担当がいいでーす","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet531-3","talkText":"却下。あたしモカと一緒に\n買い出し行ってくるよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet531-4","talkText":"じゃあアタシはツリーとか\n飾りつけやっておくよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet531-5","talkText":"じゃあ私とひまりちゃんが\n料理担当だね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet531-6","talkText":"今年も楽しんでいこ～！\nえい、えい、おー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}