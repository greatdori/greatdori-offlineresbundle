{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet537","backstageTalkSetId":537,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet537-1","talkText":"多惠同學，\n祝你生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet537-2","talkText":"生日禮物，我們選了一雙\n兔子拖鞋要送你","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet537-3","talkText":"好可愛！\n這個顏色和阿異一模一樣呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet537-4","talkText":"謝謝你們兩位！\n我會好好珍惜地使用的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}