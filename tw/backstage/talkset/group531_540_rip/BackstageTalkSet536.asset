{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet536","backstageTalkSetId":536,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet536-1","talkText":"生日快樂～\n惠惠！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet536-2","talkText":"哇，謝謝大家！\n……這個是，肉塊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet536-3","talkText":"答對了～！\n是肉塊造型的毛毯唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet536-4","talkText":"我們為了找這個，\n找了超久的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet536-5","talkText":"我們覺得你收到這個，\n絕對會非常開心","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet536-6","talkText":"嗯，我很開心哦！蓋著這個\n感覺會夢到滿山滿海的肉呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}