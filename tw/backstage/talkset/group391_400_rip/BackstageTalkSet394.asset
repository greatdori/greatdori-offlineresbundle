{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet394","backstageTalkSetId":394,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet394-1","talkText":"好熱～……\n好想吃冰啊～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet394-2","talkText":"其實啊，我們家店裡，\n開始賣剉冰了喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet394-3","talkText":"咦，真的嗎！？\n我一定要去！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet394-4","talkText":"呵呵，\n等你們來！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}