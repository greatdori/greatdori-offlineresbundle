{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet395","backstageTalkSetId":395,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet395-1","talkText":"啊，那是我們超商的\n夏天限定甜點對吧！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet395-2","talkText":"嗯，因為我很喜歡\n最近每天都會買喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet395-3","talkText":"那個很好吃對吧！\n我也很喜歡耶～♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}