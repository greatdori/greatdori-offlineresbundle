{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet393","backstageTalkSetId":393,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet393-1","talkText":"今天好熱啊……\n薰學姊還好嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet393-2","talkText":"呵呵，一切都是\n看你的心怎麼想喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet393-3","talkText":"熱的時候自己去想像\n雪山就可以了啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet393-4","talkText":"不、不愧是薰學姊……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}