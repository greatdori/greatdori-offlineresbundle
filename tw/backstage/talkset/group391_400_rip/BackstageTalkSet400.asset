{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet400","backstageTalkSetId":400,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet400-1","talkText":"你們以前有對電風扇做過\n啊～這樣發出聲音的事嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet400-2","talkText":"聲音會聽起來很奇怪對吧。\n我沒做過喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet400-3","talkText":"但是……日菜他到現在\n偶爾都還會這樣做呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet400-4","talkText":"啊哈哈……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}