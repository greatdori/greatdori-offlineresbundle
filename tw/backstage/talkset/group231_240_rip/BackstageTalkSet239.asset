{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet239","backstageTalkSetId":239,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet239-1","talkText":"我今天找到了感覺惠惠\n會喜歡的髮飾喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet239-2","talkText":"……！！我知道了。\n是兔子款的吧。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet239-3","talkText":"抱、抱歉……\n是吉他款的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}