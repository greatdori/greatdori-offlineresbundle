{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet234","backstageTalkSetId":234,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet234-1","talkText":"嗯～山吹烘焙坊的\n巧克力螺旋麵包超好吃。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet234-2","talkText":"里美吃起來\n感覺真的很享受呢。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}