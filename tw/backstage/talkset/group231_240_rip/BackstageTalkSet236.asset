{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet236","backstageTalkSetId":236,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet236-1","talkText":"啊，今天回家的時候\n順便去小綾那邊吧。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet236-2","talkText":"呵呵，那我就拜託爸爸\n做巧克力螺旋麵包囉。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}