{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet233","backstageTalkSetId":233,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet233-1","talkText":"昨天吃的筑前煮，\n真的超好吃的呢。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet233-2","talkText":"啊，我昨天晚餐\n也是吃筑前煮喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet233-3","talkText":"好巧喔～！我跟有咲\n吃飯的喜好應該很搭呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}