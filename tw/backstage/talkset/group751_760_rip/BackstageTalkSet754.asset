{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet754","backstageTalkSetId":754,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet754-1","talkText":"嗚哈～……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet754-2","talkText":"春天，為什麼這麼\n讓人想睡呢……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet754-3","talkText":"應該是因為……\n暖洋洋很舒服吧……？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet754-4","talkText":"作業也都告一段落了……\n要不要，睡個午覺呢……？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet754-5","talkText":"那……\n就，睡一下下好了……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}