{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet751","backstageTalkSetId":751,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet751-1","talkText":"之前，我和妹妹們一起參加\n了我家附近的馬拉松大賽","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet751-2","talkText":"雖然有點冷，但我們\n還是有一起跑完全程！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet751-3","talkText":"這是當時拍的照片！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet751-4","talkText":"哦哦，三姊妹手牽手\n跑進終點耶～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet751-5","talkText":"（認不出……\n紫紫到底是哪一個）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}