{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet757","backstageTalkSetId":757,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet757-1","talkText":"薰學姊，請問\n你在看什麼呢……？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet757-2","talkText":"你說這個嗎？\n這是我的虛幻詩集喔","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet757-3","talkText":"我有寫了一些\n以春天為題的詩篇","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet757-4","talkText":"哇，我也可以\n和學姊一起看嗎……？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}