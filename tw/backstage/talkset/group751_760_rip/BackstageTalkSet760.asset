{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet760","backstageTalkSetId":760,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet760-1","talkText":"演技的重點是，去貼\n近角色，再表現出來","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet760-2","talkText":"我也可以做到嗎……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet760-3","talkText":"當然可以。\n來嘗試看看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet760-4","talkText":"那總之，先來演個\n被囚禁的公主吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet760-5","talkText":"我相信某天一定\n會有王子來救窩！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet760-6","talkText":"真是一位有活力的公主。\n王子一定會馬上前來的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}