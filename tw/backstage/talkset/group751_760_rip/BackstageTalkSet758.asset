{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet758","backstageTalkSetId":758,"snippets":[{"talkId":1,"characterIds":[32],"voiceId":"TalkSet758-1","talkText":"八潮同學，我有問題！\n以《春》著名的……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet758-2","talkText":"你是指韋瓦第嗎","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[32],"voiceId":"TalkSet758-3","talkText":"咦咦！？　為什麼\n你只聽剛才那個就知道！？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet758-4","talkText":"這是基本常識喔","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}