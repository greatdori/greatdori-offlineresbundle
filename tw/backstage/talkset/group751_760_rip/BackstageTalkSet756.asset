{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet756","backstageTalkSetId":756,"snippets":[{"talkId":1,"characterIds":[34],"voiceId":"TalkSet756-1","talkText":"唉～。春天的小芙\n也超級可愛的～！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet756-2","talkText":"咦？　春天的我和其他\n季節的我不一樣嗎？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[34],"voiceId":"TalkSet756-3","talkText":"當然不一樣啊～！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet756-4","talkText":"每一分每一秒的小芙\n都是不同的小芙！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet756-5","talkText":"原來如此……！　這是，\n「諸行無常」的意思對吧！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}