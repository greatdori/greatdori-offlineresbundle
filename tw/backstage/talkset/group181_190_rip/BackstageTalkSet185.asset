{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet185","backstageTalkSetId":185,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet185-1","talkText":"湊同學，你在做什麼呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet185-2","talkText":"有一個推播都消不掉。這是為什麼呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet185-3","talkText":"原因出在哪裡呢？來查看看好了。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet185-4","talkText":"亞子也要幫忙查！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet185-5","talkText":"那麼，我也來查看看……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21,22,24,25],"voiceId":"TalkSet185-6","talkText":"……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet185-7","talkText":"（大家都在看手機……現在是怎樣？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}