{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet777","backstageTalkSetId":777,"snippets":[{"talkId":1,"characterIds":[31],"voiceId":"TalkSet777-1","talkText":"我想買新的皮衣","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet777-2","talkText":"哇～！　學姊要買秋裝嗎！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet777-3","talkText":"LOCK最後也有買猶豫\n很久的那件針織衫吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[32],"voiceId":"TalkSet777-4","talkText":"是的！　因為真的太可愛了\n所以我最近很常穿他","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet777-5","talkText":"嗯。你上次穿的時候\n看起來真的很適合你","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}