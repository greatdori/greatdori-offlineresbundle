{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet774","backstageTalkSetId":774,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet774-1","talkText":"小千你看！　這家咖啡廳\n已經開賣秋季餐點了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet774-2","talkText":"對耶，看起來真好吃。\n是在車站附近的店吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet774-3","talkText":"嗯！　啊，上面說現在\n露臺區是賞楓的好時機","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet774-4","talkText":"呵呵，那我們下次\n一起過去看看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet774-5","talkText":"好耶～！\n下禮拜練習前怎麼樣？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}