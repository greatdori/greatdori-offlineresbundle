{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet773","backstageTalkSetId":773,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet773-1","talkText":"盆栽們終於慢慢\n從酷暑中回復活力了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet773-2","talkText":"太好了，他們又有精神了。\n這樣暫時可以安心了吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet773-3","talkText":"還不行，接下來要\n準備幫盆栽過冬了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet773-4","talkText":"真的閒不下來耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}