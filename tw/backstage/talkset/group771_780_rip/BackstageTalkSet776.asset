{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet776","backstageTalkSetId":776,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet776-1","talkText":"鏘鏘－！\n育美去撿了橡果喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet776-2","talkText":"太棒了！\n滿到快從袋子溢出來了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet776-3","talkText":"啊！　對了！　\n來在橡果上畫表情吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet776-4","talkText":"好耶！　那先把\n他們拿出來排好吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}