{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet779","backstageTalkSetId":779,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet779-1","talkText":"那個，LOCK，\n我問你喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet779-2","talkText":"「咕哇－！」的聲音跟\n「沙啷～……」的聲音","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet779-3","talkText":"哪個比較好啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[32],"voiceId":"TalkSet779-4","talkText":"咦？　我想想喔……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet779-5","talkText":"香澄學姊彈的話\n兩個都很棒！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet779-6","talkText":"欸嘿嘿～，都很好嗎～\n謝謝你喔，LOCK～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}