{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50004","backstageTalkSetId":50004,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet50004-1","talkText":"小日菜，\n祝你生日快樂","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50004-2","talkText":"這邊的是生日禮物！\n請打開看看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50004-3","talkText":"哇～！謝謝大家～！\n有好多東西呢～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50004-4","talkText":"是彩學姊的點子！\n低調的外出服裝！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet50004-5","talkText":"首先，帽子是\n伊芙同學送的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet50004-6","talkText":"衣服是\n千聖學姊和彩學姊選的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[16],"voiceId":"TalkSet50004-7","talkText":"墨鏡呢\n是和我一樣的款式喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet50004-8","talkText":"我們也稍微有知名度了\n出門時變裝一下比較好喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet50004-9","talkText":"其實就算被發現了\n也沒關係的說～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50004-10","talkText":"不過感覺很好玩\n我馬上來穿看看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[17],"voiceId":"TalkSet50004-11","talkText":"華麗登場～！\n看起來怎麼樣啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet50004-12","talkText":"哇～！\n非常適合唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}