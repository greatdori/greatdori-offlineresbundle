{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50001","backstageTalkSetId":50001,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet50001-1","talkText":"紗夜收到禮物\n會不會很開心呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50001-2","talkText":"亞子覺得這個一定\n超適合紗夜學姊的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet50001-3","talkText":"畢竟大家都說了\n就只能選那個了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet50001-4","talkText":"要是能被好好珍惜的話……\n真的會讓人非常開心呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}