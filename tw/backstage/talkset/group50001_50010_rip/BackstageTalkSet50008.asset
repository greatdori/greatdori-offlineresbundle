{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50008","backstageTalkSetId":50008,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet50008-1","talkText":"千聖學姊！\n祝你生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50008-2","talkText":"我們準備了非常特別的\n生日禮物！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50008-3","talkText":"謝謝大家。\n到底是什麼呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50008-4","talkText":"彩學姊，日菜學姊！\n麻煩你們了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50008-5","talkText":"好～～！\n小千生日快樂～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet50008-6","talkText":"生日禮物是……\n這邊的紅茶套組？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50008-7","talkText":"沒錯！我們覺得\n這個非常適合千聖同學！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[20],"voiceId":"TalkSet50008-8","talkText":"今天請務必\n讓我們來為你服務！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[16],"voiceId":"TalkSet50008-9","talkText":"為了今天\n我練習了上百次喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50008-10","talkText":"小千快看快看～！\n準備，我拉～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[16],"voiceId":"TalkSet50008-11","talkText":"嗚哇哇哇！\n看，看招！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50008-12","talkText":"呵呵，好令人吃驚呀。\n真的非常謝謝大家用心準備","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}