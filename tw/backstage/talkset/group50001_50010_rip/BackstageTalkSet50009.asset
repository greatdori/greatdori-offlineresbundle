{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50009","backstageTalkSetId":50009,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50009-1","talkText":"明天就是蘭的生日了\n大家都做好準備了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet50009-2","talkText":"聽到「預備！」的時候\n大家就要開始哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50009-3","talkText":"放心交給我吧！\n謝謝大家的幫忙","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50009-4","talkText":"禮物也\n準備好了對吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50009-5","talkText":"小緋的品味～\n讓人好期待唷～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}