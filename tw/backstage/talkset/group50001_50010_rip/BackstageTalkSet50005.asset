{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50005","backstageTalkSetId":50005,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet50005-1","talkText":"終於要到明天了\n里美琳的生日","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50005-2","talkText":"惠惠，謝謝你\n做了禮物的事前調查","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50005-3","talkText":"不會喔。\n其實是有咲發現的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50005-4","talkText":"拿在手上的時候，\n真的很可怕就是了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[1],"voiceId":"TalkSet50005-5","talkText":"場地的準備也就定位了\n好期待明天呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}