{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50007","backstageTalkSetId":50007,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet50007-1","talkText":"明天就是千聖學姊的\n生日呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50007-2","talkText":"日菜同學的計畫，\n能夠順利進行就好了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet50007-3","talkText":"嗯嗯，現在就\n讓人好緊張……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet50007-4","talkText":"都已經練習了那麼多次了\n沒問題，沒問～題的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50007-5","talkText":"就算失敗了，\n也完全是小彩的風格呀！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}