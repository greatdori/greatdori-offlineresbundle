{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet245","backstageTalkSetId":245,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet245-1","talkText":"啊啊……\n這是多麼虛幻。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet245-2","talkText":"薰、薰學姊，\n你怎麼了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet245-3","talkText":"嗯，我是在看\n心推薦給我的書……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet245-4","talkText":"（他、他在哭……\n是那麼感人的故事啊。）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}