{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet244","backstageTalkSetId":244,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet244-1","talkText":"我這邊有多出來的麵包……\n不介意的話，你要吃嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet244-2","talkText":"謝謝你。啊啊……\n這是多麼香甜的氣味啊。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet244-3","talkText":"那、那個……\n這是咖哩麵包耶。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet244-4","talkText":"呵呵……即使如此，\n味道還是香甜的啊。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}