{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2024","backstageTalkSetId":2024,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2024-1","talkText":"…………","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2024-2","talkText":"怎麼了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2024-3","talkText":"瑠唯同學一定\n很喜歡牛奶之類的吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2024-4","talkText":"不討厭也不喜歡，\n為什麼這麼問？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2024-5","talkText":"沒是喔！　就是想問看看！\n啊哈哈……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[29],"voiceId":"TalkSet2024-6","talkText":"原來不是靠牛奶\n長高的啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[26],"voiceId":"TalkSet2024-7","talkText":"（我懂你的心情喔，\n小紫……！）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}