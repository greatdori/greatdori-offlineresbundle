{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2023","backstageTalkSetId":2023,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2023-1","talkText":"哇啊～，這些餅乾\n看起來好好吃耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2023-2","talkText":"可以拿一個來吃嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2023-3","talkText":"哇啊！　不行不行！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2023-4","talkText":"這些，\n是我做的裝飾品！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet2023-5","talkText":"咦？　這些是假的！？\n真的假的啦！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet2023-6","talkText":"就算這麼靠近看，\n還是覺得他們就是餅乾……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}