{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2027","backstageTalkSetId":2027,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2027-1","talkText":"下次做演出服，\n用這種設計怎麼樣？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2027-2","talkText":"這個好帥！\n瑠唯同學覺得呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2027-3","talkText":"只要是普通能穿上的衣服的話，\n什麼樣式都可以","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2027-4","talkText":"出現了！\n瑠唯，每次都這樣說－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[30],"voiceId":"TalkSet2027-5","talkText":"不過……右手袖子的設計\n我希望可以簡潔一些","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2027-6","talkText":"哦！少見的發言！\n雖然是沒差，但為何？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[30],"voiceId":"TalkSet2027-7","talkText":"因為會干擾演奏","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[29],"voiceId":"TalkSet2027-8","talkText":"這，這也是\n很重要的部分呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}