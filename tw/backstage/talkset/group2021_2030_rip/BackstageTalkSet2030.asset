{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2030","backstageTalkSetId":2030,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2030-1","talkText":"欸嘿嘿ー♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2030-2","talkText":"紫紫心情很不錯哦！\n唯唯，你知道發生什麼了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2030-3","talkText":"我們來這裡的路上，\n被陌生人問路了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2030-4","talkText":"是問我的哦！　也就是說\n我看起來很值得信賴對吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2030-5","talkText":"（那是因為唯唯\n看起來很難親近……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet2030-6","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2030-7","talkText":"哼哼♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2030-8","talkText":"（不過，不要說穿好了）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}