{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2032","backstageTalkSetId":2032,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2032-1","talkText":"啊，是透透和唯唯耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2032-2","talkText":"你們兩位在做什麼呢－？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2032-3","talkText":"這不是七深嗎！\n……話說，瑠唯竟然也在！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2032-4","talkText":"我才想問你們，\n是什麼時候在這裡的？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2032-5","talkText":"咦，你們兩位\n竟然沒查覺到彼此都在嗎！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}