{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2035","backstageTalkSetId":2035,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2035-1","talkText":"我想和大家一起\n進行團練的宿營～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2035-2","talkText":"好像很好玩喔！\n現在就開始吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2035-3","talkText":"現、現在的話有點太趕了，\n不過我也想參加","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2035-4","talkText":"如果這樣能讓練習的品質\n提高，我也不介意","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2035-5","talkText":"宿營的餐點就交給我吧！\n我對煮飯很有自信！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2035-6","talkText":"二之助自信滿滿的樣子\n反而讓人好不安……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2035-7","talkText":"什麼～竟然這麼說\n小透沒有飯吃了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}