{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2037","backstageTalkSetId":2037,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2037-1","talkText":"這次一定要認真提出\n讓人火熱的LIVE相關的意見哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2037-2","talkText":"上次大家討論到一半\n就開始亂開玩笑了呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2037-3","talkText":"從舞台後面\n射出雷射光怎麼樣呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2037-4","talkText":"哦，很不錯！\n很帥！　採用～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2037-5","talkText":"噴出煙霧，\n感覺也很帥氣呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2037-6","talkText":"這個也很讚！\n採用～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[30],"voiceId":"TalkSet2037-7","talkText":"我認為比起特效\n我們更應該用演奏取勝","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[27],"voiceId":"TalkSet2037-8","talkText":"這個才是最帥的呢！\n瑠唯的提案也被採用了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet2037-9","talkText":"剛剛那個比起說是提案，\n不如說更像提醒吧……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}