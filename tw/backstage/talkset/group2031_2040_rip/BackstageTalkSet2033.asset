{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2033","backstageTalkSetId":2033,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2033-1","talkText":"啊，對了\n這些，是要分給大家的伴手禮","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2033-2","talkText":"謝謝，是巧克力耶\n看起來好好吃","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2033-3","talkText":"啊，我知道這個！\n是很有名的店對吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2033-4","talkText":"沒有錯喔－，我這周末\n去了比利時一趟","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2033-5","talkText":"這是國外的伴手禮嘛！？\n好、好厲害……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2033-6","talkText":"會嗎？\n總之，大家一起吃吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet2033-7","talkText":"這個，真的很好吃對吧～。\n我也很喜歡","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[30],"voiceId":"TalkSet2033-8","talkText":"我下周也會出國\n我也會買點東西回來","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[26],"voiceId":"TalkSet2033-9","talkText":"大家真的都是千金小姐呢\n這種感覺真是久違了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}