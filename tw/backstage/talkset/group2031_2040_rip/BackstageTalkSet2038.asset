{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2038","backstageTalkSetId":2038,"snippets":[{"talkId":1,"characterIds":[32],"voiceId":"TalkSet2038-1","talkText":"這是從我老家那邊寄來的，\n請享用！　這叫做五平餅！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet2038-2","talkText":"哇啊！　看起來真好吃～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[32],"voiceId":"TalkSet2038-3","talkText":"我爸媽說要我送給\n照顧我的人","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet2038-4","talkText":"所以就拿來給我了嗎！？\nLOCK、謝謝－－！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}