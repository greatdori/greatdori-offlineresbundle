{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2039","backstageTalkSetId":2039,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet2039-1","talkText":"原來是這樣。\n用了非常高級的沙發呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[33],"voiceId":"TalkSet2039-2","talkText":"桌子是……\n居然是玻璃製的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet2039-3","talkText":"進度如何？\nLIVE House的評鑑還順利嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet2039-4","talkText":"也叫Galaxy來做幾個\n這樣的小房間好了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}