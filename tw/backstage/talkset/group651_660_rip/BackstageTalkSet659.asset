{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet659","backstageTalkSetId":659,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet659-1","talkText":"聽著鈴蟲的鳴聲\n讓人心情非常平靜呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet659-2","talkText":"鈴蟲的鳴聲……\n以及，淡淡的月光……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet659-3","talkText":"兩者合而為一，非常有情調呢。\n啊啊……好虛幻……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}