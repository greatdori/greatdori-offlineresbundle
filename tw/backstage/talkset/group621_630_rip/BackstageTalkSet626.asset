{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet626","backstageTalkSetId":626,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet626-1","talkText":"這件T恤，好像不錯","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet626-2","talkText":"哦哦－，\n看起來很適合蘭喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet626-3","talkText":"小卡呢，\n就選這邊這件不同色的好了～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet626-4","talkText":"……也行，我沒有意見。\n再逛回去看看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}