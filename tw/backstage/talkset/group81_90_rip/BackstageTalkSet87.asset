{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet87","backstageTalkSetId":87,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet87-1","talkText":"米歇爾〜！\n我們出去玩吧！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet87-2","talkText":"不，我想要\n把衣服換掉啊……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet87-3","talkText":"那我就等米歇爾你\n把衣服換完喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet87-4","talkText":"我覺得他應該\n不是這個意思才對喔……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet87-5","talkText":"育美我，今天想要\n去吃飯耶～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet87-6","talkText":"（趕快讓我換衣服啊……）","lipAnimation":"","fontColorType":0,"fontSizeType":1,"balloonType":2}]}}