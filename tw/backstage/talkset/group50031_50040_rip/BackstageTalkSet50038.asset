{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50038","backstageTalkSetId":50038,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50038-1","talkText":"白金同學，\n祝你生日快樂","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50038-2","talkText":"今天呢，我們準備了\n超帥氣的蛋糕哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet50038-3","talkText":"帥氣的……\n蛋糕……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50038-4","talkText":"鏘鏘－！　請看！\n特製蛋糕！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50038-5","talkText":"好、好驚人……啊，\n這枝法杖莫非是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50038-6","talkText":"NFO裡也有出現\n這隻法杖沒錯吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet50038-7","talkText":"是、是的……\n還原度非常高……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[23],"voiceId":"TalkSet50038-8","talkText":"那個，燐子！\n把這枝法杖拔起來看看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[25],"voiceId":"TalkSet50038-9","talkText":"好、好的……！\n嘿……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50038-10","talkText":"哇啊－！　燐燐！\n超帥氣的耶－！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}