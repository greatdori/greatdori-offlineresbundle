{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50037","backstageTalkSetId":50037,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet50037-1","talkText":"明天是燐子生日呢。\n亞子，謝謝你準備了這麼多","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50037-2","talkText":"欸嘿嘿，\n因為我也想讓燐燐開心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50037-3","talkText":"呵呵，請亞子幫忙\n真的是對的選擇呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50037-4","talkText":"是啊，真期待\n白金同學明天的反應","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}