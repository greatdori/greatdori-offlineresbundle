{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50040","backstageTalkSetId":50040,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50040-1","talkText":"蘭－！　小鶇－！\n看鏡頭，微笑！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet50040-2","talkText":"哇啊，嚇我一跳！\n好哦，微笑……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet50040-3","talkText":"緋瑪麗，從剛剛\n就拍了好幾張了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50040-4","talkText":"當然要啊！\n因為我超開心的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50040-5","talkText":"摩卡和巴也來！\n看鏡頭，微笑！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet50040-6","talkText":"耶伊，小緋\n恭喜恭喜～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50040-7","talkText":"對了，既然機會難得\n大家要不要一起拍一張呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[8],"voiceId":"TalkSet50040-8","talkText":"我贊成！　大家靠過來\n近一點！　好哦微笑！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[10],"voiceId":"TalkSet50040-9","talkText":"你喜歡我們準備的禮物\n真是太好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50040-10","talkText":"對啊！　我一定會好好\n珍惜這個兒童相機！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}