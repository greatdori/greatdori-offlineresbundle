{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50032","backstageTalkSetId":50032,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50032-1","talkText":"摩卡，生日快樂\n這是今年的禮物","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet50032-2","talkText":"我們一起想出了\n摩卡收到會開心的東西哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet50032-3","talkText":"嗯嗯～？\n這、這個是……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50032-4","talkText":"特特特大號麵包！　怎麼樣？\n有沒有嚇一跳！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50032-5","talkText":"嚇了好～大一跳～\n我長年的心願終於實現了～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50032-6","talkText":"我們也有準備果醬\n盡量吃喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50032-7","talkText":"這樣，暫時就不用\n煩惱麵包不夠了吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet50032-8","talkText":"不過啊\n小綾也嚇了一跳了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet50032-9","talkText":"畢竟也說了\n「第一次看到這麼大的麵包」","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50032-10","talkText":"啊哈哈……什麼！\n摩卡已經吃完了嘛！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50032-11","talkText":"我就知道會這樣……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[7],"voiceId":"TalkSet50032-12","talkText":"我的胃啊\n已經是５次元空間了哦～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}