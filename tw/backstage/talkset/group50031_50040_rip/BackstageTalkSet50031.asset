{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50031","backstageTalkSetId":50031,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50031-1","talkText":"禮物的準備\n這樣就無懈可擊了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet50031-2","talkText":"請沙綾幫忙真的沒錯呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet50031-3","talkText":"這麼大的\n我還是第一次看到","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet50031-4","talkText":"但如果是摩卡\n大概瞬間就會吃掉了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}