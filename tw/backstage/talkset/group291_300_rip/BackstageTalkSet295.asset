{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet295","backstageTalkSetId":295,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet295-1","talkText":"昨天久違地，\n有天文社的活動喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet295-2","talkText":"我找到一等星以後，\n就有了嚕♪的感覺耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet295-3","talkText":"哎呀，真湊巧耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet295-4","talkText":"我昨天啊，\n也有找到一等星唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}