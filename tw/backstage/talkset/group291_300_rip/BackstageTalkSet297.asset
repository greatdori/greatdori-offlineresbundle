{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet297","backstageTalkSetId":297,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet297-1","talkText":"薰薰你，為什麼\n會想要演戲呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet297-2","talkText":"這個啊，是因為\n舞台在呼喚著我啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet297-3","talkText":"啊哈哈，薰薰你\n果然很有趣耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}