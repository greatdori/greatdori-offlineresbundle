{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet299","backstageTalkSetId":299,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet299-1","talkText":"小莉莎，你今天\n聞起來比平常還香耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet299-2","talkText":"真的嗎？因為我換了\n比較好一點的洗髮精了唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}