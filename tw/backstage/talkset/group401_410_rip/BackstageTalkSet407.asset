{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet407","backstageTalkSetId":407,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet407-1","talkText":"小芙，生日快樂～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet407-2","talkText":"祝你生日快樂～！這是給你的禮物喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet407-3","talkText":"哇啊，謝謝你們！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet407-4","talkText":"快點拆開來看吧！會覺得嚕♪喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet407-5","talkText":"這是……日本城堡的模型呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet407-6","talkText":"呵呵，你好像很開心，真是太好了♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}