{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet410","backstageTalkSetId":410,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet410-1","talkText":"你今天沒有跟\nPopipa的大家一起嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet410-2","talkText":"對，我覺得偶爾像這樣\n一個人獨處的時間也很重要","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet410-3","talkText":"的確，\n可能就如你所說的呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet410-4","talkText":"雖是這麼說，但馬上\n就又想要見面了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}