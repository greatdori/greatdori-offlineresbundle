{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet357","backstageTalkSetId":357,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet357-1","talkText":"今天舞蹈社的練習，\n做得很好嘛","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet357-2","talkText":"耶嘿嘿，真的嗎！？……不對","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet357-3","talkText":"只要有我這暗黑之力，唔嗯……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet357-4","talkText":"嗚嗚～找不到好的\n句子啦～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}