{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet351","backstageTalkSetId":351,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet351-1","talkText":"聽說昨天，你跟日菜\n出門了是嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet351-2","talkText":"是啊……你從日菜那聽說的嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet351-3","talkText":"嗯，他非常興奮。\n跟我說了好幾次耶～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet351-4","talkText":"日菜，看起來好像\n真的很開心耶～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}