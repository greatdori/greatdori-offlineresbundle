{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet745","backstageTalkSetId":745,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet745-1","talkText":"休息室，\n真的好舒服喔～","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet745-2","talkText":"我也這麼覺得，我偶爾在\n不用練習的時候也會來","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet745-3","talkText":"……啊，對了！\n乾脆也在學校蓋一個好了！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet745-4","talkText":"……咦咦！？\n那絕對行不通啦～！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}