{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet750","backstageTalkSetId":750,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet750-1","talkText":"今年的流行語\n已經被決定了嗎－？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet750-2","talkText":"不曉得耶。\n今年會是哪些呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet750-3","talkText":"我的流行語\n已經確定了喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet750-4","talkText":"是「姐姐！」","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet750-5","talkText":"……別說這種傻話，\n我要回去了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[17],"voiceId":"TalkSet750-6","talkText":"啊－，等一下，\n姐姐等等我－！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}