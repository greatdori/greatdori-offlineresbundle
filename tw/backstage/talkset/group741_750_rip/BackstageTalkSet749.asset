{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet749","backstageTalkSetId":749,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet749-1","talkText":"冬天騎車不會\n很冷嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[33],"voiceId":"TalkSet749-2","talkText":"雖然會冷，但空氣\n很清新所以很舒服喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet749-3","talkText":"原來是這樣！\n那是怎樣的感覺啊－？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet749-4","talkText":"我下次讓你坐後座","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet749-5","talkText":"真的嗎！？\n好耶－！　好棒喔－！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}