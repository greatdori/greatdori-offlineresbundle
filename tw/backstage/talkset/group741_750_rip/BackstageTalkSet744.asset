{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet744","backstageTalkSetId":744,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet744-1","talkText":"學姊在看什麼啊－？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet744-2","talkText":"玩偶的照片喔。\n我找了蠻多的－","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet744-3","talkText":"我在想下次和美咲做\n手工藝的時候要做什麼～","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet744-4","talkText":"原來如此……這樣的話，\n我很推薦瑪麗喔！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet744-5","talkText":"啊，商店街那隻兔子嗎？\n感覺有點難度但好像不錯喔！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet744-6","talkText":"完成之後請學姊也\n一定要拿給我看喔！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}