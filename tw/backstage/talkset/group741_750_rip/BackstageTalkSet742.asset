{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet742","backstageTalkSetId":742,"snippets":[{"talkId":1,"characterIds":[31],"voiceId":"TalkSet742-1","talkText":"白金學姊，那本漫畫\n該不會是……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet742-2","talkText":"是《小響弦》……\n小亞推薦我看的……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet742-3","talkText":"其實……你看\n我也和益木借了","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet742-4","talkText":"真的很可愛對吧……\n譬如說這個故事……！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet742-5","talkText":"啊，我也很喜歡這裡！\n我們一起接著看下去吧？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[25],"voiceId":"TalkSet742-6","talkText":"好的……一起看吧……！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}