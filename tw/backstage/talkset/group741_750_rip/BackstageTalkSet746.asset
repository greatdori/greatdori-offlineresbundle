{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet746","backstageTalkSetId":746,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet746-1","talkText":"花音學姊，好慢喔……\n會不會是在哪邊迷路了啊","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet746-2","talkText":"咦？　奧澤同學，\n你在等花音學姊嗎？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet746-3","talkText":"嗯，原本這時候早就\n應該要到了……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet746-4","talkText":"……我剛才有看到\n他好像正要走進車站","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet746-5","talkText":"居然，那我要快\n追上他才行……！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet746-6","talkText":"奧澤同學也過得\n很不容易呢……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}