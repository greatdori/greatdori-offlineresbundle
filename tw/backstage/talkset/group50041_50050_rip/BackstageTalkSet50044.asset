{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50044","backstageTalkSetId":50044,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50044-1","talkText":"小咲，\n祝你生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet50044-2","talkText":"有咲，這給你！\n是我們親手做的留言板哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50044-3","talkText":"我們一起寫了很多\n想讓告訴有咲的事哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50044-4","talkText":"謝，謝了……\n這讓人很害羞耶……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50044-5","talkText":"這個留言板\n是香澄提案要做的喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet50044-6","talkText":"明明有學生會的工作要忙\n卻又總是為我們付出許多","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2],"voiceId":"TalkSet50044-7","talkText":"即使是困難的樂句\n也不會敷衍了事","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50044-8","talkText":"而且總是非常\n掛心著我們大家呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet50044-9","talkText":"謝謝你這麼\n重視Popipa！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet50044-10","talkText":"……又沒什麼\n做到這些是理所當然的吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1],"voiceId":"TalkSet50044-11","talkText":"哇啊！　有咲沒在鬧彆扭！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[5],"voiceId":"TalkSet50044-12","talkText":"囉，囉嗦！\n偶爾這樣也還好吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}