{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50043","backstageTalkSetId":50043,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50043-1","talkText":"就是明天了呢……！\n嗚嗚，好緊張哦～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50043-2","talkText":"要是我們的心意能\n傳達給有咲就好了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50043-3","talkText":"只要寫下平時所想的\n就一定沒問題","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet50043-4","talkText":"惠惠說的沒錯！\n等等哦，有咲～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}