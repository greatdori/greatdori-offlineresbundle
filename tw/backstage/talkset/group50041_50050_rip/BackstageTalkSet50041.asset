{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50041","backstageTalkSetId":50041,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50041-1","talkText":"明天……是友希那同學\n的生日，真令人期待……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50041-2","talkText":"對啊，莉莎姊的點子\n真的超級棒！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50041-3","talkText":"是，是嗎？\n友希那也開心的話就好了～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50041-4","talkText":"我覺得像那樣慶祝\n也非常不錯","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}