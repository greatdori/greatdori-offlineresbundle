{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50042","backstageTalkSetId":50042,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50042-1","talkText":"湊同學，辛苦了\n這是點心和……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet50042-2","talkText":"蜂蜜茶……\n請享用，希望你喜歡……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet50042-3","talkText":"謝謝你們兩個。\n香氣非常棒呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50042-4","talkText":"亞子來幫你搥背！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50042-5","talkText":"還有這個！　是傳說中的\n療癒系影片哦－☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50042-6","talkText":"（貓咪的影片剪輯……！？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet50042-7","talkText":"……不對，今天突然間\n大家到底是怎麼了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50042-8","talkText":"友希那學姊！\n今天不是你生日嗎！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50042-9","talkText":"所以我們今天想讓\n友希那放鬆一下","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet50042-10","talkText":"要維持演出的品質\n適當的休息也是必要的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50042-11","talkText":"如果有希望我們做的\n請儘管告訴我們……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet50042-12","talkText":"原來是這樣啊。\n謝謝你們，我很開心","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}