{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50046","backstageTalkSetId":50046,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50046-1","talkText":"我們要讓過生日的小彌\n玩這個！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50046-2","talkText":"飛鏢挑戰賽！\n射中才有禮物喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet50046-3","talkText":"至於是什麼禮物\n要看顏色來決定","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50046-4","talkText":"綠色是括香瓶\n紅色是票匣","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50046-5","talkText":"然後藍色是馬克杯\n小彌，加油吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet50046-6","talkText":"好，好的！　我會加油！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50046-7","talkText":"我射！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50046-8","talkText":"哦哦！　射中綠色\n所以禮物是括香瓶喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50046-9","talkText":"麻彌學姊真厲害！\n居然一發就中了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet50046-10","talkText":"小菜，我問你喔。\n射下的禮物要怎麼辦？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[17],"voiceId":"TalkSet50046-11","talkText":"當然是全都要\n送給小彌啊～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[19],"voiceId":"TalkSet50046-12","talkText":"咦咦！？\n謝，謝謝大家……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}