{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet317","backstageTalkSetId":317,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet317-1","talkText":"我想到了下一場\nLIVE的點子喔！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet317-2","talkText":"真不愧是心耶。\n請務必讓我聽聽","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet317-3","talkText":"是在晚上學校裡的頂樓，\n和星星一起演奏喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet317-4","talkText":"與星空一同演奏出\n共鳴……虛幻啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}