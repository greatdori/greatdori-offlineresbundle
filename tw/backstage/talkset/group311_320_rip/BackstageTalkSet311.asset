{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet311","backstageTalkSetId":311,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet311-1","talkText":"奥澤同學，DJ的練習\n應該要怎麼做啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet311-2","talkText":"你問我要怎麼做喔……\n就是看看厲害的人……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet311-3","talkText":"嗯～……我好像只有做一些，\n很普通的事情耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet311-4","talkText":"原來如此！也就是說\n基本工是最重要的呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}