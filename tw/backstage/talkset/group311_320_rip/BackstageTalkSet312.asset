{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet312","backstageTalkSetId":312,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet312-1","talkText":"高中生就能當鼓手……\n大和同學好厲害啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet312-2","talkText":"不、不是那麼\n厲害的事情啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet312-3","talkText":"跟米歇爾小姐比起來\n自己這樣根本……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet312-4","talkText":"不不不！反而我這，\n才是一點都不厲害呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}