{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet162","backstageTalkSetId":162,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet162-1","talkText":"燐子學姊，請問\n你現在有空嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet162-2","talkText":"嗯，現在有空……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet162-3","talkText":"我有一段音節不太會彈，\n希望你能幫我看一下！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet162-4","talkText":"你不介意由我來看的話……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}