{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet27","backstageTalkSetId":27,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet27-1","talkText":"超商的甜點，\n真是每天都在進化呢〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet27-2","talkText":"啊，我打工的地方，\n有緋瑪麗好像會喜歡的新甜點喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet27-3","talkText":"真的嗎！？\n我要去看看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}