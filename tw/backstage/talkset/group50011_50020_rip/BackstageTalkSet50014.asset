{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50014","backstageTalkSetId":50014,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50014-1","talkText":"花音學姊，\n請慢慢地直直走過來","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50014-2","talkText":"嗚，嗚耶耶……\n要，要做什麼呢……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50014-3","talkText":"好的，到達終點了\n已經可以睜開眼睛囉","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50014-4","talkText":"花音！\n生日快樂！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet50014-5","talkText":"哇！\n好大的水母……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet50014-6","talkText":"其實這個呢，\n是懶骨頭唷～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet50014-7","talkText":"因為覺得很適合花音，\n所以特別準備了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50014-8","talkText":"被溫柔地包覆著的虛幻\n就如同是花音的模樣呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[13],"voiceId":"TalkSet50014-9","talkText":"快點快點，小音學姊！\n快點坐下看看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50014-10","talkText":"哇啊，好像真的\n坐在水母上面一樣……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[14],"voiceId":"TalkSet50014-11","talkText":"…………呼呼","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[15],"voiceId":"TalkSet50014-12","talkText":"竟然，睡著了～～～！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}