{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50013","backstageTalkSetId":50013,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50013-1","talkText":"禮物的事情，\n大家沒跟花音學姊說吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet50013-2","talkText":"要是被看到我們在搬的話，\n就失敗了喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50013-3","talkText":"好像一不小心就會說溜嘴，\n真令人緊張呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet50013-4","talkText":"啊啊，明天一定是\n格外虛幻的一天呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50013-5","talkText":"我好期待\n花音的笑容哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}