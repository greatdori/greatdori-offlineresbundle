{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50019","backstageTalkSetId":50019,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50019-1","talkText":"明天是小芙的生日！　\n好期待喔－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet50019-2","talkText":"要送給小芙的禮物，我猶豫了好久","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet50019-3","talkText":"不過，\n猶豫了那麼久沒有白費呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50019-4","talkText":"小彩挑選的禮物\n非常可愛哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet50019-5","talkText":"太好了！　\n希望明天小芙也會很開心","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}