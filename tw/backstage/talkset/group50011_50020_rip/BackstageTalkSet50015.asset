{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50015","backstageTalkSetId":50015,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet50015-1","talkText":"沙綾會喜歡\n我們準備的禮物嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50015-2","talkText":"好想快點看看\n穿上這個的樣子唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet50015-3","talkText":"一定很適合沙～綾的！\n對吧，有咲！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50015-4","talkText":"不要問我啦！雖然\n我也覺得會很適合就是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}