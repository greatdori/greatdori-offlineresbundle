{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50012","backstageTalkSetId":50012,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet50012-1","talkText":"小巴～\n生快～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50012-2","talkText":"用這個\n讓日本的祭典嗨翻天吧～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50012-3","talkText":"謝啦～！\n……這是祭典外罩嗎！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50012-4","talkText":"哼哼～！\n這個，可是手工製作的唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet50012-5","talkText":"好棒呀！\n做工真的非常細緻耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50012-6","talkText":"我現在\n可以穿上看看嗎！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet50012-7","talkText":"當然！\n我們也想要快點看看呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet50012-8","talkText":"嘿咻……\n怎麼樣！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[6],"voiceId":"TalkSet50012-9","talkText":"嘛，還不錯呢。\n很適合你唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet50012-10","talkText":"小巴\n非常帥氣唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[8],"voiceId":"TalkSet50012-11","talkText":"大家請看鏡頭～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}