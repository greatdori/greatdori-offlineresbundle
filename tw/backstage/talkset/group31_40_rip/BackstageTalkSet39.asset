{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet39","backstageTalkSetId":39,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet39-1","talkText":"虛幻……不對、虛幻……不對呢……虛幻……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet39-2","talkText":"薰、薰同學……你在做什麼呢……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet39-3","talkText":"啊啊，這不是麻彌嗎。\n沒什麼，我只是稍微在做點練習","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet39-4","talkText":"是什麼的練習呢……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}