{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet34","backstageTalkSetId":34,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet34-1","talkText":"你看，小美咲。\n我換掉待機畫面了喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet34-2","talkText":"啊，是跟之前\n不一樣的水母呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet34-3","talkText":"耶嘿嘿，其實是昨天\n在水族館拍的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}