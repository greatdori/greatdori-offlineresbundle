{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet278","backstageTalkSetId":278,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet278-1","talkText":"芬蘭是世界上屈指可數的\n咖啡消耗國喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet278-2","talkText":"是這樣啊！\n呵呵，總覺得很開心耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}