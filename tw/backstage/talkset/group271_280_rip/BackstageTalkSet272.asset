{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet272","backstageTalkSetId":272,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet272-1","talkText":"我看到瀨田學姊你\n在進行演技練習的時候囉","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet272-2","talkText":"那場決鬥的場景，\n真的很熱血耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet272-3","talkText":"呵呵，謝謝你。\n請期待我的正式演出吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}