{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet271","backstageTalkSetId":271,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet271-1","talkText":"哎呀，居然會在這裡\n遇見小貓咪呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet271-2","talkText":"小貓咪是……\n在說我嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet271-3","talkText":"我看起來不適合\n被叫什麼小貓咪吧……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet271-4","talkText":"呵呵，我的眼中看來\n不管是誰都是小貓咪喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}