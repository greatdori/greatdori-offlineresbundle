{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50060","backstageTalkSetId":50060,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet50060-1","talkText":"薰同學，\n祝你生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50060-2","talkText":"禮物是育美我們覺得\n「虛幻」的東西哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet50060-3","talkText":"謝謝，這是……\n雪花球嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50060-4","talkText":"對啊，雪花緩緩地飄落\n感覺像在童話世界，非常虛幻","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50060-5","talkText":"而且，還閃閃發光\n超漂亮的對吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[14],"voiceId":"TalkSet50060-6","talkText":"放在房間裡當裝飾\n也不會太突兀","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet50060-7","talkText":"啊啊，這是何等\n虛幻的禮物啊……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50060-8","talkText":"然而，大家重視虛幻的\n那份心意才更讓我……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[12],"voiceId":"TalkSet50060-9","talkText":"啊啊，真是太虛幻了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet50060-10","talkText":"啊哈哈……\n薰學姊開心就好了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}