{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50053","backstageTalkSetId":50053,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet50053-1","talkText":"要送給彩學姊了禮物\n已經沒問題了呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50053-2","talkText":"嗚嗚，進店裡的時候\n讓我超緊張的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50053-3","talkText":"啊哈哈，連在店員面前\n動作也超僵硬的說－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50053-4","talkText":"真是的，重頭戲還沒開始喔？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50053-5","talkText":"為了讓小彩開心過生日\n大家明天一起加油吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}