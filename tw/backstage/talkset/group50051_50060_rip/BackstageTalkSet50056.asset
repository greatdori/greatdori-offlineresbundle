{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50056","backstageTalkSetId":50056,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50056-1","talkText":"鶇，生日快樂","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50056-2","talkText":"禮物是蘭提議要送的\n是非常可愛的花哦～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50056-3","talkText":"這些花，每一種都是\n大家親自挑的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50056-4","talkText":"哇啊，我好開心！\n有哪些花呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50056-5","talkText":"我選的是瑪格麗特！\n花語是「真正的友情」喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50056-6","talkText":"我挑的是洋甘菊\n聽說有安神的效果","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50056-7","talkText":"小卡選了紫丁香\n蘭，這個的花語是～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50056-8","talkText":"「重要的朋友」\n你明明就是查好才選的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50056-9","talkText":"啊哈哈～，\n小卡是小冒失鬼嘛～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet50056-10","talkText":"最後是鬱金香\n是鶇誕生月份的代表花","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50056-11","talkText":"放在店裡或其他\n你喜歡的地方裝飾吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[10],"voiceId":"TalkSet50056-12","talkText":"好，謝謝大家！\n呵呵，這些花好香哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}