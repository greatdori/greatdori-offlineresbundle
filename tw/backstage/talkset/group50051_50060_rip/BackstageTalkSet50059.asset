{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50059","backstageTalkSetId":50059,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50059-1","talkText":"送薰學姊那個當禮物\n真的沒問題嗎","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50059-2","talkText":"育美把自己當成薰薰\n才選了那個當禮物的喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50059-3","talkText":"我也是喔！　所以最後\n才會想到要選那個當禮物","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50059-4","talkText":"啊哈哈，的確是非常\n虛幻的禮物呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}