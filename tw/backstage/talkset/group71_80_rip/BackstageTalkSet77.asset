{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet77","backstageTalkSetId":77,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet77-1","talkText":"鏘～，你們看！\n我之前烤的蛋糕！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet77-2","talkText":"小緋瑪麗，你會做蛋糕嗎？\n好厲害～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet77-3","talkText":"有咲之前不是也一起\n做過巧克力了嗎！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet77-4","talkText":"咦～，好好喔！\n我也想要一起做～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet77-5","talkText":"好啊好啊！\n大家一起做吧～☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}