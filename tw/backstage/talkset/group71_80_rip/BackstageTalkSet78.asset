{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet78","backstageTalkSetId":78,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet78-1","talkText":"那麼現在開始就來進行\n要做什麼蛋糕的會議！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet78-2","talkText":"耶～！\n有咲想做什麼？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet78-3","talkText":"總、總之\n做一個不會太難的……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}