{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet793","backstageTalkSetId":793,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet793-1","talkText":"冷天就會讓人想辦\nLIVE對吧，友希那學姊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet793-2","talkText":"……這兩者之間，\n有什麼關聯嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet793-3","talkText":"當然是因為要用\nLIVE把寒冷吹走啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet793-4","talkText":"在夏天時，我好像也\n有聽你說過類似的話","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}