{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet631","backstageTalkSetId":631,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet631-1","talkText":"咦，手臂附近是\n曬傷了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet631-2","talkText":"和小蘭他們一起去\n海邊玩，不知不覺就……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet631-3","talkText":"要是不介意的話，\n我借你修護用的乳液吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet631-4","talkText":"這是千聖學姊推薦我的，\n非常有效喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}