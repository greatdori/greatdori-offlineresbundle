{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet429","backstageTalkSetId":429,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet429-1","talkText":"呼～跟大家一起來買東西好開心啊～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet429-2","talkText":"我平常不會去逛那種店，感覺滿新鮮的。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet429-3","talkText":"挑選禮物比想像中還要花時間呢。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet429-4","talkText":"小亞……會不會喜歡呢……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet429-5","talkText":"反正是大家選的，別擔心啦☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}