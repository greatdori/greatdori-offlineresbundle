{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet650","backstageTalkSetId":650,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet650-1","talkText":"明天，我要和小千\n一起去車站前的咖啡廳","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet650-2","talkText":"如果有空的話，\n小紗夜要不要來呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet650-3","talkText":"咖啡廳……很不錯呢\n請務必讓我參加","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet650-4","talkText":"我也會問看看小彩\n和小燐有沒有空","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}