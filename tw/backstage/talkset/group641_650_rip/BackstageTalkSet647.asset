{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet647","backstageTalkSetId":647,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet647-1","talkText":"手機桌布是兔子的照片耶！\n是小惠惠家養的嗎","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet647-2","talkText":"沒錯，這是阿異","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet647-3","talkText":"不過我之前用的是\n漢堡排的照片","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet647-4","talkText":"我也要把桌布換成\n姊姊的照片！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}