{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50023","backstageTalkSetId":50023,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet50023-1","talkText":"明天終於就是\n香澄的生日了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50023-2","talkText":"要是小澄喜歡\n我們準備的禮物就好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet50023-3","talkText":"「那個」也準備萬全了\n真是令人期待","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50023-4","talkText":"拿著「那個」走在路上\n真的太引人注目了啦～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}