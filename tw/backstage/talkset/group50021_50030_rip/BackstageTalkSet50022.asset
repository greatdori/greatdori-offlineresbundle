{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50022","backstageTalkSetId":50022,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50022-1","talkText":"小亞……\n祝你生日快樂……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50022-2","talkText":"好高興！　謝謝大家！\n這個箱子該不會是！？’","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet50022-3","talkText":"全部都是要送給\n宇田川同學的禮物喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50022-4","talkText":"這麼多！？\n太好了吧－－！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50022-5","talkText":"好的！　雖然很突然\n但現在要進入問答時間！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet50022-6","talkText":"問答！？　接受挑戰！\n我一定會答對的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet50022-7","talkText":"這些禮物\n分別是誰送的呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet50022-8","talkText":"亞子，你一定能\n回答出正確答案的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[24],"voiceId":"TalkSet50022-9","talkText":"好、好的！　我會加油！\n我想想喔……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50022-10","talkText":"這個NFO的玩偶是\n燐燐送的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50022-11","talkText":"是的……小亞……\n答對了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[24],"voiceId":"TalkSet50022-12","talkText":"太棒了－！　我會照\n這個節奏繼續答對的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}