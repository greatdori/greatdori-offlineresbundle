{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50027","backstageTalkSetId":50027,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50027-1","talkText":"好的，這樣，\n明天的準備也完成了吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50027-2","talkText":"剛才試看的時候\n真的非常漂亮呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50027-3","talkText":"連育美我也非常興奮！\n小心心，會高興嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet50027-4","talkText":"我們明天可要讓\n心笑容滿面才行呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}