{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50030","backstageTalkSetId":50030,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet50030-1","talkText":"……奇怪，怎麼感覺\n氣氛好像不太一樣？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50030-2","talkText":"呵呵呵……歡迎光臨\n闇之饗宴……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50030-3","talkText":"咦！？　亞子？\n還有大家也都……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50030-4","talkText":"現在開始要展示\n特別的闇之力量……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50030-5","talkText":"在空無一物的書桌上……\n蓋上一塊布……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet50030-6","talkText":"這一塊布沒有\n任何加工或機關","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet50030-7","talkText":"把布慢慢地\n抽掉……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50030-8","talkText":"原本空無一物的書桌上\n咚地，出現了禮物！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50030-9","talkText":"闇之饗宴，就是魔術嘛！\n還有這個，是圍裙耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet50030-10","talkText":"莉莎，生日快樂\n這份禮物怎麼樣呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet50030-11","talkText":"非常的可愛喔！\n我會珍惜地使用的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}