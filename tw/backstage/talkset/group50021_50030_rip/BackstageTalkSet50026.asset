{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50026","backstageTalkSetId":50026,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50026-1","talkText":"育美，生日快樂\n我們為你準備了禮物哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50026-2","talkText":"禮物！？\n太棒了－！　是什麼呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50026-3","talkText":"只要你進去那裡面\n就可以知道了喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet50026-4","talkText":"我知道了！　我跳！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet50026-5","talkText":"好厲害！　\n育美身上變成了浴衣！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet50026-6","talkText":"呵呵，這件浴衣\n是要送給育美的禮物","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet50026-7","talkText":"大家都說這件浴衣\n很可愛，一定很適合小育","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[13],"voiceId":"TalkSet50026-8","talkText":"真、真的適合育美我嗎？\n不會很奇怪嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50026-9","talkText":"現在的育美，\n超～級可愛！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[13],"voiceId":"TalkSet50026-10","talkText":"欸嘿嘿……總覺得\n現在臉頰好熱","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet50026-11","talkText":"機會難得，\n就穿著浴衣去祭典玩吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[13],"voiceId":"TalkSet50026-12","talkText":"嗯！　好喔！\n我要吃很多東西！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}