{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50028","backstageTalkSetId":50028,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet50028-1","talkText":"哎呀！\n我是最早到的耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet50028-2","talkText":"怎麼了？\n怎麼突然變暗了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50028-3","talkText":"哎呀？　這次換\n這邊跑出星星來了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50028-4","talkText":"亮晶晶的\n好漂亮！　像海一樣！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12,13,14,15],"voiceId":"TalkSet50028-5","talkText":"心\n生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[14],"voiceId":"TalkSet50028-6","talkText":"大家一起試著\n做了星象儀哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet50028-7","talkText":"為了要讓小心心開心\n大家都很努力喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50028-8","talkText":"你喜歡這些\n虛幻的特效嗎","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50028-9","talkText":"喜歡！\n這個景色非常漂亮！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet50028-10","talkText":"哈哈，心的眼睛\n也亮晶晶的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[11],"voiceId":"TalkSet50028-11","talkText":"我的眼睛裡面\n一定也跑進了星星呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}