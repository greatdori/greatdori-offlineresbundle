{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet522","backstageTalkSetId":522,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet522-1","talkText":"冬って、甘いもの\nいっぱい食べたくなるよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet522-2","talkText":"あたしは甘いものが\n苦手ですけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet522-3","talkText":"確かに最近ビターチョコを\n結構、食べてる気がします","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet522-4","talkText":"えへへ、このチョコ\nビター味だけど食べる？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}