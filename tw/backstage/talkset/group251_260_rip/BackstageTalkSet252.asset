{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet252","backstageTalkSetId":252,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet252-1","talkText":"蘭的那搓紅色挑染，\n真的很酷耶～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet252-2","talkText":"我要不要也試著弄一下\n一樣的挑染呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet252-3","talkText":"這個嘛，\n沒差，看你啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet252-4","talkText":"啊哈哈！蘭人真好～♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}