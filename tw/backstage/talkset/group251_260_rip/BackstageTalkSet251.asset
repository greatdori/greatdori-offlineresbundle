{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet251","backstageTalkSetId":251,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet251-1","talkText":"咦？小蘭，你一個人？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet251-2","talkText":"嗯，只有我喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet251-3","talkText":"那要不要\n跟我一起出去玩？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet251-4","talkText":"好耶。\n我們走吧。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}