{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet259","backstageTalkSetId":259,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet259-1","talkText":"你看你看，巴！\n這件衣服，可不可愛？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet259-2","talkText":"是啊。非常適合\n緋瑪麗你耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet259-3","talkText":"巴好像很適合\n這一件衣服！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet259-4","talkText":"還有沒有，\n其他適合的衣服呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}