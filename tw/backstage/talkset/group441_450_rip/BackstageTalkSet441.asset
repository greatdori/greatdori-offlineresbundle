{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet441","backstageTalkSetId":441,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet441-1","talkText":"各位，你們明天的準備都做好了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet441-2","talkText":"是在說禮物嗎？禮物的話準備好囉。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet441-3","talkText":"亞子也準備萬全囉～！是跟燐燐一起準備的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet441-4","talkText":"如果他喜歡這份禮物……就好了呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}