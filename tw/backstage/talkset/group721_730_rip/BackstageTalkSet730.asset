{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet730","backstageTalkSetId":730,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet730-1","talkText":"要不要去吃\n拉麵啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet730-2","talkText":"又要吃豚骨拉麵嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet730-3","talkText":"不是，這次要吃的是\n堆滿香菇的豚骨拉麵喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet730-4","talkText":"果然～又是豚骨拉麵","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}