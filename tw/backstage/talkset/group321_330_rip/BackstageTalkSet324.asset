{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet324","backstageTalkSetId":324,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet324-1","talkText":"把指甲用得閃閃亮亮的\n真有趣耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet324-2","talkText":"你是說美甲嗎？\n嗯，很有趣喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet324-3","talkText":"要不要我下次\n也幫心你弄弄看呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}