{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet323","backstageTalkSetId":323,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet323-1","talkText":"心心你啊，頭髮\n真的好漂亮耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet323-2","talkText":"是嗎？\n我不是很懂這種事耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet323-3","talkText":"啊哈哈，這樣喔？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet323-4","talkText":"本來還想問你\n護髮的訣竅說～真可惜♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}