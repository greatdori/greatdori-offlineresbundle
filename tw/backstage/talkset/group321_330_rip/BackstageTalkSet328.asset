{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet328","backstageTalkSetId":328,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet328-1","talkText":"嗚耶耶……怎麼辦……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet328-2","talkText":"怎麼啦花音？\n你好像在煩惱著什麼事呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet328-3","talkText":"我有一個想去的地方\n但是太遠了我怕會迷路……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet328-4","talkText":"呵呵，這樣的話就交給我來\n帶領花音你前往吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}