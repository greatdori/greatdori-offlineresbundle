{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet327","backstageTalkSetId":327,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet327-1","talkText":"薰同學，你之前的舞台劇，\n真的好棒喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet327-2","talkText":"主角貓的心情，\n很完整得傳達出來了耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet327-3","talkText":"呵呵，看來我有確實地\n化身成貓，那我就放心啦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}