{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet303","backstageTalkSetId":303,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet303-1","talkText":"小彌，最近\n你工作很努力耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet303-2","talkText":"真的嗎？能被這麼說\n我非常開心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet303-3","talkText":"會讓人覺得我自己也要努力\n可以激勵人心喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}