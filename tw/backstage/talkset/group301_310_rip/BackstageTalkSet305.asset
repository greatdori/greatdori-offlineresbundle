{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet305","backstageTalkSetId":305,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet305-1","talkText":"剛剛跟一個綁著武士頭的人\n擦身而過耶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet305-2","talkText":"是在拍時代劇嗎？\n我總有一天也想要去演！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet305-3","talkText":"呵呵，總有一天\n能夠演出就太好了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}