{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet304","backstageTalkSetId":304,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet304-1","talkText":"貝斯的弦要換的時機\n是什麼時候啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet304-2","talkText":"這很難呢……貝斯的話\n常常是因人而異喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet304-3","talkText":"找到適合自己的時機\n應該會比較好喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet304-4","talkText":"是這樣的啊。\n我又學到一課了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}