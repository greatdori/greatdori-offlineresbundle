{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet310","backstageTalkSetId":310,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet310-1","talkText":"麻彌學姊，今天要不要\n一起吃飯呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet310-2","talkText":"當然！\n要去哪吃呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet310-3","talkText":"之前，我找到一間好像\n很好吃的日式餐廳！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}