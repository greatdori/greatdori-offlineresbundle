{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet504","backstageTalkSetId":504,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet504-1","talkText":"怎麼樣呢？\n我送的生日禮物","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet504-2","talkText":"雖然有點嚇人\n但有咲會很開心吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet504-3","talkText":"嗯嗯。因為我選了\n很可愛的款式呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet504-4","talkText":"好期待喔～\n有咲明天的反應！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}