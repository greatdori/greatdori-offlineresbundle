{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet506","backstageTalkSetId":506,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet506-1","talkText":"市谷同學……\n生日快樂……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet506-2","talkText":"我們也準備了\n生日禮物唷～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet506-3","talkText":"謝謝。\n這個是……擴香瓶？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet506-4","talkText":"沒錯唷。\n是檜木的香味","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet506-5","talkText":"是很溫和的氣味……\n我覺得很治癒人心……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet506-6","talkText":"謝謝！\n我會放在房間裡使用的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}