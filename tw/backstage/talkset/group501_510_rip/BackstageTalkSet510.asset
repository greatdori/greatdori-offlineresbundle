{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet510","backstageTalkSetId":510,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet510-1","talkText":"この前、イルミネーション\n見に行ったんです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet510-2","talkText":"わあ〜、キレイだね！\nSNS映えしそう～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet510-3","talkText":"次のお休みの日に、\n私も見に行こうかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet510-4","talkText":"あ、なら私も！　他にも\nいい所があるんですよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}