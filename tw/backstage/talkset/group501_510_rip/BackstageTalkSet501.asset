{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet501","backstageTalkSetId":501,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet501-1","talkText":"明天是湊同學的生日呢。\n宇田川同學，怎麼了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet501-2","talkText":"收到禮物之後會開心嗎\n嗚嗚……我好擔心～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet501-3","talkText":"小亞……\n先冷靜一下……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet501-4","talkText":"不用這麼擔心\n一定會很開心的啦☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet501-5","talkText":"亞子，說不定一直到明天\n之前都會很緊張……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}