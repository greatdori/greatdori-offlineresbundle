{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet503","backstageTalkSetId":503,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet503-1","talkText":"友希那學姊，\n生日快樂","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet503-2","talkText":"我們準備了\n生日禮物！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet503-3","talkText":"謝謝。\n這是……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet503-4","talkText":"是蜂蜜！\n好像可以加進紅茶裡唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[21],"voiceId":"TalkSet503-5","talkText":"謝謝你們兩位。\n我很開心","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}