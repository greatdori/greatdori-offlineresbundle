{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet507","backstageTalkSetId":507,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet507-1","talkText":"好的，看樣子\n大家都到齊了呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet507-2","talkText":"要去買要送給小彌的\n生日禮物沒錯吧～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet507-3","talkText":"因為很猶豫要買什麼才好\n和大家一起讓我很有信心","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet507-4","talkText":"所以，\n小彩已經有想法了對吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet507-5","talkText":"嗯！\n大家一起去買東西吧～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}