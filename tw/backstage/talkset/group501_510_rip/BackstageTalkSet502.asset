{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet502","backstageTalkSetId":502,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet502-1","talkText":"友希那學姊～！\n生日快～樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet502-2","talkText":"這個是大家一起挑的……\n禮物……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet502-3","talkText":"謝謝。\n原來如此，有很多種類呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet502-4","talkText":"亞子挑的超帥的戒指\n怎麼樣呀！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet502-5","talkText":"我挑了髮飾唷。\n你願意用的話我會很開心的☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet502-6","talkText":"我送的是圍巾。\n因為天氣變冷了所以","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet502-7","talkText":"謝謝。\n每一項我都會珍惜地使用的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}