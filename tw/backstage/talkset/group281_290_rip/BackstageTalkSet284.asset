{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet284","backstageTalkSetId":284,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet284-1","talkText":"嗯～……那支舞，\n馬上就會失敗耶……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet284-2","talkText":"小育，\n你有沒有什麼訣竅？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet284-3","talkText":"唔嗯，你把腰這樣\n啾因一下就好了喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet284-4","talkText":"可不可以再講得\n更詳細一點……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}