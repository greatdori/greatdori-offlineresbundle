{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet286","backstageTalkSetId":286,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet286-1","talkText":"PasPale的衣服啊，\n飄飄的好可愛唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet286-2","talkText":"飄飄裙好像水母，\n光看著就好療癒唷～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet286-3","talkText":"（嗯……\n這是被稱讚沒錯吧？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}