{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet290","backstageTalkSetId":290,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet290-1","talkText":"明天的行程是……\n哎呀，明天是放假耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet290-2","talkText":"最近工作也好多，\n終於可以休息了耶～!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet290-3","talkText":"雖然很感謝很忙這件事\n但偶爾也是想要休息的呀","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet290-4","talkText":"對啊～對啊～！\n明天就盡情的玩吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}