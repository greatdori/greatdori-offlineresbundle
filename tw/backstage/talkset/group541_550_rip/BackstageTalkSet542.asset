{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet542","backstageTalkSetId":542,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet542-1","talkText":"今年もあと少しで\n終わりですね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet542-2","talkText":"そうだ！　ね、みんなで\n忘年会やろうよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet542-3","talkText":"さんせー！　あこ、\n闇鍋やってみたいです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet542-4","talkText":"闇鍋……？　せめて食べら\nれるものにしてほしいわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet542-5","talkText":"お鍋の具に限定すれば\nいいかもしれません……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet542-6","talkText":"なら、みんなでお鍋の具を\n持ち寄るっていうのは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet542-7","talkText":"わぁ、それすっごく\n楽しそう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[22],"voiceId":"TalkSet542-8","talkText":"肉と野菜を用意しておけば\n偏った鍋にはならないかと","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[21],"voiceId":"TalkSet542-9","talkText":"ええ。\nそれなら安心ね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[25],"voiceId":"TalkSet542-10","talkText":"（みんなでお鍋……\n楽しみ、だな……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}