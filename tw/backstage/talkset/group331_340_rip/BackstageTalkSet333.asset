{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet333","backstageTalkSetId":333,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet333-1","talkText":"薰，今天午休的時候\n你是不是在學校中庭跳舞了呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet333-2","talkText":"因為下次的舞台劇，\n我要扮演一名舞者呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet333-3","talkText":"為了融入角色，\n所以才要跳舞啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}