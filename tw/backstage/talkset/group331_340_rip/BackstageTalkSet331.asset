{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet331","backstageTalkSetId":331,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet331-1","talkText":"其實啊，我寫了封信\n給米歇爾喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet331-2","talkText":"為了表達平時\n受他關照的感謝之意","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet331-3","talkText":"可以的話，\n能幫我轉交給他嗎","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet331-4","talkText":"（……怎麼辦，\n這個，我能不能看啊）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}