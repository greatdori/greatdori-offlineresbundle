{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet765","backstageTalkSetId":765,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet765-1","talkText":"沙綾，這個草帽\n是不是很可愛？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet765-2","talkText":"對耶，向日葵裝飾\n很有夏天的感覺","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet765-3","talkText":"該怎麼辦～，\n我要買下來嗎～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet765-4","talkText":"呵呵，那我們要不要\n一起去把他買下來？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}