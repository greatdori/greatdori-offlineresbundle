{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet764","backstageTalkSetId":764,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet764-1","talkText":"啊－，合奏真\n是太開心了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet764-2","talkText":"對啊！　我也\n流了滿身大汗！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[33],"voiceId":"TalkSet764-3","talkText":"對了，這之後要不\n要去旭澡堂一趟呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet764-4","talkText":"夏天剛洗完澡喝\n彈珠汽水最過癮了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet764-5","talkText":"很不錯耶，\n我們走吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}