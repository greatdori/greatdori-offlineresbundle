{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet603","backstageTalkSetId":603,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet603-1","talkText":"お父様は、ライブ前に\n差し入れをくださるのね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet603-2","talkText":"少し恥ずかしいんですけど\nみんなすごく喜んでて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet603-3","talkText":"私たちも、練習にお菓子を\n持ち寄ったりするんですよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet603-4","talkText":"演奏前のお菓子って、\n不思議な効果ありますよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}