{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet194","backstageTalkSetId":194,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet194-1","talkText":"小彌，吉他的狀況好像怪怪的耶。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet194-2","talkText":"我幫你調整一下琴頸喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet194-3","talkText":"小彌。這次節目的劇本是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet194-4","talkText":"封面是黃色的那個！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet194-5","talkText":"麻彌學姊，你有帶OK繃嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet194-6","talkText":"包包裡面有喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[18],"voiceId":"TalkSet194-7","talkText":"（有小彌在真是太好了呢……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}