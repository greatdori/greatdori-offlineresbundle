{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet228","backstageTalkSetId":228,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet228-1","talkText":"因為小有咲很聰明，\n我覺得好厲害喔～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet228-2","talkText":"突、突然講這個幹嘛！\n但還是謝謝你……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet228-3","talkText":"育美也要再認真\n念書一點才行呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet228-4","talkText":"你、你不介意的話，\n我是可以教你啦……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}