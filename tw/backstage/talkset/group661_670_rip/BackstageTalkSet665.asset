{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet665","backstageTalkSetId":665,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet665-1","talkText":"我呀，看到落葉的時候\n就會馬上踩上去喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet665-2","talkText":"我懂那種感覺！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet665-3","talkText":"落葉會發出各種不同的聲音\n聽起來很有趣對吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}