{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet719","backstageTalkSetId":719,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet719-001","talkText":"然後啊，這個是深淵魔劍！\n是不是很帥氣！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet719-002","talkText":"呃……？\n深，深淵……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet719-003","talkText":"是限定的闇屬性裝備，\n超級超級稀有的喔～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet719-004","talkText":"還有冥王鎧甲，\n和光輝騎士之類的裝備哦～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet719-005","talkText":"光輝，騎士……\n聽起來好像有點帥氣","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet719-006","talkText":"就是說啊～！？　真白\n也一起來玩看看啦～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}