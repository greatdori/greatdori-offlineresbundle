{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet712","backstageTalkSetId":712,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet712-1","talkText":"請問，是只要裝飾上\n喜歡的東西就好了沒錯吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet712-2","talkText":"沒有錯☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet712-3","talkText":"呵呵，這真是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet712-4","talkText":"好的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet712-5","talkText":"收尾就麻煩\n伊芙同學了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet712-6","talkText":"包在我身上！\n嘿咻～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet712-7","talkText":"大功告成～！\n怎麼樣呢，美竹同學","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet712-8","talkText":"呃，雖然不太普通……\n但還不錯","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[12],"voiceId":"TalkSet712-9","talkText":"啊啊……多麼美麗呀！\n這真是符合新年的虛幻呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[23],"voiceId":"TalkSet712-10","talkText":"喜歡的事物大集合的感覺♪\n今年感覺會是熱鬧的１年哦☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[20],"voiceId":"TalkSet712-11","talkText":"是的！　各位，\n今年也請多多指教！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}