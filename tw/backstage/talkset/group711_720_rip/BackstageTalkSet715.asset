{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet715","backstageTalkSetId":715,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet715-1","talkText":"我們要表演合作特技。\n現、現在表演開始……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet715-2","talkText":"好耶－大成功！\n多虧了美咲學姊的指導！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet715-3","talkText":"太誇張了拉，\n我什麼事都沒做啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet715-4","talkText":"呵呵，練習雖然很難\n不過也很開心呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet715-5","talkText":"鏘鏘－！　怎麼樣啊？\n讓人嚕♪起來的新絕招～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet715-6","talkText":"哈哈……沒想到除了心之外\n還有人可以這麼容易做到","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet715-7","talkText":"最後～一次♪\n小真白來試試吧～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet715-8","talkText":"好、好的……\n嘿、嘿咻！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet715-9","talkText":"可惜，小真白\n只差一點點而已！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet715-10","talkText":"嗯，努力有了回報呢。\n今年也要繼續努力哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[26],"voiceId":"TalkSet715-11","talkText":"好、好的\n我會加油","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}