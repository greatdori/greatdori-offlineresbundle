{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet714","backstageTalkSetId":714,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet714-1","talkText":"大家～\n準備好了嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet714-2","talkText":"準備完成，彩學姊。\n請不要猶豫直接開始吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[],"voiceId":"TalkSet714-3","talkText":"新年恭喜～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet714-4","talkText":"嗯。這很有新年的感覺！\n感覺很不錯對吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet714-5","talkText":"來拍張照當紀念吧～！\n瑠唯，笑開一點～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet714-6","talkText":"我覺得用什麼\n表情拍都可以","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet714-7","talkText":"嗚哇～瑠唯\n今年還是一樣一板一眼耶～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[5],"voiceId":"TalkSet714-8","talkText":"等、等一下。\n大過年的不要吵架啦～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet714-9","talkText":"吵架？\n我們並沒有在爭吵","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet714-10","talkText":"對了！　大家聽我說\n要不要來寫今天的展望呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[32],"voiceId":"TalkSet714-11","talkText":"這提議真棒！\n展望越遠大越好！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet714-12","talkText":"說的沒錯。還有\n大家要好好相處哦♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}