{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet713","backstageTalkSetId":713,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet713-1","talkText":"寄宿在吾身的暗黑力量啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet713-2","talkText":"貫穿吧！\n混沌射擊！！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet713-3","talkText":"哇啊，小亞好厲害～。\n接下來輪到小益了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet713-4","talkText":"我和花音學姊一起\n在扇面上畫了插圖","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet713-5","talkText":"是巧克力螺旋麵包和水母哦♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet713-6","talkText":"嗚……這太可愛了\n讓人不忍射穿……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet713-7","talkText":"MASKING同學……\n要是沒射中就功虧一簣了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[33],"voiceId":"TalkSet713-8","talkText":"沒辦法了……！\n只好做了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[3],"voiceId":"TalkSet713-9","talkText":"最後換冰川學姊了呢。\n靶心居然這麼小","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet713-10","talkText":"……所謂「正矢必中」。\n以正姿射出的箭矢，必定會……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[24],"voiceId":"TalkSet713-11","talkText":"好、好厲害喔紗夜學姊\n超超超級帥氣～～！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[22],"voiceId":"TalkSet713-12","talkText":"呵呵，\n看來今年會是好年呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}