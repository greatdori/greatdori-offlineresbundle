{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet720","backstageTalkSetId":720,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet720-001","talkText":"這，這是現在\n流行的甜點……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet720-002","talkText":"要怎麼說才好呢\n真是驚人呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet720-003","talkText":"這個角度超好看～！\n糟糕啦，人家真的是天才吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet720-004","talkText":"啊，但從這邊拍\n好像也蠻讚的耶？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet720-005","talkText":"嗯～，好猶豫要不要\n兩張都上傳喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet720-006","talkText":"……桐谷同學，\n請問可以開動了嗎","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}