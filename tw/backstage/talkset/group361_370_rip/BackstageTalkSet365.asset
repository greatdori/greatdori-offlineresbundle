{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet365","backstageTalkSetId":365,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet365-1","talkText":"明天是日菜同學的生日呢。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet365-2","talkText":"他會喜歡我們送的禮物嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet365-3","talkText":"呵呵，那個他一定會喜歡的。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet365-4","talkText":"希望他能去玩得開心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}