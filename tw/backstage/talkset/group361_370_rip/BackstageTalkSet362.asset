{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet362","backstageTalkSetId":362,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet362-1","talkText":"終於就是明天了呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet362-2","talkText":"冰川同學……不知道會不會喜歡這份禮物……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet362-3","talkText":"能做的事情我們都做了，就只剩下做好覺悟而已。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet362-4","talkText":"你們在做那個的時候是用那麼拚命的氣勢喔！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}