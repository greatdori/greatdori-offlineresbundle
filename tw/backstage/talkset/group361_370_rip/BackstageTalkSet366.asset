{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet366","backstageTalkSetId":366,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet366-1","talkText":"日菜學姊，生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet366-2","talkText":"這個禮物給你！是大家一起選的喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet366-3","talkText":"哇～什麼什麼？裡面有什麼？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet366-4","talkText":"是天象館的觀賞券喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet366-5","talkText":"你就跟小紗夜兩個人一起去吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[17],"voiceId":"TalkSet366-6","talkText":"哇～！好啊！我馬上就去約他～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}