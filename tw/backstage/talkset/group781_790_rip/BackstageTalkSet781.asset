{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet781","backstageTalkSetId":781,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet781-1","talkText":"我有個問題要問小育！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet781-2","talkText":"請問小育覺得星星\n爆炸了會怎麼樣－？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet781-3","talkText":"什麼－！　育美\n不喜歡爆炸啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet781-4","talkText":"所以……那個……\n答案是育美會很難過！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet781-5","talkText":"啊哈哈！\n居然給我這種答案－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}