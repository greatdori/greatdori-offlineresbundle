{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet787","backstageTalkSetId":787,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet787-1","talkText":"我讀了鶇\n推薦的小說","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet787-2","talkText":"你說的是那部小說吧。\n如何呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet787-3","talkText":"有種被作者溫柔的筆觸\n吸引進去的感覺……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet787-4","talkText":"我好像可以明白\n鶇會喜歡的原因了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet787-5","talkText":"呵呵，我也這麼認為","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}