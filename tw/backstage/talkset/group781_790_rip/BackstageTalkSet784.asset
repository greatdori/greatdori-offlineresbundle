{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet784","backstageTalkSetId":784,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet784-1","talkText":"巧克力螺旋麵包的\n「螺旋」指的是什麼呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet784-2","talkText":"聽你這麼一說……\n要查查看嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet784-3","talkText":"我看看喔，好像原本是\n義大利文的「號角」","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet784-4","talkText":"號角嗎……有沒有哪邊\n在辦號角的演奏會啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet784-5","talkText":"……你會不會\n著迷過頭了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}