{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet788","backstageTalkSetId":788,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet788-1","talkText":"前陣子，我稍微出了\n遠門拍了一些照片回來","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet788-2","talkText":"原來是這樣……\n我可以看嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet788-3","talkText":"當然可以！\n這張是早晨的公園……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet788-4","talkText":"好美……\n空氣好清晰……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet788-5","talkText":"（彷彿殷殷期盼著\n即將展開的一天）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet788-6","talkText":"呵呵，你很喜歡嗎？\n然後啊，這邊的是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}