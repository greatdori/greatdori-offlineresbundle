{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet786","backstageTalkSetId":786,"snippets":[{"talkId":1,"characterIds":[34],"voiceId":"TalkSet786-1","talkText":"麻彌小姐的專欄，\n這次也讓人五體投地～～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet786-2","talkText":"嘿嘿……\n謝謝你！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[34],"voiceId":"TalkSet786-3","talkText":"那些器材們，每個都\n接收到麻彌小姐的愛……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet786-4","talkText":"啊～～～PAREO\n也好想變成器材～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet786-5","talkText":"那，那真是太光榮了……\n啊哈哈……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}