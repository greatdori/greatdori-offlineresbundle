{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet599","backstageTalkSetId":599,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet599-1","talkText":"このあと、ツグミさんの\nところでバイトなんです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet599-2","talkText":"部活もたくさん入ってるし\n大変じゃない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet599-3","talkText":"変化の術を極めし、\nミサキさん程では……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet599-4","talkText":"え、それって、もしかして\nミッシェルのこと……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}