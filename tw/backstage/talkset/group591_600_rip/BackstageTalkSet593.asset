{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet593","backstageTalkSetId":593,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet593-1","talkText":"今ぐらいの陽気が\n犬の散歩には一番ね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet593-2","talkText":"白鷺さんは犬を飼って\nいるのでしたね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet593-3","talkText":"ええ。今度一緒に\nお散歩でもどうかしら？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet593-4","talkText":"……！　もしお邪魔じゃ\nないようでしたら……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}