{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet676","backstageTalkSetId":676,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet676-1","talkText":"念書之秋……\n期末考加油！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet676-2","talkText":"你還真是用功呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet676-3","talkText":"這個秋天，瑠唯同學有特別\n想努力做什麼嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet676-4","talkText":"沒有……\n就和平時差不多呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}