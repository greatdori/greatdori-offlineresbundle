{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2011","backstageTalkSetId":2011,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2011-1","talkText":"哦，二之助。\n你在吃什麼啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2011-2","talkText":"三明治喔！\n這間店很好吃－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2011-3","talkText":"看起來真的超可口的！\n二之助，分我吃一口！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2011-4","talkText":"真是的……\n真拿你沒辦法耶……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}