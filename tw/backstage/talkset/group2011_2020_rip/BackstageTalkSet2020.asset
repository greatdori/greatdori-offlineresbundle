{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2020","backstageTalkSetId":2020,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2020-1","talkText":"哦哦，照片裡面這些人是\n紫紫的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2020-2","talkText":"是我的妹妹們喔！\n很可愛對吧～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2020-3","talkText":"嗯，嗯嗯！\n三姊妹都很可愛呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2020-4","talkText":"（一瞬間看不出來\n哪個才是紫紫……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}