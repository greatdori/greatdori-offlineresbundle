{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet465","backstageTalkSetId":465,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet465-1","talkText":"摩卡，生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet465-2","talkText":"今年的禮物不太一樣喔～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet465-3","talkText":"哦哦～好像塞了很多各式各樣的漫畫呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet465-4","talkText":"大家都把自己最推薦的漫畫放進來了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet465-5","talkText":"雖然我送的那個是緋瑪麗跟我說的就是了。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet465-6","talkText":"我們挑了你應該沒看過的，覺得如何？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet465-7","talkText":"每個感覺都好有趣～小卡超感謝喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}