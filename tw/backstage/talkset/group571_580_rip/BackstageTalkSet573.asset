{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet573","backstageTalkSetId":573,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet573-1","talkText":"よいしょっ！　よいしょっ！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet573-2","talkText":"はいっ！　はいっ！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet573-3","talkText":"すごい……二人とも\nめちゃくちゃ息合ってる","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet573-4","talkText":"はんはえ～","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet573-5","talkText":"モカ～、食べるか喋るか\nどっちかにしなよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet573-6","talkText":"じゃあ食べる～。\nモチモチうまうまだよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet573-7","talkText":"やったー！　嬉しいな。\nがんばった甲斐があるよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet573-8","talkText":"次、モカ達の番だからな。\n大事なのはテンポだぞ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet573-9","talkText":"りょ～か～い。\nまかせて～～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet573-10","talkText":"ほ、ホント平気？　その\nテンポ心配なんだけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}