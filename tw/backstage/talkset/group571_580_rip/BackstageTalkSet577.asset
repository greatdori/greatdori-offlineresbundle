{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet577","backstageTalkSetId":577,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet577-1","talkText":"今度ポピパのみんなで\nピクニックに行こうよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet577-2","talkText":"それで楽器を持って行って\nお外で演奏するの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet577-3","talkText":"ただ……ドラムは\n持っていけなくない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet577-4","talkText":"気合いがあれば大丈夫！\nみんなで運ぼう！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}