{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet42","backstageTalkSetId":42,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet42-1","talkText":"紗夜學姊，你昨天\n有登入NFO嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet42-2","talkText":"是、是啊，因為有新的關卡","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet42-3","talkText":"我記得……好像是擊退暗黑龍吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet42-4","talkText":"（咦？那個……不是高級關卡嗎……？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}