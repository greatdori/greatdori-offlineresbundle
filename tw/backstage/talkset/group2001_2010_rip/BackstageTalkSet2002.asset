{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2002","backstageTalkSetId":2002,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2002-1","talkText":"看起來很睏呢，小透","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2002-2","talkText":"真心超想睡。人家的家啊，\n每天都早上５點就起床了－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2002-3","talkText":"５點！？\n為、為什麼要這麼早起……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2002-4","talkText":"……是為什麼呢？\n人家也沒有想過！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}