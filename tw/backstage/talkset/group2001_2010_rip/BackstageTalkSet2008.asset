{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2008","backstageTalkSetId":2008,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2008-1","talkText":"有沒有那種站在舞台上\n也不會緊張的方法啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2008-2","talkText":"大家都說把觀眾們\n想成蔬菜就好了喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2008-3","talkText":"原來如此……\n不過蔬菜有點……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2008-4","talkText":"啊，對耶\n白白不怎麼喜歡蔬菜呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}