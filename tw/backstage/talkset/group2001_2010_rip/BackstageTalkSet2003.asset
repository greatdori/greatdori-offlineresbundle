{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2003","backstageTalkSetId":2003,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2003-1","talkText":"瑠唯同學，\n沒有事情的時候都在做什麼呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2003-2","talkText":"真要說的話\n我沒有沒事情做的時候呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2003-3","talkText":"因為我總是會先\n寫好一整天的行程表","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2003-4","talkText":"真、真不愧是瑠唯同學……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}