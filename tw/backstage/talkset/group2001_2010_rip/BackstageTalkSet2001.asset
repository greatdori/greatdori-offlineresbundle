{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2001","backstageTalkSetId":2001,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2001-1","talkText":"服裝的設計啊\n都是什麼時候想出來的呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2001-2","talkText":"去卡拉ＯＫ的時候，\n或是拍大頭照的時候之類的？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2001-3","talkText":"啊，還有和朋友一起\n吃飯吃到一半的時候！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2001-4","talkText":"都、都是在玩的時候\n想到的呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}