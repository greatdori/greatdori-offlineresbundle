{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet414","backstageTalkSetId":414,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet414-1","talkText":"我從以前就在想了\n真多虧你這樣也能演奏呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet414-2","talkText":"啊～，就是只要習慣了\n就總是會有辦法的吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet414-3","talkText":"無論何事練習都是最重要的\n不就是這樣嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet414-4","talkText":"的確是這樣沒錯呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}