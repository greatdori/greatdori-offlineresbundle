{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet111","backstageTalkSetId":111,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet111-1","talkText":"吶，里美。我們一起問喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet111-2","talkText":"唔、嗯……！預備～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3,8],"voiceId":"TalkSet111-3","talkText":"薰學姊為什麼會這麼帥氣呢！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet111-4","talkText":"薰學姊為什麼會這麼帥氣呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet111-5","talkText":"呵呵……雖然很難一語道盡……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet111-6","talkText":"但硬要說的話，沒錯……就是因為虛幻吧。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3,8],"voiceId":"TalkSet111-7","talkText":"好、好帥氣……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet111-8","talkText":"……你們為什麼會得出這個結論呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}