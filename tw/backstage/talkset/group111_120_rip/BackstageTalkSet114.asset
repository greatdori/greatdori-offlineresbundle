{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet114","backstageTalkSetId":114,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet114-1","talkText":"沙綾，你們家有在徵求打工人員嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet114-2","talkText":"嗯～如果有會輕鬆很多，但現在好像沒在招募耶。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet114-3","talkText":"這樣啊～……真可惜……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet114-4","talkText":"摩卡，你只是想吃員工餐的麵包吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet114-5","talkText":"而且那樣便利商店的打工該怎麼辦？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet114-6","talkText":"嗚嗚～被圍攻～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}