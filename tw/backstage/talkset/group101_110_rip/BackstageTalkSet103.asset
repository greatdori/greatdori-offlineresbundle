{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet103","backstageTalkSetId":103,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet103-1","talkText":"啊，小心心！米歇爾在那邊喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet103-2","talkText":"真的耶！米歇爾也在休息嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet103-3","talkText":"唔、嗯，對啊～大家也辛苦了。","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet103-4","talkText":"奧澤同學，辛苦了。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":1,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet103-5","talkText":"謝謝你～小咲。","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet103-6","talkText":"演得好徹底……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}