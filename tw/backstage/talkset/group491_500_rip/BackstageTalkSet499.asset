{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet499","backstageTalkSetId":499,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet499-1","talkText":"小緋瑪麗！\n生日快樂！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet499-2","talkText":"哇～！\n謝謝大家～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet499-3","talkText":"這是溫柔的我們準備的\n生日禮物唷～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet499-4","talkText":"啊，這個是！\n是我一直想要的鴨舌帽！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet499-5","talkText":"你之前說過\n有點想要對吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[6],"voiceId":"TalkSet499-6","talkText":"還有這一個蛋糕也是\n在緋瑪麗喜歡的店買的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[8],"voiceId":"TalkSet499-7","talkText":"禮物和生日蛋糕……！\n嗚哇，謝謝大家……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[7],"voiceId":"TalkSet499-8","talkText":"耶咿～\n今年的作戰也大成功～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}