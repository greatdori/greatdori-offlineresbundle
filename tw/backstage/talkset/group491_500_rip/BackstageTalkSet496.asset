{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet496","backstageTalkSetId":496,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet496-1","talkText":"燐子～！\n生日快樂～！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet496-2","talkText":"雖然是要給你驚喜\n會不會太超過了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet496-3","talkText":"不會……沒這回事……\n我很開心……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet496-4","talkText":"請看！\n是要送給燐燐的禮物唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet496-5","talkText":"啊，是NFO的周邊……\n而且是剛出沒多久的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet496-6","talkText":"除了拜託亞子挑禮物之外\n我們還做了蛋糕","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet496-7","talkText":"蛋糕看起來也很好吃……\n我真的……很開心……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}