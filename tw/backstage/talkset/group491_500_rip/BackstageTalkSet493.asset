{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet493","backstageTalkSetId":493,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet493-1","talkText":"生日快樂，美咲\n這是我們準備的禮物唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet493-2","talkText":"謝謝大家。\n啊，這個玩偶……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet493-3","talkText":"是美咲跟米歇爾唷！\n是我們自己做的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet493-4","talkText":"米歇爾和小美兩個人\n關係非常好呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet493-5","talkText":"要把羊毛氈做得漂亮\n真的好困難呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet493-6","talkText":"沒這回事，成品做得很棒。\n真的非常謝謝大家","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}