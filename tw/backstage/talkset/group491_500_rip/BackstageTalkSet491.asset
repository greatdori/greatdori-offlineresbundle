{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet491","backstageTalkSetId":491,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet491-1","talkText":"ハッピーハロウィン！\nみんな楽しみましょ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet491-2","talkText":"あぁ、儚いハロウィンに\nしようじゃないか","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet491-3","talkText":"さんせー！\nはぐみ、鬼ごっこしたい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet491-4","talkText":"鬼って……ちょっと和の\n要素強すぎない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet491-5","talkText":"私、ハロウィンのお菓子に\nお団子持ってきたよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet491-6","talkText":"だから、\n和の要素強いですって！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}