{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet495","backstageTalkSetId":495,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet495-1","talkText":"明天是燐子的生日呢。\n亞子，生日禮物呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet495-3","talkText":"我也確認過了，\n真的要送那個嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet495-2","talkText":"絕對沒問題！\n燐燐一定會很開心的～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet495-4","talkText":"都說了沒問題了！\n大家請放心相信亞子！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet495-5","talkText":"要準備燐子喜歡的禮物\n拜託亞子就對了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}