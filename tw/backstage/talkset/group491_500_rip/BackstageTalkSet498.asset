{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet498","backstageTalkSetId":498,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet498-1","talkText":"呵，呵，呵。\n今天的準備也非常完美～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet498-2","talkText":"只要遇上緋瑪麗的生日\n摩卡就很有精神呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet498-3","talkText":"某種程度上有一種\n最期待的感覺……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet498-4","talkText":"總，總之小緋瑪麗\n開心的話就好了呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}