{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet492","backstageTalkSetId":492,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet492-1","talkText":"明天是美咲的生日呢。\n要怎麼替他慶祝才好呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet492-2","talkText":"想要送小美一份他會\n開心的禮物呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet492-3","talkText":"我想到了一個\n非常棒的點子！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet492-4","talkText":"呵呵，我覺得他\n一定會很開心的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}