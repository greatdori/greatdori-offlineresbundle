{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet435","backstageTalkSetId":435,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet435-1","talkText":"明天是育美的生日呢。要怎麼慶祝才好？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet435-2","talkText":"我是打算送育美玫瑰花跟自己做的詩喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet435-3","talkText":"我打算用煙火跟遊行幫他慶祝喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet435-4","talkText":"那、那麼，呃……我要怎麼辦……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet435-5","talkText":"花音學姊，你冷靜點。普通地慶祝就好囉。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}