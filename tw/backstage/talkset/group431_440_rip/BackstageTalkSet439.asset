{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet439","backstageTalkSetId":439,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet439-1","talkText":"小心心，生日快樂～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet439-2","talkText":"來，這個給你。是生日禮物。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet439-3","talkText":"謝謝你們！裡面有什麼呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet439-4","talkText":"送了我們「笑容的來源」給你喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet439-5","talkText":"我是送了「虛幻的來源」喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[11],"voiceId":"TalkSet439-6","talkText":"這真是超棒的生日禮物，我好高興喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}