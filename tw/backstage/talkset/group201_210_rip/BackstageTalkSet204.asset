{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet204","backstageTalkSetId":204,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet204-1","talkText":"我今天也繞去\n山吹烘焙坊了～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet204-2","talkText":"每個麵包看起來都好好吃，\n不知道要買什麼超猶豫的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet204-3","talkText":"呵呵。\n多謝你的捧場喔，香澄。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}