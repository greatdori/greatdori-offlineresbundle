{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet207","backstageTalkSetId":207,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet207-1","talkText":"小蘭，你別在吉他袋上的\n那個人偶是……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet207-2","talkText":"這是緋瑪麗\n做的護身符喔。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet207-3","talkText":"小緋瑪麗好厲害喔～\n這個很可愛呢。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}