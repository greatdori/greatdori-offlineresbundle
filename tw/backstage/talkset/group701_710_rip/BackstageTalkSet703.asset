{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet703","backstageTalkSetId":703,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet703-1","talkText":"呼～，好重－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet703-2","talkText":"你買了什麼來啊？\n好大一包","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet703-3","talkText":"這該不會是，\n新年才藝表演大會的用具吧～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet703-4","talkText":"咦！？\n為什麼你會知道！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet703-5","talkText":"居然還問為什麼……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet703-6","talkText":"這邊可以看出\n這些東西是什麼哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[6],"voiceId":"TalkSet703-7","talkText":"緋瑪麗那組\n要表演的是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[8],"voiceId":"TalkSet703-8","talkText":"啊哇哇哇哇！\n不可以說出來～～～！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet703-9","talkText":"畢竟說好了\n到新年前都要保密呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet703-10","talkText":"我們每個人的組別都不同\n答案當天才能揭曉呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[7],"voiceId":"TalkSet703-11","talkText":"不過啊，小緋那組\n要表演的就是～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[8],"voiceId":"TalkSet703-12","talkText":"不不不不可以說啦～～！！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}