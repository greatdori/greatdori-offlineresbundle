{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet707","backstageTalkSetId":707,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet707-1","talkText":"嗚嗚，只有我一個人\n一直做不到……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet707-2","talkText":"還有一點時間，\n只要練習就可以辦到！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet707-3","talkText":"啊，在聊才藝表演嗎～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet707-4","talkText":"對啊。我學東西很慢\n所以進度落後了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet707-5","talkText":"不過學姊們也很\n溫柔地指導了我們對吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet707-6","talkText":"雖然是這樣沒錯～……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet707-7","talkText":"白白，加油～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet707-8","talkText":"唯唯和透透被分到\n同一組對吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[27],"voiceId":"TalkSet707-9","talkText":"對！　人家已經無懈可擊了！\n瑠唯也有親眼見識到吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[30],"voiceId":"TalkSet707-10","talkText":"如果不說你忘記\n拿東西的部分的話","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[27],"voiceId":"TalkSet707-11","talkText":"最後還不是成功了\n也還好吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[29],"voiceId":"TalkSet707-12","talkText":"啊，好了好了\n你們兩位……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[28],"voiceId":"TalkSet707-13","talkText":"不論是哪一組感覺\n都很不容易呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}