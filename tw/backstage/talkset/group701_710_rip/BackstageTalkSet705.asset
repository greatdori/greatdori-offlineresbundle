{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet705","backstageTalkSetId":705,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet705-1","talkText":"哎呀，現在是在\n討論才藝表驗大會嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet705-2","talkText":"各位！\n沒錯，就是這樣","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet705-3","talkText":"我們的表演排場很大\n所以準備起來也不容易～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet705-4","talkText":"薰的確會說出\n天馬行空的提案呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet705-5","talkText":"這是常有的事情啦。\n嘿嘿","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet705-6","talkText":"呵呵，大家都很開心耶～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet705-7","talkText":"彩學姊的組別\n進行的順利嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[16],"voiceId":"TalkSet705-8","talkText":"我們組之前一起彩排過了喔～\n小菜呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet705-9","talkText":"我們組應該算還在\n個人練習的階段吧～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet705-10","talkText":"我現在正在構思\n會讓人嚕♪起來的新絕招～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet705-11","talkText":"再透漏下去的話\n就會被知道要表演什麼了喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[17],"voiceId":"TalkSet705-12","talkText":"啊，對耶。有說好表演內容\n要保密到新年才能公布","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}