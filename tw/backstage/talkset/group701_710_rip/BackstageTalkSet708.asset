{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet708","backstageTalkSetId":708,"snippets":[{"talkId":1,"characterIds":[],"voiceId":"TalkSet708-1","talkText":"要我表演才藝！？\nＷhy！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet708-2","talkText":"可以和CHU²大人同組\nPAREO非常開心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[],"voiceId":"TalkSet708-3","talkText":"我不是在說那個！\n我是要說又沒有表演的必要！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[31],"voiceId":"TalkSet708-4","talkText":"益木和LOCK的組別\n進展順利嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet708-5","talkText":"非常順利！我們組有彩學姊\n替大家注意進度……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet708-6","talkText":"我們組目前也\n還算順利","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[34],"voiceId":"TalkSet708-7","talkText":"那個，LAYER學姊的組員\n我記得好像是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[31],"voiceId":"TalkSet708-8","talkText":"嗯，我和小花一組。\n所以練習也很開心喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[31],"voiceId":"TalkSet708-9","talkText":"還有，\n阿異也在喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[34],"voiceId":"TalkSet708-10","talkText":"阿異是在說，\n那個……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[31],"voiceId":"TalkSet708-11","talkText":"沒錯沒錯。\n小花養的－－","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[],"voiceId":"TalkSet708-12","talkText":"Stop！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[],"voiceId":"TalkSet708-13","talkText":"才藝表演的內容\n是Secret才對","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[32],"voiceId":"TalkSet708-14","talkText":"CHU²同學……\n你其實也很期待吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[],"voiceId":"TalkSet708-15","talkText":"煩、煩死了！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}