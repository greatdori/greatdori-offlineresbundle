{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet704","backstageTalkSetId":704,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet704-1","talkText":"渾沌射擊！\n這個怎麼樣，紗夜學姊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet704-2","talkText":"我說過很多次了，\n沒有必要喊口號","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet704-3","talkText":"呵呵……在聊才藝表演\n大會的話題嗎……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet704-4","talkText":"沒錯！　我們的表演超厲害\n請你好好期待哦，燐燐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet704-5","talkText":"嗯……我們也會，\n好好加油……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet704-6","talkText":"是啊。要從現在開始\n繼續鍛鍊肺活量","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet704-7","talkText":"不，不用……\n好像會有打氣機……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet704-8","talkText":"居然，是那樣嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet704-9","talkText":"好好喔～。可以跟團員\n分到相同的組別～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet704-10","talkText":"莉莎不是也準備得\n很開心嗎","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet704-11","talkText":"對啊，很開心喔☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[23],"voiceId":"TalkSet704-12","talkText":"我們組的表演排場超大，\n大家要好好期待喔!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[24],"voiceId":"TalkSet704-13","talkText":"哇啊，\n新年可不可以快點到啊～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}