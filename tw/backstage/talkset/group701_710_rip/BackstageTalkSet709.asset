{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet709","backstageTalkSetId":709,"snippets":[{"talkId":1,"characterIds":[11,13],"voiceId":"TalkSet709-1","talkText":"Yeah！\nHappy New Year！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet709-2","talkText":"要開始囉～！\n嘿啊！　嘿啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":3,"characterIds":[34],"voiceId":"TalkSet709-3","talkText":"哦哦～～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet709-4","talkText":"接下來換我們了哦。\n一起加油吧♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[],"voiceId":"TalkSet709-5","talkText":"這真、真的\n有點太高了啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[34],"voiceId":"TalkSet709-6","talkText":"不用擔心♪\n我們有準備軟墊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet709-7","talkText":"不要怕！　只要鼓起勇氣\n什麼事情都可以辦到喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[11],"voiceId":"TalkSet709-8","talkText":"沒錯，最重要的是笑容。\n大家一起來～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9,11,13],"voiceId":"TalkSet709-9","talkText":"嘿啊～SMILE～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":10,"characterIds":[],"voiceId":"TalkSet709-10","talkText":"Unbelievable……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}