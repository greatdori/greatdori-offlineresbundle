{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet706","backstageTalkSetId":706,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet706-1","talkText":"你們兩個，才藝表演大會\n準備得還行嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet706-2","talkText":"嗯！　完全可以喔！\n對吧，心心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet706-3","talkText":"美咲在操心什麼呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet706-4","talkText":"我和育美會一起\n讓大家都露出笑容喔！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet706-5","talkText":"因為是你們兩個\n所以我才擔心好嗎！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet706-6","talkText":"呵呵……美咲那份\n替夥伴著想的心意……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet706-7","talkText":"啊啊，真是虛幻","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet706-8","talkText":"呵呵……那，\n小美咲的組別還順利嗎？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet706-9","talkText":"還行，我們組還算順利。\n畢竟我也算是有經驗的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet706-10","talkText":"有經驗……？\n你們要表演什麼呢……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet706-11","talkText":"啊！　不是啦\n這要保密才行……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[11],"voiceId":"TalkSet706-12","talkText":"一定是用笑容讓大家\n也充滿笑容的「笑容才藝」！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[13],"voiceId":"TalkSet706-13","talkText":"好期待喔～～！\n小美的笑容才藝！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[12],"voiceId":"TalkSet706-14","talkText":"我也非常期待能欣賞到\n美咲令人捧腹大笑的才藝喔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[15],"voiceId":"TalkSet706-15","talkText":"會不會把標準設得太高啊……\n一般來說不會這麼期待吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}