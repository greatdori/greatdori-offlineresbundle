{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet702","backstageTalkSetId":702,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet702-1","talkText":"新年的才藝表演大會，\n大家已經決定好要做什麼了嗎！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet702-2","talkText":"喂，不是說好\n不准問這個了嗎～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet702-3","talkText":"雖然是約好了沒錯～，\n但還是會在意嘛！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet702-4","talkText":"我們組……呵呵。\n大家一定會大吃一驚吧～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet702-5","talkText":"對啊！\n還有邀請到特別嘉賓！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet702-6","talkText":"超期待的～。\n我們組是和式風格喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet702-7","talkText":"我們組也是\n春節感滿滿的感覺","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet702-8","talkText":"嗯～～～，\n超想知道的～～～！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet702-9","talkText":"總之，\n敬請期待新年那天","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[1],"voiceId":"TalkSet702-10","talkText":"嗚嗚～，還要再睡\n幾天新年才會到啊～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}