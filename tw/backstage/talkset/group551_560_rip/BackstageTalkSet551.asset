{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet551","backstageTalkSetId":551,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet551-1","talkText":"今井さんのクッキー\nいつも美味しいです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet551-2","talkText":"ありがと！　でもアタシ\n紗夜のクッキーも好きだな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet551-3","talkText":"みんなのことを思って\n作ったのがわかるから","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet551-4","talkText":"そ、それは……今井さんも\n同じでしょう？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}