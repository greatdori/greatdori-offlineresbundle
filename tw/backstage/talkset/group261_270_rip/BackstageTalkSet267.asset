{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet267","backstageTalkSetId":267,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet267-1","talkText":"我烤了餅乾喔。\n你吃吃看","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet267-2","talkText":"哦，謝啦，小鶇！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet267-3","talkText":"嗯！跟平常一樣地\n好吃唷！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}