{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet261","backstageTalkSetId":261,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet261-1","talkText":"抱歉我遲到了，\n等很久了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet261-2","talkText":"不會，沒有！可是……\n小鶇你會遲到還真少見耶","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet261-3","talkText":"因為餅乾再一下下\n就要烤好了所以……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet261-4","talkText":"哇～，是餅乾耶！\n好像很好吃～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}