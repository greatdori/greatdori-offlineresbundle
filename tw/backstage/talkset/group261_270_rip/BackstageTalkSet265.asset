{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet265","backstageTalkSetId":265,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet265-1","talkText":"今天社團活動的練習，\n好辛苦喔～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet265-2","talkText":"因為網球就是要\n在球場上跑來跑去啊～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet265-3","talkText":"因為要殺球手腕都\n硬梆梆了，腳也好酸～～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet265-4","talkText":"啊～，我超懂。\n超級超級懂唷","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}