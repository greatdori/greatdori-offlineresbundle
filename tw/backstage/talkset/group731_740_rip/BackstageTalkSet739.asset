{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet739","backstageTalkSetId":739,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet739-1","talkText":"有沒有什麼\n好玩的事情啊～","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet739-2","talkText":"那我們出發去\n找好玩的事情吧！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet739-3","talkText":"哦哦～，\n有種冒險開啟的預感～","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet739-4","talkText":"我馬上去準備\n米歇爾氣球過來！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet739-5","talkText":"好耶－！\n天空之旅，出發～！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}