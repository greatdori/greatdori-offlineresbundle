:0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"七深，你在笑什麼啊？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev223-ep3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"沒想到以開始玩樂團為契機，\n居然會讓這麼多事情都發生了改變～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev223-ep3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"而且還全都是正向的改變哦？\n這點讓我很開心～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev223-ep3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"啊哈哈，七深你也太誇張的吧～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev223-ep3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"人家我啊，可是每天都會進步一萬步喔！\n寫在這上面的東西，就只是冰山一角而已","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev223-ep3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"我看看哦，透透寫的是……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev223-ep3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":1,"soundReferenceIdx":2,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"「大家開始會一起去家庭式餐廳」\n「午休時，大家開始會一起吃飯」","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":28,"voiceId":"ev223-ep3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"「像是在LIVE結束後，大家也會一起拍合照\n(順帶一題，LIVE後真心超嗨的！）」","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":28,"voiceId":"ev223-ep3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"沒錯沒錯！　LIVE結束後，明明已經在舞台上耗盡體力了，\n但不知道為什麼還能那麼嗨耶～。這算樂團七大不可思議吧？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev223-ep3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"筑紫","body":"真是的－！　才沒有那種七大不可思議好嗎～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"ev223-ep3-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"就廣町個人而言，一起吃午餐還有在LIVE後拍合照，\n雖然不是什麼大事，但能看出我們的關係變得很要好，\n讓人覺得非常開心～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev223-ep3-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"真白","body":"我也是……\n能和大家起去做的事情變多了，真的很開心","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev223-ep3-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"對吧！　瑠唯，你要選這個也沒關係喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev223-ep3-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEf