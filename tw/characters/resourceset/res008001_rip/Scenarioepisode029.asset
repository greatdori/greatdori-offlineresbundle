orSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":12,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":13,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"我叫上原緋瑪麗～！\n高中1年級～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"參加的社團是網球社，還在速食店打工。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"還有呢，就是在Afterglow這個樂團裡彈貝斯～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"樂團裡面我算是隊長啦。\n雖然看起來很不可靠……。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"這個樂團是由小時玩伴所組成，\n可是，該說是沒協調性，還是很有個性……。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"呵，主要是其中2名啦。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"上次練習時還遲到，\n原因竟然說是『麵包店大特價就跑去看看』……。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"……啊，不好意思讓你聽我抱怨。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"雖然很多辛苦，不過每天也很開心。\n這是真的！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"剛剛雖然說他們很有個性，\n不過當音樂合奏起來，卻是奇妙的開心呢～。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"所以才會接納有些過於自由的成員吧。\n……嘿嘿嘿。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":"嗯〜，講著講著就有幹勁了！\n好～，來吧！！！\n加、加、油～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"緋瑪麗","body":