0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"我是特別喜歡這本耶","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev63-ep5-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"啊～，這本很棒耶。\n不過，這個我記得是滿悲傷的故事對吧？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev63-ep5-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"嗯。不過，故事的最後\n原本壞心眼的王子，\n獲得了溫柔的心情變得幸福了喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev63-ep5-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"對啊對啊！\n雖然中途很悲傷，但到最後變成很溫暖的\n一則故事對吧！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev63-ep5-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"嗯。不過……繪本真是不可思議耶。\n明明就是已經看過好幾次的故事，但想到的時候\n又會想再看一次耶","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev63-ep5-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"的確是。內容我明明都還記得，\n但每次看都會很興奮呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev63-ep5-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"應該說是，每次看的時候都可以看到不同的景色嗎……\n會發現，啊啊，原來也有這層意義啊\n所以無論多久何時都可以維持在最喜歡的心情吧？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev63-ep5-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"就是啊。\n大概是，因為真的有蘊含了各式各樣的心情吧？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev63-ep5-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whe