-n-lock-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"那邊可以看見一支很高的煙囪對吧。\n那是我現在寄宿的旭澡堂。\n益木學姊也很常來光顧喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"嗯，的確是這樣呢……家人不在身邊，\n真的會讓人小小地感到寂寞……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"不過，我也已經習慣了在東京的生活，\n每天都過得很開心喔！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"咦？　最開心的部分……應該是加入了樂團吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"其實我國３的時候非常煩惱要以後要做什麼，\n那個時候剛好在SPACE看了Poppin'Party的LIVE","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"真的無法言喻……，非常地感動！\n幾乎是做夢也會夢到的滿滿的感動！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"升學考試的時候，國中時組的樂團沒辦法繼續練下去","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"所以我就想，要在有像Poppin'Party這麼棒的樂團在的\n這個城市裡組樂團，和他們登上同一個舞台看看！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"雖然剛來東京的時候，完全找不齊團員，\n非常的令人沮喪……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"受到我最喜歡的Popipa邀請的時候\n因為Popipa是那五個團員的Popipa，\n多了我一個就失禮了，所以拒絕了邀約……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"就在那時，剛好被CHU²同學挖角了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"雖然也有過疑惑，但現在能以RAS一員的身分\n和大家一起練習、一起辦LIVE，讓我非常開心","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"memorial-n-lock-016","vol