Index":1,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":31,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":32,"delay":0,"isWaitForSkipMode":0},{"actionType":7,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":6,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":0,"progressType":1,"referenceIndex":0,"delay":2.5,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"兩位好，麻里奈小姐，{{userName}}","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"你好，小紗夜。你今天是來個人練習的對吧？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"是的。我前幾天出了一趟遠門，\n所以今天想連同那天的份一起好好練習回來","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呵呵，小紗夜還是一樣認真進取耶。\n對了，你說出遠門，是去了哪邊啊？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"我和羽澤同學一起，去了我們喜歡的\n小說的故事背景舞台的那座城鎮","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"雖然原本的目的是要去吃那座小鎮的咖啡廳\n賣的巧克力瑞士捲，不過在抵達咖啡廳之前\n我們一路上遇見了許多美好的風景","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"很棒耶－，感覺很好玩耶！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"是的，空氣清新，氣氛寧靜……是一座令人心靈平靜的小鎮，\n不過一想到小說的故事舞台就在眼前，\n就連平凡的景色也讓人感到十分雀躍","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"這樣啊！　呵呵，好像進到了小說世界裡面，感覺真的好有趣。\n對了，巧克力瑞士捲嚐起來怎麼樣呢？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"我們想去的咖啡廳當天不巧臨時歇業……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呃，居然。\n那真的好可惜喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"是啊，不過……經過羽澤同學的提議，\n我們後來決定自己動手做小說裡的巧克力瑞士捲","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"是喔～，感覺很有趣耶！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"是的。為了製作食譜，我們重看了小說，\n又比之前對故事情節有更深的理解了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"而且更重要的是，和大家一起做的過程中\n我們彼此共度了一段「共享快樂」的有意義的時光","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呵呵，突發事件被賦予了正面意義","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"不過，提議自己做巧克力瑞士捲，\n還真是有小鶇的風格","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"是啊，羽澤同學這種積極正向的態度，\n真的讓我學習到很多","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":22,"voiceId":"ev177-me1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"其他還有，他也發現了平時路過會錯過的\n剛開不久的梅花","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"做巧克力的時候也是，\n他對戶山同學他們說了「你們做得開心，我也教得很開心」","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf_left01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"他很擅長像這樣，\n發現日常生活中得微小變化，\n和找到他人的優點……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呵呵……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0},{"characterId":22,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"？　請問怎麼了嗎，麻里奈小姐","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":22,"voiceId":"ev177-me1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"不是什麼大事，我只是覺得小紗夜\n從剛剛開始就一直很開心地在說小鶇的優點","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"是，是嗎……？\n我自己沒有發現……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev177-me1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"說不定，小紗夜也在和擅長找出別人優點的小鶇\n相處的過程中，得到影響了吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"真的，是嗎……\n如果是的話，就太令人開心了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":22,"voiceId":"ev177-me1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"嗯嗯。希望小紗夜以後也能常\n和小鶇一起出門去各種地方玩","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev177-me1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characte