,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"episode-r-rokka-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"不禁讓人想「原來這首曲子可以像這樣玩啊……」\n又讓人期待著下次的風貌，令我非常興奮！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"episode-r-rokka-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"……是嗎。\n我的鼓聲原來有做了這麼有趣的事嗎","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"episode-r-rokka-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"咦咦咦，抱、抱歉……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"episode-r-rokka-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"沒事，這不也很好嗎～\n樂團不就是要做這種事嗎，我猜啦","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterI