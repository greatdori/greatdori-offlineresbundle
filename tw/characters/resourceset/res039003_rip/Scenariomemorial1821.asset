rId":225,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-sr-soyo-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"凜凜子","body":"今後也會定期請他過來，\n我想會有很多機會受到他的照顧喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-sr-soyo-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"是這樣的啊，我叫做，長崎爽世","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"今後也要請你，多多指教","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"bye02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"……話說回來，兩位是在休息中嗎？\n是的話很抱歉，我打擾到你們了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"serious02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"凜凜子","body":"啊〜，沒關係喔。雖然是在休息中，\n但也同時在讓他記住餐廳的菜單呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-sr-soyo-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"凜凜子","body":"對了。既然餐廳常客的小爽在這，\n如果你能跟他說說推薦菜色就太好了呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-sr-soyo-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"別這麼說，什麼常客啊。\n只是因為這裡的菜色，每一種都很好吃所以才不知不覺常來了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"……不過，讓我想想喔。\n我常點的，是熱格雷伯爵茶","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"很清爽，很好入口……\n如果要我推薦一種的話，就是這個了吧〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"凜凜子","body":"嗯嗯。果然客人的意見最值得參考了呢。\n還有些其他的嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-sr-soyo-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"咦〜？　我想想喔……\n還有就是，食物類也很豐富呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"像是輕食啊、點心之類的。\n努力練習的話肚子就會餓，所以很感激呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"例如像炸薯條，\n就很適合樂團裡的大家一起吃……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"聖代呢，我的熟人常常點，\n因為份量很足夠會令人覺得很豪華","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"凜凜子","body":"哇啊，有收到好評那就太棒了！\n我可是很努力地想了各種點子呢〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-sr-soyo-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"呵呵，一直很感謝你","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"bye02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"memorial-sr-soyo-021","volume":1}],"speed":0