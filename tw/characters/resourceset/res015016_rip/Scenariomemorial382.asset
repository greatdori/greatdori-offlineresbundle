{"characterId":15,"voiceId":"ev33-me3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"話說回來，你還真能滑耶〜\n不會很難行動或是很冷嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev33-me3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"那個啊……其實\n不知為何滑雪場出現一群黑西裝打扮的人，\n交給我冬季專用的米歇爾裝","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev33-me3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"冬季專用的米歇爾裝……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev33-me3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"是的，裡面非常溫暖，\n外面的毛好像是防水材質，比想像中的還要更舒適","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev33-me3-015","volume":1}],"speed":0,"