enStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"真白","body":"可，可是，樂團活動還有其他事都很忙……\n也還要想下次新曲的歌詞……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"uziuzi01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"urafes-MS-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"筑紫","body":"不要找藉口－！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"urafes-MS-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"真白","body":"嗚，嗚嗚……！\n誰叫數學越來越難，\n英文單字也全都記不住……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"urafes-MS-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"筑紫","body":"嗯～……。不過，小真白，你不是能順手\n就寫出妖精和龍的名字嗎。\n我還以為你對英文應該蠻拿手的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"urafes-MS-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"w