01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev162-ep3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"我嗎？　嗯－……中庭或走廊吧！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev162-ep3-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"因為中庭很容易積落葉跟垃圾，\n走廊也是大家平時都會經過的地方！\n不論是哪邊，打掃乾淨過後一定會讓人覺得心情很好！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev162-ep3-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"哦－，真不愧是美化委員！　很有幹勁喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev162-ep3-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"啊，不過，不管抽到什麼地方\n我都會盡全力去打掃！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voic