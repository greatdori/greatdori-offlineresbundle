d":13}],"windowDisplayName":"育美","body":"欸嘿嘿！　那是育美第一次看馬戲團表演，\n所以覺得非常興奮……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev164-me5-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"育美","body":"才覺得走鋼絲的人快掉下去，\n但他翻了一圈又維持平衡了！\n以為已經結束的魔術，其實還一直進行著！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev164-me5-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"育美","body":"光是猜下個瞬間會發生什麼事，就讓人覺得好快樂！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev164-me5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"對啊對啊，畢竟事事難料就是馬戲團的醍醐味呀","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nnf05","expressionName":"smile02","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev164-me5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"育美","body":"就是說啊！　一點