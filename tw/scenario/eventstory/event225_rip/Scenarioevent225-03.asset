fault","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event225-03-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"你跟他說可樂餅，他應該也不知道那是什麼吧。\n它是馬鈴薯跟絞肉裹上麵包粉後油炸的料理――","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event225-03-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"夏洛特","body":"該不會你說的是炸肉餅吧？\n如果是的話，我祖母有做過好幾次給我吃！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"nnf05","expressionName":"smile02","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event225-03-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"夏洛特","body":"聽說好像是法國的炸肉餅傳到日本，\n變成了可樂餅。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event225-03-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"育美","body":"咦！？原來可樂餅……是從法國來的！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"cha