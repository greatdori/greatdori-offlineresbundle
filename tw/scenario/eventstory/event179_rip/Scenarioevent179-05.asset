ult","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event179-05-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"嗯。雖然說法不太好，但我覺得益木也沒錯。\n不過，我有點意外耶，小唯居然會這麼說","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event179-05-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"因為小唯，比起說對的事情就是對的，\n倒不如給我一種「做多餘的舉動就是錯的」的感覺","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event179-05-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"…………\n也是，我以前可能是那麼想的沒錯","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event179-05-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"不對，我的想法即使在現在也並沒有改變。\n只是，我也開始覺得\n採取佐藤學姊的作法也能有所收穫而已","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event179-05-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"這樣啊……\n可以理解但並不接受，是這種感覺嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event179-05-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"…………\n真要說的話應該是反過來才對。\n應該說成，不能理解但可以接受","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event179-05-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"嗯－，什麼意思呢……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event179-05-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"……我的樂團團員，總是拿心意和夥伴成理由\n採取沒有效率的方法，我完全無法理解是什麼原因驅使他們行動","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId"