Idx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"這些我們都沒做","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event189-01-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"LIVE觀眾A","body":"Afterglow今天的LIVE，超棒的說。\n感覺身體都熱了起來","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"LIVE觀眾B","body":"我懂～。\n有種「FUTURE WORLD FES. 」的Roselia的感覺！","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0},{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"LIVE觀眾A","body":"不過，真要說的話還是Roselia比較厲害。\n那場演出，真心無從挑剔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"LIVE觀眾A","body":"話說，「FUTURE WORLD FES. 」也快開始了。\n今年不曉得會怎樣","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","vo