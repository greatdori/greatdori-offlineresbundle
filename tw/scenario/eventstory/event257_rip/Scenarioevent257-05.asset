le的快樂情緒漸漸傳遞出去，\n大家，真的都在盡情地享受……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-05-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈央","body":"（這……比我想像得還更加……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-05-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"――♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event257-05-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻彌","body":"大家，我們做到了……！\n我們成功突破了第３輪戰！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event257-05-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"會場真的嗨～～到不行耶！\n我當時就覺得我們能成功！！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions"