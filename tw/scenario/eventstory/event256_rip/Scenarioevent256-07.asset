rs":[{"characterId":34}],"windowDisplayName":"PAREO","body":"對。不管將來是要做音樂，還是升學進高中，\n他們是說等到時候再一起討論……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"event256-07-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"雖說有種因為覺得你是孩子才把答覆的時間往後延了的感覺，\n但對我們來說這樣可正剛好啊。\n只要有時間的話我們就可以盡可能地準備說服用的資料嘛","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event256-07-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"我父母所想的期限是到考大學為止……\n在那之前我得好好地表達出我的心情才行","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"event256-07-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"高中的這３年，不能悠哉地度過了呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event256-07-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"cha