d":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"咦……？　","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nnf03","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event258-02-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":210}],"windowDisplayName":"蘭的爸爸","body":"在為數眾多的選擇中，會做出專注花道的這個選擇\n真的很符合蘭的個性。只不過，你知道你為何能如此選擇嗎？","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":210,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"那是因為……我已經決定了今後要比以往\n更認真地去面對花道，不是嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event258-02-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":210}],"windowDisplayName":"蘭的爸爸","body":"你能夠這樣子做出決定，是因為蘭你還處於\n隨時都可以去選擇其他選項的環境啊","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":210,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":210}],"windowDisplayName":"蘭的爸爸","body":"因為假設，你退出了樂團，跟小卡他們之間的\n關係也不會因此