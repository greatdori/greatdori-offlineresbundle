eWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"嗯！　我也想看！\n聲音是從後面傳來的吧？\n我們去看一下好了！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event44-02-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"這２個人真的是好奇心的聚合體呢……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event44-02-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"美咲！　香澄！　你們看！\n那邊的人在打太鼓！\n哇～，好大的太鼓喔～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event44-02-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"真的耶！\n可能跟我的身高差不多耶！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event44-02-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"巴","body":"喔？　香澄……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event44-02-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"啊！　是小巴！\n小心心你看！　在那裡的是小巴耶！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event44-02-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"真的耶！\n該不會巴也是被太鼓的聲音所誘惑，\n才來到這裡的嗎！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event44-02-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"不不不……\n看他的裝扮，一定不是好嗎","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event44-02-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"巴","body":"嗯？　原來心跟美咲也在阿？\n你們怎麼會在這裡？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event44-02-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"那個啊，我跟小心心跟小美咲一起放學回家，\n就聽到從神社傳來太鼓的聲音，\n以為有舉辦祭典所以就跑來看看了！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event44-02-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"巴","body":"原來如此。但真的抱歉啊～。\n其實周末才要舉辦祭典。\n今天只是來練習和太鼓而已","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event44-02-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"咦？　剛剛的太鼓的聲音，是小巴演奏的嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event44-02-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"原來是這樣！　太厲害了！\n是個非常愉悅的節奏喔！\n我的身體會不由自主躍動呢！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event44-02-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"巴","body":"哈哈哈，很高興聽到你這麼說。\n啊，對了。現在休息結束後馬上會再進行練習，\n如果有時間的話，要不要看一下練習呢？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event44-02-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"咦！？　可以嗎！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event44-02-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"巴","body":"當然啦！\n有觀眾在旁邊看的話，\n演奏也會更加賣力的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event44-02-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"太好了～！\n小心心！　我們一起看吧！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"e