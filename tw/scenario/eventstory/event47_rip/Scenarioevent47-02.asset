tHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"啊！\n我記得，跟小育第一次在公園見面的，\n好像也是這種大熱天喔！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event47-02-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"香澄","body":"哇～！　這個公園好棒喔！\n有好多『玩具設施』喔～！\n我要從哪一個開始玩呢～！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-02-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"香澄","body":"我想想……\n要～選～哪～一～個～呢～，\n就～交～給～神～明～選～擇～吧～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-02-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"香澄","body":"好耶～，是盪鞦韆～！\n來吧！　我要去玩盪鞦韆了～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-02-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkChara