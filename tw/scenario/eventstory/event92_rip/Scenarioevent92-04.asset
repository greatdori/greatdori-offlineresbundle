,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"有咲","body":"原來撞我的人是你啊，惠惠！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event92-04-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"但是啊，不過只是扮裝走在路上而已，\n感覺卻非常好玩呢！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event92-04-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"我懂那種心情～！\n有種非日常的感覺，讓人很雀躍呢。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event92-04-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"街景看起來好像也跟平常不一樣了！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event92-04-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundRef