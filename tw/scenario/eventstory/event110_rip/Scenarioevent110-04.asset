equirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"對啊。到現在還沒聽到球先生的聲音過","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event110-04-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"不過呢，心。我發現了一件非常重要的事唷。\n要和別人打好關係之前，首先要先讓對方了解自己才行","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event110-04-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"對呢！　這真的是非～常重要的事情呢！\n謝謝你告訴我，薰！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event110-04-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"不用客氣。這也是為了讓練習賽順利進行","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event110-04-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"那麼，必須要快點進行自我介紹才對呢！\n首先由我開始！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event110-04-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"球先生，你好！　我的名字叫弦卷心唷！\n在一個叫Hello,Happy World!的樂團裡唱歌！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event110-04-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"壘球的話，我負責擔任右外野手！\n喜歡的東西是大家的笑容！　笑容真的是超棒的東西呢！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event110-04-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"心","body":"然後呢，我想要和你當好朋友！\n變成好朋友之後，我們一起笑容滿點地打壘球吧！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event110-04-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}]