indowDisplayName":"日菜","body":"週末的天氣是……大晴天耶〜。\n吶，去海邊怎麼樣？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event86-01-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千聖","body":"海、海邊……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event86-01-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"哇，海邊！　我想去！\n我去年雖然有因為工作去過海邊，\n但是想說如果私底下也能去的話就好了呢〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event86-01-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千聖","body":"海邊啊……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event86-01-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"小千反對嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,