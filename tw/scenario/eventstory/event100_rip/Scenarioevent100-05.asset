:0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"唔、嗯……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"隨著『孤獨之城』的一再播出，也提高了注目，\n還被評為一部精采的作品……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"而你在那之後，因為在『孤獨之城』的演技獲好評，\n也接連得到演出各種作品的機會呢。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千聖","body":"明明是我的事情，你卻記得這麼清楚啊。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event100-05-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"呵呵，你是我重要的兒時玩伴嘛。\n而後某一天，你就接下了\n個性溫柔又抱持強烈正義感的偵探角色。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"雖然是和在『孤獨之城』中扮演過的角色個性完全相反，\n你還是演得很出色，我還記得很清楚，這時\n班上同學們對你投注的眼光都變得不一樣了。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"大家真的很狡猾耶。\n自從「小學生偵探真子」開播之後，\n就突然開始說小千溫柔又帥氣。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"我還是覺得……無法接受……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"沒關係啦，小薰。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"咦……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"已經、沒關係了。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"小薰、媽媽、妹妹……還有雷歐。\n只要我喜歡的大家知道\n我是個怎樣的人，那就夠了。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"不管其他人們是怎麼看待我，\n在當女演員的人還是我。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"小千，你怎麼了？突然這樣說……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"我一直在想，要是不再有覺得悲傷的心情該怎麼辦？\n而且，也因此感到很害怕……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"但就連那種心情，還有至今沒有體會過的心情，\n全都可以透過演戲表現出來呢。這也沒什麼好怕的。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"但是……小千呢？\n小千去哪裡了呢？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"小薰真是溫柔呢。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"小薰，你不可忘記這份溫柔喔。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"呵呵，雖然有點膽小，還會被雷歐拉著跑，\n但那就是小薰嘛。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"小千……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voice