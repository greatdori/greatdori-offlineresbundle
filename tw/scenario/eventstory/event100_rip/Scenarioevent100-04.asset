","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-04-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"要是有人對我那樣說，我就會嚇到又很害怕……\n什麼話都說不出來了。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-04-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"……","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":320,"voiceId":"event100-04-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"如果，我也可以變得跟小千一樣堅強就好了。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-04-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千聖","body":"……我也不是想成為堅強的人。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-04-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceI