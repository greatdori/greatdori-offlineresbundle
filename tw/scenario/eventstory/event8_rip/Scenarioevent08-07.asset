ectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"那個……我是因為受到步美小姐的話激勵，\n才目標成為偶像的！步美小姐經常說……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event08-07-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":213}],"windowDisplayName":"步美","body":"『無論是怎麼樣的人，只要努力，夢想就會成真。\n所以請別想『反正我就是』，\n正視自己的夢想吧』……這句話嗎","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":213,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":213}],"windowDisplayName":"步美","body":"我也是相信著這句話，才能努力到今天的。\n我說的話有傳達到給你，真的很高興呢","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":213,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":213}],"windowDisplayName":"步美","body":"是嗎。就是因為這個嗎。\n……所以小彩和我才那麼相似呢","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":213,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"咦……！！","tention":0,"lipSyn