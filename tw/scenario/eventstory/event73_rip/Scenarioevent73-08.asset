aracterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event73-08-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"莉莎","body":"啊哈哈，對呀對呀！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event73-08-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"從那之後，總覺得自然而然地\nRoselia的氣氛就變好了起來","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"event73-08-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"燐子","body":"是的。大家把Roselia的事情……\n看得、比以前……\n更加重要，我覺得那件事……成為了這樣的契機……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event73-08-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"莉莎","body":"哎呀，雖然也因為那樣，這個『Neo-Aspect』的時候\n也有各自不互相理解的地方呢〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionNam