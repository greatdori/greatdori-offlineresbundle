tartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"但透透一問了關於手機的事，\n卻很少見地回不出話來","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event223-03-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"筑紫","body":"其實……我也不曉得怎樣才是正確的。\n他們兩邊說的，我都明白","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event223-03-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"也是，雖然必須遵守校規沒錯……\n但這次真的有點太突然了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event223-03-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"筑紫","body":"對啊……\n唉……我明明就是團長","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event223-03-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深",