":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"我也很怕牙醫，所以可以懂惠惠的心情呢……\n因為鑽頭很可怕，所以還哭著說：我不想去～呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event241-02-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"多惠","body":"就是說啊，一想到非得去看牙醫才行\n我就連聽到工程現場的鑽頭聲都會怕了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event241-02-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"多惠","body":"不管做什麼事我都會一直想到看牙醫這件事……\n連上課中，也會一直去看課本裡面的人的牙齒\n完全無法集中精神呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event241-02-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"有咲","body":"這麼嚴重啊……\n那，果然還是得趁早去看牙醫才對啦。\n我不會害你的，你乾脆今天就先預約……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nnf04","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event241-02-054","volume":1}],"speed":0,