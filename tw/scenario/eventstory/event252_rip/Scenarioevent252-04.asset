},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"友希那","body":"嗯嗯，謝謝你，爸爸。","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event252-04-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"大學生","body":"白金同學，那麼就下堂課見。\nAll Fes.，要加油喔！","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"燐子","body":"好的，謝謝你……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event252-04-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"燐子","body":"（雖然說也可能是因為是音樂系……\n但因為All Fes.的事情跟我搭話的人變多了呢……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event252-04-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"燐子","body":"（這麼一個關注度高的音樂祭……\n為了不失敗，得把該做的事都做完再登台才行……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"serious01","expre