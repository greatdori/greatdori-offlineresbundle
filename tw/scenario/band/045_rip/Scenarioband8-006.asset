henFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"我找找，公告欄公告欄……\n鼓手招募，鍵盤手和貝斯手招募……嗯？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"thinking03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"啊！　是昨天月森女的學生！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"啊〜，你是昨天在RiNG前面的那個女生……對吧？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"（要說月森女的話，那就是名門中的名門大小姐學校……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"（有傳聞說那是只有政治家或藝人的小孩才能進去就讀的學校，\n要是先和他打好關係的話，或許會有好事發生……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"非常謝謝當時你那麼關心我，還向我搭話。\n但是我卻沒有向你道謝就回去了，非常抱歉","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"這種小事，你不用放在心上哦","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"那時候被一個不認識的女生纏上了，讓我很困擾呢～。\n他一直和我抱怨一些我聽不懂的事，真的是～……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"抱歉啊，我朋友造成你的困擾了。\n雖然我覺得他也沒有什麼惡意就是了……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"（完，完蛋了～……！\n沒想到這個人，和昨天的那傢伙居然會是朋友……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"這個，那個……\n不小心說了你朋友的壞話，真對不起……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"呵呵，沒關係的哦。\n突然被人用那種語氣搭話，\n會嚇一跳也是理所當然的吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"對了，站在這裡說話也不太好，\n我們去那邊的咖啡廳喝茶聊天吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"哇～！　好厲害好厲害！\n剛剛的演奏，非常帥氣哦！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event235-06-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"今天彈這樣就滿足了嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event235-06-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":38}],"windowDisplayName":"樂奈","body":"滿足了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":38,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":38,"voiceId":"event235-06-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"那個吉他手，是什麼……好厲害！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"嗯，他很厲害吧〜\n那個女生，我偶爾會看到他在這裡演奏喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"咦，咦……\n話說，這個咖啡廳真厲害呢，\n居然連讓人演奏的舞台都有","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"呵呵，你從剛才開始就一直都是講敬語呢，\n我們大概是同年紀喔？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"咦？　你是高一嗎？\n我想說你很穩重，還以為你是學姊呢～！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"那個，我可以請問你叫什麼名字嗎？\n我，叫做愛音！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"小愛音啊。\n我叫做爽世喔，請多指教～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"……所以，\n小愛音你現在在找樂團成員嗎？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"你剛剛是不是一直在看招募樂手的公告欄？\n所以才想說你是不是想加入樂團呢～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"啊啊～……是這樣沒錯啦，\n但我完全沒有看到我想擔任的位置有在招募……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"這樣的話，要不要用社群軟體找找看呢？\n只要一搜尋的話，就會出現很多不同位置的招募資訊喔","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-06-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"愛音","body":"咦～，社群軟體裡……還有這種資訊啊。\n爽世同學，你很了解有關樂團的事呢！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-06-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"爽世","body":"……因為我，之前有玩過樂團","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":39,"voiceId":"event235-06-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffec