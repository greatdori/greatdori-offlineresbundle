","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"akeomestory2024-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"あたしたちもたくさん楽しいことがあったわよ！\nまず、美咲が生徒会長になったの！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"akeomestory2024-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"美咲、学校のみんなを笑顔にするために\nとーってもがんばってるわ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"akeomestory2024-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"それと、花女にあたしの幼なじみが転校してきたの！\nみんなで歓迎会をしたりおにぎりパレードをしたり、\n毎日がすっごく楽しかったわ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"akeomestory2024-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"おにぎりパレード……？\nええと、よくわからないけどなんだか素敵そうなパレードだね。\nましろちゃんは？　去年はどんな１年だった？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"akeomestory2024-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"私たちも……いろんなことに挑戦した１年だったと思います。\nG.B.T.に出場して、\n月ノ森音楽祭にもまた出ることを決めて……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"akeomestory2024-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"この先どうなるかわからないですけど……\n少しずつ前に進めていけたらいいなって思ってます","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"akeomestory2024-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"Afterglowも……G.B.T.に参加したり、\nRoseliaと２マンライブしたり、いろいろあった","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"akeomestory2024-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"正直、今年もどんな年になるかわからない。\nけど、１つ１つちゃんと向き合っていきたいって、そう思ってる","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"akeomestory2024-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"レイヤ","body":"RASも……いろいろなことがあったな。\nG.B.T.やいろんなコンテストに参加したり……\nいつの間にか『コンテスト荒らし』なんて呼ばれてたり","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"akeomestory2024-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"レイヤ","body":"あとは『Japan Rock Fes.』にも\n参加することになった。\nきっと、これからもRASの活動はどんどん広がっていく……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"akeomestory2024-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"レイヤ","body":"Change the world――私たちが世界を変える。\n立ちはだかるモノすべて乗り越えてみせるから。\nみんな、見ててね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"akeomestory2024-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"もちろん！\nレイさんとRASの活躍、絶対見逃さないから！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"akeomestory2024-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"ポピパはね～、りみりんが塾をがんばって～、\n有咲は生徒会副会長になって～、\n私とさーやはバイトを始めたよ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"akeomestory2024-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"あとあと、関西にライブをしに行って～、\n何かすっごく大きなことをやろうって決めたんだ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"akeomestory2024-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"大きなことって、何？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"akeomestory2024-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}