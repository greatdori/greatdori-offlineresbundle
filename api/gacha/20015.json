,"weightTotal":0},"2":{"rate":88.5,"weightTotal":36},"3":{"rate":8.5,"weightTotal":33},"4":{"rate":3,"weightTotal":50}},null,null],"paymentMethods":[{"gachaId":20015,"paymentMethod":"paid_star","quantity":60,"paymentMethodId":20171792,"count":1,"behavior":"once_a_day","pickup":true,"costItemQuantity":60,"discountType":0},{"gachaId":20015,"paymentMethod":"free_star","quantity":250,"paymentMethodId":20171793,"count":1,"behavior":"normal","pickup":false,"costItemQuantity":250,"discountType":0},{"gachaId":20015,"paymentMethod":"free_star","quantity":250,"paymentMethodId":20171794,"count":10,"behavior":"over_the_3_star_once","pickup":false,"costItemQuantity":2500,"discountType":0},{"gachaId":20015,"paymentMethod":"gamon_ticket_1","quantity":1,"paymentMethodId":20171795,"count":10,"behavior":"over_the_3_star_once","pickup":false,"costItemQuantity":10,"discountType":0,"ticketId":1001},{"gachaId":20015,"paymentMethod":"gamon_ticket_2","quantity":1,"paymentMethodId":20171796,"count":1,"behavior":"over_the_3_star_once","pickup":false,"costItemQuantity":1,"discountType":0,"ticketId":1002},{"gachaId":20015,"paymentMethod":"normal_ticket","quantity":1,"paymentMethodId":20171797,"count":1,"behavior":"normal","pickup":false,"costItemQuantity":1,"discountType":0,"ticketId":1}],"resourceName":"gacha590","bannerAssetBundleName":"banner_gacha590","gachaName":[null,null,"ＨＡＰＰＹ屬性轉蛋",null,null],"publishedAt":[null,null,"1609398000000",null,null],"closedAt":[null,null,"1609765199000",null,null],"description":[null,null,"★★以上的團員出現！僅會出現ＨＡＰＰＹ屬性團員！部分★★以上的團員附有ＬＩＶＥ服裝！",null,null],"annotation":[null,null,"・將以下方記載的機率出現對應團員。\n・出現的團員全部皆為特訓前的狀態。\n・期間限定的團員，未來也會有可能再次登場。\n但目前再次登場的時間尚未確定。\n・｢保證１人★３以上｣請於｢必中轉蛋提供比例｣中進行確認。\n・每位團員所表示的出現機率，\n是以小數點第４位進行四捨五入來進行表示，\n所以總合數值可能並非為100%，尚請各位玩家注意。",null,null],"gachaPeriod":[null,null,"12/15 20:59 為止",null,null],"gachaType":"normal","type":"special","newCards":[],"information":{"description":[null,null,null,null,null],"term":[null,null,"2020/12/31 15:00～2021/01/04 20:59",null,null],"newMemberInfo":[null,null,null,null,null],"notice":[null,null,"・1天1次限定的轉蛋只能使用付費的STAR進行轉蛋。\n・1天1次限定的轉蛋將於每日凌晨4點進行重置。\n・STAR消耗將以免費的作為優先順序。\n・出現的團員全部皆為特訓前的狀態。\n・轉蛋有可能會出現重複的團員。\n・如果獲得重複的團員，將會自動送入休息室。\n・每次轉蛋都會依照出現機率進行抽選。舉例來說，出現機率為1%的團員並不會在100次中必定出現1次。\n・「南風吹SUMMER PARADISE轉蛋」登場的團員也會出現在這個轉蛋中，但出現機率有所差異。\n・出現機率的詳細說明在第二分頁，請點擊『出現機率』進行確認。\n・期間限定的團員，在本次轉蛋結束後並不會在一般轉蛋中登場，但有可能會於其他限定主題中的轉蛋登場，目前再次登場的時間未定。\n・出現機率的詳細說明在第二分頁，請點擊『出現機率』進行確認。\n・在進行轉蛋時，即使遊戲強制結束或是切斷網路連線，導致無法顯示『轉蛋結果畫面』，當次的團員也已經全部獲得了，請於團員一覽或是休息室中進行確認。\n・舉辦的期間也有可能會進行變更，尚請包涵。",null,null]}}