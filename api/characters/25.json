chool":["四ツ葉女子大学","Yotsuba Women's University","四葉女子大學","四叶女子大学","hanasakigawa_high"],"schoolCls":["A組","A","A組","A班","A반"],"schoolYear":["大学1年生","College 1st-Year","大學1年級","大一",3],"part":"keyboard","birthday":"971708400000","constellation":"libra","height":157}}