 University","慶鵬女子大學","庆鹏女子大学","hanasakigawa_high"],"schoolCls":["A組","A","A組","A班","A반"],"schoolYear":["大学1年生","College 1st-Year","大學1年級","大一",3],"part":"drum","birthday":"957970800000","constellation":"taurus","height":156}}