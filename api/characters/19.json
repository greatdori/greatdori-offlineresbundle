o Women's University","慶鵬女子大學","庆鹏女子大学","haneoka_high"],"schoolCls":["B組","B","B組","B班","B반"],"schoolYear":["大学1年生","College 1st-Year","大學1年級","大一",3],"part":"drum","birthday":"973177200000","constellation":"scorpio","height":161}}