enceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"내레이션","body":"각지의 다이묘들은 자신들의 야망을 이루기 위해 싸움을 벌이며\n천하는 전에 없을 정도로 혼란스러워졌다……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"2021ap-01-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"내레이션","body":"와카미야 가문이 다스리는 이 땅에도\n드디어 유력 다이묘의 손길이 다가오기 시작했다……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"2021ap-01-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"이브 님! 닌자한테 연락이 왔습니다!\n역시 사요 씨의 군대는 이 땅을 벗어나\n수도로 향하려는 모양입니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"2021ap-01-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"드디어 「하나사키가와 제일의 명궁」이라\n불리는 사요 씨가 병사를 움직였군요……\n어쩔 수 없네요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"2021ap-01-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"나도 보러 갔었는데, 수가 엄청났어~\n그만 천하통일은 포기하는 게 좋지 않을까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":17,"voiceId":"2021ap-01-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"아뇨, 그럴 수는 없어요!\n지금 이 순간에도 전쟁에 고통받는 백성이 있으니까요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"2021ap-01-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"으으…… 이브 님, 훌륭하십니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"cry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"2021ap-01-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"아하하, 예전엔 하나사키가와의 얼빠진 녀석이라 불렸는데 말이지~\n분명 벚나무를 향해 목도를 휘둘렀지?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"2021ap-01-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"그것은 옛적의 일!\n지금 와서 보면 꿈속 환영 같은 일이에요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"