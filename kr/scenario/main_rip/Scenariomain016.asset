talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"응……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"main016-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"타에","body":"마리나 씨는 우리의 공통점을 찾으라고 했지만\n그게 우리 모두의 타협점을 찾으라는 건 아니라고 생각해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"main016-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"타에","body":"처음으로 모두 모여 연주를 들었던 날……\n공연장에 정말 여러 가지 음악이 울려 퍼졌지만\n하나도 같은 것이 없어서 굉장히 즐거웠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"main016-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"타에","body":"나는 모든 밴드의 음악이 좋아.\n뚝심이 있기 때문에 좋다고 생각해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"main016-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"오타에가 말하고자 하는 걸 모르는 건 아니야.\n우리 또한 뭔가를 포기해야 하는 상황이 된다고 하면\n그렇게 간단하게 포기 못 하잖아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"main016-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"음~ ……모두의 장점을 잘 살린 라이브를 하고 싶다.\n모두의 차이점 역시 살리고 싶다. 그만큼 모두의\n의견은 맞지 않는다…… 결국 제자리걸음이구나~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"main016-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"정말~~ 모르겠어~!!\n나는 어차피 머리 쓰는 건 잘 못 하고…… 아! 그거다!!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"cry01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"main016-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"……왠지 굉장히 좋지 않은 예감이 들어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"main016-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카