,"voices":[{"characterId":8,"voiceId":"event115-04-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"나는 부러웠던거야……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"sad01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event115-04-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"있지. 나는 저번 라이브를 한 뒤로 계속 답답했어.\n우리와 Roselia의 라이브…… 전혀 다르다고 생각했거든.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event115-06-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"란・모카・토모에","body":"…………!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"surprised01","expressionName":"default","timingSyncValue":0},{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"event115-06-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"나도 말야, 완전히 같은 생각이었어…… Afterglow는\n평소대로일텐데, 어째서인지 납득하고 싶지 않았어……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event115-06-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"………… 나도 그 마음, 이해해.\n지금까지 이런 적이 없었는데, 그 라이브를 본 후로는……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":6,"voiceId":"event115-06-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"계속 무언가가 부족한 기분이었어. 괴로웠지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event115-06-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"그러니까, 모두는 같은 답답함을 품었는데,\n하지만 그게 나쁘다는 게 아니고, 그러니까……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event115-06-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"…… 모두도 분명 「저런 라이브를 하고 싶다.」고\n생각하고 있는 거 아닐까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event115-06-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"란・모카・토모에","body":"…………!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"surprised01","expressionName":"default","timingSyncValue":0},{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"event115-06-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"나도 그래. 라이브를 한 뒤 왠지 다른 것 같다고\n생각했어. 좋은 연주를 했는데도 어째서 그런걸까 생각했어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event115-06-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"지금까지 본 적 없을 정도로 굉장한 라이브…… 그런 라이브를\n우리도 하고 싶다고 생각했어. 그랬더니 홀가분해졌어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event115-06-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"…… 그래. 그런 굉장한 라이브도 있다는 걸 알게 돼서\n지금까지의 당연함이 조금 변했어……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"charac