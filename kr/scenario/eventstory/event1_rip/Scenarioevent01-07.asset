e":0}],"voices":[{"characterId":5,"voiceId":"event01-07-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"아리사, 드디어 원래대로 돌아왔구나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event01-07-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"…………저기, 우리 집에 오는 건…… 싫답니……다.\n오호호호호……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event01-07-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"……이치가야 씨, 이제 포기하자.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event01-07-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"마, 망할~!\n그, 그래, 이렇게 된 마당에 더 숨길 것도 없겠지!\n똑똑히 말해두겠어! 난 엄청 참고 있었단 말이야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"angry02","expressionName":"","timingSyncValue":0},{"characterId":15,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event01-07-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"일단 카스미! 뭐야, 대체 꽃놀이 시작할 때의 구호!\n어째서 의문도 없이 받아들이냐고!\n조금은 이상하다고 생각해 봐!!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"angry02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event01-07-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"그리고 검은 옷을 입은 사람들에 대한 것도 잘도 받아들이더구먼!?\n너무 빠르잖아!? 의문 같은 건 하나도 안 떠오르냐!?\n진짜 나는 태클 걸고 싶어서 근질근질해 죽겠던데!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"angry01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event01-07-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"그리고……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":5,"voiceId":"event01-07-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"무, 무슨 일인가요!?\n아리사 씨에게 악마라도 씐 게 아닌가요!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event01-07-056"