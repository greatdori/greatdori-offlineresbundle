[{"characterId":4,"voiceId":"event24-06-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":303}],"windowDisplayName":"한네","body":"여러분, 괜찮으시다면 이브에 대한 걸\n저한테 많이 알려 주세요! 일본에서 어떤 식으로 함께\n지냈는지…… 그리고","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":303,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":303}],"windowDisplayName":"한네","body":"여러분은 이브의 어떤 면이 좋은지!","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":303,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"조…… 좋은지!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event24-06-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"흐흥~ 아리사, 부끄러워하기 없기라고~?\n오늘은 한네 짱한테 이브 짱에 대해 잔~뜩\n말해줘야지!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"niyaniya01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event24-06-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectRe