0-01-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"응응, 츠구 마녀 분장도 잘 어울려!\n모처럼이니까 롤러코스터 앞에서 사진 찍자!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event200-01-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"입장했을 때도 찍었잖아. 얼마나 찍을 생각이야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event200-01-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"몇 장이든 찍을 거야~! 모처럼 할로윈이잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event200-01-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"그리고 모두 함께 변장하고 놀이공원에 오다니\n처음인걸. 추억을 잔뜩 남겨두고 싶잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event200-01-008","volume":1}],"speed":0,"fontSize":0,