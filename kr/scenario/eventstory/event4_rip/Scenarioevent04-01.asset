Factor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event04-01-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"와~ 그 카디건 너무 귀엽다!\n틀림없이 기뻐할 것 같은데?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event04-01-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"……그, 근데 언니랑 나는\n취향이 많이 달라서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"odoodo01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event04-01-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"리미링이 고른 생일 선물이라면\n유리 선배는 뭐든지 기뻐할 것 같은데?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event04-01-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"그럴까……\n그렇지만 역시 이왕 선물하는 거니까,\n나도 제대로 된 걸 주고 싶어서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressi