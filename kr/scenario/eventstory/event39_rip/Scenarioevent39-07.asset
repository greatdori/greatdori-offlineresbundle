SyncValue":0}],"voices":[{"characterId":19,"voiceId":"event39-07-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"전에 이상적인 무사에 대해서\n이야기해 준 적이 있지 않으십니까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event39-07-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"네, 자신의 신념을 관철하여 동료를 소중히 한다……\n그런 훌륭한 사람이 되는 것이 제 목표에요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event39-07-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"지금 이브 씨는 그 목표에 꽤 가까워져 있다고 생각하지 말입니다?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event39-07-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"네?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":