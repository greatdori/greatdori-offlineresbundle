Name":"smile01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event191-04-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"덕분에 벌써 기운 다 빠졌어~…\n미안, 마실 물 있었나?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event191-04-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"네, 여기요…\n조금 전에 바닷가 가게에서 사 왔으니까… 시원할, 거예요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event191-04-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"땡큐, 린코.\n하아~~ 맛있다~~~ 유키나도 마실래?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event191-04-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"고마워, 마실게.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event191-04-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"그보다 린린 네는 벌써 바닷가 가게에 갔던 거야?\n배고프기 시작하니까 같이 가려고 했는데.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event191-04-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"음료를 잠깐, 사러 간 것뿐이야…\n아무것도, 안 먹었어…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event191-04-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"그렇구나! 그러면, 같이 갈 수 있겠네!\n…아, 마침 언니네도 돌아왔다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event191-04-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"하아~ 정말 사요 씨 굉장했어요!\n처음이라고는 믿지 못할 훌륭한 솜씨!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"simizimi01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-04-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"아니에요, 우다가와 씨가 잘 가르쳐 준 덕분이라고 생각해요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf01_openeye","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"event191-04-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"다음에는 세계유산이라도 만들어 볼까요? 후후후.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-04-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"후~ 다녀왔어~\n오오~ 이거 참 모두 모여있네~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-04-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"어서 와! 성은 완성했어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event191-04-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWind