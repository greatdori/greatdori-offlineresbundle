":1,"motions":[{"characterId":17,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event13-06-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"그렇네요!\n지금까지 개인적인 이야기를 한 적이 거의 없었으니까\n이런 기회를 더욱더 만들고 싶네요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event13-06-063","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"있지~! 우리 언니도 개를 좋아해.\n치사토 짱이랑 사이 좋아질 수 있을 것 같아!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event13-06-064","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"어머, 사요 짱도 그렇구나. 몰랐네.\n다음에 학교에서 말 걸어볼까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event13-06-065","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"치사토","body":"(오늘은 즐거웠어……\n처음으로 모두한테 진짜 나를 전한 것 같아.)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"mot