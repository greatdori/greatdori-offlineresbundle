yncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf04","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-06-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"인터뷰 진행자","body":"싸, 싸워요……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"아, 그런 뜻이 아니라~ 물론 음악으로 말이죠.\n서로가 납득할 때까지 합동 라이브를 할 겁니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-06-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"Afterglow는 도망치지도 숨지도 않아요.\n어떤 때라도 받아줄 겁니다.\n모두한테 저희 힘을 보여주도록 하겠어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-06-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"인터뷰 진행자","body":"아, 아하하…… 왠지\n전 세계의 걸즈 밴드를 향해 선전포고를 한 것 같네요.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishClo