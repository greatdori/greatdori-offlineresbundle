ePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"카스미","body":"저기~ 저기~! 이 그네 비어 있어?\n나도 타도돼?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-02-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":308}],"windowDisplayName":"하구미","body":"응! 타도돼!\n같이 타자!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":308,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":308,"voiceId":"event47-02-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"굉장히 더운 날이어서\n그네에서 부는 바람이 기분 좋았던 게 왠지 기억이나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":13,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event47-02-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"응응! 하구미도 살짝 떠올랐어!\n누가 그네를 더 잘 타는지 경쟁했었지!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event47-02-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"호~ 과연~\n그게 카스미랑 하구미의 가장 첫 번째 만남이었구나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event47-02-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"근데 고작 그거로 잘도 매주 놀 정도로 친해진 거냐……?\n난 좀 믿기 어렵지만~……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event47-02-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"나는 동생들이 있어서 알 것 같은데.\n애들은 왠지 금방 친해지잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event47-02-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"아, 그리고 있지!\n분명히 그다음에……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event47-02-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"카스미","body":"어~!?\n하~짱은 벌써 자전거를 탈 수 있는 거야? 굉장하다~!\n나는 있지, 아직 보조 바퀴를 달고 타~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-02-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":308}],"windowDisplayName":"하구미","body":"카스미 짱이라면 금방 탈 수 있을 거야~!\n하구미가 가르쳐줄게!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":308,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":308,"voiceId":"event47-02-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":308}],"windowDisplayName":"하구미","body":"그러니까~ 여기에 타잖아~?\n그다음에 슝~ 하고 구르는 거야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":308,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":308,"voiceId":"event47-02-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"카스미","body":"그러니까……\n이렇게~ 이렇게 하고~…… 슝~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-02-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effe