1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event02-07-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"……그래, 아버지가.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event02-07-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"잘됐네. 유키나.\n그래도 아버님도 직접 말씀해 주셨으면 좋았을 텐데.\n유키나가 솔직하지 못한 건 아버님을 닮아서 그런 건가?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event02-07-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"……리사.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event02-07-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"아하하, 미안, 미안.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"kime01","ex