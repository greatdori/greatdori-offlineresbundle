"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그래, 맞아!\n니코리나를 환영하는 파티인걸!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event208-02-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"니코링, 어제까지 업무 엄~청 열심히 했잖아!\n하구미도 뉴스에서 봤어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event208-02-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"카오루","body":"그래. 이 파티는 니코리나 환영 겸\n열심히 일한 위로 겸, 내일 떠나는 그대의 송별……\n즉, 그런 것이지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nnf05","expressionName":"default","timingSyncValue":0},{"characterId":14,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event208-02-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"낮에는 같이 놀이공원에서 놀고\n밤에는 라이브를 하기로 했어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event208-02-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":328}],"windowDisplayName":"니코리나","body":"여러분…… 그렇게까지 해 주시다니……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":328,"motionName":"ando01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":328,"voiceId":"event208-02-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":328}],"windowDisplayName":"니코리나","body":"여러분과 만난 것만으로도 무척 기쁜걸요……\n아버님께 말씀드리면 분명 오고 싶었다고 하실 거예요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":328,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":328,"voiceId":"event208-02-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"아버님이라면…… 닛코리 아저씨 말이야!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event208-02-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":328}],"windowDisplayName":"니코리나","body":"네. 아버님도 그 이후로 여러분의 열성 팬이 되셔서,\n여러분의 노래를 항상 듣고 계세요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":328,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId