henFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":328}],"windowDisplayName":"니코리나","body":"후후후, 그렇게 긴장하지 마세요.\n와아, 경치가 아름다워요……\n놀이공원 바깥도 보여요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":328,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":328,"voiceId":"event208-03-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"아, 저기 보이는 게 밤에 라이브 할 공연장이에요.\n멤버들이 열심히 준비했으니 기대해 주세요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":15,"voiceId":"event208-03-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":328}],"windowDisplayName":"니코리나","body":"설마 이런 성대한 파티를 준비해 주실 거라곤\n상상도 못 했어요.\n정말 감사합니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":328,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":328,"voiceId":"event208-03-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"확실히 놀이공원을 파티장으로 삼겠다는 생각은\n코코로가 아니면 떠올리기 어렵죠……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event208-03-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectRefer