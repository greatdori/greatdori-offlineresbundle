ReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"아~~! 맞아맞아~!\n다 같이 이불 나란히 놓고 잤지! 그거 재밌었어~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event83-02-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"타에","body":"친구들이 집에 자러 오는 건 처음이라서\n엄청 즐거웠어. 또 왔으면 좋겠는걸.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event83-02-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"갈래갈래! 아리사네 집에서는 자주 자지만\n오타에네 집에는 별로 못 갔으니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"jaan01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event83-02-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"그보다 너희가 멋대로 하는 거뿐이잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event83-02-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그렇다는 건 오디션 합격 기념일 전날은\n「오타에네 집에서 처음 잔 기념일」이네!\n그날도 파티할까!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event83-02-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"그건 너무 나갔어.\n그렇게 따지면 끝이 없다니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event83-02-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"후후후.\n뭐 「오타에네 집에서 처음 잔 기념일」은 일단 놔두고\n오디션 합격 기념일은 파티하는 걸로 결정이지?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event83-02-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"응, 그건 꼭 하자!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event83-02-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"chara