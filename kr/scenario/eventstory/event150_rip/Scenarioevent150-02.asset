fectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"연구…… 라고 할 수 있을지는 모르겠지만\n곡의 세계관은 중요하게 생각하고 있어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event151-02-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"바이올린 소리가 들어가도 위화감이 없는 세계관을\n만든다고 하는게 맞을까.\n그것에 대해서는 클래식 같은 걸 참고하고 있어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event151-02-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"(루이 씨……\n그런 걸 생각하면서 작곡을 했구나……)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"kandou01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event151-02-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"과연~\n클래식을 참고하다니……\n그 감각은 츄츄 씨랑 통하는 게 있을지도 모르겠네요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event151-02-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requir