:0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"우리의 곡을 다른 사람들이 부른다니.\n왠지 나는 납득이 되질 않아.\n제대로 말로 표현 못 하겠지만…… 답답해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event27-02-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"으~음…… 곡을 제공하는 건 커버하는 것과도 또 조금 다르니 말이야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event27-02-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"토모에도 말했지만, 유명해지고 싶다거나\n그런 생각으로 밴드를 하는 건 아니니까,\n소속사 사람이 한 얘기도 나는 잘 모르겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event27-02-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"파스파레의 곡을 만드는걸로\n우리의 인지도도 올라간다는 소리지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event27-02-007","volume"