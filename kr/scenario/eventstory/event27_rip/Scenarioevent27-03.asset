":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"신경 써주셔서 감사합니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event27-03-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"당치도 않습니다! 저희도 오늘 분위기를\n너무 딱딱하게 만들고 싶지는 않습니다.\n부디 편히 계십시오.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event27-03-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"그러면 특훈을 시작하죠!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event27-03-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"저기 말이야! 어땠어? 우리 연주!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event27-03-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"굉장했어요! 게다가 MC 연습까지 하시는군요!\n아이돌은 대단하네요……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event27-03-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"아~ 그건 말이야, 아야 짱은 이야기할 것들을 생각해둬야\n하는 타입이라서 그래! 그런 부분은 좀 다르겠네~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event27-03-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"으으…… 돌직구……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event27-03-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"리, 리액션하기 힘드네요, 방금 이야기는……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event27-03-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"아하하…… 죄송합니다……","tention":0,"l