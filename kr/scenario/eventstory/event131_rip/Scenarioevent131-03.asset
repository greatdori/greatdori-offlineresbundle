깨달아 버렸단다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event131-03-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"아, 응. 만드는 방법은 간단하지만\n할머니만큼 점토로 능숙히 물건을 만들기는 어렵겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event131-03-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"카오루","body":"그게 아니야. 점토로 무언가 만들 수는 있겠다만……\n하지만 나는 마법을 걸 수가 없단다……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event131-03-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"아앗! 맞아!\n하구미도 마법 못 써~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event131-03-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"마법이라니……\n아, 가격표에 적혀있던 그거 말이지?","tentio