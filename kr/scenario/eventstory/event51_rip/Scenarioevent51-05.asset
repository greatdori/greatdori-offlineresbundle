01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"evenr51-05-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"그런 게 갑갑하다는 거야!\n아~~ 진짜! 아까부터 진짜, 토모에 별로야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"evenr51-05-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"라, 란 짱! 조금만 진정해~~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"evenr51-05-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"맞아~ 란이 진정하고 말하지 않으면\n란도 무슨 말을 하고 싶은 건지 모른다고~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"evenr51-05-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"아코가 어떻다고 하는 게 아니라\n토모에는 어떻게 생각하는지를 듣고 싶다고!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncV