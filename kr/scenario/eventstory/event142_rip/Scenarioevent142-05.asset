:0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"저희 집은 좀처럼 기타를 사주지 않았어요. \n결국 용돈을 꾸준히 모아서 제가 샀지만요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-05-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"어렸을 땐 골판지로 기타를 만들어서\n치는 흉내를 내며 놀았어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-05-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"어린이가 만든 거니까 넥이 금세 부러져서\n그때마다 테이프로 고치고…… 그립다~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-05-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"……너, 멋진데.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-05-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenc