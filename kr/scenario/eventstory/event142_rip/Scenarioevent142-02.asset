Value":0}],"voices":[{"characterId":32,"voiceId":"event142-02-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"호오. 그럼 오늘 쇼핑은 쇼핑몰로 해볼까? \n나도 그거 사두고 싶거든. …… 가자.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"네? 아직 아침 8시인데요……? \n가게는 아직 아무도 안 열렸을 거예요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"아, 그렇구나. 앞으로 2시간은 안 열겠네……\n시간이 꽤 있는걸.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"……응? 하지만 분명 거기 영화관은\n이른 시간부터 열지 않았었나?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"정말인가요? \n영화라면 대충 2시간 정도니까 딱 적당하네요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"지금부터 시간에 맞는 건…… 음. \n이거 2개 같아요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"오오! 이거 내가 보고 싶었던 거다! \n이런, 아슬아슬한데. 서두르자 록!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"다행이다, 생각보다 일찍 도착했네. \n아직 여유가 있겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"마스키 씨가 바이크로 속도 내서 그래요~……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"하지만 설마 마스키 씨가 보고 싶다던 영화가\n이쪽일 줄은 생각 못 했어요. \n다른 하나인 액션 영화 쪽인 줄 알았는데……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"뭐? 당연히 이쪽이지. \n어린이용 애니메이션이지만\n어른이 봐도 눈물 난다며 평판이 자자하거든.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"호오~ 그렇게까지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"자, 티켓 사자. 너도 학생 수첩 꺼내.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"……응? 마스키 씨, 뭔가 떨어졌는데요? \n……사진?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"오…… 고마워. \n옛날 사진이라 잃어버리면 큰일이거든.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"여기 찍힌 어린아이가\n어렸을 때 마스키 씨인가요? \n정말 귀엽네요~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"그래? \n그때부터 아버지한테 자주 눈매가 안 좋다는 말을 들었거든.\n봐, 내 옆 바이크에 올라탄 분이 아버지야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"저, 정말이다! \n오너한테는 어제도 Galaxy에서 인사했어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"그리고 반대쪽이 라멘 은하 점장. \n뒤에 있는 사람이 데스 갤럭시의 보컬이지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"모두의 젊은 시절 사진……! \n멋지지만 평범한 사람이네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"응?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"앗, 아뇨! 밴드명이 데스 갤럭시니까\n엄청난 화장을 한 사람들을 상상해서……\n그게, 데스라는 단어도 들어있고요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event142-02-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"뭐야 그건. \n무대에서 내려오면 당연히 평범한 사람이지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"이 사진은 데스 갤럭시가 원맨 라이브로\n대성공했을 때라고 했어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"아버지 밴드 멤버는 무슨 일만 있으면 이 공원까지\n바이크 타고 날아왔거든.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"벤치 정도밖에 놓여있지 않지만\n언덕 위에 있어서 야경이 아주 예뻐.\n사진으로 보면 잘 전해지지 않지만……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"연주 때문에 싸운 날도 신곡이 만들어진 날도……\n다양한 이유를 들고 이곳에 같이 갔던 것 같아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"들뜬 어른을 보는 게 왠지…… 나쁘지 않았지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event142-02-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectRefer