HideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"응! 정말 도움이 됐어!\n고마워!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event81-06-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"……지금 내가 있는 이유.\n음악을 접한 계기는 틀림없이 유키나고……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event81-06-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":319}],"windowDisplayName":"리사","body":"유키나 짱은 노래 엄청 잘하네!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":319,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":319,"voiceId":"event81-06-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":318}],"windowDisplayName":"유키나","body":"고마워.\n우리 아빠는 훨씬 잘해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":318,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":318,"voiceId":"event81-06-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":319}],"windowDisplayName":"리사","body":"오~! 그렇구나! 굉장하다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":319,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":319,"voiceId":"event81-06-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":318}],"windowDisplayName":"유키나","body":"우리 아빠는 「밴드」를 하고 있어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":318,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":318,"voiceId":"event81-06-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":319}],"windowDisplayName":"리사","body":"밴드? 그게 뭐야? 리사도 하고 싶어~!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":319,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":319,"voiceId":"event81-06-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":318}],"windowDisplayName":"유키나","body":"그럼 다음에 셋이서 「세션」하자.\n다 같이 연주하는 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":318,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":318,"voiceId":"event81-06-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"그날부터 나랑 유키나, 유키나네 아버지 세 명의\n작은 밴드가 결성됐다.\n매일 장난감 악기로 연주 놀이를 하면서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":23,"voiceId":"event81-06-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":319}],"windowDisplayName":"리사","body":"세션 즐거워!\n유키나 짱네 아빠는 악기 연주도 노래도 잘해~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":319,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":319,"voiceId":"event81-06-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"유키나의 아버지","body":"그러니? 그래도 리사 짱이나 유키나한테는 못 미친단다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":318}],"windowDisplayName":"유키나","body":"나도 아빠처럼 더 잘하고 싶어.\n어떻게 하면 잘 할 수 있을까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":318,"motionName":"nf02","expressionName":"default","timingSyncValue":0},{"characterId":319,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":318,"voiceId":"event81-06-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"유키나의 아버지","body":"유키나, 노래 좋아하니?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","volume":1}],"speed":0,"fontSi