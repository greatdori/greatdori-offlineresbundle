":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"괴물이 아니라! 봐!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event92-05-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"자, 잠깐만 언니……\n그렇게 크게 소리치지 마. 부끄럽다니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"event92-05-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"와, 아스카 짱이네!\n저기 봐, 아스카 짱이 있어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event92-05-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"타에","body":"아, 여기 록도 있어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event92-05-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":317}],"windowDisplayName":"롯카","body":"아, 안녕하세요.\n정말 오랜만이에요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":317,"motionName":"surprised02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":317,"voiceId":"event92-05-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"록~~~!\n오랜만이야~ 잘 지냈어!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event92-05-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":317}],"windowDisplayName":"롯카","body":"무, 물론 잘 지냈어요!\n팝핀파 여러분도 변함없으신 것 같아서 다행이에요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":317,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":317,"voiceId":"event92-05-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"지금 마침 아짱이랑 록 이야기를 하고 있어!\n「호랑이도 제 말 하면 온다.」이라는 거지 이건!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event92-05-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"오늘은 무슨 일이야? 우연?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event92-05-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"일단 할로윈 퍼레이드를 구경하러 온 건데\n설마 언니네가 참가했을 줄은……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":317,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"event92-05-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"있지! 아짱이랑 록도 같이 걷자!!\n진짜 엄~~~청 재밌으니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event92-05-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":317}],"windowDisplayName":"롯카","body":"파, 팝핀파 분들과, 같이!?\n아뇨아뇨아뇨아뇨, 그건 안 돼요!\n그건…… 일단 안 할게요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":317,"motionName":"surprised02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":317,"voiceId":"event92-05-015","vol