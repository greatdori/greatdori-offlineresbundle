orSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":119,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":67,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":0}],"windowDisplayName":"RBG 멤버","body":"그보다 마야 짱,\n어째서 다양한 장르의 서포트를 하는 거야?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"RBG 멤버","body":"잘하는 장르로 축소하면 좀 더 하기 쉬울 것 같은데……\n다양한 곡조의 드럼을 연주하면 힘들지 않아?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"아하하……\n확실히 그 소리는 자주 듣습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event199-05-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"하지만, 뭐라고 할지……\n이 방식이 제게는 맞는 것 같지 말입니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event199-05-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"RBG 멤버","body":"맞아?","tention":0,"lipSyncMo