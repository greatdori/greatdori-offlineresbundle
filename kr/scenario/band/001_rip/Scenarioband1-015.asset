ad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"band1-015-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"타에","body":"곡은 조금 만들었어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"band1-015-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"미안해, 카스미 짱. 중간부터 곡만 집중하고\n가사 아이디어는 별로 내질 못해서.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"awate01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"band1-015-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"머리를 맞대고서 아무것도 안 하는 것보다 낫지.\n그것보다 슬슬 저녁 준비를 해야지. 안 그럼 밥 못 먹는다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"band1-015-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"핫. 밥! 다 같이 만드는 거지!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voice