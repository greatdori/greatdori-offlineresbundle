야. 라이브 생중계를 도입하는\n첫 록킹 스타 페스티벌이 된다.\n다들, 잘 부탁하마!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-13-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":215}],"windowDisplayName":"오너","body":"토야마……\n너도 사람들한테 한마디 하렴.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"nf_left01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-13-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"앗!? 제, 제가요……!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event147-13-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":215}],"windowDisplayName":"오너","body":"네가 하지 않으면 어떻게 하니.\n모두 네 말을 듣고싶어 한다고.\n자, 마이크.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-13-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"으, 으음…… 저기……","tention":0,"lipSyncMo