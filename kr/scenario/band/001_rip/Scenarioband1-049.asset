:0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":215}],"windowDisplayName":"오너","body":"라이브를 성장시키기 위해서 필요한 것은 마음뿐만이 아니란다.\n기술도 필요하지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-14-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":215}],"windowDisplayName":"오너","body":"음악의 역사는 새로운 기술과 함께 쌓여왔으니까.\n음악을 사랑하는 마음과 기술.\n이 두 개가 합쳐져서 새로운 음악이 태어나는 거란다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-14-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":215}],"windowDisplayName":"오너","body":"마음 부분은 너희한테 충분히 봤단다.\n그렇기에 나는 내가 해야 할 것을 안 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-14-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":215}],"windowDisplayName":"오너","body":"고맙다, Poppin'Party.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":215,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":215,"voiceId":"event147-14-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"