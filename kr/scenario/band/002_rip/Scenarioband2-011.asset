:0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"토모에","body":"(예쁜 석양이네.\n이렇게 석양을 보면 중학교 때\n옥상에서 다섯 명이서 석양을 본 추억이 떠오르는군.)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band2-011-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"토모에","body":"(……결국 떨어져도 함께 있던 순간을 생각하네.\n뭐, 계속 그 다섯이서 함께였으니까 당연한가.)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band2-011-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"토모에","body":"(사과해야겠지…… 히마리한테도 모카한테도.\n……그리고 란한테도.)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band2-011-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"여보세요. 히마리? 석양이 예쁘니까 히마리도 보라고.\n……히마리도 지금 보고 있었어?\n……하하, 그런가? 통했네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"band2-011-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"