":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"그 밴드…… 잡지에서 본 적 있어.\n인디 시절의 음악은 특히 명반이었다고……\n미나토 씨의 아버지가…… 그런 분이었다니……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"band5-018-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"나는 Roselia를 만들고\n개인감정을 숨기면서 「우리의 음악을 완성한다」는 거짓말로\n오직 나만을 위해 너희를 속였어……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"band5-018-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"전에는 말로 잘 표현할 수 없었지만, 내겐 책임이 있어.\n……나는 Roselia에서 빠져야 한다고 생각해.\n나랑 다르게 너희의 신념은 진짜니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"band5-018-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"잠깐 기다……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"surprised01","expressionName":"default","timingSyncValue":0},{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"