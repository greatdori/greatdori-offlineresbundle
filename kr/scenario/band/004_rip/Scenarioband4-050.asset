racters":[{"characterId":20}],"windowDisplayName":"이브","body":"(앞을 알 수 없어도 모두가 있다면 괜찮아요!\n각자 형태는 다르다 해도 동료를 서로 받쳐주려는 마음,\n파스파레를 생각하는 마음은 하나!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":20,"voiceId":"event135-15-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"(결코 끝나지 않고 전해지는 이야기를 그리기 위해서……\n그 등을 제가 지키겠어요!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":20,"voiceId":"event135-15-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"(앞을 알 수 없기에 곰곰이 생각해서\n자신이 납득할 수 있는 답을 낸다……\n그것이 분명 가장 자신다운 아이돌로서의 모습!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event135-15-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"(그 답이 틀려도 좋습니다.\n실패해도 괜찮습니다!\n왜냐하면 그 걸음이야말로 「아이돌」이니까!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event135-15-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"(이제 아무것도 무섭지 않아……\n앞을 알 수 없다고 해도 착실히 앞으로 나아갈 수 있어……\n내 뒤를 모두가 밀어주고 있는 것이 확실히 느껴져.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":16,"voiceId":"event135-15-038","volume"