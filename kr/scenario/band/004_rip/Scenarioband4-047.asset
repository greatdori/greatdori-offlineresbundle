talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"괜찮습니다!\n그보다 지금부터 얘기를 나누면 늦어지니 말입니다.\n밖에 나가는 것보다 오히려 저희 집이 나을 겁니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event135-12-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"ViVidCanvas 여러분도 급하게 모여주셔서\n고맙습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event135-12-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"연습생들은 셋이서 같이 있었지?\n「하나마루◎안단테」연습하고 있었어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event135-12-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":219}],"windowDisplayName":"세리나","body":"네.\n파스파레 분들께서 납득하실 수 있도록\n아야 씨의 영상을 보면서 연구했어요.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":219,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"그런 건 무리야! 아야 짱은 아야 짱이니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event135-12-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":218}],"windowDisplayName":"미오","body":"네……?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":218,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"예를 들어 후렴의 「괜찮아」라는 말 하나만 떼놓고 봐도\n아야 씨랑 여러분은 전하는 상대가 다를 것입니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event135-12-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"그렇다면, 분명 말투나 말의 전달 방법은 바뀌어야 할 것입니다.\n아야 씨와 같은 풍경을 볼 수는 없습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event135-12-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"그렇기에 ViVidCanvas만이 노래할 수 있는\n「하나마루◎안단테」가 되어야만 하는 겁니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event135-12-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"re