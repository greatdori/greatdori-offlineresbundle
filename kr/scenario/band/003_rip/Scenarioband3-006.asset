ay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":93,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":60,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":61,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":94,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"일단 지금까지 내가 생각한\n즐거운 일 리스트를 소개할게!\n이걸로 「밴드」를 하려고 해!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"어디어디? 바다 모래사장에서 성을 만든다…… 클로버로\n왕관을 만든다…… 별똥별을 찾으러 산에 오른다……\n……음, 이거……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"band3-006-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"카오루","body":"갓 빨래한 시트의 냄새를 맡는다…… 배가 부르도록\n과자를 먹는다…… 후후…… 이건……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"band3-006-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"하구미・카오루","body":"정말 좋다!!!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"","timingSyncValue":0},{"characterId":12,"motionName":"kime04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"카논・미사키","body":"(……「밴드」랑 전혀 상관없어……!!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"surprised01","expressionName":"","timingSyncValue":0},{"characterId":15,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"에헤헤, 그렇지?\n이거로 매일 다 함께 즐겁게 지낼 수 있어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"코, 코코로 짱……! 전부 굉장히 즐거워 보이긴 하지만\n악기를 연주하거나 노래를 부르거나 곡을 연주하지 않으면\n음악을 하는 게 아니잖아……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"awate01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"band3-006-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그래?\n꼭 음악을 해야만 하는 거야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"앗, 그랬지. 밴드는 음악 하는 거잖아!\n음악…… 「소리 음」에…… 「즐거울 악」?\n으~음? 뭔가 잘 모르겠다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"band3-006-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"꼭 그래야 한다기보다 그게……!\n……어, 그러니까……\n…………으으.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"awate01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"band3-006-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미사키","body":"(우와…… 이 애는 이런 식으로 계속\n이 세 명에게 끌려다닌 건가……\n하긴, 착하고 마음 약해 보여……)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"저기. 어제 역 앞에서\n츠루마키 코코로랑 드럼 쳤었죠?\n어쩌다가 그렇게 됐어요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"그게…… 저도 잘…… 모르겠어요.\n……제가 드럼을 팔려고 악기점에 가는데\n코코로 짱이 밴드 멤버라고 해서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"odoodo01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"band3-006-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"어? 그러면 드럼을 그만두려고 하는 상황에서\n억지로 밴드에 집어넣은 거잖아요.\n그래도…… 괜찮아요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"괘, 괜찮은 건지 안 괜찮은 건지……\n그래도…… 원래는 이런 저 자신을 바꾸고 싶어서\n드럼을 했던 건데…… 좌절해버려서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"odoodo01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"band3-006-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"그랬더니 코코로 짱이\n용기라면 자기가 주겠다고 하더니……\n제가 필요하다고…… 밴드의 구세주라고도 불러 주고……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"band3-006-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"저…… 죄송하지만.\n뭔가 좋게만 말하고 있는데, 그거 단적으로 말하면\n납치돼서 억지로 밴드에 들어간 거예요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"여, 역시…… 그런 건가요……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"band3-006-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미사키","body":"(어쨌든 난 이 밴드에서 나갈 거야.\n할 수 있다면 이 애도 같이.\n혼자서는 절대 이런 거 못 견뎌.)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"~~핫!! 그거야!! 그거였어!!\n밴드로 소리를 즐기는 거야!!\n하구미, 너는 천재구나!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"jaan01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"엇, 진짜?\n하구미, 밴드에 재능이 있는 걸까?\n얏호~~~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"band3-006-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"카오루","body":"그렇군…… 그럼 다 같이\n소리를 즐기는 아득한 여행을 떠나자꾸나……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"band3-006-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"으~음!! 카오루도 최고야!!\n그러면 하나둘 하면 다 같이 음악을 하는 거야!\n하나~~~둘! 시작!!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"모두","body":"…………","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"band3-006-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"……그래서 무엇을 하면 되는 걸까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"아니, 악기도 없잖아!?\n상식적으로 그것부터 아니냐고……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그렇지만! 나는\n어쨌든 밴드로 즐거운 일을 하고 싶은걸!\n즐거운 일을 하지 않으면 시작할 수 없잖아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"그럼 그 즐거운 일을\n생각하면 되는 거 아니에요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그게 매일 언제나 생각하고 있는데도\n바로 나오지 않을 때도 있다구.\n즐거운 일은 꽤 어려우니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"휴우……\n잘은 모르겠지만, 꽤 어렵다면서\n왜 그렇게까지 고민하는 건데……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미사키","body":"(좀 더 여고생이 생각해야 할 일들이 있을 거\n같은데요. 진로라든가…… \n아니, 이렇게 호화로운 저택에 살면 그럴 필요 없나?)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그 이유는 뻔하잖아!\n「온 세상을 웃는 얼굴로 채우고」 싶으니까!!\n그래…… 나는 온 세상을 웃는 얼굴로 채우고 싶어!! 이 밴드로! ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"카오루・하구미","body":"온 세상을……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"","timingSyncValue":0},{"characterId":12,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미사키・카논","body":"웃는 얼굴로……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"","timingSyncValue":0},{"characterId":14,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그래. 나는 무엇보다 사람들의 웃는 얼굴이 제일 좋아!\n그러니까 온 세상을 웃는 얼굴로 가득 채워서 넘치게 하는 거야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"oowarai01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"아니. 그런 걸 어떻게 해.\n세상에는 전쟁이나 빈곤……\n여기 일본만 해도 그래……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"왜 안 된다고 생각해?\n아니, 왜 안 되는 걸까?\n웃고 싶지 않은 사람은 세상 어디에도 없는걸?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"다들 매일 웃고 즐거운 게 최고지.\n즐거워지고 싶지 않은 사람이 있을 리 없잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그러니까 이 밴드로 세계를 돌면서\n웃는 얼굴로 가득 채우는 거야!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"jaan01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"band3-006-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"……어, 어어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"band3-006-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미사키","body":"(지, 진심으로……\n진심으로 온 세상을 웃는 얼굴로 가득 채울 수 있다고 생각하고 있어.\n……바보다, 완전무결하고 순수한 바보……!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"band3-006-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"카오루","body":"감동했단다, 코코로…… 사람은…… 한 가지 역할만을\n계속할 수 없다고 생각해왔다. 하지만 그대들의 왕자,\n아니 세상의 왕자 역할이라면 기쁘게 받아들이지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"band3-006-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"대단해……\n하구미도……정말 좋은 거 같아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"band3-006-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"하구미는 소프트볼 같이 여러 가지 스포츠를 해왔는데\n져서 우는 사람을 많이 봤어.\n그걸 보면 하구미