erId":27,"voiceId":"band6-20-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"우리도 즐길 테니까\n이 스테이지를 모두도 즐겨달라고!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-20-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"들어주세요, 「금빛의 프렐류드」……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-20-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"(좋아~ 최고조! 제대로 모두의 소리가 들려!\n의도한대로 음을 맞추고 있어!\n나 꽤 재능 있는 거 같은데!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-20-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"(그보다 꽤 연습했으니까. 잘 생각해보면\n이렇게 진심으로 연습한 건 처음인 것 같아. 생각보다 훨씬\n밴드에 빠진 거 아냐, 나!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-20-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"나나미","body":"(시로 짱, 조금 긴장한 거 같은데 즐거워 보여.\n츠~짱도 토~코 짱도. 루이루이…… 도 분명\n지금 무대에 선 것을 즐기고 있겠지.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"band6-20-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"나나미","body":"(이런 걸 예전부터 동경했어. 다 같이 한마음으로 뭉치는 느낌.\n청춘이라는 느낌이…… 지금 엄청 들어!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"band6-20-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"(감정에 휩쓸리지 않고 현실을 보며 미래가 보이는 길을 간다.\n그것이 성공을 위해, 정상에 서기 위해 필요한 것.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"band6-20-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"(그런데도 이 밴드가 나아가는 곳이 신경 쓰여……\n내 생각이 옳은지 어떤지, 그걸 알 수 있는 건 지금부터야.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"band6-20-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"(굉장해……! 지금까지 중 가장 깔끔하게 소리가 맞춰졌어……!\n할 수 있잖아, 우리들!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-20-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"(쿠라타 씨 덕분일까…… 모두의 마음이\n하나가 되었으니까. 역시 너도 특별해.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-20-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"(모두의 소리가 받쳐주고 있어……\n그렇게나 무서웠던 무대가 무섭지 않아…… 엄청 즐거워!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-20-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"(그날, CiRCLE에서 느꼈던 그 마음이야.\n무슨 굉장한 일이 일어날 것 같은\n무언가가 시작될 것만 같은 그 마음……!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-20-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"(빛으로 가득한 그 풍경은 아직 안 보이지만…… 알겠어.\n눈 앞의 이 풍경이, 지금 느낀 그 마음이\n그 빛나는 곳으로 이어지는 거야……!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-20-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"으으, 재밌었어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-20-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"제대로 쳐서 진심 다행이야~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-20-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"라이브가 뜨거웠어.\n모두 즐겁게 들어줬어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName