가 비싼 가게에서 팔 만한 것 같아……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-18-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"나나미","body":"그, 그렇구나……\n으으, 평범하게 한다는 건 어렵네……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"band6-18-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"뭐, 의상도 완성되었으니 음악제는 반드시 성공시키자!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-18-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"그래. 아, 그렇지.\n모두한테 상담하고 싶은 게 있는데 괜찮아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-18-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"음악제를 향해서 한 곡 더\n오리지널 곡을 만들어보는 게 어떨까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-18-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"오리지널?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-18-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"오리지널 곡은 하나뿐이잖아?\n하나 더 만드는 게 우리다움을 보여줄 수 있지 않을까 싶어서.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-18-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"나나미","body":"음악제까지는 아직 시간이 있으니까 한 곡은 될 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"band6-18-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"좋네, 만들자~!\n오리지널이라면 마구마구 원하니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-18-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"뭐, 만든다고 해도 만드는 건 야시오 씨가 되겠지만……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-18-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"상관없어. 음악을 안 한 공백이 있으니까\n곡 만드는 감을 되찾기에는 좋은 기회라고 생각하니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"band6-18-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"나나미","body":"그러면 결정!\n가사 만들기는…… 역시 시로 짱이겠네!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"band6-18-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"그렇지! 또 자신 없다고 하면 안 돼~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"band6-18-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"이제 안 그래……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-18-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"마시로","body":"나한테 맡겨진 일이라면 할 수 있는 한 열심히 해 보고 싶어……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"band6-18-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"응응, 왠지 점점 밴드답게 되어가고 있네!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-18-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"츠쿠시","body":"작사는 쿠라타 씨, 작곡은 야시오 씨.\n의상은 토우코 짱 하고 히로마치 씨. 역할 분담도 완벽해!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"band6-18-063","volume":1}],"speed":0,"fontS