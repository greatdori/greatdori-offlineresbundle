ntion":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"halloC-area12-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"벌써 먹어봤어? 역시 모카.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"halloC-area12-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"유령 모양 빵이라든가 박쥐 모양 빵이라든가\n귀엽고 맛있지, 먹기 전부터 다 먹을 때까지\n계속~ 행복했어~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"halloC-area12-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"눈으로 봐도 즐겁지, 먹으면 맛있지,\n아~ 계속~ 할로윈이었으면 좋을 텐데~\n100종류 정도 있어도 괜찮을 것 같아~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"halloC-area12-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"사아야","body":"아하하, 고마워.\n아무리 그래도 100종류는 어려울 것 같지만\n좀 더