eo-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"디자인은 츄츄 님과 함께 체크하긴 했지만\n완성된 걸 보는 게 기대돼서요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"memorial-n-pareo-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"네, 스튜디오 의상 디자인과 감수도 츄츄 님이세요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"memorial-n-pareo-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"맞아요! 츄츄 님은 대단하세요~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"memorial-n-pareo-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"츄츄 님은 밴드와 관련된 건 뭐든 다룰 줄 아시는\n슈퍼 지니어스♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"memorial-n-pareo-007","volume":1}],"speed"