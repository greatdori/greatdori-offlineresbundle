],"windowDisplayName":"히마리","body":"그, 그런 건 아닌데……\n음…… 맞아! 곤경에 처한 애를 돕기 위해서\n남몰래 도와줬다고나 할까~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"ev144-ep2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"남몰래……? 그게 무슨 소리야……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev144-ep2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"그, 그것보다 토모에네는 상점가 어땠어?\n갔었지? 감사 데이!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"ev144-ep2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"그래, 엄청 재밌었어.\n특히 미셸이랑 마리가 말이야……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev144-ep2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"호오, 마