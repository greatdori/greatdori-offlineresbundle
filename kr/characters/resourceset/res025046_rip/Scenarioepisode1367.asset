,"motions":[{"characterId":25,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev171-ep1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"그런가요.\n그래도, 힘든 일이 있으면 언제든 말해주세요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev171-ep1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"시로카네 씨는 무슨 일이든 떠안아 버리니까요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev171-ep1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"……과연.\n최근에 린코의 소리가 잠긴 것처럼 느껴진 이유는\n그 이벤트가 원인이었네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev171-ep1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"앗…… 제 소리가, 평소랑 달랐어요……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev171-ep1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"아주 약간. 그냥 내가 신경이 쓰였을 뿐이야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev171-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"그리고, 오늘은 가벼운 소리가 울려퍼졌어.\n이벤트를 통해서 무언가 얻은 것이 있는 거 아닐까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev171-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"맞아요…… 많이, 있어요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev171-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"훌륭한 학생회장이 되려면……\n아직, 가야 할 길이 멀지만요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev171-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"적어도, 이상적인 제게 가까워지고 있다는 것을……\n배운 것 같아요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev171-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"토모에 씨하고 둘이서 이야기했을 때\n그렇게 깨달은 것 같아요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev171-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"과연, 토모에도 아코랑 같이 이벤트에 갔었지!\n토모에랑 린코가 둘이서 이야기하다니 왠지 신기한데?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev171-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"확실히, 우다가와 씨와 셋이서 이야기하는 것은 자주 보는데\n단둘이서 이야기하는 모습은 별로 본 적이 없네요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"v