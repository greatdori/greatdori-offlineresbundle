henStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"꽃의…… 요정……!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"(다행이다. 이해했나 봐) ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_sad","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"굉장하네, 미셸은.\n핑크색이라서 귀엽고. 하구미는 실은 무지하게\n미셸이 부러워.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"(……엥?\n이유 없이 좋아하는 줄 알았는데\n아닌가……?)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"하구미는 핑크색 같은 건 절대로 어울리지 않잖아.\n자주 남자라고 오해받고……\n그래서 사실은 미셸같이 되고 싶어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"(……엥? 이거 곰인데?\n……아…… 뭐… 바보 트리오라고 놀리고는 있지만\n하구미도 나름대로 이런저런 고민이 있구나……)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"……미셸도 말이지.\n이런…… 곰이지만 사실은 곰답지 않게\n푹신푹신한 걸 좋아하기도 해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"엇! 그런 거야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"응. 동생을 위해 양모 펠트 봉제 인형을 만들고 있는데\n원래는 나도 그런 거 좋아해. 하지만 나한테 봉제 인형 같은 건\n어울리지 않으니까 창피해서 여동생에게 주는 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"아. 하구미도 귀여운 과자 같은 거\n나보다 여자다운 애들에게 주고 그랬어……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-063","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"하지만 하구미 짱은 곰이 아니라\n여자아이니까 앞으로도 점점 귀여워질 거야.\n미셸은 곰이니까…… 앞으로도 쭉 곰이지만.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-064","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"하구미","body":"미셸은 곰이라도 굉장히 귀여운데!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-065","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"미셸","body":"응…… 그러네.\n그러니까 미셸도 하구미 짱도\n앞으로 더욱더 귀여워질 거야. 기대되네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-066","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_story_03","motionName":"","expressionName":"","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":13,"costumeType":"013_casual","motionName":"","expressionName":"","moveSpeedType":0},{"type":3,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"","motionName":"","expressionName":"","moveSpeedType":0},{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_story_01","motionName":"","expressionName":"","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_story_01","motionName":"sad01","expressionName":"","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_story_01","motionName":"surprised01","expressionName":"","moveSpeedType":0},{"type":3,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_story_01","motionName":"","expressionName":"","moveSpeedType":0},{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_story_03","motionName":"","expressionName":"","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffset