"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"딱 잘라 말하자면 상~당~히 피곤해요.\n……후우.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"알다시피, 전 언제나 코코로나 하구미, 카오루 씨랑\n같이 있잖아요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"그 애들에게 휘둘리고 있으니까\n꽤 익숙해졌을 텐데……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"그 꽃놀이의 멤버들은 여간내기가 아닌 사람들만 모여버렸거든요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"특히 토야마 씨는 코코로와 같은 계통이라는 것을 느꼈어요.\n주위 사람들을 휘말리게 하는 인간 특유의 아우라 말이죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"아직은 그렇게까지 친한 건 아니지만……\n어쩌다가 친해지면…… 후우.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"아아, 물론 그게 싫다는 건 아니에요.\n그저 요주의 인물이다, 이거죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"그리고 이치가야 씨에겐 놀랐어요.\n그 애의 본모습이 그런 줄 몰랐거든요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"공부 잘하고 차분한 인상이었는데……\n좋은 의미로 친근감이 솟아난다고 해야 하나……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"……그래도 벚꽃은 정말로 예뻤고\n모두와 많은 이야기를 나눴으니까,\n뭐, 나쁜 모임은 아니었어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"토야마 씨네 멤버들과는 반도 다르고\n보통은 접점도 별로 없으니까\n그렇게 즐거울 줄 몰랐어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"미사키","body":"벚꽃 파워 장난 아니다, 란 느낌이네요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"memorial105-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound"