wDisplayName":"토우코","body":"그러니까~ 원하는 것을 뽑을지 못 뽑을 것 같은\n그런 조마조마함이 즐겁다니까~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev151-ep4-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"더욱 모르겠어.\n획득 유무가 불확정적인 것에 일부러 시간과 노력을 소모하기보다\n확실히 획득할 수 있는 수단을 고르는 것이 효율적이잖니.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"ev151-ep4-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"아니, 그게 그렇지 않다니까.\n진짜 루이는 머리가 굳었단 말이지~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev151-ep4-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"적어도 인형 뽑기 게임은\n내가 흥미를 가질만한 게 아니라는 건 알았어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"ev151-ep4-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"애초에 게임센터에\n흥미를 가질만한 것이 있다고는 생각하지 않지만.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"ev151-ep4-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"아니아니, 게임센터을 너무 우습게 본다니까!\n아, 그러면 스티커 사진!\n스티커 사진이라면 루이도 마음에 들어하지 않을까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev151-ep4-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"루이","body":"스티커 사진?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"ev151-ep4-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"스티커 사진이라는 건 기계 안에서 사진을 찍고\n그걸 작은 스티커로 만드는 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"ev151-ep4-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDispl