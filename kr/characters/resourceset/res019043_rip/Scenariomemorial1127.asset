"actionType":4,"progressType":0,"referenceIndex":24,"delay":4.699999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":15,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":25,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":16,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":26,"delay":2.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":27,"delay":2.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":18,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":19,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"으으…… 추워……!\n따뜻한 음료라도……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"어라? 저기 있는 건……\n마리나 씨, {{userName}} 씨! 안녕하십니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"앗, 마야 짱!\n그러고 보니 이브 짱한테 라디오 이야기 들었어.\n파스파레 멤버가 이벤트에 나갔다면서.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev143-me5-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"아, 공개방송 말입니까!\n하아~ 즐거운 이벤트였습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"저희는 게스트였습니다만\n관객이 엄청 좋아했습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"그리고 공개방송 후에도 이브 씨의 라디오가 평이 좋아서\n방송하는 시간에는 SNS 태그가 트렌드에 들어갈 정도로\n인기가 있었습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"와아, 대단한걸!\n많은 사람이 이브 짱의 라디오를 듣고 있네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev143-me5-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"맞습니다. 그건 분명\n이브 씨의 라디오에 신기한 힘이 있어서라고 생각합니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"신기한 힘?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev143-me5-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"네. TV나 인터넷 방송과는 다르게\n라디오에서는 표정을 볼 수 없습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"그런데도 목소리와 단어 만으로\n이브 씨가 지금 어떤 표정을 짓고 있는지 상상이 됩니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"모습이 보이지 않기에 오히려 가깝게 느껴지는 듯 합니다……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"어쩌면 이브 씨도 사연을 통해서\n청취자의 표정을 떠올리면서 말하는 걸지도 모르겠습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"과연.\n표정은 보이지 않지만 목소리 톤이나 단어 선택에서\n전해지는 감정이 있다는 말이구나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev143-me5-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"맞습니다. 청취자한테 기운을 불어넣는\n코너가 인기인 것도 이브 씨가 갖고 있는\n강함과 상냥함이 목소리로 전해지기 때문 아닐까 생각합니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"이브 씨의 목소리를 들으면\n「내일부터 또 열심히 하자」하고 기운이 나지 말입니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"확실히 평소에 이야기 나눠도\n이브 짱의 긍정적인 말투에 기운을 받는걸.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev143-me5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"그렇지 말입니다! 마리나 씨네도\n꼭 이브 씨의 라디오에 사연을 보내주시기 바랍니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev143-me5-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"응, 그럴게!\n나도 이브 짱한테 기운을 받고 싶어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyn