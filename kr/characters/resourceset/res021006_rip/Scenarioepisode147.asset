uirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"그럼 리퀘스트를 받아 놓기로 할까~\n유키나는 어떤 거 먹고 싶어? 매번 만드는 건\n심플한 거니까 가끔은 다른 맛으로 만들어도 괜찮을 것 같은데~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"gattsu01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode147-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"다른 맛이라는 건…… 어떤 거?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode147-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"예를 들면 홍차의 풍미를 더 해도 좋고, 초콜릿이 들어간 것도 좋고,\n특이하게 녹차가 들어간 것도 좋지~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"eeto01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode147-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"저요저요~! 아코는 땅콩이 들어간 게 좋아~!\n바삭바삭, 오독오독! 같은 거로!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"gattsu01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"episode147-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requi