undReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"다른 분들은 어떠세요!?\n아코가 생각한 엄청 멋진 라이브, 전해졌나요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"글쎄……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"알겠어…… 아코 짱……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev78-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"죄송합니다만, 저도 이해가 잘 안 되네요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev78-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"사요 씨도!?\n으으, 아스카랑 롯카한테 설명했을 때보다\n더 잘 설명한 거 같은데……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"쿵~ 펑~ 같은 의성어는\n설명하기에 그리 좋지 않은 말이라고 생각해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev78-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"아코가 하고 싶다는 게 있다는 건 알겠지만\n설명을 듣는 입장에서는 그리 확실하게\n이미지를 잡을 수 없어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"으으……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"일단 하나씩 해석해 줄 수 있을까.\nRoselia를 위해서 생각해 준 거니까\n제대로 이해하고 싶어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"유키나 씨…… 넵!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"우선 오프닝부터.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"아마도 암전 이후에 핀 스포트라이트가 비추고\n거기에 유키나가 있다는 느낌인 걸까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"마, 맞아맞아! 그런 느낌!\n그래서 유키나 씨가 멋진 주문을 외우면\n우리가 소환되고……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"실제 주문은 아코가 생각해낼 거야?\n나는 그리 자세히는 모르니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"그, 그게…… 그건, 그……\n우리를 소환할만한 어둠의 힘이 느껴지는\n멋진 느낌의 주문을……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"……어렵네.\n가사를 생각하는 것보다도 난이도가 높아 보이네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"으으……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"저, 저기…… 의미로서는…… 소개하는 듯이 해도\n괜찮을 거예요…… 중요한 건, 주문을 외우는 거라……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev78-ep1-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"예를 들면…… 유키나 씨가 어려운 말을 써서……\n멤버를 소개하면……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev78-ep1-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"맞아! 그거야 그거, 그런 느낌이면 충분할 거예요!\n유키나 씨가 말하면 분명 멋질 거예요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"우다가와 씨의 세계관에 있는 말…… 이라는 건 알겠지만\n어려운 말이라면 관객한테 전달되지 않을 리스크가 있겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev78-ep1-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"뭐 그 부분은 의외로 기세랑 분위기로 해결되지 않을까?\n무슨 의미인지 모르는 곡이라도 멋져! 라고 생각할 때도 있고.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"분위기라고 하니까 이야기 도중에\n어둠의 힘이라는 말이 자주 나오는 것 같은데……\n이건 뭐야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"어둠의 힘이에요!\n진짜 굉장한 힘인데, Roselia의 연주에 의해서\n어둠이 이렇게…… 그오오오오오 하는 느낌으로 높아지고……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"그오오오 하는 소리는…… 지금까지의 라이브에서는\n나온 적 없었어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"그 소리는…… 공연장이 고조돼서……\n공기가 일렁이는듯한 느낌을…… 표현한 거라고 생각해요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev78-ep1-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"아~ 그런 거 있지~ 분위기가 고조되다 보면\n우리랑 관객의 공기가 뒤섞여서\n좋은 느낌의 일체감이 느껴지잖아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"그것에 의해 어둠의 힘이라는 게 깃든다는 느낌인 걸까?\n관객의 열기나 일체감으로 연주의 힘이 늘어난다는\n이미지인 걸까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev78-ep1-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"하나 더 물어봐도 될까?\n아코는 어둠의 힘으로 죽은 자가 되살아난다고 했는데……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"그건 우리 연주에 어둠의 힘이 깃들어서\n땅속에 잠든 죽은 자들이 드드득! 되살아나는 건데……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"……과연, 그게 아코가 생각하는\n라이브 이미지라는 거구나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"네……! 저기, 어떠셨어요? 전달이 됐나요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"적어도 처음 설명을 들었을 때보다는\n더 많이 이해한 거 같아. 생각 이상으로 큰\n이미지를 그리고 있었네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"Roselia의 멋짐을 표현하려면\n그 정도는 해야겠다고 생각했어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"아하하, 아코의 세계가 나타난 느낌이야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"노래나 의상의 이미지도…… 잘 맞추고 있다고 생각해요……\n무엇보다, 와 준 사람들이…… Roselia의 세계를\n즐겨줬으면…… 좋겠어요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev78-ep1-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"네, 저도 완벽하지는 않지만 우다가와 씨의 정열은\n제대로 전달됐어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev78-ep1-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"모두들…… 그러면……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"실현시키는 건 아직 어려울 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev78-ep1-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"최대한 아코의 이미지를 무너트리지 않도록\n라이브로서 실현하기 위해서는 과제가 많겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev78-ep1-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"실현……?\n아하핫, 그래, 그렇지!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"왜 그래 리사 언니?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev78-ep1-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"아니, 예전이었다면 유키나나 사요는 「무슨 소리를 하는 거야?」\n「그것보다 연습입니다.」라고 하면서 끝냈을 텐데.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"실현하기 위해 생각하고 있는 두 사람도 그건 그거대로\n정말로 성실하다는 생각이 들었어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev78-ep1-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"아코도 Roselia의 멤버인걸. 어떤 이상이\n있는지, 제대로 생각해 둬야해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"vo