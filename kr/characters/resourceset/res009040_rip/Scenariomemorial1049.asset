enFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"하아, 하아……! 이 돈코츠 라멘으로\n금방 배부르게 해 줄게, 히마리……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"fes2-TM-part2-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"이제 완전히 가을이라고 생각했는데, 오늘은 별나게 덥네.\n빨리 물 뿌리고 어머니 일 도와주러 가야지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"fes2-TM-part2-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"우왓, 차가워!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"fes2-TM-part2-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"토모에 짱!? 미안해, 달려오는 거 못 봤어……!\n젖었네, 괜찮아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"fes2-TM-part2-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCl