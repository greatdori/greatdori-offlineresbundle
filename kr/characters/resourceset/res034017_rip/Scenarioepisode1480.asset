":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":41,"delay":3.9000000953674316,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":18,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":35}],"windowDisplayName":"츄츄","body":"파레오! 너, 좋아하는 음식 있어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"2022birthdayStory-034-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"앗, 파레오 말인가요?\n츄츄 님이 앙~ 해주는 거라면 뭐든 먹어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"그러면 곤란하다고.\n자, 오늘은 네 생일이잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"2022birthdayStory-034-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"레이야","body":"마스키가 케이크 만들어 줄 건데\n이왕이면 파레오가 좋아하는 걸 넣고 싶대.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"2022birthdayStory-034-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"알려주시면 저랑 마스키 씨가 사 올게요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"2022birthdayStory-034-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"음…… 그렇다고 해도…… 앗.\n최근에 즐겨 먹는 과자라면 있어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"새로 나온 이 젤리에요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"오, 실물을 갖고 있다면 알아보기 더 쉽지.\n……그런데 어째서 이걸 좋아하게 된 거야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"2022birthdayStory-034-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"록","body":"겉보기에는 그냥 컬러풀한 젤리네요……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"2022birthdayStory-034-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"앗……? 여, 여러분…… 정말 모르시겠어요……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"맛이 다섯 종류 있는걸요……?\n복숭아랑 소다랑 레몬이랑 청사과랑 포도라고요……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"아무리 봐도 파스파레잖아요~!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"츄츄","body":"잘 갖다 붙이네……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"2022birthdayStory-034-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"그럴 수가~! 봉투에서 하나 꺼낼 때, 누구 색인지에 따라서\n파레오가 취하는 행동이 크게 달라진다니까요!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"예를 들면 전철에서 노래를 들을 때, 복숭아라면 「꿈 그라」\n레몬이라면 「흔들흔들」…… 이런 식으로요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"레이야","body":"후훗. 파레오한테 그게 중요하다는 것은 충분히 이해했어.\n마스키…… 어떻게 할래?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"2022birthdayStory-034-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"마스킹","body":"그래. 요구르트 같은 거 써서 타르트를 만들면\n제대로 된 케이크 토핑이 될 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"2022birthdayStory-034-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"와아, 그런가요! 정말 좋아하는 여러분께\n정말 좋아하는 멤버들 컬러로 된 케이크로 축하를 받는다니……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"파레오","body":"파레오는 태어나서 정말 다행이에요~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"happy01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"2022birthdayStory-034-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":35,"costumeType":"035_school_winter","motionName":"","expressionName":"default","moveSpee