?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"fes-TG-part2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"츠구미","body":"굉장히 즐거웠어!\n다른 밴드의 멤버들이랑\n연습하는 게 신선한 느낌이었어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"fes-TG-part2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"그렇네.\n그럭저럭 이려나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"fes-TG-part2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"히마리","body":"란은 또 그런 말이나 하고~!\n사진은 엄청 즐거워 보였다구!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"fes-TG-part2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"란이랑 미나토 씨, 얼굴이 빨갛게 달아올라 있었어~\n무슨 일이 있던 거야~?","tention":0,"lipSyncMode":1,"motionChangeFact