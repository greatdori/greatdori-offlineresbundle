cterId":9}],"windowDisplayName":"토모에","body":"그런데 이제야 납득이 되네요.\n리사 씨가 제안한 거군요. 그래서 모카도…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"simizimi01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev191-ep5-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"? 아오바 씨가, 뭐라고 하셨나요…?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nnf03","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev191-ep5-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"네!? 아니, 제 말은…!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev191-ep5-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"아, 아니야 린린!\n언니는 「모기도」라고 말하려던 거야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev191-ep5-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"토모에","body":"마… 맞아요! 그래도 여름 바다니