lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"전부 다 귀엽지 말입니다……\n이건 확실히 고민될 것 같지 말입니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev50-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"음~…… 내가 볼 땐 이거려나!\n이브 짱한테 무조건 어울릴 것 같아!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"어머, 아야 짱도?\n나도 이게 제일 좋을 것 같아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"그, 그런가요……\n저한테는 좀 어른스러운 느낌도 드는걸요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"그렇지 않아.\n이브 짱이라면 분명 어울릴 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"응응, 나도 이게 룽♪ 하고 왔어!\n그렇지, 마야 짱?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev50-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"네!\n저도 무척 귀여운 것 같지 말입니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev50-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"여러분……!\n네! 저, 이 수영복으로 하고 싶어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"여러분, 정말 고마워요.\n이거로 해수욕 준비는 완벽해요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"잠깐 기다려, 이브 짱.\n다른 준비는 다 끝난 거니?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"다른 거…… 인가요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"정말~ 이브 짱.\n여름 바다는 자외선 대비가 정말 중요하잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"아아! 선크림 말씀이시죠!\n물론 확실하게 준비해 놨어요, 여기!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"이브 짱…… 여름 자외선을 우습게 보면 안 돼.\n그리고 바다에도 들어갈 거지?\n물에 들어가도 지워지지 않는 거로 하는 게 좋아.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"혹시 괜찮으면 내 선크림을 줄게.\n자, 여기. 살을 절대 태우고 싶지 않을 때 써.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"엇!\n그런, 제가 받아도 괜찮나요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"괜찮아, 이건 예비용이니까.\n신경 쓰지 말고 쓰면 좋겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"아, 그거 나도 치사토 짱이 알려준 건데\n정말 살이 안 타니까 나도 추천해!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"그렇군요, 정말 고마워요!\n소중하게 쓸게요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"소중하게 쓰는 건 기쁘지만\n여러 번 발라야 한다?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"아참! 그럼 나는\n최고의 셀카를 찍는 방법을 알려줄게!\n바다라면 무조건 사진을 찍을 테니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"정말인가요!?\n꼭 알려주세요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"예를 들면 살짝 시선을 트는 거야.\n셀카라면 카메라를 보는 시선이라 임팩트가 센 것 같지 않아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"진짜네요!\n듣고 보니 그런 것 같아요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"그치?\n그러니까 있지, 이렇게 팔을 뻗고서\n자신의 손가락을 보는 듯한 느낌으로……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"네, 네!\n시선을 틀어서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"아!\n그리고 각도도 중요해!\n찍을 때는 반드시 살짝 위에서 찍어야 해!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"과연!\n이렇……게 인가요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"응응! 이브 짱, 잘하네!\n그런 느낌이야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev50-ep1-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"고마워요, 아야 씨!\n바다에서 셀카를 잔뜩 찍어서 보여드릴게요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"아참, 이브 씨.\n수분 보충도 잊으면 안 되지 말입니다!\n열사병은 무섭지 말입니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev50-ep1-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"아, 알겠어요!\n물을 잔뜩 마실게요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"마야","body":"네. 그리고 머리가 멍~해지면 바로 쉬시길 바라지 말입니다.\n그리고 다치지 않게 조심하십시오.\n소독약과 반창고를 가지고 가시면 안심이지 말입니다!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev50-ep1-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"뭐야뭐야, 다 같이 이브 짱한테 어드바이스?\n그럼 난 수영의 극치를 전수해줄게!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev50-ep1-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"극치……!\n알려주세요, 히나 씨!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"아, 그치만 엄청 간단해.\n발을 가볍게 파닥거리고, 팔을 쭉~하고 나면\n나머지는 그냥 첨벙첨벙~되니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev50-ep1-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"그, 그러니까……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"잠깐 히나 짱,\n그러면 이브 짱이 이해하기 어렵지 않을까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev50-ep1-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"괘, 괜찮아요!\n파닥, 쭉, 첨벙첨벙~이죠!\n제가 반드시 극치에 도달할게요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"응!\n이브 짱이라면 분명 괜찮을 거야~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev50-ep1-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"네!\n여러분, 정말 고마워요! 에헤헤.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"이브 짱, 왜 그래~?\n싱글벙글거려~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev50-ep1-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"이브","body":"아니요, 전 정말 여러분께 많은 도움을 받고 있는 것 같아서요.\n전 여러분이 정말 좋아요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev50-ep1-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"아하하, 갑자기 왜 그러는 거야~?\n이브 짱, 이상해!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev50-ep1-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"치사토","body":"정말, 히나 짱도 얼버무리지 말래도.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"s