":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev170-ep5-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"유키나 씨, 히카와 씨…… 찾았어요……\n이 가게예요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev170-ep5-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"과연 크리스마스 샵이라서 그런지\n다양한 장식이 있네요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev170-ep5-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"우리가 바라던 곳이네.\n빨리 고르자.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev170-ep5-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"분명 저번에 이야기 나눴을 때는 우다가와 씨가\n아무튼 방 안을 컬러풀하게 만들고 싶다고 했는데요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSy