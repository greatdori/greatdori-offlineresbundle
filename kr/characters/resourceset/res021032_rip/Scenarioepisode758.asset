eIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"그래. 아직 우리가 채우지 않으면 안 되는 부분이 남아있어.\n마루야마 씨 말대로 간주도 그렇지만\n후렴을 조금 더 브러쉬 업 해야겠어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"fes-YK-part1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"지금 느낌도 좋긴 하지만……\n확실히 다 같이 부른다면 조금 심플한 게 나을 거 같고.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"fes-YK-part1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"그렇구나, 이대로는 다 같이 노래하기 어렵겠네.\n걸즈 밴드 파티에 찾아온 관객들도\n가능하면 같이 불렀으면 좋겠고.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"fes-YK-part1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"코코로","body":"그거라면 응원 함성도 넣고 싶은걸!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"fes-YK-part1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requireP