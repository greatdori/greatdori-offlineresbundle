xpressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"할머님께서 못 먹게 하셔서\n전혀 먹어보지 못했다니까요~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"우리 할머님가 완전 엄격하셔서\n일식 이외에는 인정하지 않거든요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그, 그렇구나…… 잠깐, 하, 할머님?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-ssr-toko-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"토우코 짱은 아가씨라는 느낌이 별로 안 들었는데\n왠지 지금 약간 그런 느낌이 들었지, {{userName}} 씨.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-ssr-toko-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"그래서 계속 못 먹고 있다가\n중학생 때 찬스가 왔거든요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"왜, 중학생이 되면 다양한 곳에 가 보게 되잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"나도 행동범위가 넓어져서\n할머님께는 비밀로 하고 편의점에 가서 거기서 먹었어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"이야~ 처음에는 물 버리는 법도 완전 몰라서\n점원 아줌마한테 여러 가지 가르쳐달라고 했었는데.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"먹기까지 엄청 고생했지만\n처음으로 먹은 컵 야키소바는 진짜 맛있었어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"그렇게 소스 범벅인 짜릿한 음식은\n정말 먹어본 적이 없었거든!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"토우코","body":"집에 자주 나오는 일식이 고양이라면 컵 야키소바는 진짜 타이거라구!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"memorial-ssr-toko-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후후후, 꽤나 충격적인 체험이었나 봐.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressio