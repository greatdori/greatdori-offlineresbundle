6,"progressType":1,"referenceIndex":5,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"앗짱~! 이것 좀 봐~!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"돌아오자마자 뭐야!? …… 잡지?\n꽤 유명한 음악잡지잖아. 서점에 있는 거 자주 보는데.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"맞아! 걸즈 밴드 특집으로 팝핀파가 실렸거든~\n음~ 어느 페이지더라…… 찾았어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"어디어디……\n와, 꽤 크게 실려있네……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"흐흥~ 대단하지~\n기뻐서 10권 정도 살 뻔 했어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"그렇게 많아도 쓸데없잖아.\n……아, 인터뷰도 실렸네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"와, 발견했구나~♪\n괜찮다면 소리 내서 읽어줄까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"괜찮아, 내가 읽을게……\n……그런데 언니, 대기실에서 먹은 과자에\n관한 것만 대답한 거 아니야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그치만 대기실도 즐거웠는걸~\n그날은 리미링이 스페셜한 과자를\n가지고 왔으니까~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"무려 유리 선배가 외국에서 보내준 거래!\n스마트폰으로 찍어놨는데…… 아, 이거야 이거!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"굉장하지!? 왠지 끄트머리가 초콜릿 같은 느낌이\n들기도 하고 게다가 한가운데가 카스텔라처럼 되어있어!\n그래서 엄청 달아!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"음악잡지니까 음악 이야기를 해야지.\n기자도 곤란해 한 거 아니야?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그렇지 않아, 신나서 같이 떠들썩하게 이야기 나눴는걸!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"그건 맞춰준 거지……\n꽤 커다란 공연장 같은데 이거 언제 라이브였어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"왜, 지난번에 앗짱한테 티켓 줬잖아.\n그 라이브 때!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"아, 결국 다른 일 있어서 못 갔지……\n와, 이 사진 웃는 얼굴이 대단하네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"이건~ 라이브 도중에 오타에랑 눈이 맞아서\n나도 모르게 웃어버린 부분인 거 같아, 아마도.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그리고 이건 MC 중이였나?\n아리사랑 학교 선생님 흉내를 냈어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"그래서 아리사 씨가 이렇게 곤란한 표정을 지었구나……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"하아…… 언니는 긴장 같은 거 안 해?\n이렇게 많은 사람 앞에서 노래하는 건데……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"긴장은 하지!\n그래도 즐거운 마음이 더 커!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"라이브는 항상 그래.\n그래서 다음 라이브도 엄~청나게 기대 돼!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그때보다 더 좋은 라이브를 하자고\n지금 팝핀파 멤버끼리 연습하고 있거든~\n다음 주말에는 아침부터 밤까지 계속 창고 연습이야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"fes2-KM-part1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"아스카","body":"……뭐랄까 언니는 항상 최선을 다하네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"fes2-KM-part1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"최선을 