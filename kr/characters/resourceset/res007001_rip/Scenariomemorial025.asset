haracterId":7}],"windowDisplayName":"모카","body":"가는 길에 다 같이 언제나 가는 곳에 들렀다가 갈까~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"언제나 가는 곳이 어디냐고?\n훗훗훗~ 그거야 언제나 가는 곳은\n언제나 가던 곳이죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"우리는 꼬맹이였을 때부터 계속 같이 있었으니까\n「언제나」라든가 「그거」 같은 식으로 통하는 게\n많이 있답니다~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"뭐라고 해야 하나, 말하지 않아도 통하는 관계라고 할까~?\n필링으로 대화하는 나에게는\n고마운 일이야~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"……그렇지만 애들은 자꾸 「모카는 자유인이야」\n「너무 특이해서 무슨 말을 하는지 모르겠어」라고\n하긴 하는데~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"뭐 그게 이 모카의 장점인 거니까.\n브이~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"소꿉친구들이다 보니 사이가 엄청 좋아요~\n싸움 같은 싸움은 해본 적도 없고.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"원래부터 사이가 좋았지만, 밴드를 시작하고 나서\n더욱 사이가 좋아진 듯한 느낌이 든단 말이죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"뭐랄까. 더욱더 애들에 대해서\n이해하게 되었다고 해야 할까?\n음악에서 전해진다 해야 할까?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"쉽게 말하자면 소친이였다고나 할까?\n아시겠죠? 소꿉친구~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"엥? 너무 줄여서 말했다고요?\n에이 뭐, 아무렴 어떻습니까~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"아, 그리고 아까 말했던 「언제나 가는 곳」은\n빵집 이야기예요~\n연습 끝나고 돌아가는 길에 자주 들리는 곳이에요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"훗훗훗~ {{userName}} 씨\n우리 비밀을 알아버리고 말았네요~?\n밤길 조심하세요~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"농담~ 농담~\n그런 이상한 얼굴 하지 말아요~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"자, 그럼~ 슬슬 애들을 따라가지 않으면\n혼나겠는데?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"그럼 수고하셨습니다.\n{{userName}} 씨도 대충 마무리하시길~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial025-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"모카","body":"맞다. 다음 연습 때는\n빵을 사 올게요~\n훗후~ 고딩이 주는 간식~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterI