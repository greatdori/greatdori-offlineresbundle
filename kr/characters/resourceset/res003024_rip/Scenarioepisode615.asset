enStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"나도…… 언니를 위해서\n뭔가를 해주고 싶다고 생각했으니까……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev72-ep2-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"유리","body":"그렇구나…… 응, 그럼\n그 말대로 해볼까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":302,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":302,"voiceId":"ev72-ep2-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"리미","body":"응! 맡겨줘!\n우리만이 아니라 친구들 밴드도 불러서\n와~하고 떠들썩하게 하자!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev72-ep2-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"유리","body":"밴드가 모인다면\n그대로 라이브 하자! 라고 될 것 같네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":302,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":302,"voiceId":"ev72-ep2-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characte