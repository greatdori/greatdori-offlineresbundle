ndowDisplayName":"유키나","body":"「있었을지도 모르는 미래」……?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev166-ep4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"아마도 레이야가 이사 가지 않았다면\n타에랑 밴드를 맺었을지도 모른다고 생각하거든……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev166-ep4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"그 말을 듣고 잠깐 생각했어.\n나도 어쩌면 그때 베이스를 연주하지 않았다면\nRoselia 멤버가 안 됐을지도 모른다고 말이야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev166-ep4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"…………","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev166-ep4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"그날뿐만이 아니라\n작은 일이나, 아주 사소한 일로도 다른 선택을 했다면\n전혀 다른 지금이 되었을지도 모른다고 생각했거든.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev166-ep4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"앞으로도 말이야, 무언가를 선택할 때\n그런 가능성이 따라오지 않을까 생각했어……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev166-ep4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"……리사.\n그런 어쩌면 하는 이야기를 해도 의미 없다고 생각해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev166-ep4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"리사","body":"그, 그렇긴 하지만! 알고 있긴 한데~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev166-ep4-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"유키나","body":"알고 있다면 어째서 그런 이야기를 내게