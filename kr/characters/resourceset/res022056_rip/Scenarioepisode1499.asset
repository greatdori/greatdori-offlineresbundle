Id":17}],"windowDisplayName":"히나","body":"그렇구나, 수학여행! 하나사키가와는 이 시기였던가.\n부럽다~ 나도 교토 가고 싶어~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev185-ep1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"잠깐, 히나. 수학여행의 목적은 어디까지나 「수학」\n그냥 놀러 가는 게 아니잖아?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev185-ep1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"말은 그렇게 하지만\n언니도 기대하고 있으면서~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev185-ep1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"히나","body":"교토 추천 명소나 맛있는 가게를\n있는 대로 알아보고 있잖아!\n나는 다 아는걸?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev185-ep1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayN