ogressType":1,"referenceIndex":19,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":20,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":20,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":21,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":21,"delay":3,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":22,"delay":6,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":23,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"란 짱, 안녕!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"네? 아…… 안녕하세요.\n두 분은 오늘도 일하세요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"아니, 오늘은 둘 다 쉬는 날이야.\n친구랑 영화라도 보려고 해서 기다리는 중인데\n{{userName}} 씨랑 우연히 만났어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"저도 기다리고 있는 중이에요.\n오늘은 히마리랑 쇼핑하러 가기로 약속해서.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"아, 그렇지.\n저번에 토모에 귀걸이 찾는 거.\n도와주셔서 감사했습니다.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"아니야 아니야!\n무사히 찾아서 다행이야.\n토모에 짱도 한숨 돌렸겠네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"토모에보다 히마리가 더 기뻐했지만요.\n찾았을 때 울었던 거 같았으니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그랬어?\n후훗, 왠지 히마리 짱 답네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"히마리는 그런 경향이 있죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"남의 일이라도 자신 일처럼 기뻐하기도 하고 화내기도 하고.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그런 사람은\n함께 있어주는 것만으로도 도움이 되지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"분명 이번에 토모에 건도\n그런 게 아닐까 싶어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"뭐, 본인은 전혀 자각하지 못하고\n저희가 말해줘서 이제야 깨달은 것 같지만.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후훗, 그랬구나.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"하지만 본인은 리사 씨처럼\n믿음직스러운 사람이 되고 싶다고 말했지만요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후훗, 리사 짱처럼 말이지~\n확실히 리사 짱은\n엄청 눈치도 빠르고 믿음직하지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"하지만 저는 딱히 히마리가\n리사 씨처럼 되지 않아도 괜찮다고 생각해요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"히마리한테는 히마리만의 장점이 있으니까.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그거 본인한테 말해주는 건 어때?\n분명 기뻐할 거 같은데.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"그건…… 부끄러우니까 안 할래요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"그리고 히마리가 그렇게 되고 싶다고 말하니\n응원하고 싶기도 하고.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후훗, 그것도 그러네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev85-me3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"……어라, 벌써 시간이.\n히마리, 어쩌면 약속장소를 잘못 알고 있나……\n저는 잠깐 주변 확인 좀 하고 올게요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev85-me3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCh