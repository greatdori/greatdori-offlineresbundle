Id":4,"voiceId":"episode102-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"맞아, 그랬어!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode102-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"아아~ 내 이미지가……!\n……괜히 카스미가 꽃놀이 가자! 같은 말은 꺼내서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"episode102-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"또 그런다~\n그렇게 말하면서도 은근슬쩍 싱글거리고 있었으면서.\n사실 즐거웠잖아? 솔직해지자~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"hukumi01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode102-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"바, 바보냐!?\n재미없었다고!\n아예 잊어버리고 싶다니까!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"shame01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"episode102-019","volume":1}],"speed":0,"fontSize":0,"whenFini