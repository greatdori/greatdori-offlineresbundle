ow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"맞아맞아.\n그래서 골까지 얼마만큼 행운이 따랐는지 겨루는 거야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev101-ep1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"행운이 따랐는지 말인가요?\n어떻게 비교하는 거죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev101-ep1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"아, 칸에 작은 숫자가 적혀있어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev101-ep1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"과연, 멈춘 칸의 숫자를\n더해가는 거군요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev101-ep1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"사요 씨 정답! 멈춘 칸의 숫자를 더해서\n합친 수가 클수록 행복하다는 거야.\n아, 물론 골인 순서도 관계있으니까 신경 써야 해!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev101-ep1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"그러면 먼저 직업 정하자~!\n우선 아코먼저! 룰렛 돌리고……\n음, 아코는…… 파랑 6!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev101-ep1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"파랑 6은…… 스포츠 선수네요.\n그러면 다음에는 제가……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev101-ep1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"농가인 듯해요.\n어떤 야채를 기르는 걸까요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev101-ep1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"은근히 들떠있네요, 사요 선배……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev101-ep1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"사요","body":"시작한 이상 질 수 없죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev101-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"오, 다음은 내 차례네. 음……\n으엑…… 일용직!?\n시작 전부터 격차 너무 큰 거 아니야!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev101-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"흠~ 나는 닌자인가.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev101-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"오오, 란 짱 멋지다~!\n어둠을 가르는, 아름다운…… 음, 짠~ 하는 것 같아!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev101-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"그러면 마지막은 내 차례야.\n에잇…… 음 빨강 1인가?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev101-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"아코","body":"굉장해 대마왕이야! 아코는 항상 대마왕 노리는데\n잘 안 걸린단 말이지~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev101-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"아리사","body":"어이어이, 직업은 커녕 차원이 다르잖아……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev101-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"카논","body":"대, 대마왕의 일은 어떤 걸까……?","tention":0,"li