{{userName}} 씨, 안녕하세요!\n지금 팝핀파 멤버들하고 놀러 가려고요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"bye01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그렇구나. 아, 그 가방에 단 별 부적\n엄청 귀엽네. 혹시 직접 만들었어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"네, 팝핀파 멤버가 하나씩 갖고 있어요.\n저번에 가정 과목 숙제하다가 만들었어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후후, 그렇구나.\n아, 그러고 보니 사아야 짱한테 들었어.\n저번에 CHiSPA한테 곡을 만들어 줬다면서?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"맞아요!\n저도 제대로 참가하고 싶었는데\n숙제에 쫓기는 바람에~……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그렇구나. 카스미 짱이었으면 답답했겠네?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"맞아요!\n저도 빨리 도와주고 싶었는데\n좀처럼 숙제에 집중을 못 해서요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"하지만 아리사가 빨리 끝내면 빨리 도울 수 있다는\n말을 듣고 그렇구나! 하고 깨달았죠.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"덕분에 어떻게든 기한 안에 끝낼 수 있었어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후후, 그랬구나.\n그래서 두 사람이 만든 곡은 어땠어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그게 정~말 굉장했어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"사~야의 상냥함이 가득 담긴 듯한 가사에\n오타에도 이런 기타를 치는구나 싶어서 놀랐고요……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"어쩐지 팝핀파인데\n평소의 팝핀파가 아닌 것 같은\n아주 새로운 노래였어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"과연. 둘이서 협력해서 만들었기에\n태어난 곡인지도 모르겠네.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"그럴 거예요!\n그리고 두 사람이 만든 곡을 어레인지하는 게 엄청 즐거웠어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"이런 소절을 붙이면 더 멜로디가 살지 않을까\n인트로를 이렇게 하면 가사가 마음에 더 전해지지 않을까\n그런 생각을 했더니 두근거려서……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"어쩐지, 아주 귀여운 아이한테\n아주 귀여운 옷을 입혀주는 느낌이었어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후후, 왠지 정말 멋진 비유네.\n즐겁게 어레인지한 게 전해져","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"맞아요! 그런 즐거움을 다시금 깨달아서\n역시 음악 제공하기를 잘한 것 같아요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"또 기회가 있으면 해보고 싶어요~\n그리고 곡이 완성된 뒤에는 CHiSPA처럼\n같이 라이브하고 싶어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"응 응, 분명 또 그런 기회가 있을 거야.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"후후, 그건 그렇고\n카스미 짱 이야기를 들었더니 나도 CHiSPA의 곡을\n들어보고 싶은걸.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev183-me3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"정말 굉장히 좋은 곡이니까\n꼭 CHiSPA 라이브에 놀러 가 보세요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"카스미","body":"아, 큰일 났다. 약속 시간 지각하겠어!\n그러면 마리나 씨, 저는 그만 가 볼게요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev183-me3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"응, 잘 가. 조심해.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02"