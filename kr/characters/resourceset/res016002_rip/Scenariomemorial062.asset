0}],"voices":[{"characterId":16,"voiceId":"memorial062-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"가……감사합니다!\n실은 저도 그렇게 생각해서……!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"이 의상을 처음 봤을 때\n정말로 기뻤어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"저, 아이돌이 되는 게 꿈이었으니까……\n이런 귀여운 의상을 입게 된다고 생각하니\n가슴 속이 따끈따끈해져서…… 에헤헤♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"게다가 이거 보세요!\n이 의상 색깔…… 핑크색이에요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"저 핑크색이 정말 좋아요♪\nThe 아이돌이란 느낌이 들지 않나요?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"그러니까 핑크색이 제 의상의 색이라는 말을 들었을 때\n제 전용 의상이라고 생각하니…… 굉장히 감격했어요!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"……앗, 죄송해요! 아까부터 제 얘기만 늘어놓고……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"아야","body":"괜찮다고요? 정말인가요?\n후아…… 다행이다~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"memorial062-015","volume":1}],"speed":0,"fontSize":0,"whenFinishClo