haracterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev97-me2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"저랑, 아코 짱이…… 플레이하는……\n게임하고, 콜라보 이벤트가…… 개최돼서……\n그 이벤트에, 참가하고 왔어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev97-me2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"그건, 힘을 합쳐서 미션을……\n클리어한다는 이벤트라……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev97-me2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"린코","body":"미션은 무척…… 어려운것, 뿐이었지만……\n모두의 협력도 있어서, 어떻게든……\n클리어 할 수 있었어요.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"ev97-me2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"마리나","body":"그렇구나! 과연 Roselia야!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionN