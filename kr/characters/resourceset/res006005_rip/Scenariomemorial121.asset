erId":6}],"windowDisplayName":"란","body":"……아, 그러고 보니.\n있지, 당신은 밤하늘에 가득한 별을 본 적이 있어?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"memorial122-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"손에 꼽을 수 있을 정도밖에 없다고?\n뭐, 보통은 볼 기회가 그렇게 많지는 않지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":6,"voiceId":"memorial122-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"실은 얼마 전에\n카스미랑 츠구미랑 같이 천체관측을 하러 갔어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"memorial122-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"다 같이 산을 오르다가 우연히 만나게 된 코코로네 별장까지 가서 말이지.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"memorial122-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"란","body":"이미 그 시점에는 피로가 꽤 쌓여 있긴 했지만\n밤하늘을 보기 위해 깨어 있어야 했어.","tention":0,"lipSyncMode":1,"motionChangeFactor":1