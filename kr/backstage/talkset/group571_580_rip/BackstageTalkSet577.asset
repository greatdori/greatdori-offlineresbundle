{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet577","backstageTalkSetId":577,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet577-1","talkText":"다음에 팝핀파 멤버끼리\n소풍 가자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet577-2","talkText":"그리고 악기 가져가서\n밖에서 연주하는 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet577-3","talkText":"그런데…… 드럼은\n가져갈 수 없지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet577-4","talkText":"기합이 있으면 괜찮아!\n다 같이 옮기자!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}