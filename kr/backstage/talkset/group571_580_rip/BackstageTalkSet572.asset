{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet572","backstageTalkSetId":572,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet572-1","talkText":"이거 봐봐! 창고에서 이런 걸\n찾았어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet572-2","talkText":"와~! 커다란 연이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet572-3","talkText":"다 같이 날리러 가자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet572-4","talkText":"그렇게 큰 연이면 안 뜰지도\n모른다?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet572-5","talkText":"확실히 바람이 없으면\n어려울 거 같네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet572-6","talkText":"괜찮아.\n우리라면 할 수 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet572-7","talkText":"왜 그렇게\n자신만만한 거냐……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet572-8","talkText":"응응, 분명 괜찮을 거야!\n렛츠 고!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet572-9","talkText":"아, 잠깐만 기다려\n카스미, 오타에!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[3],"voiceId":"TalkSet572-10","talkText":"후훗, 재밌겠다~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}