{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet573","backstageTalkSetId":573,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet573-1","talkText":"영차! 영차!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet573-2","talkText":"자! 자!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet573-3","talkText":"굉장해…… 두 사람 다\n엄청나게 호흡이 잘 맞네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet573-4","talkText":"여히미 해~","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet573-5","talkText":"모카~ 먹든지 말을 하든지\n하나만 하라구~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet573-6","talkText":"그러면 먹을래~\n쫀득하고 맛있어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet573-7","talkText":"신난다~! 기쁜걸.\n열심히 한 보람이 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet573-8","talkText":"다음은 모카네 차례니까.\n중요한 건 템포라고!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet573-9","talkText":"알~았~어.\n맡겨줘~~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet573-10","talkText":"저, 정말 괜찮겠어? 그\n템포가 걱정되는데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}