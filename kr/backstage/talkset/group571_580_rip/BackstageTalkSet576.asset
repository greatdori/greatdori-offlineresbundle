{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet576","backstageTalkSetId":576,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet576-1","talkText":"헬로해피 사자춤이야!\n어흥~!","lipAnimation":"","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet576-2","talkText":"굉장해! 나\n사자춤은 처음 봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet576-3","talkText":"나쁜 아이는 없느냐~?\n크로켓 먹어버리겠다~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet576-4","talkText":"아니, 그건 사자춤이 아니잖아.\n크로켓도 안 먹고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet576-5","talkText":"액운을 물리치고 행복을 가져온다.\n아아, 덧없구나……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[11],"voiceId":"TalkSet576-6","talkText":"다음 라이브는\n사자춤으로 나가자!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet576-7","talkText":"찬성~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet576-8","talkText":"아아. 실로 운수 가득한\n라이브가 될 것 같구나.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet576-9","talkText":"그렇게 되면 한마디로 사자춤이랑\n미셸이랑, 카논 씨?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet576-10","talkText":"우에엥……\n자신 없는데~……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}