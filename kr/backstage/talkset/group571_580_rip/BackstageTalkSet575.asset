{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet575","backstageTalkSetId":575,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet575-1","talkText":"그러면 잘 봐~!\n에잇!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet575-2","talkText":"오, 굉장합니다!\n히나 씨, 잘하셨지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet575-3","talkText":"버라이어티 공연장이 떠들썩\n해질 게 틀림없어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet575-4","talkText":"남은 건 아야 짱이네.\n열심히 해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet575-5","talkText":"응! 반드시\n성공시킬게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet575-6","talkText":"간다!\n……에잇!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[16],"voiceId":"TalkSet575-7","talkText":"아~앗!\n……아파!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[19],"voiceId":"TalkSet575-8","talkText":"아깝습니다!\n약간 부족했지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet575-9","talkText":"분명 곧 잘 될 거예요!\n한 가지 기예는 도에 통한다, 예요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet575-10","talkText":"그러네!\n좋아~ 다시 한 번!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}