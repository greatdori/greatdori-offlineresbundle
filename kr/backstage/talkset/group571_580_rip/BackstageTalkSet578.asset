{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet578","backstageTalkSetId":578,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet578-1","talkText":"봄은 좋네.\n다양한 꽃이 피니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet578-2","talkText":"민들레, 연꽃\n토끼풀……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet578-3","talkText":"전부 토끼가 엄청 좋아하는 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet578-4","talkText":"그쪽이냐!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0}]}}