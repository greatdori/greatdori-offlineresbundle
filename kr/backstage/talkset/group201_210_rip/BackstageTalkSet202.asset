{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet202","backstageTalkSetId":202,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet202-1","talkText":"카스미의 헤어 스타일은\n어떻게 만드는 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet202-2","talkText":"오타에도\n이 헤어 스타일로 할래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet202-3","talkText":"아니, 토끼 귀 모양\n헤어 스타일을 하고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet202-4","talkText":"토끼 귀!\n해보자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}