{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet207","backstageTalkSetId":207,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet207-1","talkText":"란 짱, 기타 케이스에\n달려 있는 인형은 뭐야……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet207-2","talkText":"히마리가\n만든 부적이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet207-3","talkText":"히마리 짱, 굉장하다~!\n귀여워, 이거.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}