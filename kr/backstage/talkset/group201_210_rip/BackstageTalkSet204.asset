{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet204","backstageTalkSetId":204,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet204-1","talkText":"오늘은 야마부키 베이커리에\n들렸어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet204-2","talkText":"어떤 빵이든 다 맛있어 보여서\n뭘 살지 고민했어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet204-3","talkText":"후훗.\n언제나 고마워, 카스미.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}