{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet685","backstageTalkSetId":685,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet685-1","talkText":"시험도 끝났고\n팟! 하고 놀고 싶네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet685-2","talkText":"좋다! 마침 옷을\n보고 싶었거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet685-3","talkText":"결정! 다음 휴일에는\n쇼핑몰이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}