{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet681","backstageTalkSetId":681,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet681-1","talkText":"아기 고양이에게 있어서\n덧없음은 무엇이니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet681-2","talkText":"……모르겠습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet681-3","talkText":"덧없음, 그것은 정열……\n덧없음, 그것은 사랑……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet681-4","talkText":"자, 함께 덧없음을\n추구하는 건 어떠니!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[30],"voiceId":"TalkSet681-5","talkText":"……연습이 있어서\n이만 실례하겠습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}