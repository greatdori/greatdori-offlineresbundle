{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet490","backstageTalkSetId":490,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet490-1","talkText":"마을 안이 할로윈\n장식으로 가득하네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet490-2","talkText":"네!\n거리를 걷는 게 즐거워요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet490-3","talkText":"아, 같이 할로윈\n영상 찍어서 올리지 않을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet490-4","talkText":"괜찮지 말입니다! 팬 분도\n기뻐할 것 같습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet490-5","talkText":"엄청 룽♪ 한\n느낌이야! 빨리 찍자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}