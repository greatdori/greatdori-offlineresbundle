{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet489","backstageTalkSetId":489,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet489-1","talkText":"이거…… 만들어 봤는데\n괜찮으면……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet489-2","talkText":"코르사주! 할로윈\n같아서 귀여워!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet489-3","talkText":"의상으로서도 잘 어울리겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet489-4","talkText":"그러면 특별히 할로윈\n라이브라도 할까!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet489-5","talkText":"좋은 생각이에요. 바로\n세트를 정하죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}