{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet485","backstageTalkSetId":485,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet485-1","talkText":"카오루 씨 흉내내는 거\n봐 주세요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet485-2","talkText":"덧없구나……\n어때요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet485-3","talkText":"아아, 카스미 짱.\n무척이나 덧없었단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}