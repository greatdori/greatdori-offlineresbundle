{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50036","backstageTalkSetId":50036,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet50036-1","talkText":"미사키! 생일\n축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50036-2","talkText":"미~군의 축하를 위해\n같이 춤추자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50036-3","talkText":"앗 잠깐 뭐야!?\n춤!? 왜!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50036-4","talkText":"같이 춤추면\n즐겁잖아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet50036-5","talkText":"우리는 미~군이\n즐거웠으면 좋겠어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet50036-6","talkText":"자, 미사키도 같이\n춤추지 않겠니!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[15],"voiceId":"TalkSet50036-7","talkText":"하아, 하아……\n히, 힘들어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet50036-8","talkText":"미사키 짱, 수고했어.\n자, 물 마셔.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet50036-9","talkText":"카, 카논 씨……\n지금은 천사로 보여……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50036-10","talkText":"모두 미사키 짱을 기쁘게\n하려고 많이 생각했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet50036-11","talkText":"아하하…… 뭐, 마음은\n엄청 잘 받았어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}