{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50040","backstageTalkSetId":50040,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50040-1","talkText":"란~! 츠구~!\n자, 치즈!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet50040-2","talkText":"앗, 깜짝 놀랐어!\n치, 치즈……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet50040-3","talkText":"히마리, 아까부터\n꽤 많이 찍네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50040-4","talkText":"물론이야! 엄청\n기쁜걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50040-5","talkText":"모카하고 토모에도!\n자, 치즈!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet50040-6","talkText":"오예~ 히~짱\n생축~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50040-7","talkText":"그래, 이번 기회에\n다 같이 찍지 않을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[8],"voiceId":"TalkSet50040-8","talkText":"그거 찬성! 모두 모여\n모여! 자 치즈!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[10],"voiceId":"TalkSet50040-9","talkText":"선물이 마음에 들어서\n다행이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50040-10","talkText":"응! 이 토이카메라,\n평생 소중히 할게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}