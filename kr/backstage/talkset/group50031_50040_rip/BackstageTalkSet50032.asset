{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50032","backstageTalkSetId":50032,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50032-1","talkText":"모카, 생일 축하해.\n자, 올해 생일 선물이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet50032-2","talkText":"모카가 어떤 걸 좋아할지\n같이 생각해 봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet50032-3","talkText":"으음~?\n이, 이건……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50032-4","talkText":"초대형 빵! 어때?\n놀랐어!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50032-5","talkText":"엄~청 놀랐어~ 긴 세월의\n꿈이 드디어 이루어졌어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50032-6","talkText":"잼도 준비했으니까\n많이 먹어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50032-7","talkText":"이걸로 당분간 빵 때문에\n곤란할 일은 없겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet50032-8","talkText":"그건 그렇고 사아야 짱도\n꽤 놀랐지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet50032-9","talkText":"이렇게 큰 빵은 처음\n본다고 하더라.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50032-10","talkText":"아하하…… 잠깐 모카!\n벌써 다 먹었어!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50032-11","talkText":"역시\n이렇게 될 줄 알았어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[7],"voiceId":"TalkSet50032-12","talkText":"내 위장은 이미\n5차원이거든~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}