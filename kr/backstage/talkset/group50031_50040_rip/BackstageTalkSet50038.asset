{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50038","backstageTalkSetId":50038,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50038-1","talkText":"시로카네 씨, 생일\n축하드려요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50038-2","talkText":"오늘은 엄청 멋진\n케이크를 준비했어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet50038-3","talkText":"멋진……\n케이크……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50038-4","talkText":"짜잔~! 자!\n특제 케이크야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50038-5","talkText":"괴, 굉장해…… 아,\n설마 이 지팡이는……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50038-6","talkText":"NFO에서 이 지팡이를\n쓰고 있는 거지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet50038-7","talkText":"네, 네……\n퀄리티가 대단해요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[23],"voiceId":"TalkSet50038-8","talkText":"저기 린코!\n그 지팡이 뽑아 봐!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[25],"voiceId":"TalkSet50038-9","talkText":"네, 네……!\n에잇……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50038-10","talkText":"와아~! 린린!\n엄청 멋지다~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}