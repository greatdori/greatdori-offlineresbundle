{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50037","backstageTalkSetId":50037,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet50037-1","talkText":"내일은 린코의 생일이네.\n아코, 여러가지로 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50037-2","talkText":"에헤헤, 린린을\n기쁘게 해주고 싶었어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50037-3","talkText":"후후, 역시 아코한테\n부탁한 게 정답이었어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50037-4","talkText":"네, 내일 시로카네 씨의\n반응이 기대되네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}