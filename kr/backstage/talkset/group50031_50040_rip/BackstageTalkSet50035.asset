{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50035","backstageTalkSetId":50035,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet50035-1","talkText":"내일은 미사키 짱\n생일이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50035-2","talkText":"실컷\n즐겁게 만들어주자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet50035-3","talkText":"아아, 미사키의 덧없는 웃는 얼굴이\n눈에 선하구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50035-4","talkText":"함께 멋진\n생일을 만들자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}