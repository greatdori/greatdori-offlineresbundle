{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50039","backstageTalkSetId":50039,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet50039-1","talkText":"히마리한테 딱 맞는 걸\n찾아서 다행이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet50039-2","talkText":"생각보다 종류가 다양했지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet50039-3","talkText":"그걸로 멋진 추억을\n함께 남기고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet50039-4","talkText":"히~짱, 내일도\n분명 울겠네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}