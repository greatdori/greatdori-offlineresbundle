{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet389","backstageTalkSetId":389,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet389-1","talkText":"팝핀파도\n여름 페스티벌에 나가고 싶다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet389-2","talkText":"페스티벌이라니\n우리한테는 너무 이르잖냐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet389-3","talkText":"잔뜩 연습하면\n분명 괜찮아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet389-4","talkText":"후~…… 카스미는\n여전하구만.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}