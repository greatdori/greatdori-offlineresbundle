{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet387","backstageTalkSetId":387,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet387-1","talkText":"여름은 말이야, 큰일이지~\n특히 지갑 사정이……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet387-2","talkText":"여름 한정 상품 같은 게\n잔뜩 나오니까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet387-3","talkText":"난 근무시간 늘렸어\n신작 빵을 위해서~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet387-4","talkText":"모카는 변하질 않네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}