{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet388","backstageTalkSetId":388,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet388-1","talkText":"시로카네 씨, 별로\n안색이 좋지 않네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet388-2","talkText":"더위를 먹은 걸지도\n모르겠어요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet388-3","talkText":"건강에 신경 쓰도록 해.\n무리하면 안 돼요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet388-4","talkText":"네,\n감사합니다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}