{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet693","backstageTalkSetId":693,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet693-1","talkText":"하네오카는…… 뷔페가\n있죠……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet693-2","talkText":"그래 맞아!\n하나여고도 하자구!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet693-3","talkText":"우선 수북하게 쌓인 포테이토에\n양동이 푸딩이지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet693-4","talkText":"야, 양동이 푸딩……!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}