{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet698","backstageTalkSetId":698,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet698-1","talkText":"겨울의 동물이라 불리는\n장난감이 이번에 나오거든요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet698-2","talkText":"그게 뭐야~?\n어떤 동물이 나오는데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet698-3","talkText":"여우, 산너구리,\n아키타 견 같은 것도 있어요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet698-4","talkText":"언니가 좋아하겠다~!\n선물하고 싶어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet698-5","talkText":"저도 관심 있으니까\n같이 사러 가지 않으실래요~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}