{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet695","backstageTalkSetId":695,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet695-1","talkText":"스틱을 새로\n사려고 하는데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet695-2","talkText":"추천하는 게 있으면\n가르쳐 주실래요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet695-3","talkText":"물론입니다! 괜찮으시면\n다음에 보러 갑시다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}