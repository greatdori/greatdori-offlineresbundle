{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet697","backstageTalkSetId":697,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet697-1","talkText":"따뜻한 초코 소라 빵이\n먹고 싶어졌어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet697-2","talkText":"뭐야 그게!?\n하구미도 먹고 싶어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet697-3","talkText":"아, 튀기면 더~ 더욱\n맛있을지도 몰라!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet697-4","talkText":"갓 튀긴 초코 소라 빵……\n엄청 맛있겠다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet697-5","talkText":"리미링, 오늘 돌아가서\n튀겨 봐~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}