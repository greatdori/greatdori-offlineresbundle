{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2026","backstageTalkSetId":2026,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2026-1","talkText":"하아~\n배가 텅텅 비었어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2026-2","talkText":"연습 끝나면\n배고파지지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2026-3","talkText":"그러면 가면서\n패밀리 레스토랑에 들를래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2026-4","talkText":"갈래 갈래! 들렀다 가자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2026-5","talkText":"나나미 짱,\n금방 기운 차렸네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[28],"voiceId":"TalkSet2026-6","talkText":"이런 거\n하고 싶었거든~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2026-7","talkText":"연습 끝나고 패밀리 레스토랑 가는 건\n평범한 일 같은데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2026-8","talkText":"평범하니까\n좋은거야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}