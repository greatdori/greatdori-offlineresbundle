{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2022","backstageTalkSetId":2022,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2022-1","talkText":"…………하아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2022-2","talkText":"츠쿠시 짱 기운이 없네.\n무슨 일 있어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2022-3","talkText":"오늘은 머리카락이 잘\n안 묶여서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2022-4","talkText":"(평소랑 똑같아\n보이는데……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet2022-5","talkText":"(어디가 다른지\n전혀 모르겠어……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[29],"voiceId":"TalkSet2022-6","talkText":"하아……\n기운 빠지네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}