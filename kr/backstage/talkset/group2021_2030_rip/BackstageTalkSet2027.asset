{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2027","backstageTalkSetId":2027,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2027-1","talkText":"다음에 의상을 만들 때\n이런 디자인은 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2027-2","talkText":"이거 멋지다!\n루이 씨는 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2027-3","talkText":"그냥 입는 거라면\n뭐든 상관없어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2027-4","talkText":"또!\n루이는 항상 그렇다니까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[30],"voiceId":"TalkSet2027-5","talkText":"그래도…… 오른 소매 디자인은\n심플하게 해 줬으면 좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2027-6","talkText":"오, 웬일!\n물론 상관없는데 그건 왜?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[30],"voiceId":"TalkSet2027-7","talkText":"연주할 때 방해돼.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[29],"voiceId":"TalkSet2027-8","talkText":"그, 그것도\n중요한 점이지……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}