{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2024","backstageTalkSetId":2024,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2024-1","talkText":"…………","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2024-2","talkText":"왜 그래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2024-3","talkText":"역시 루이 씨는\n우유 좋아해?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2024-4","talkText":"좋지도 싫지도\n않은데, 왜?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2024-5","talkText":"아니야! 좋아할 것 같아서!\n아하하……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[29],"voiceId":"TalkSet2024-6","talkText":"우유 먹고 키가 컸다는\n소리는 아니네……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[26],"voiceId":"TalkSet2024-7","talkText":"(그 마음, 나도 이해해.\n츠쿠시 짱……!)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}