{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2023","backstageTalkSetId":2023,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2023-1","talkText":"와~ 맛있어 보이는\n쿠키네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2023-2","talkText":"하나 먹어도 돼?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2023-3","talkText":"아앗! 그건 안 돼!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2023-4","talkText":"이건 내가 만든\n액세서리야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet2023-5","talkText":"엥? 이거 가짜야!?\n진짜로!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet2023-6","talkText":"자세히 봐도\n진짜 쿠키 같아……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}