{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2030","backstageTalkSetId":2030,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2030-1","talkText":"에헤헤~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2030-2","talkText":"츠~짱 기분 좋아 보이네!\n루이루이, 무슨 일 있었어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2030-3","talkText":"여기 오다가 모르는\n사람이 길을 물어봤거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2030-4","talkText":"나한테 말이지! 믿음직하게\n보였다는 소리잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2030-5","talkText":"(혹시 루이루이가\n무서웠던 거 아닐까……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet2030-6","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2030-7","talkText":"흐흥~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2030-8","talkText":"(뭐, 모르는 게 약이라는\n말도 있지.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}