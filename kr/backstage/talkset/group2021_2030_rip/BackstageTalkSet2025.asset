{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2025","backstageTalkSetId":2025,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2025-1","talkText":"B곡조 부분이 더욱\n신났으면 좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2025-2","talkText":"아지타토에서\n리솔루토로 잇자는 거지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2025-3","talkText":"음~ 그거랑은 조금\n다른 것 같은데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2025-4","talkText":"시로 짱은 어떻게 생각해?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2025-5","talkText":"두, 둘이 뭐라고 하는지\n잘 모르겠어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}