{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet100","backstageTalkSetId":100,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet100-1","talkText":"학생회 회의가 너무 많아!\n좀 줄여도 되잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet100-2","talkText":"그러게요…… 우리 학교도\n많네요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet100-3","talkText":"음~ 정말 조금은\n줄일 수 없으려나~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet100-4","talkText":"결정! 아주 회의를\n전부~ 없애버리자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet100-5","talkText":"지, 직권남용이다……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}