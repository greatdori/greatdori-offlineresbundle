{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet94","backstageTalkSetId":94,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet94-1","talkText":"곡을 만들 때는 어떤 걸\n신경 쓰시나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet94-2","talkText":"코코로가 갑자기 노래하는 걸\n안 놓치고 듣는 거죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet94-3","talkText":"그렇구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet94-4","talkText":"여러 가지 의미로\n힘들겠어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}