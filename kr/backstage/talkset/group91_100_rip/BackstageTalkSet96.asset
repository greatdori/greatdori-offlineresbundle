{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet96","backstageTalkSetId":96,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet96-1","talkText":"언니!\n리사 언니, 하구미~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet96-2","talkText":"앗! 댄스부\n집합이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet96-3","talkText":"아하하, 그러게~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet96-4","talkText":"합동으로 댄스 이벤트라도\n해보고 싶은걸~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}