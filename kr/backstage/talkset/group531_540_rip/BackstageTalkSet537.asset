{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet537","backstageTalkSetId":537,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet537-1","talkText":"타에 씨, 생일\n축하드려요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet537-2","talkText":"선물은 토끼\n슬리퍼로 해봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet537-3","talkText":"귀엽다! 이 색\n옷짱이랑 똑같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet537-4","talkText":"두 사람 모두 고마워.\n소중히 신을게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}