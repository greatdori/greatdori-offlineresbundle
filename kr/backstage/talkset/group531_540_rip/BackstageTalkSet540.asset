{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet540","backstageTalkSetId":540,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet540-1","talkText":"축하해, 아야 짱.\n이거 선물이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet540-2","talkText":"헤어끈이네~!\n반짝거려!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet540-3","talkText":"에헤헤, 아야 선배하고\n닮은 거 같아서!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet540-4","talkText":"귀엽고\n반짝거리니까♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet540-5","talkText":"에헤헤, 부끄러워~\n두 사람 다 고마워!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}