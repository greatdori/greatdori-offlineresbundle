{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet533","backstageTalkSetId":533,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet533-1","talkText":"모두 선물 교환\n준비됐어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet533-2","talkText":"네, 주옥같은 일품을\n준비했어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet533-3","talkText":"나도 룽♪ 한\n느낌이 오는 걸 갖고 왔어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet533-4","talkText":"선물이 이런 거로 괜찮을지\n불안하지 말입니다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet533-5","talkText":"이런 건 마음이\n중요하니까 걱정하지 마.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet533-6","talkText":"그러면 시작하자…… 어,\n내 선물 어디갔지!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}