{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet534","backstageTalkSetId":534,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet534-1","talkText":"코코롱, 산타 할아버지한테\n편지 보냈어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet534-2","talkText":"응, 헬로해피의 동료가\n되어줘! 라고 적었어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet534-3","talkText":"산타 할아버지는 모두를\n웃는 얼굴로 만드는 동지니까 말이지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet534-4","talkText":"저기 카논 씨. 코코로의\n부탁이라는 게……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet534-5","talkText":"후훗, 왠지\n실현될 것 같은걸.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}