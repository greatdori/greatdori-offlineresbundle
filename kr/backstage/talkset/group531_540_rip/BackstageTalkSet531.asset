{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet531","backstageTalkSetId":531,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet531-1","talkText":"좋아~ 올해 크리스마스에\n각자 할 담당을 정해보자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet531-2","talkText":"네~ 모카 짱은\n먹는 담당이 좋습니다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet531-3","talkText":"기각. 내가 모카랑 같이\n쇼핑하러 갈게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet531-4","talkText":"그럼 나는 트리랑 이것저것\n꾸밀게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet531-5","talkText":"그러면 나랑 히마리 짱이\n요리 담당이네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet531-6","talkText":"올해도 즐겁게 보내자~!\n에이, 에이, 오~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}