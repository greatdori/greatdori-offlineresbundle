{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet538","backstageTalkSetId":538,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet538-1","talkText":"내일은 아야 씨의\n생일이네요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet538-2","talkText":"아야 씨가\n기뻐해 주시겠지 말입니다?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet538-3","talkText":"어쩌면 감동해서 울어\n버릴지도 모르겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet538-4","talkText":"후훗, 역시\n아야 짱은 재밌다니까~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}