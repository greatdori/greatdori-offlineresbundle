{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet535","backstageTalkSetId":535,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet535-1","talkText":"내일은 드디어\n오타에의 생일이네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet535-2","talkText":"선물이랑 파티\n준비도 완벽해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet535-3","talkText":"오타에가 기뻐하는 얼굴이\n눈에 선한걸.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet535-4","talkText":"그치. 빨리\n내일이 왔으면 좋겠어♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}