{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet231","backstageTalkSetId":231,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet231-1","talkText":"오늘 상점가는\n북적거리네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet231-2","talkText":"난 사람이 많으면\n거기 있는 거 자체가 피곤해서.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet231-3","talkText":"아아, 그 마음은\n엄청 공감돼.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}