{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet236","backstageTalkSetId":236,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet236-1","talkText":"앗, 오늘 돌아갈 때\n사아야 짱네 갈게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet236-2","talkText":"후후, 그럼 아버지께\n초코 소라빵 부탁해 놓을게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}