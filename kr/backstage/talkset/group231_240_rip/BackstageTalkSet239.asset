{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet239","backstageTalkSetId":239,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet239-1","talkText":"오늘은 오타에가 좋아할 만한\n헤어 액세서리를 봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet239-2","talkText":"……!! 알겠다.\n토끼 모양이었구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet239-3","talkText":"미, 미안……\n기타 모양이었어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}