{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet361","backstageTalkSetId":361,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet361-1","talkText":"사~야네 가게 빵은\n맛있지~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet361-2","talkText":"초코 소라빵이\n엄청 맛있어~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet361-3","talkText":"야마부키 베이커리의\n팬이 많구만.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet361-4","talkText":"응. 햄버그도\n있으면 좋은데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet361-5","talkText":"우리 집은 빵집이니까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}