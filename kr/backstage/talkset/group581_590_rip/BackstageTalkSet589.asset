{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet589","backstageTalkSetId":589,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet589-1","talkText":"가게에서 딸기 디저트를\n팔기 시작했어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet589-2","talkText":"와아, 맛있겠다~\n봄에 어울리는 메뉴야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet589-3","talkText":"나중에 치사토 씨와 함께\n드시러 오세요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}