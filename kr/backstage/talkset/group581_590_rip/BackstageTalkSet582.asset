{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet582","backstageTalkSetId":582,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet582-1","talkText":"선크림을 바르는걸\n깜빡했어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet582-2","talkText":"아직 봄이니까 괜찮을 겁니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet582-3","talkText":"그게 봄에도 의외로\n살이 탈 수 있거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet582-4","talkText":"그렇습니까!? 저는\n완전히 방심하고 있었습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}