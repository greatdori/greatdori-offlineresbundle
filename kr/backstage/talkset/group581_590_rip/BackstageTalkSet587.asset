{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet587","backstageTalkSetId":587,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet587-1","talkText":"내일은\n꽃놀이 할 거야! ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet587-2","talkText":"그래그래. 그래서 이번엔\n어디 갈 건데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet587-3","talkText":"미국이야. 미국 전역의 벚꽃축제를\n보러 갈 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet587-4","talkText":"잠깐잠깐잠깐 미국 전역이라니……\n근처도 괜찮잖아……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}