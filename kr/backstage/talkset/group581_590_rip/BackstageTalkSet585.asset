{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet585","backstageTalkSetId":585,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet585-1","talkText":"후아~암.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet585-2","talkText":"꽤 졸린 거 같네.\n날이 좋아서 늦잠을 잔 잔 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet585-3","talkText":"사실 온라인 게임 하다가\n밤을 새버렸거든요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet585-4","talkText":"……그냥\n수면 부족이었구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}