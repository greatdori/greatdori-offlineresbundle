{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet588","backstageTalkSetId":588,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet588-1","talkText":"하구미, 머리카락에 벚꽃\n꽃잎이 붙었단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet588-2","talkText":"앗? 정말?\n떼어 줘 떼어 줘~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet588-3","talkText":"아니, 그대로가 좋겠군.\n마치 벚꽃 정령 같구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet588-4","talkText":"훗…… 실로 덧없구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}