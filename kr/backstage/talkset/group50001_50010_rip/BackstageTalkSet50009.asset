{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50009","backstageTalkSetId":50009,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50009-1","talkText":"내일은 란 생일인데\n모두 준비는 다 됐지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet50009-2","talkText":"하나~둘! 하고 난 타이밍에\n하는거라구!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50009-3","talkText":"맡겨달라니까!\n여러 가지 준비해줘서 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50009-4","talkText":"선물도\n준비해줬잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50009-5","talkText":"히~짱의 센스를\n기대하고 있을게~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}