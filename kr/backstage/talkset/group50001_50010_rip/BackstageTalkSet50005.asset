{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50005","backstageTalkSetId":50005,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet50005-1","talkText":"오늘은 드디어\n리미링의 생일이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50005-2","talkText":"오타에, 선물\n조사 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50005-3","talkText":"아니야. 아리사가\n알아봐 줬거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50005-4","talkText":"가져오는 거 꽤나\n무섭긴 했어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[1],"voiceId":"TalkSet50005-5","talkText":"장소 준비도 다 됐으니\n내일이 기대돼!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}