{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50008","backstageTalkSetId":50008,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet50008-1","talkText":"치사토 씨! 생일\n축하드립니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50008-2","talkText":"굉장한 선물을\n준비했어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50008-3","talkText":"고마워.\n대체 어떤 걸까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50008-4","talkText":"아야 씨, 히나 씨!\n부탁드려요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50008-5","talkText":"알았어~!\n치사토 짱 축하해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet50008-6","talkText":"선물이……\n이 홍차 세트야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50008-7","talkText":"네! 치사토 씨한테\n딱이라고 생각했습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[20],"voiceId":"TalkSet50008-8","talkText":"오늘은 이걸로 한 잔\n대접해 드릴게요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[16],"voiceId":"TalkSet50008-9","talkText":"오늘을 위해서\n많이 연습했거든!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50008-10","talkText":"치사토 짱 잘 봐~!\n하나 둘, 영차~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[16],"voiceId":"TalkSet50008-11","talkText":"우와앗!\n에, 에잇~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50008-12","talkText":"후후, 엄청 놀랐어.\n모두 정말 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}