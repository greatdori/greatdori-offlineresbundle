{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50004","backstageTalkSetId":50004,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet50004-1","talkText":"히나 짱,\n생일 축하해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50004-2","talkText":"여기 선물입니다!\n열어봐 주시지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50004-3","talkText":"와아~! 고마워~!\n잔뜩 있네~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50004-4","talkText":"아야 씨가 제안한\n변장 코디에요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet50004-5","talkText":"우선, 모자는\n이브 씨가 고르셨습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet50004-6","talkText":"옷은 치사토 씨랑\n마야 씨가 고르셨어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[16],"voiceId":"TalkSet50004-7","talkText":"선글래스는\n나랑 똑같은 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet50004-8","talkText":"우리도 유명해 졌으니까\n조금 변장하는 게 좋아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet50004-9","talkText":"그냥 들켜도\n괜찮은데 말이야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50004-10","talkText":"그래도 재밌어 보이니까\n빨리 입어볼게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[17],"voiceId":"TalkSet50004-11","talkText":"짠~!\n봐, 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet50004-12","talkText":"와~! 엄청\n잘 어울려!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}