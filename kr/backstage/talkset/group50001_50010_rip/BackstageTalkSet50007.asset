{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50007","backstageTalkSetId":50007,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet50007-1","talkText":"내일은 치사토 씨\n생일이네요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50007-2","talkText":"히나 씨의 아이디어가\n잘 됐으면 좋겠습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet50007-3","talkText":"우우, 벌써\n두근거리는걸……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet50007-4","talkText":"많이 연습했으니까\n괜찮아 괜찮~아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50007-5","talkText":"만약 실패하더라도 그것도\n아야 짱 답잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}