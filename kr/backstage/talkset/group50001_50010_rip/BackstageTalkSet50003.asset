{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50003","backstageTalkSetId":50003,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet50003-1","talkText":"히나 씨한테 줄 선물은\n이거면 확실하지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet50003-2","talkText":"응응! 그걸로 하는 게\n정답이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50003-3","talkText":"이걸 계기로 조심 좀\n해 줬으면 좋겠는데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50003-4","talkText":"히나 씨가 좋아해\n주실까요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}