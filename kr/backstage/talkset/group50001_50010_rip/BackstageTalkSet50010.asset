{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50010","backstageTalkSetId":50010,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50010-1","talkText":"어라, 어둡네……\n아직 아무도 안 왔나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7,8,9,10],"voiceId":"TalkSet50010-2","talkText":"란!\n해피 버스데이!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50010-3","talkText":"자 여기! 애정을 듬뿍 담은\n히마리 특제 인형이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet50010-4","talkText":"고, 고마워 히마리……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet50010-5","talkText":"올해는 히마리가\n엄청 열심히 했다니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50010-6","talkText":"폭죽 같은 것도\n준비해 왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50010-7","talkText":"히~짱의 뜨거운 마음을\n받아줘~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50010-8","talkText":"으, 응. 모두,\n그러니까…… 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50010-9","talkText":"란, 귀여운 인형 받아서\n좋겠네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50010-10","talkText":"앗! 귀여워!?\n다행이야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[8],"voiceId":"TalkSet50010-11","talkText":"사실 너희 것도\n만들어 왔어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[8],"voiceId":"TalkSet50010-12","talkText":"이것도 부적이랑 같이\n우리끼리 달고 다니자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}