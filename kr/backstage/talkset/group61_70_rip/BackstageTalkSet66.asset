{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet66","backstageTalkSetId":66,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet66-1","talkText":"아리사, 공부 가르쳐 줘~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet66-2","talkText":"뭐~?\n저번에도 가르쳐 줬잖냐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet66-3","talkText":"으으~\n부탁해, 아리사~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet66-4","talkText":"아리사, 도와줘.\n쪽지 시험, 장난 아닌가 봐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}