{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet65","backstageTalkSetId":65,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet65-1","talkText":"미사키!\n이야기할 게 있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet65-2","talkText":"……어라? 미사키가 여기에\n들어오는 걸 봤는데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet65-3","talkText":"기, 기분 탓이 아닐까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet65-4","talkText":"위험했다, 위험했어……\n안 늦었다~","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}