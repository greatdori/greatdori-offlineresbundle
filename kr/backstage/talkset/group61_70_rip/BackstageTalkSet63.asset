{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet63","backstageTalkSetId":63,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet63-1","talkText":"……아!\n지금 신곡을 떠올렸어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet63-2","talkText":"어, 지, 지금!?\n잠깐 기다려 코코로!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet63-3","talkText":"카논 씨, 펜이랑 종이!\n펜이랑 종이!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet63-4","talkText":"지, 지금 가지러 갈게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet63-5","talkText":"라~ 라~♪\n라라라라~~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}