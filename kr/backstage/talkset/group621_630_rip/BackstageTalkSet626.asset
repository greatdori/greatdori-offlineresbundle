{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet626","backstageTalkSetId":626,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet626-1","talkText":"이 티셔츠 좀 괜찮아 보이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet626-2","talkText":"오오~\n란한테 어울리겠어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet626-3","talkText":"모카 짱은 여기 있는\n색만 다른 거로 할까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet626-4","talkText":"……뭐, 괜찮네.\n돌아갈 때 보러 가자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}