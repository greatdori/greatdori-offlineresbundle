{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet519","backstageTalkSetId":519,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet519-1","talkText":"겨울 테니스복은\n귀엽다니까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet519-2","talkText":"새 거 사고 싶긴 하지만\n그래도 이번 달은 위기고……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet519-3","talkText":"세일 할 때까지\n기다릴 수 밖에 없겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet519-4","talkText":"그럴 수 밖에 없겠어~\n좋아~ 아르바이트 열심히 해야지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}