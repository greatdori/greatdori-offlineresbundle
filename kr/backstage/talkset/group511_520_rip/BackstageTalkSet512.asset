{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet512","backstageTalkSetId":512,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet512-1","talkText":"오늘도 춥네. 레온\n산책시키려면 힘들겠는걸.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet512-2","talkText":"그럴 때는 옷짱을\n안고 있으면 돼요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet512-3","talkText":"폭신거리고 따뜻해요.\n다음에 같이 산책하러 가요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet512-4","talkText":"그래…… 생각해 볼게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}