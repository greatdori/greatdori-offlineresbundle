{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet515","backstageTalkSetId":515,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet515-1","talkText":"어디 웃는 얼굴이 될 만한 게\n없을까!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet515-2","talkText":"그, 그러면……\n핫 밀크를 마시면……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet515-3","talkText":"몸이 따뜻해져서……\n핫해져요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet515-4","talkText":"멋진걸! 모두한테\n가르쳐 주자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}