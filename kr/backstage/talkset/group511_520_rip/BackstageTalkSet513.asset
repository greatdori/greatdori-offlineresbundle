{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet513","backstageTalkSetId":513,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet513-1","talkText":"피자 빵, 카레 빵,\n그라탕 빵~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet513-2","talkText":"겨울엔 맛있는 빵이\n가득하네요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet513-3","talkText":"아하하, 겨울 아니더라도\n언제나 맛있다니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet513-4","talkText":"그렇네요~ 역시\n빵은 굉장해~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}