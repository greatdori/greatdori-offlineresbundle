{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet460","backstageTalkSetId":460,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet460-1","talkText":"토야마 씨, 대체 무슨\n고민을 하는 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet460-2","talkText":"독서의 가을이라는 건 만화라도\n괜찮다고 생각하시나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet460-3","talkText":"그건…… 잘 모르겠어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}