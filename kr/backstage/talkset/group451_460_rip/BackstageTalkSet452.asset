{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet452","backstageTalkSetId":452,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet452-1","talkText":"이 책 엄청\n재미있었어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet452-2","talkText":"그래서 음…… 여기요.\n보답이라고 할까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet452-3","talkText":"이건…… 책갈피……?\n단풍이 무척, 예뻐요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet452-4","talkText":"고마워요……\n소중히, 간직할게요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}