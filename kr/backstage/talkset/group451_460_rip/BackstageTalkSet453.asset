{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet453","backstageTalkSetId":453,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet453-1","talkText":"카논 씨의 가을은\n어떤 가을인가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet453-2","talkText":"최근에 책을 자주 읽으니까\n독서의 가을 아닐까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet453-3","talkText":"이브 짱은?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet453-4","talkText":"저는 물론\n무사도의 가을이에요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}