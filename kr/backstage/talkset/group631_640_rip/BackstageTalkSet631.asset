{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet631","backstageTalkSetId":631,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet631-1","talkText":"어라, 그 팔 부분은\n햇볕에 탄 겁니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet631-2","talkText":"란 짱네랑 바다에 갔더니\n나도 모르게……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet631-3","talkText":"괜찮다면 케어 용\n크림을 빌려드리겠습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet631-4","talkText":"효과 좋은 것을 치사토 씨가\n가르쳐 주셨지 말입니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}