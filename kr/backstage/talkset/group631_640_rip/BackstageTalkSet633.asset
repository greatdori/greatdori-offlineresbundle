{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet633","backstageTalkSetId":633,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet633-1","talkText":"오늘은 거대한 불꽃놀이를\n만들어보려고 해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet633-2","talkText":"어, 엄청 굉장해……\n어떤 걸 만들 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet633-3","talkText":"미셸\n얼굴 불꽃이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet633-4","talkText":"그렇지! 사아야를 위해서\n빵 불꽃도 만들게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet633-5","talkText":"아하하, 그건\n모카도 기뻐하겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}