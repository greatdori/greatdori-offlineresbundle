{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet171","backstageTalkSetId":171,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet171-1","talkText":"나 말고는 전부\n키보드 담당이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet171-2","talkText":"그러고 보니 그렇구만.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet171-3","talkText":"정말이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet171-4","talkText":"그러고 보니…… 그렇네요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet171-5","talkText":"귀중한 시간이네요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet171-6","talkText":"……공감되는 이야기 같은 거\n듣고 싶을지도 모르겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}