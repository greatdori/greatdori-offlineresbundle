{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet176","backstageTalkSetId":176,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet176-1","talkText":"지금부터 어둠의 드러머\n회의를 시작한다……!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet176-2","talkText":"어, 어둠의 드러머……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet176-3","talkText":"암흑 속에서 드럼은\n칠 수 있을 것 같나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet176-4","talkText":"제 생각에는……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet176-5","talkText":"어둠이라는 게 그런\n의미인 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}