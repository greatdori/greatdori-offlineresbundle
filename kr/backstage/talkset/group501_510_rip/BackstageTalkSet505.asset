{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet505","backstageTalkSetId":505,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet505-1","talkText":"아리사~!\n생일 축하해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet505-2","talkText":"우왁!\n깜짝이야……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet505-3","talkText":"서프라이즈 성공이네.\n아리사, 좋은 표정이었어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet505-4","talkText":"아리사 짱, 여기.\n생일 선물!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet505-5","talkText":"미니 분재잖아!\n어, 정말로 기뻐……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet505-6","talkText":"선물 서프라이즈도\n잘 된 것 같네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}