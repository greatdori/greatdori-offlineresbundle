{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet509","backstageTalkSetId":509,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet509-1","talkText":"야마토 씨,\n생일 축하해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet509-2","talkText":"이건, 선물이에요……\n괜찮다면 받아주세요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet509-3","talkText":"미나토 씨, 그리고 시로카네 씨!\n고맙습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet509-4","talkText":"드럼 매트와 천이\n들어있어요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[21],"voiceId":"TalkSet509-5","talkText":"야마토 씨한테는 실용적인\n물건으로 하는 게 좋을 거 같았어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet509-6","talkText":"감사히 쓰도록\n하겠습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}