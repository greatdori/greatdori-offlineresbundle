{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet507","backstageTalkSetId":507,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet507-1","talkText":"좋아~ 이걸로\n모두 모였네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet507-2","talkText":"마야 짱한테 줄 선물\n사러 가는 거지~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet507-3","talkText":"뭘 살지 망설이고 있었는데\n같이 가게 돼서 든든해요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet507-4","talkText":"그럼 분명 아야 짱한테\n생각이 있는 거겠지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet507-5","talkText":"응! 그러면 다 같이\n사러 가자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}