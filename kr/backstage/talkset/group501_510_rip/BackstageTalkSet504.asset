{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet504","backstageTalkSetId":504,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet504-1","talkText":"어땠어?\n내 생일 선물.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet504-2","talkText":"조금 놀라긴 했지만\n아리사라면 기뻐할 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet504-3","talkText":"응. 엄청 귀여운 걸\n찾을 수 있었으니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet504-4","talkText":"내일 아리사의 반응이\n기대된다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}