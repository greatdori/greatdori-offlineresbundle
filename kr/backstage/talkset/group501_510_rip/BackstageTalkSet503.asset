{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet503","backstageTalkSetId":503,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet503-1","talkText":"유키나 선배 생일\n축하드려요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet503-2","talkText":"생일 선물을\n준비했습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet503-3","talkText":"고마워.\n이건……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet503-4","talkText":"꿀입니다! 홍차에\n넣는 용도라고 했습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[21],"voiceId":"TalkSet503-5","talkText":"둘 다 고마워.\n기뻐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}