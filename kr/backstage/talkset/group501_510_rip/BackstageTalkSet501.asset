{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet501","backstageTalkSetId":501,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet501-1","talkText":"내일은 미나토 씨의 생일이네요.\n우다가와 씨, 왜 그러시죠?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet501-2","talkText":"우우…… 선물\n기뻐해 주실까 걱정이 돼서~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet501-3","talkText":"아, 아코 짱……\n침착하게……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet501-4","talkText":"그렇게 걱정하지 않아도\n분명 기뻐할 거라니까☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet501-5","talkText":"아코는 내일까지\n계속 긴장할 것 같아……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}