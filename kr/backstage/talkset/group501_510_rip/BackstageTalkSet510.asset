{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet510","backstageTalkSetId":510,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet510-1","talkText":"얼마 전에 일루미네이션\n보러 갔어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet510-2","talkText":"와아~ 예쁘다!\nSNS에 올리기 좋겠어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet510-3","talkText":"다음 쉬는 날에\n나도 보러 가 볼까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet510-4","talkText":"아 그럼 저도! 여기 말고도 \n좋은 장소가 있거든요~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}