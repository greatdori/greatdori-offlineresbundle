{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet502","backstageTalkSetId":502,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet502-1","talkText":"유키나 씨~! 생일\n축하드려요~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet502-2","talkText":"이건 다 같이 고른……\n선물이에요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet502-3","talkText":"고마워. 과연,\n여러 가지 들어있구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet502-4","talkText":"아코가 고른 엄청 멋진\n반지 어때요!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet502-5","talkText":"나는 헤어 액세서리 샀어.\n써줬으면 좋겠어☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet502-6","talkText":"저는 머플러를.\n추워졌으니 필요할 것 같았죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet502-7","talkText":"고마워 전부 소중히\n쓰도록 할게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}