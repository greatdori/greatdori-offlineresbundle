{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet374","backstageTalkSetId":374,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet374-1","talkText":"란의 생일, 내일인가~\n살짝 긴장됐어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet374-2","talkText":"히~짱은 걱정이 많구려~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet374-3","talkText":"괜찮아.\n분명 기뻐할 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet374-4","talkText":"아하하!\n란이 기뻐하는 얼굴이 기대되는걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}