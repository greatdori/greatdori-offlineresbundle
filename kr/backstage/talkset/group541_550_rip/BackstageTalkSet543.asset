{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet543","backstageTalkSetId":543,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet543-1","talkText":"올해도 순식간에\n지나갔지 말입니다~ 후헤헤.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet543-2","talkText":"있지~ 있지~\n내년에는 뭐 하고 싶어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet543-3","talkText":"저는 좀 더 전통 문화를\n배우고 싶어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet543-4","talkText":"내년 이야기를 하기 전에 올해의\n매듭도 잘 지어야겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet543-5","talkText":"응! 팬을 위해서\n감사 영상도 찍자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet543-6","talkText":"팬 여러분, 좋은\n연말 보내고 계신가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet543-7","talkText":"올해도 대단히\n많은 신세를 졌습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet543-8","talkText":"덕분에 엄청 룽♪\n한 1년이 됐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[18],"voiceId":"TalkSet543-9","talkText":"내년은 올해 이상의\n저희를 보여드릴게요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet543-10","talkText":"내년에도 파스파레를\n잘 부탁드립니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}