{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet541","backstageTalkSetId":541,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet541-1","talkText":"벌써 연말이네.\n올해도 많은 일이 있었지~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet541-2","talkText":"그러게요~ 연말 정도는\n느긋하게 보내고는 싶지만……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet541-3","talkText":"모처럼 다 같이 모였으니까\n뭔가 재밌는 게 하고 싶은걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet541-4","talkText":"그거야, 하구미!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet541-5","talkText":"나는 시 낭독회를\n추천한단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet541-6","talkText":"나의 덧없는 시로\n모두의 마음을 떨리게 하고 싶구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet541-7","talkText":"나는 눈싸움 하고싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[13],"voiceId":"TalkSet541-8","talkText":"하구미는\n소프트볼 하고 싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[14],"voiceId":"TalkSet541-9","talkText":"후후…… 느긋한 건\n힘들 거 같네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet541-10","talkText":"뭐~ 라스트스퍼트죠.\n열심히 하자고요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}