{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet545","backstageTalkSetId":545,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet545-1","talkText":"올해도 벌써 끝이구나.\n순식간에 지나갔지~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet545-2","talkText":"응응! 여러 가지\n기념일이 생겼어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet545-3","talkText":"내년도 올해만큼\n즐거운 한 해가 됐으면 좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet545-4","talkText":"그러면 지금부터 다 같이\n뭘 할지 생각해보자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet545-5","talkText":"내년 일정을 미리 짠다는\n거구만. 괜찮은데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet545-6","talkText":"우와~ 하고 싶은 게\n너무 많아서 고민돼~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[4],"voiceId":"TalkSet545-7","talkText":"맞아~ 점점\n많이 떠올라.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[2],"voiceId":"TalkSet545-8","talkText":"나는\n100개 정도 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet545-9","talkText":"나도 그 정도 있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet545-10","talkText":"아무리 그래도\n그건 너무 많잖아!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}