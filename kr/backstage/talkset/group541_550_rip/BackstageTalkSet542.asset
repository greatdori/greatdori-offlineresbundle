{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet542","backstageTalkSetId":542,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet542-1","talkText":"올해도 곧 조금 있으면\n끝나는군요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet542-2","talkText":"그렇지! 있지, 같이\n송년회 하자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet542-3","talkText":"찬성~! 아코는\n어둠의 전골을 하고 싶어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet542-4","talkText":"어둠의 전골……? 적어도 먹을 수\n있는 걸로 해주면 좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet542-5","talkText":"전골 재료를 제한하면\n괜찮을 거 같아요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet542-6","talkText":"그러면 다 같이 전골 재료를\n가지고 오는 건 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet542-7","talkText":"와아, 그거 엄청\n재밌겠다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[22],"voiceId":"TalkSet542-8","talkText":"고기랑 채소를 준비해두면\n이상한 전골은 안 되겠죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[21],"voiceId":"TalkSet542-9","talkText":"그래.\n그거라면 안심이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[25],"voiceId":"TalkSet542-10","talkText":"(함께 먹는 전골……\n기대, 된다……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}