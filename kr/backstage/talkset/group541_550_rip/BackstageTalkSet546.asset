{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet546","backstageTalkSetId":546,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet546-1","talkText":"이거 봐봐! 이 사진 속\n아코 멋지지 않아!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet546-2","talkText":"명계의 번견, 케르베로스를\n거느리고 있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet546-3","talkText":"엄청 큰 개다! 옆에 있는\n아코 짱도 귀여워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet546-4","talkText":"귀, 귀여운 게 아니라\n멋지다고 해 줘~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}