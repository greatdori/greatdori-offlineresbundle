{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet673","backstageTalkSetId":673,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet673-1","talkText":"이번에 우리 학교에서\n군고구마 대회를 열어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet673-2","talkText":"응? 학교에서?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet673-3","talkText":"그래! 츠구 짱한테\n부탁해 뒀어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet673-4","talkText":"츠구미 짱이 고생이네……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}