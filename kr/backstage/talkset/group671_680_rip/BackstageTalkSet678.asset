{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet678","backstageTalkSetId":678,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet678-1","talkText":"이번에 역 앞에 노래방이\n생기는 것 같아요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet678-2","talkText":"좋은데! 오픈하면\n다 같이 놀러 가자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet678-3","talkText":"찬성이에요~!\n와아~ 진짜 기대된다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}