{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet219","backstageTalkSetId":219,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet219-1","talkText":"리사 씨는 믿음직스러운\n언니 같은 느낌이에요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet219-2","talkText":"아하하, 고마워!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet219-3","talkText":"하지만 분명 카스미 동생도\n카스미를 그렇게 생각할 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}