{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet211","backstageTalkSetId":211,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet211-1","talkText":"카스미 짱, 공부 중?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet211-2","talkText":"우우, 맞아요……\n이번에 보충수업이 있어서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet211-3","talkText":"힘이 돼주고 싶지만\n나도 공부는 좀……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}