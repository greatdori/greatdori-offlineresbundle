{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet212","backstageTalkSetId":212,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet212-1","talkText":"핀란드는\n별이 잘 보인다고 했지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet212-2","talkText":"무척 예뻐요!\n오로라도 볼 수 있어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet212-3","talkText":"오로라!? 좋겠다~\n나도 보고 싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}