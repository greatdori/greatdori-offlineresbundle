{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet216","backstageTalkSetId":216,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet216-1","talkText":"유키나 선배! 어떡하면\n노래를 잘 할 수 있나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet216-2","talkText":"노력하는 수밖에 없어.\n음악에 지름길은 없어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}