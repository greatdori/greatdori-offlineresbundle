{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet218","backstageTalkSetId":218,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet218-1","talkText":"리사 씨! 네일아트 좀\n가르쳐 주세요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet218-2","talkText":"오케이~!\n어떤 네일아트가 하고 싶어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet218-3","talkText":"별을 이미지 해서\n반짝거리게 하고 싶어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}