{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet184","backstageTalkSetId":184,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet184-1","talkText":"미셸,\n여기 있었구나!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet184-2","talkText":"찾고 있었단다, 아기 고양이.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet184-3","talkText":"그런데 이번은 미~군이\n없는데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet184-4","talkText":"미사키 짱은\n급한 일이 있어서 돌아갔어~","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet184-5","talkText":"아! 하구미, 미~군한테\n볼일이 있었어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet184-6","talkText":"!?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet184-7","talkText":"(힘들겠네, 미사키 짱.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}