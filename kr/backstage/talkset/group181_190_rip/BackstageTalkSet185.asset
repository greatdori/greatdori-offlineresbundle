{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet185","backstageTalkSetId":185,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet185-1","talkText":"미나토 씨,\n뭐하고 계신가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet185-2","talkText":"알림 하나가 안 사라지고 있어.\n뭘까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet185-3","talkText":"원인이 뭘까요?\n알아보도록 하죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet185-4","talkText":"아코도 알아볼게요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet185-5","talkText":"그럼, 저도……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21,22,24,25],"voiceId":"TalkSet185-6","talkText":"……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet185-7","talkText":"(다들 스마트폰을 보고 있는데\n……무슨 일?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}