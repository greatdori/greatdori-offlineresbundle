{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet773","backstageTalkSetId":773,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet773-1","talkText":"드디어 분재가 여름 더위에\n회복되기 시작했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet773-2","talkText":"기운을 차려서 다행이야.\n그러면 당분간은 안심이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet773-3","talkText":"아니, 이제부터 분재의\n월동 준비지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet773-4","talkText":"바쁘겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}