{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet774","backstageTalkSetId":774,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet774-1","talkText":"이거 봐! 이 카페\n가을 메뉴 시작했대!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet774-2","talkText":"어머, 맛있겠네.\n역 근처에 있었나?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet774-3","talkText":"응! 아, 테라스석도\n단풍이 절정이래!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet774-4","talkText":"후후, 그러면 다음에\n같이 가 볼까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet774-5","talkText":"야호~!\n다음 주 연습 전에는 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}