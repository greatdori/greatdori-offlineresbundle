{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet776","backstageTalkSetId":776,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet776-1","talkText":"짜잔~!\n도토리 주웠어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet776-2","talkText":"정말 멋지다!\n봉투에서 넘칠 것 같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet776-3","talkText":"아! 그렇지! 이것에\n얼굴 그려보자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet776-4","talkText":"좋아! 우선\n펼쳐놓아 보자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}