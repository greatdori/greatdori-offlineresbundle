{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet780","backstageTalkSetId":780,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet780-1","talkText":"츠쿠시 짱, 이날\n근무 일정 말인데…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet780-2","talkText":"혹시\n사람이 부족한가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet780-3","talkText":"응… 부탁할 수 있는 사람이\n츠쿠시 짱 밖에 없거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet780-4","talkText":"저, 저 밖에…!\n괜찮아요, 할게요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}