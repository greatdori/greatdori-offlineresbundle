{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet779","backstageTalkSetId":779,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet779-1","talkText":"있잖아 록,\n내 말 좀 들어봐~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet779-2","talkText":"규왕~! 하는 소리랑\n샤랑~…하는 소리.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet779-3","talkText":"어느 게 더 좋을까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[32],"voiceId":"TalkSet779-4","talkText":"네? 으음…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet779-5","talkText":"카스미 선배가 친다면\n둘 다 멋져요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet779-6","talkText":"에헤헷~ 둘 다구나~\n고마워 록~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}