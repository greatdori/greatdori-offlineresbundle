{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet51","backstageTalkSetId":51,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet51-1","talkText":"내일은 오랜만에\n하루 종일 레슨이네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet51-2","talkText":"꽤 하드한\n연습이 될 것 같지 말입니다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet51-3","talkText":"전반에는 개인 레슨이고\n후반은 합동 레슨이네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet51-4","talkText":"난 그사이에 별도\n스케줄도 있어서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet51-5","talkText":"오오, 아야 씨, 바쁘시지 말입니다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}