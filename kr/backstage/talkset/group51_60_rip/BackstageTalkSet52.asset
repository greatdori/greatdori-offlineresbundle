{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet52","backstageTalkSetId":52,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet52-1","talkText":"아야 씨, 뭘\n보고 계십니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet52-2","talkText":"지금은 모두의 SNS를\n보고 있어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet52-3","talkText":"아야 씨는 매일 제대로\n업로드하시지 말입니다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet52-4","talkText":"전 매일 좋아하는 무사의\n말을 쓰고 있어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}