{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet57","backstageTalkSetId":57,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet57-1","talkText":"카논이랑 미사키는\n어디에 간 걸까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet57-2","talkText":"혹시 우리 집에 크로켓을\n사러 간 게 아닐까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet57-3","talkText":"과연, 먼저 간 것인가……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet57-4","talkText":"우리도 빨리 하구미네\n가게에 가자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}