{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2007","backstageTalkSetId":2007,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2007-1","talkText":"시로 짱, 시로 짱.\n이거 줄게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2007-2","talkText":"와, 어쩌다 이렇게\n많이 가지고 있는 거야!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2007-3","talkText":"사은품이 갖고 싶어서\n상자로 샀거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2007-4","talkText":"다른 사람한테도\n나눠줘야지~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}