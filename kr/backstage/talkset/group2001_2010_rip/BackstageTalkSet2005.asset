{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2005","backstageTalkSetId":2005,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2005-1","talkText":"츠쿠시 짱,\n스마트폰으로 뭐 보고 있어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2005-2","talkText":"드럼 스틱을\n멋지게 돌리는 방법 강의!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2005-3","talkText":"마시로 짱도\n뭔가 해보지 않을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2005-4","talkText":"앗, 나, 나는 괜찮아……\n부끄러우니까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}