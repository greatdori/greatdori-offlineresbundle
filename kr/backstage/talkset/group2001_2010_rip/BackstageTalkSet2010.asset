{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2010","backstageTalkSetId":2010,"snippets":[{"talkId":1,"characterIds":[30],"voiceId":"TalkSet2010-1","talkText":"수학 쪽지 시험\n결과가 별로 안 좋았나 보네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2010-2","talkText":"공부 같은 건 미크론이야!\n어떻게든 되겠지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2010-3","talkText":"너 미크론이 무슨 뜻인지도\n모르잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2010-4","talkText":"미, 미크론은\n미크론이잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}