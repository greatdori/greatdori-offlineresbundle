{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2002","backstageTalkSetId":2002,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2002-1","talkText":"졸려 보이네, 토우코 짱.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2002-2","talkText":"완전 졸려. 우리 집은\n매일 아침 5시에 일어나거든~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2002-3","talkText":"5시!?\n뭐, 뭐 하려고……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2002-4","talkText":"……뭐 때문일까?\n생각해 본 적 없어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}