{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2001","backstageTalkSetId":2001,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2001-1","talkText":"옷 디자인은\n어떨 때 떠올라?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2001-2","talkText":"노래방 갈 때나\n스티커 사진 찍을 때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2001-3","talkText":"아, 그리고 친구들하고\n크레페 먹을 때도!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2001-4","talkText":"아, 놀 때만\n떠오르는구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}