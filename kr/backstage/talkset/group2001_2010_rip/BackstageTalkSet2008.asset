{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2008","backstageTalkSetId":2008,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2008-1","talkText":"무대에서 긴장하지 않는\n방법이 있을까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2008-2","talkText":"관객을 채소라고\n생각하면 된다고 하던데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2008-3","talkText":"과연……\n하지만 채소는 좀……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2008-4","talkText":"아, 그러고 보니\n채소 싫어했지……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}