{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50026","backstageTalkSetId":50026,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50026-1","talkText":"하구미, 생일 축하해.\n선물을 준비했단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50026-2","talkText":"선물!?\n신난다~! 뭔데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50026-3","talkText":"그건 이 안에\n들어가 보면 알 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet50026-4","talkText":"알았어! 에잇!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet50026-5","talkText":"멋지다~! 하구미가\n유카타가 됐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet50026-6","talkText":"후후, 그 유카타가\n하구미에게 주는 선물이란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet50026-7","talkText":"귀여워서 분명 어울릴 거라고\n모두 그랬거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[13],"voiceId":"TalkSet50026-8","talkText":"저, 정말 어울려?\n이상하지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50026-9","talkText":"지금 하구미\n엄~청 귀여워!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[13],"voiceId":"TalkSet50026-10","talkText":"에헤헤…… 왠지 뺨이\n뜨거워졌어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet50026-11","talkText":"모처럼 입었으니까 이대로\n축제 구경 가자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[13],"voiceId":"TalkSet50026-12","talkText":"응! 좋아~!\n잔뜩 먹어야지~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}