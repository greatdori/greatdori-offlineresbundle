{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50027","backstageTalkSetId":50027,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50027-1","talkText":"자, 내일 준비는\n이걸로 문제없겠지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50027-2","talkText":"아까 살짝 봤을 때\n정말 예뻤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50027-3","talkText":"하구미도 두근거려!\n코코롱이 기뻐하겠지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet50027-4","talkText":"내일은 우리가\n웃는 얼굴로 만들어 줘야지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}