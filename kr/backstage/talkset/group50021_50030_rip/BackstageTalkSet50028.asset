{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50028","backstageTalkSetId":50028,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet50028-1","talkText":"어머! 내가\n제일 먼저 왔네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet50028-2","talkText":"뭘까?\n갑자기 어두워졌어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50028-3","talkText":"어라? 이번에는\n별이 나왔어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50028-4","talkText":"반짝거려서 정말\n예뻐! 바다같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12,13,14,15],"voiceId":"TalkSet50028-5","talkText":"코코로\n해피 버스데이!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[14],"voiceId":"TalkSet50028-6","talkText":"우리가 플라네타륨을\n만들어 봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet50028-7","talkText":"코코롱을 기쁘게 해주려고\n열심히 만들었어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50028-8","talkText":"이 덧없는 연출이\n마음에 드니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50028-9","talkText":"응! 이 경치\n무척 멋져!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet50028-10","talkText":"하하, 코코로 눈이\n엄청나게 반짝거려.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[11],"voiceId":"TalkSet50028-11","talkText":"틀림없이 내 눈에도\n별이 들어온 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}