{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50022","backstageTalkSetId":50022,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50022-1","talkText":"아코 짱……\n생일 축하해……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50022-2","talkText":"와아~! 고마워!\n설마 그 상자는!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet50022-3","talkText":"전부 우다가와 씨한테 주는\n선물이에요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50022-4","talkText":"이렇게나 많이!?\n굉장해~~~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50022-5","talkText":"자! 갑작스럽지만\n여기서 아코한테 퀴즈!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet50022-6","talkText":"퀴즈!? 좋아~!\n꼭 맞추겠어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet50022-7","talkText":"이 선물은 과연\n누가 주는 것일까요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet50022-8","talkText":"아코라면 분명\n다 맞출 수 있을거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[24],"voiceId":"TalkSet50022-9","talkText":"네, 네! 열심히 할게요!\n어디 보자, 으음……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50022-10","talkText":"이 NFO 인형은\n……린린!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50022-11","talkText":"응…… 아코 짱……\n정답이야……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[24],"voiceId":"TalkSet50022-12","talkText":"신난다~! 이 기세로\n전부 맞춰야지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}