{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50030","backstageTalkSetId":50030,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet50030-1","talkText":"……응? 왠지 평소하고\n분위기가 다른데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50030-2","talkText":"훗훗훗…… 잘 오셨습니다\n어둠의 연회에……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50030-3","talkText":"뭐야!? 아코?\n그리고 모두……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50030-4","talkText":"지금부터 위대한\n어둠의 힘을 보여드리죠……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50030-5","talkText":"아무것도 없는 책상 위에……\n천을 덮습니다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet50030-6","talkText":"이 천에는 어떠한 장치도\n없어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet50030-7","talkText":"천을 천천히\n잡아당기면……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50030-8","talkText":"아무것도 없었던 책상에\n선물이 짠~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50030-9","talkText":"어둠의 연회라니, 마술이잖아!\n그리고 이거 앞치마네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet50030-10","talkText":"리사, 생일 축하해.\n선물은 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet50030-11","talkText":"엄청 귀여워!\n잘 쓸게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}