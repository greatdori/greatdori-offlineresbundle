{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet748","backstageTalkSetId":748,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet748-1","talkText":"(아, 츄츄 씨다…)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":2,"characterIds":[35],"voiceId":"TalkSet748-2","talkText":"…무슨 일이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet748-3","talkText":"아, 그, 그게…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet748-4","talkText":"이, 이렇게\n쾌청한 날씨 속에서…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet748-5","talkText":"…연설이라도 시작하려는거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}