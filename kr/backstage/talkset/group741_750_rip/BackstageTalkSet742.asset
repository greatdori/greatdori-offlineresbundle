{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet742","backstageTalkSetId":742,"snippets":[{"talkId":1,"characterIds":[31],"voiceId":"TalkSet742-1","talkText":"시로카네 씨, 그 만화는\n혹시……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet742-2","talkText":"스내피 짱이에요……\n아코 짱이 추천해줘서……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet742-3","talkText":"사실…… 이거.\n저도 마스키한테 빌렸거든요.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet742-4","talkText":"귀엽죠……\n이런 이야기는……!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet742-5","talkText":"아, 저도 그 부분 좋아해요!\n같이 계속 읽을까요?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[25],"voiceId":"TalkSet742-6","talkText":"네…… 부디……!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}