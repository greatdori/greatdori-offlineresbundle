{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet746","backstageTalkSetId":746,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet746-1","talkText":"카논 씨 늦네…\n어디서 헤매고 있는거 아닐까","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet746-2","talkText":"음? 오쿠사와 씨,\n카논 선배 기다려?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet746-3","talkText":"응, 원래는 벌써\n도착했어야 하는데…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet746-4","talkText":"…조금 전에 역으로\n가는 걸 봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet746-5","talkText":"앗, 빨리\n따라가 봐야겠어…!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet746-6","talkText":"오쿠사와 씨도 고생하네…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}