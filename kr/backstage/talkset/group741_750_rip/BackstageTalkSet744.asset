{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet744","backstageTalkSetId":744,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet744-1","talkText":"뭐 보세요~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet744-2","talkText":"인형 사진이야.\n알아보고 있거든~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet744-3","talkText":"다음에 미사키랑 같이 만들 때\n뭘 만들까 찾고 있어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet744-4","talkText":"과연… 그렇다면\n마리를 추천드려요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet744-5","talkText":"아, 상점가 토끼 말이지?\n어려워 보이지만 괜찮겠어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet744-6","talkText":"완성하면 꼭 저한테도\n보여주세요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}