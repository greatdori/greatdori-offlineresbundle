{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet228","backstageTalkSetId":228,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet228-1","talkText":"아~짱은 똑똑해서\n굉장해~라고 생각해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet228-2","talkText":"가, 갑자기 뭐야!\n그래도 고마워……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet228-3","talkText":"하구미도 더 제대로\n공부해야지~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet228-4","talkText":"나, 나라도 괜찮으면\n공부 가르쳐 줄 수 있는데……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}