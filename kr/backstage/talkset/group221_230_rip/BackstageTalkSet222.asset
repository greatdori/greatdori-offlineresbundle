{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet222","backstageTalkSetId":222,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet222-1","talkText":"카스미네는 늦는구만~\n길을 돌아서 오는 건가?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet222-2","talkText":"후후, 걱정되면\n전화해 보는 건 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet222-3","talkText":"벼, 별로\n그런 거 아니라니까!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}