{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet226","backstageTalkSetId":226,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet226-1","talkText":"빤히~~~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet226-2","talkText":"츠, 츠루마키 씨?\n왜 그래……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet226-3","talkText":"난 좀 더, 좀 더,\n아리사의 웃는 얼굴이 보고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet226-4","talkText":"(뭐, 뭐를 할지\n불안한데……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}