{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet230","backstageTalkSetId":230,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet230-1","talkText":"아, 미셸이다.\n오쿠사와 씨, 수고했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet230-2","talkText":"……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet230-3","talkText":"어라, 반응이 없는데\n오쿠사와 씨 안에 없는 건가.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet230-4","talkText":"……헉!\n따뜻해서 잠들어 버렸어……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}