{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet104","backstageTalkSetId":104,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet104-1","talkText":"코코롱, 이번 쉬는 날에\n뭐할 예정이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet104-2","talkText":"해외여행을 갈 거야!\n미셸이랑 가는 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet104-3","talkText":"엥……\n처음 듣는데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet104-4","talkText":"좋겠다~!\n나도 가고 싶다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet104-5","talkText":"잠깐, 카스미!\n되지도 않는 소리 하지 마!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet104-6","talkText":"그런가,\n여권도 없으니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet104-7","talkText":"그런 게 아니라니까~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":8,"characterIds":[15],"voiceId":"TalkSet104-8","talkText":"잠깐, 코코로!\n방금 이야기, 자세히!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}