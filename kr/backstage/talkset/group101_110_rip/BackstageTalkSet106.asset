{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet106","backstageTalkSetId":106,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet106-1","talkText":"사요 씨, 히나 선배!\n빅뉴스예요!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet106-2","talkText":"지금 케이크 뷔페에서\n자매할인을 하고 있어요!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet106-3","talkText":"정말!?\n언니, 가자!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet106-4","talkText":"……아무 일정이\n없으면 말이지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}