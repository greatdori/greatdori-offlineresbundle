{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet103","backstageTalkSetId":103,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet103-1","talkText":"아, 코코롱!\n미셸이 있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet103-2","talkText":"정말이네!\n미셸도 쉬는 중?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet103-3","talkText":"으, 응, 그렇지~\n너희도 수고했어.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet103-4","talkText":"오쿠사와 씨, 수고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":1,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet103-5","talkText":"고마워~ 아리사 짱.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet103-6","talkText":"완벽하게 하고 있어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}