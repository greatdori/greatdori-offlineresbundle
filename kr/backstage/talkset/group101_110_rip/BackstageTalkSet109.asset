{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet109","backstageTalkSetId":109,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet109-1","talkText":"아, 토모 찡이다!\n오늘은 전통식 큰북 연습?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet109-2","talkText":"그래, 방금 끝난 참이야.\n이제 곧 본공연이니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet109-3","talkText":"후후, 토모에의 전통식 큰북은\n듣고 있으면 힘이 나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet109-4","talkText":"맞아맞아!\n기분이 맑아져.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet109-5","talkText":"아하핫, 그럼 본공연도\n기대하고 있으라고!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}