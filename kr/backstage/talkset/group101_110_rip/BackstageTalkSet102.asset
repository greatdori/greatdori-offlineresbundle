{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet102","backstageTalkSetId":102,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet102-1","talkText":"이런 것도 있구나……\n사 놓을까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet102-2","talkText":"미사키 짱!\n뭐 봐?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet102-3","talkText":"양모 펠트 책을\n찾아보고 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet102-4","talkText":"미사키 짱은 이것저것\n엄청 잘 만들어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet102-5","talkText":"……분재도 만들어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet102-6","talkText":"부, 분재는 좀……\n근데 의외로 재밌을지도.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[15],"voiceId":"TalkSet102-7","talkText":"만들면 이치가야 씨한테\n체크를 받아볼까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}