{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet101","backstageTalkSetId":101,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet101-1","talkText":"하암~……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet101-2","talkText":"아리사 짱, 엄청\n졸린 것 같은데, 괜찮아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet101-3","talkText":"지금…… 학교에서…… 아침\n인사 운동을 하고 있어서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet101-4","talkText":"학생회는 매일 같이\n참가해야 해서 말이야……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet101-5","talkText":"우와~! 힘들겠다!\n난 절대로 못 해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet101-6","talkText":"히나 선배, 우리도 다음 주부터\n하는데요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet101-7","talkText":"엥~!? 싫어~!\n츠구 짱 어떻게 해 봐~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}