{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet265","backstageTalkSetId":265,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet265-1","talkText":"오늘 부활동 연습은\n하드했어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet265-2","talkText":"테니스는 코트 안을\n돌아다녀야 하니까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet265-3","talkText":"서브하면 팔도 당기지,\n다리도 힘들지……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet265-4","talkText":"아~ 정말 그래.\n엄청 공감 가.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}