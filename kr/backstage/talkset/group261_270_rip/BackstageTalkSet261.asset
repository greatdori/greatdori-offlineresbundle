{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet261","backstageTalkSetId":261,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet261-1","talkText":"늦어서 미안해,\n기다렸어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet261-2","talkText":"아니야, 전혀! 근데……\n츠구가 늦다니 별일이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet261-3","talkText":"쿠키가 좀만 더 구우면\n완성될 것 같았으니까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet261-4","talkText":"와~ 쿠키다!\n맛있겠다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}