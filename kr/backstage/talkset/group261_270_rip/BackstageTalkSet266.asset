{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet266","backstageTalkSetId":266,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet266-1","talkText":"앗, 미사키 짱,\n마침 잘 왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet266-2","talkText":"아, 우에하라 씨,\n마침 잘 왔다니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet266-3","talkText":"이 신작 디저트,\n엄청 맛있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet266-4","talkText":"괜찮으면\n한 입 먹어봐!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}