{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet269","backstageTalkSetId":269,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet269-1","talkText":"이번에 상점가에서\n축제를 해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet269-2","talkText":"축제!?\n무척 재밌겠다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet269-3","talkText":"나도 무조건\n놀러 갈게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet269-4","talkText":"그래, 꼭 와줘!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}