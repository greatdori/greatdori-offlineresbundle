{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2035","backstageTalkSetId":2035,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2035-1","talkText":"언제 한번 다 같이\n합숙 같은 것도 해보고 싶어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2035-2","talkText":"엄청 재밌겠다!\n지금 당장 하자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2035-3","talkText":"그, 그건 너무 갑작스럽긴 하지만\n확실히 해 보고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2035-4","talkText":"그래서 연습이 더 잘\n된다면 나도 상관없어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2035-5","talkText":"합숙 요리는 나한테 맡겨!\n요리는 자신 있거든!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2035-6","talkText":"후~스케가 자신이 넘치면\n왠지 불안한데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2035-7","talkText":"뭐~ 그런 말 하면\n토우코 짱은 밥 굶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}