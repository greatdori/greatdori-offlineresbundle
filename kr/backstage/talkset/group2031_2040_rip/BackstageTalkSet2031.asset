{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2031","backstageTalkSetId":2031,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2031-1","talkText":"저기~ 시로, 내일\n약속 말인데~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2031-2","talkText":"…………","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2031-3","talkText":"시로?\n이봐~ 무시하지 마~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2031-4","talkText":"지금은 안 들릴 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2031-5","talkText":"새로운 가사가\n떠오를 것 같대.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2031-6","talkText":"과연.\n그건 어쩔 수 없지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}