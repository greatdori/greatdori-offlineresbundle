{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2039","backstageTalkSetId":2039,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet2039-1","talkText":"흐음.\n꽤 괜찮은 소파를 쓰는구만.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[33],"voiceId":"TalkSet2039-2","talkText":"테이블은……\n유리로 됐고……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet2039-3","talkText":"어때? 라이브 하우스\n시찰은 순조로워?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet2039-4","talkText":"Galaxy에도 이런\n방을 만들자고 해볼까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}