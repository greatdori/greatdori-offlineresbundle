{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2036","backstageTalkSetId":2036,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2036-1","talkText":"좀 더 모두가\n신나는 라이브 하고 싶지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2036-2","talkText":"좋은 생각이야! 어떤 걸\n해야 신이 날까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2036-3","talkText":"음…… 시로가\n춤추면서 노래한다든지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2036-4","talkText":"뭐……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2036-5","talkText":"그러면 탬버린 같은 걸\n드는 것도 괜찮겠다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet2036-6","talkText":"자, 잠깐만……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2036-7","talkText":"아, 마라카스는 어때?\n흔들면서 노래하는 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet2036-8","talkText":"츠, 츠쿠시 짱까지!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet2036-9","talkText":"……개그하는 밴드라도\n될 생각이니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}