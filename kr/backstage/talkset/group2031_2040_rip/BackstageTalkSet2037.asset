{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2037","backstageTalkSetId":2037,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2037-1","talkText":"이번에야말로 진짜 신나는\n라이브를 생각하자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2037-2","talkText":"지난번에는 모두 도중에\n장난만 쳤으니까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2037-3","talkText":"무대 뒤에서\n레이저가 나오는 건 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2037-4","talkText":"오, 괜찮은데!\n멋지다! 채용~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2037-5","talkText":"연기가 피어오르는 것도\n멋있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2037-6","talkText":"그것도 좋다!\n채용~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[30],"voiceId":"TalkSet2037-7","talkText":"연출보다 연주로\n매료시켜야 한다고 생각해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[27],"voiceId":"TalkSet2037-8","talkText":"그게 가장 멋진데!\n루이 의견도 채용!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet2037-9","talkText":"방금 말은 의견이 아니라\n주의를 준 것 같은데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}