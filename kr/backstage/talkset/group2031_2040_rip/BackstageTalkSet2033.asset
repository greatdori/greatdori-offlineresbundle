{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2033","backstageTalkSetId":2033,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2033-1","talkText":"아, 그렇지!\n이거, 모두한테 주는 선물.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2033-2","talkText":"고마워, 맛있어 보이는\n초콜릿이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2033-3","talkText":"아, 이거 알아!\n유명한 가게 거지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2033-4","talkText":"맞아~ 주말에\n벨기에 다녀왔거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2033-5","talkText":"해외 선물이야!?\n괴, 굉장하다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2033-6","talkText":"그래?\n아무튼, 같이 먹자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet2033-7","talkText":"이거 맛있지~\n나도 좋아해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[30],"voiceId":"TalkSet2033-8","talkText":"나도 주말에 해외에 가니까\n뭐 사 올게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[26],"voiceId":"TalkSet2033-9","talkText":"모두 부자라는 사실을\n오랜만에 실감했어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}