{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet450","backstageTalkSetId":450,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet450-1","talkText":"아하핫.\n사아야, 잎이 붙어있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet450-2","talkText":"엥? 어, 어디에?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet450-3","talkText":"가만히 있어 줄래.\n지금 떼어내 줄 테니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}