{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet442","backstageTalkSetId":442,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet442-1","talkText":"리사, 생일 축하해.\n선물을 준비해봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet442-2","talkText":"피어스랑 초커 같은 게\n여러 가지 있네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet442-3","talkText":"각자가 이마이 씨한테\n어울릴만한 걸 골랐어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet442-4","talkText":"에헤헤, 아코가 고른 건\n어때? 멋지지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet442-5","talkText":"마음에 드신다면……\n착용해 보셔도 돼요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet442-6","talkText":"모두 정말 고마워!\n소중히 간직할게☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}