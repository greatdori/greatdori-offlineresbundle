{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet443","backstageTalkSetId":443,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet443-1","talkText":"리사 씨, 생일\n축하드립니다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet443-2","talkText":"저기 케이크 가져왔으니\n괜찮으면 드세요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet443-3","talkText":"와~ 받아도 돼?\n둘 다 고마워♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet443-4","talkText":"란이 준비하자고 했어요~\n도움 많이 받았다면서요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet443-5","talkText":"그, 그런 말은 안 해도\n되잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet443-6","talkText":"부끄러워하지 마♪\n자, 같이 먹을까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}