{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet449","backstageTalkSetId":449,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet449-1","talkText":"와아, 예쁜 하늘 사진이네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet449-2","talkText":"아아, 응.\n아까 찍었거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet449-3","talkText":"가을 하늘은 기분이 좋아지지.\n푸르고 맑아서.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet449-4","talkText":"맞아. 나도\n그만 넋놓고 보게 되니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}