{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet444","backstageTalkSetId":444,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet444-1","talkText":"점점 서늘해지고\n있네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet444-2","talkText":"그래…… 특히\n아침저녁으로 추워지니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet444-3","talkText":"겉옷으로 확실하게\n체온 조절을 해야겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet444-4","talkText":"그렇네. 나도\n신경 써야겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}