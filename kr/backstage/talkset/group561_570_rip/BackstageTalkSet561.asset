{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet561","backstageTalkSetId":561,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet561-1","talkText":"이번 곡 중에서 도전\n해보고 싶은 게 있어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet561-2","talkText":"나도! 그러면 오늘은\n일찍 레슨실에 갈래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet561-3","talkText":"네! 찬성이에요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}