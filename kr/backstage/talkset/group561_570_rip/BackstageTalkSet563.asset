{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet563","backstageTalkSetId":563,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet563-1","talkText":"츠구미 가게에서\n추천하는 건 뭐야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet563-2","talkText":"케이크 세트야.\n카페오레도 맛있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet563-3","talkText":"좋은걸! 엄청\n웃는 얼굴이 될 거 같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}