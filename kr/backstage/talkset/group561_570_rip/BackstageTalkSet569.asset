{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet569","backstageTalkSetId":569,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet569-1","talkText":"내일은 카오루 씨의\n생일이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet569-2","talkText":"선물은 오케이고\n또 뭐가 있을까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet569-3","talkText":"남은 건 최고의 웃는 얼굴로\n반겨주면 될 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet569-4","talkText":"그러네. 서프라이즈\n성공했으면 좋겠네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}