{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet551","backstageTalkSetId":551,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet551-1","talkText":"이마이 씨의 쿠키는\n항상 맛있어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet551-2","talkText":"고마워! 그래도 나는\n사요의 쿠키도 좋아하는 걸.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet551-3","talkText":"모두를 생각해서\n만들었다는 걸 알 수 있으니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet551-4","talkText":"그, 그건…… 이마이 씨도\n마찬가지잖아요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}