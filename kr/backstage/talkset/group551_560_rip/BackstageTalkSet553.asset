{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet553","backstageTalkSetId":553,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet553-1","talkText":"이거 봐봐!\n좋은 걸 찾았어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet553-2","talkText":"와아, 예쁜 꽃이네.\n새하얗고 푹신거려.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet553-3","talkText":"리미링 같아서\n귀엽네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet553-4","talkText":"(치, 칭찬하기\n어렵게 됐어……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}