{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet557","backstageTalkSetId":557,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet557-1","talkText":"어제 옆 교실에서\n아리사 목소리가 들렸어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet557-2","talkText":"아, 영어 수업에서\n호명 당했을 때인가.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet557-3","talkText":"그 다음에 카스미 목소리도\n들렸는데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet557-4","talkText":"선생님이 깨울 때네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}