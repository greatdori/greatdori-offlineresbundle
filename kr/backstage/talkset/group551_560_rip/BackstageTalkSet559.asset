{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet559","backstageTalkSetId":559,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet559-1","talkText":"채소 꽃으로 꽃꽂이를\n하는 건 어떻게 생각하세요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet559-2","talkText":"채소……\n그거 꽤 재밌을 거 같은데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet559-3","talkText":"브로콜리를 가운데에\n두고, 주위에……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet559-4","talkText":"브로콜리……\n왠지 생각한 거랑 다르네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}