{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet560","backstageTalkSetId":560,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet560-1","talkText":"카논의 그림은 무척\n상냥하고 따뜻하네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet560-2","talkText":"후후, 고마워.\n치사토 짱의 그림도……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet560-3","talkText":"응…… 개성적이라 마음에 들어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet560-4","talkText":"조금 뜸 들인 것처럼\n느껴졌는데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}