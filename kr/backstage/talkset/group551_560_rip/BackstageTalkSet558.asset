{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet558","backstageTalkSetId":558,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet558-1","talkText":"코코로, 어쩌지~\n숙제 문제가 너무 어려워~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet558-2","talkText":"그럴 때는\n춤추면 돼!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet558-3","talkText":"즐거워져서 분명\n답이 떠오를 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet558-4","talkText":"그렇구나!\n그럼 춤추자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}