{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet613","backstageTalkSetId":613,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet613-1","talkText":"연기하실 때\n요령이 있나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet613-2","talkText":"요령은……\n배역을 이해하는 것이지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet613-3","talkText":"이해한다면 닌자나 무사,\n동물도 연기할 수 있단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet613-4","talkText":"무사에 동물까지……!?\n굉장해요!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}