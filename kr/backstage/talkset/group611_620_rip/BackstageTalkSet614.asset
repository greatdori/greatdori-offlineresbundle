{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet614","backstageTalkSetId":614,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet614-1","talkText":"무대 연출자는\n꽤나 힘든 건가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet614-2","talkText":"힘들긴 합니다만\n적성에 맞지 말입니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet614-3","talkText":"오쿠사와 씨도\n흥미 있으십니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet614-4","talkText":"비슷한 일을 하고 있으니\n조금은요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}