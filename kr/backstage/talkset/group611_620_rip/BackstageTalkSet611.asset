{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet611","backstageTalkSetId":611,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet611-1","talkText":"오늘 우리 집에서\n저녁밥 먹지 않을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet611-2","talkText":"준하고 사나도\n토모에를 만나고 싶대.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet611-3","talkText":"좋은데, 나도\n둘 다 보고 싶기도 했고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet611-4","talkText":"가는 김에 빌렸던\n잡지도 돌려줄게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}