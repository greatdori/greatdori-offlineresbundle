{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet615","backstageTalkSetId":615,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet615-1","talkText":"다음 주 수학 시험이야~\n전혀 모르겠는데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet615-2","talkText":"나도. 함께 아리사한테\n가르쳐 달라고 하자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet615-3","talkText":"하는 김에 창고에서\n하루 자고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet615-4","talkText":"우와~! 너무 기대돼서\n공부가 손에 안 잡혀~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}