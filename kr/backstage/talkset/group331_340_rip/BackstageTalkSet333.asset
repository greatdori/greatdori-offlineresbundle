{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet333","backstageTalkSetId":333,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet333-1","talkText":"카오루, 오늘 점심시간에\n운동장에서 춤추지 않았어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet333-2","talkText":"다음 연극 무대에서는\n댄서 역할이니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet333-3","talkText":"역할에 몰입하기 위해서\n춤을 춘 거란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}