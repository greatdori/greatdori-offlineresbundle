{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet336","backstageTalkSetId":336,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet336-1","talkText":"미~군, 미~군!\n잠깐 와봐!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet336-2","talkText":"응? 왜 그래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet336-3","talkText":"코코롱이 지금부터\n라이브를 시작한대!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet336-4","talkText":"에엥!? 아무리\n그래도 너무 갑작스럽잖아!?","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}