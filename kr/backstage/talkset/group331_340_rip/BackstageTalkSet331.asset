{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet331","backstageTalkSetId":331,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet331-1","talkText":"실은 미셸에게\n편지를 썼단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet331-2","talkText":"언제나 신세 지는 것에 대해\n답례를 하고 싶어서 말이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet331-3","talkText":"괜찮다면\n전해주지 않겠니.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet331-4","talkText":"(……어떡하지,\n이거 읽어도 되는 걸까.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}