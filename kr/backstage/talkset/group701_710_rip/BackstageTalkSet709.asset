{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet709","backstageTalkSetId":709,"snippets":[{"talkId":1,"characterIds":[11,13],"voiceId":"TalkSet709-1","talkText":"오예!\n해피 뉴 이어~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":3,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet709-2","talkText":"간다~!\n으라차! 으라차!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":3,"characterIds":[34,35],"voiceId":"TalkSet709-3","talkText":"오오~~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet709-4","talkText":"다, 다음은 저희 차례예요.\n열심히 해요♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet709-5","talkText":"여, 역시\n너무 높다구!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[34],"voiceId":"TalkSet709-6","talkText":"괜찮아요♪\n쿠션도 준비했답니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet709-7","talkText":"괜찮아! 용기를 내면\n뭐든지 할 수 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[11],"voiceId":"TalkSet709-8","talkText":"맞아. 중요한 건 웃는 얼굴이야.\n모두 가는 거야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9,11,13],"voiceId":"TalkSet709-9","talkText":"으라차! 스마일~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":10,"characterIds":[35],"voiceId":"TalkSet709-10","talkText":"Unbelievable……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}