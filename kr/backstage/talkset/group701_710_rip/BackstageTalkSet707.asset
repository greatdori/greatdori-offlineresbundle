{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet707","backstageTalkSetId":707,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet707-1","talkText":"으으, 나만 시간이\n지나도 못 해……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet707-2","talkText":"아직 시간도 있으니까\n연습하면 괜찮아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet707-3","talkText":"아, 장기자랑 대회 이야기~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet707-4","talkText":"응, 나, 재주가 없으니까\n힘들어서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet707-5","talkText":"선배님들도 잘 가르쳐\n주고 있잖아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet707-6","talkText":"그렇긴 하지만~……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet707-7","talkText":"시로 쨩, 힘 내~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet707-8","talkText":"루이루이랑 토~코 짱도\n같은 팀이었지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[27],"voiceId":"TalkSet707-9","talkText":"맞아! 난 리허설 완벽! \n루이도 봤지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[30],"voiceId":"TalkSet707-10","talkText":"너가 물건을 잃어버린\n것만 제외하면.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[27],"voiceId":"TalkSet707-11","talkText":"어떻게든 됐으니까\n어쨌든 괜찮은 거 아냐?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[29],"voiceId":"TalkSet707-12","talkText":"그, 그쯤 하자\n두 사람 다……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[28],"voiceId":"TalkSet707-13","talkText":"어느 팀이든\n큰일이네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}