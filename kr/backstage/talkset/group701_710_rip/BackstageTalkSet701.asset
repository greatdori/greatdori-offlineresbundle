{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet701","backstageTalkSetId":701,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet701-1","talkText":"요즘 날씨가 너무 추우니까 이불에서\n못 나가겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet701-2","talkText":"나도나도! 알 거 같아~!\n근데 최근에 찾았거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet701-3","talkText":"뭔데뭔데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet701-4","talkText":"추울 때는 에이! 라고\n소리만 내면 바로 일어날 수 있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}