{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet705","backstageTalkSetId":705,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet705-1","talkText":"어머, 혹시\n장기자랑 대회 상담?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet705-2","talkText":"여러분!\n네, 맞아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet705-3","talkText":"내용이 엄청나서\n준비하는 것도 큰일이라~……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet705-4","talkText":"분명 카오루는 엉뚱한\n걸 말할 거 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet705-5","talkText":"항상 있는 일입니다.\n우헤헤.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet705-6","talkText":"후후, 다들 재밌겠다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet705-7","talkText":"아야 씨 팀은\n순조로운가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[16],"voiceId":"TalkSet705-8","talkText":"저번에 다 같이 리허설을 했어~\n히나 짱은?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet705-9","talkText":"우리는 아직 개인 연습 중\n이랄까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet705-10","talkText":"나는 룽♪ 하게 올\n새로운 기술을 생각해서~……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet705-11","talkText":"그 이상 말씀하시면 뭘 하는지\n알게 되지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[17],"voiceId":"TalkSet705-12","talkText":"아, 그런가. 내용은\n설날까지 비밀이였지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}