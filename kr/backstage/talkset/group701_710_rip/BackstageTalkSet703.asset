{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet703","backstageTalkSetId":703,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet703-1","talkText":"하아~ 무거웠어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet703-2","talkText":"뭐 사온 거야?\n엄청 큰 짐이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet703-3","talkText":"설마, 설날\n장기자랑 쇼핑~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet703-4","talkText":"엥!?\n어떻게 알았어!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet703-5","talkText":"왜라니……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet703-6","talkText":"산 게\n살짝 보였어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[6],"voiceId":"TalkSet703-7","talkText":"히마리 팀의\n장기자랑은……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[8],"voiceId":"TalkSet703-8","talkText":"와아아아앗!\n말하면 안 돼~~~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet703-9","talkText":"설날까지 비밀로 하기로\n다 같이 이야기했었지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet703-10","talkText":"우리는 다 다른 팀이라\n당일이 기대 돼.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[7],"voiceId":"TalkSet703-11","talkText":"뭐, 히~짱\n팀이 하는 건~……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[8],"voiceId":"TalkSet703-12","talkText":"안안안안안안돼~~!!!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}