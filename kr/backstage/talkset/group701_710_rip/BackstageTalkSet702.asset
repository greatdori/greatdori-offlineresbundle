{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet702","backstageTalkSetId":702,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet702-1","talkText":"설날 장기자랑 대회에서\n다들 뭐 할지 정했어!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet702-2","talkText":"어이, 그거 안 물어보기로\n하지 않았냐?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet702-3","talkText":"그렇긴 한데~\n그래도 신경이 쓰여서!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet702-4","talkText":"우리 팀은…… 후후.\n모두 깜짝 놀랄 거야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet702-5","talkText":"응! 특별 게스트도\n있으니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet702-6","talkText":"너무 기대 돼~\n우리는 전통적인 느낌이려나~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet702-7","talkText":"우리 팀도\nThe 설날! 이런 느낌.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet702-8","talkText":"음~~~ 엄~~~청\n궁금해~~~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet702-9","talkText":"뭐, 설날까지\n기대해야지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[1],"voiceId":"TalkSet702-10","talkText":"으으~ 앞으로 몇 번\n자야 했더라~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}