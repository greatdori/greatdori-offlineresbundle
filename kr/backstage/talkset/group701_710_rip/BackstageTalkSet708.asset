{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet708","backstageTalkSetId":708,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet708-1","talkText":"내가 장기자랑을\n한다고!? Why!?","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet708-2","talkText":"파레오는 츄츄 님과 같은\n팀이라서 기뻐요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet708-3","talkText":"그런 이야기가 아니야!\n할 필요가 없다는 얘기를 하는 거라고!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[31],"voiceId":"TalkSet708-4","talkText":"마스키랑 록 팀은\n순조롭게 진행되고 있어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet708-5","talkText":"네! 저희는 아야 선배가\n이끌어 주셔서……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet708-6","talkText":"우리 팀도 지금 있는 곳은\n순조롭지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[34],"voiceId":"TalkSet708-7","talkText":"저기, 레이야 씨 팀\n멤버는 분명……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[31],"voiceId":"TalkSet708-8","talkText":"응, 하나 짱이랑 같은 팀.\n그래서 연습도 즐거워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[31],"voiceId":"TalkSet708-9","talkText":"그리고\n옷짱도 있고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[34],"voiceId":"TalkSet708-10","talkText":"옷짱이라면\n그……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[31],"voiceId":"TalkSet708-11","talkText":"그래 맞아.\n하나 짱이 키우고 있는……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[35],"voiceId":"TalkSet708-12","talkText":"Stop!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":3,"balloonType":1},{"talkId":13,"characterIds":[35],"voiceId":"TalkSet708-13","talkText":"장기자랑 내용은\nSecret이라는 이야기야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[32],"voiceId":"TalkSet708-14","talkText":"츄츄 씨…… 사실은\n기대하고 있는 게……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[35],"voiceId":"TalkSet708-15","talkText":"시, 시끄러워!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}