{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet704","backstageTalkSetId":704,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet704-1","talkText":"카오틱 샷!\n은 어떤가요 사요 씨!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet704-2","talkText":"몇 번이고 말했지만\n구호는 필요 없습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet704-3","talkText":"후후……장기자랑 대회\n말씀이신가요……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet704-4","talkText":"그래! 엄청난 걸 할 거니까\n기대해 줘, 린린!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet704-5","talkText":"응……우리도,\n힘낼게……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet704-6","talkText":"그래. 지금부터 폐활량을\n더 단련해 놓을게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet704-7","talkText":"아, 아니…… 공기를 넣는 건\n있는 거 같아요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet704-8","talkText":"어머, 그러니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet704-9","talkText":"다들 좋겠다~ 같은 팀에\n밴다 멤버가 있어서~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet704-10","talkText":"리사도 즐거운 듯이\n준비하고 있었잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet704-11","talkText":"즐거워☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[23],"voiceId":"TalkSet704-12","talkText":"우리는 특별히 거창한 걸\n할 거니까 기대해 줘!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[24],"voiceId":"TalkSet704-13","talkText":"와아, 빨리 설날이\n됐으면 좋겠다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}