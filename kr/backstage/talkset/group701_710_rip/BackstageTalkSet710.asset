{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet710","backstageTalkSetId":710,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet710-1","talkText":"이얍!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet710-2","talkText":"영차!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet710-3","talkText":"이얏!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet710-4","talkText":"짠~!\n옷짱 등장이야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet710-5","talkText":"와……\n후후, 엄청 귀여워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet710-6","talkText":"마지막에는 큰 기술이네.\n두 사람 다 힘내.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2,8],"voiceId":"TalkSet710-7","talkText":"간다~!\n영차~~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet710-8","talkText":"대단하다!\n엄청 많이 나오고 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[18],"voiceId":"TalkSet710-9","talkText":"두, 두 사람 다……?\n이제 그만해도 되지 않을까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet710-10","talkText":"그, 그게……\n머, 멈추질 않는다구~~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[2],"voiceId":"TalkSet710-11","talkText":"응, 설날부터 기운이\n좋아서 괜찮을 거 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[31],"voiceId":"TalkSet710-12","talkText":"후후, 그러네. 분명\n수확이 많은 1년이 되겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[8],"voiceId":"TalkSet710-13","talkText":"정말~! 이제 됐으니까\n누군가 말려줘~~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}