{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet706","backstageTalkSetId":706,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet706-1","talkText":"두 사람 다 장기자랑 대회\n정말 괜찮은 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet706-2","talkText":"응! 준비는 완벽해!\n그치~ 코코롱!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet706-3","talkText":"미사키는 무슨 걱정을\n하고 있는 거니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet706-4","talkText":"나랑 하구미가\n모두를 웃는 얼굴로 만들 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet706-5","talkText":"코코코랑 하구미라서\n걱정하는 거라고!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet706-6","talkText":"후후……미사키의 그런 동료를\n배려하는 마음……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet706-7","talkText":"아아, 덧없구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet706-8","talkText":"후후…… 그래서, 미사키 짱\n팀은 순조로워?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet706-9","talkText":"뭐, 우리는 대충.\n제가 일단 경험자니까요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet706-10","talkText":"경험자……？\n무엇을 하는 걸까……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet706-11","talkText":"아! 아니 그건 비밀로 한\n이야기라서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[11],"voiceId":"TalkSet706-12","talkText":"분명 웃는 얼굴이 웃는 얼굴을 부르는\n「웃는 얼굴 장기자랑이야!」","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[13],"voiceId":"TalkSet706-13","talkText":"미~군의 웃는 얼굴 장기자랑\n기대된다~~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[12],"voiceId":"TalkSet706-14","talkText":"미사키의 포복절도 장기자랑\n기대하도록 하지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[15],"voiceId":"TalkSet706-15","talkText":"부담을 주는 방법……\n보통이 아니잖아……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}