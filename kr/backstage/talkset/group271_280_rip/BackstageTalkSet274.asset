{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet274","backstageTalkSetId":274,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet274-1","talkText":"전에 먹은 햄버그가\n엄청 맛있었지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet274-2","talkText":"우다가와 씨……\n과한 염분은 몸에 독이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet274-3","talkText":"……그건 그렇고,\n그 가게는 어디 있는 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}