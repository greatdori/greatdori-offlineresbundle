{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet272","backstageTalkSetId":272,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet272-1","talkText":"세타 선배가 연기 연습을\n하는 걸 봤어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet272-2","talkText":"그 결투 씬은\n엄청 뜨거웠어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet272-3","talkText":"후후, 고마워.\n본공연도 기대해 주길 바라마.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}