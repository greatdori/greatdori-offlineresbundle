{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet271","backstageTalkSetId":271,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet271-1","talkText":"이런, 이런 데서\n아기 고양이를 만나다니.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet271-2","talkText":"아기 고양이라니……\n저 말씀이신가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet271-3","talkText":"전 아기 고양이라고 하기에는\n크지 않나 싶은데요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet271-4","talkText":"후후, 내가 보기에는\n누구든 아기 고양이란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}