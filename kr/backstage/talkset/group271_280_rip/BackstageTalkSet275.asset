{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet275","backstageTalkSetId":275,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet275-1","talkText":"츠구 짱네 커피는\n엄청 좋은 향이 나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet275-2","talkText":"응응……\n츠구 짱도 좋은 향이 나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet275-3","talkText":"히, 히나 선배!\n부끄러워요~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}