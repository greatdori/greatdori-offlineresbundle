{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet602","backstageTalkSetId":602,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet602-1","talkText":"Afterglow는\n지금부터 연습이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet602-2","talkText":"아뇨, 얼마 전에 아코가\n갖고 싶다던 책을 주려고요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet602-3","talkText":"……왠지 토모에는\n가끔 사요랑 닮은 것 같다니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet602-4","talkText":"아하하…… 대충\n자각하고 있어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}