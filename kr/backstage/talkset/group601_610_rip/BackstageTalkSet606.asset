{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet606","backstageTalkSetId":606,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet606-1","talkText":"치사토 선배, 개\n키우고 있죠!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet606-2","talkText":"응. 다음에 같이\n산책하러 가자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet606-3","talkText":"신난다~! 보물찾기\n하러 가요~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet606-4","talkText":"(대, 대체 어디까지 갈\n생각인 걸까……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}