{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet610","backstageTalkSetId":610,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet610-1","talkText":"오늘 가게 메뉴에\n새로운 메뉴가 나올 예정이에요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet610-2","talkText":"말차 초콜릿 케이크 같은 게\n어떨까 해서요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet610-3","talkText":"과연……\n무척 맛있겠네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet610-4","talkText":"완성된다면\n히나랑 먹으러 갈게요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}