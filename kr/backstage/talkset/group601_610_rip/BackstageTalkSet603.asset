{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet603","backstageTalkSetId":603,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet603-1","talkText":"아버님께서 라이브 전에\n간식을 가져다주시는군요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet603-2","talkText":"조금 부끄럽지만\n모두 무척 기뻐해요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet603-3","talkText":"저희도 연습에 과자를\n가져오기도 해요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet603-4","talkText":"연습 전에 나오는 과자는\n신기한 효과가 있죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}