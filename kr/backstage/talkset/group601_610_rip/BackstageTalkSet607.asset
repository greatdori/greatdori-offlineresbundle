{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet607","backstageTalkSetId":607,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet607-1","talkText":"다음 달에 개봉하는 호러 영화\n엄청 기대돼~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet607-2","talkText":"어떤 이야기인데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet607-3","talkText":"주인공이 좀비가 되는\n부분부터 시작해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet607-4","talkText":"무척 재밌겠는걸!\n나도 보고 싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}