{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50041","backstageTalkSetId":50041,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50041-1","talkText":"내일…… 유키나 씨의\n생일이, 기대되네요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50041-2","talkText":"응, 리사 언니의 아이디어가\n엄청 멋져!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50041-3","talkText":"그, 그런가? 유키나가\n기뻐했으면 좋겠다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50041-4","talkText":"이런 축하 방법도\n좋은 것 같아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}