{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50044","backstageTalkSetId":50044,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50044-1","talkText":"아리사 짱, 생일\n축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet50044-2","talkText":"자, 아리사! 직접 만든\n메시지 보드야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50044-3","talkText":"아리사를 향한 마음을 다 같이\n잔뜩 적어봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50044-4","talkText":"때, 땡큐……\n왠지 부끄럽네……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50044-5","talkText":"이 메시지 보드는\n카스미가 제안했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet50044-6","talkText":"학생회 일이랑 다른 일로 힘든데\n항상 열심히 하잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2],"voiceId":"TalkSet50044-7","talkText":"어려운 소절이라도\n절대 포기하지 않고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50044-8","talkText":"이러니저러니 해도 모두를\n잘 살펴주잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet50044-9","talkText":"팝핀파를 소중히\n해 줘서 고마워!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet50044-10","talkText":"……별로\n그런 건 당연하잖냐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1],"voiceId":"TalkSet50044-11","talkText":"와아! 아리사가 솔직해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[5],"voiceId":"TalkSet50044-12","talkText":"시, 시끄러워~!\n가끔은 괜찮잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}