{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50045","backstageTalkSetId":50045,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50045-1","talkText":"후우~ 준비 오케이!\n내일이 기대되네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50045-2","talkText":"마야 씨라면 분명 화려한\n실력을 보여 줄 거예요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50045-3","talkText":"히나 짱, 그런 걸\n다 준비하다니……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet50045-4","talkText":"아하하…… 그런데 나도\n조금 해 보고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}