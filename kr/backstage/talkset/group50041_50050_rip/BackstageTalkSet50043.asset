{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50043","backstageTalkSetId":50043,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50043-1","talkText":"드디어 내일이야……!\n으으, 두근거린다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50043-2","talkText":"우리 마음이 아리사한테\n잘 전해졌으면 좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50043-3","talkText":"평소에 가진 마음을\n적으면 괜찮아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet50043-4","talkText":"오타에 말이 맞아!\n기다려, 아리사~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}