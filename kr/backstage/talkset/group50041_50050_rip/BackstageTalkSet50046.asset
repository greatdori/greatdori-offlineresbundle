{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50046","backstageTalkSetId":50046,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50046-1","talkText":"생일을 맞은 마야 짱은\n이 게임에 도전해줘야겠어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50046-2","talkText":"선물을 건\n다트 게임이에요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet50046-3","talkText":"맞춘 색에 따라 받을\n선물이 정해져.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50046-4","talkText":"녹색은 아로마 디퓨저.\n빨강은 교통카드 케이스.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50046-5","talkText":"그리고 파랑은 머그잔이야.\n마야 짱, 잘해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet50046-6","talkText":"네, 네! 잘해 보겠습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50046-7","talkText":"에잇!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50046-8","talkText":"오오! 녹색이니까\n아로마 디퓨저야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50046-9","talkText":"마야 씨, 굉장해요!\n단번에 맞췄어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet50046-10","talkText":"아, 히나 짱. 남은\n선물은 어떻게 해?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[17],"voiceId":"TalkSet50046-11","talkText":"물론 전부 마야 짱한테\n줄 거야~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[19],"voiceId":"TalkSet50046-12","talkText":"네에!? 저, 정말\n고맙습니다……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}