{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50042","backstageTalkSetId":50042,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50042-1","talkText":"미나토 씨, 수고하셨어요.\n이건 과자랑……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet50042-2","talkText":"벌꿀 차에요……\n괜찮다면, 드세요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet50042-3","talkText":"둘 다 고마워.\n향이 무척 좋네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50042-4","talkText":"아코는 어깨 주무를게요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50042-5","talkText":"그리고 여기! 힐링된다는\n소문의 동영상이야~☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50042-6","talkText":"(고양이\n동영상 모음집……!?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet50042-7","talkText":"……잠깐만, 오늘\n갑자기 무슨 일이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50042-8","talkText":"유키나 씨! 오늘\n생일이잖아요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50042-9","talkText":"그래서 오늘은 유키나가\n편안히 있으면 좋을 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet50042-10","talkText":"퍼포먼스를 유지하려면\n적절한 휴식이 필요하니까요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50042-11","talkText":"원하는 게 있으시면\n말해주세요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet50042-12","talkText":"그런 이유였다니.\n고마워, 기뻐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}