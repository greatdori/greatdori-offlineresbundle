{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet414","backstageTalkSetId":414,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet414-1","talkText":"전부터 생각한 건데\n잘도 연주를 하네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet414-2","talkText":"아~ 뭐~ 익숙해지면,\n어떻게든 된다고 해야 하나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet414-3","talkText":"무슨 일이든 연습이 중요한 게\n아니겠습니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet414-4","talkText":"확실히 그래.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}