{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet417","backstageTalkSetId":417,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet417-1","talkText":"이번에 연극부에서 이런\n공연 목록을 기획했단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet417-2","talkText":"그렇다면…… 의상의\n색을 통일시키는 게……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet417-3","talkText":"역시 린코구나.\n자세하게 이야기해 주렴.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}