{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet297","backstageTalkSetId":297,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet297-1","talkText":"카오루 군은 왜\n연기를 하려고 한 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet297-2","talkText":"그건 말이지, 연극 무대가 나를\n부르기 때문이란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet297-3","talkText":"아하핫, 역시\n카오루 군은 재밌어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}