{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet298","backstageTalkSetId":298,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet298-1","talkText":"카오루 군, 셰익스피어의\n작품 중에 뭐가 가장 좋아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet298-2","talkText":"후후, 그렇구나……\n전부 다 덧없어서 고를 수 없구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}