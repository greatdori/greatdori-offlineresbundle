{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet410","backstageTalkSetId":410,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet410-1","talkText":"오늘은 팝핀파 멤버들이랑\n함께가 아닌 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet410-2","talkText":"네, 가끔은 혼자만의\n시간도 소중하니까라고 해야 하나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet410-3","talkText":"확실히,\n그럴지도 모르겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet410-4","talkText":"그렇긴 해도 금방\n만나고 싶어지지만요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}