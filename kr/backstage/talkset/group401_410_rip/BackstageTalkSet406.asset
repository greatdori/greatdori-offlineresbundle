{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet406","backstageTalkSetId":406,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet406-1","talkText":"이브 짱한테 줄 선물은\n그거면 괜찮으려나?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet406-2","talkText":"많은 종류가\n있었지 말입니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet406-3","talkText":"그런 건 그다지\n사 본 적이 없어서 살짝 불안하네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet406-4","talkText":"엥~ 무조건 룽♪ 하게\n될 거라니까! 괜찮아, 괜찮아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet406-5","talkText":"그러게, 이브 짱이라면\n분명 기뻐할 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}