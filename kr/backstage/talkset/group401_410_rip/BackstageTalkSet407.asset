{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet407","backstageTalkSetId":407,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet407-1","talkText":"이브 짱,\n생일 축하해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet407-2","talkText":"축하드리지 말입니다~!\n여기 선물입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet407-3","talkText":"와앗!\n고마워요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet407-4","talkText":"빨리 열어 봐!\n룽♪ 할 테니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet407-5","talkText":"이건…… 성\n모형이군요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet407-6","talkText":"후훗, 기뻐하는 거\n같아서 다행이야♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}