{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet405","backstageTalkSetId":405,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet405-1","talkText":"미사키 짱…… 괜찮아?\n안 더워?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet405-2","talkText":"아직까지는……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet405-3","talkText":"다음 일은……\n생각하고 싶지 않지만.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet405-4","talkText":"힘들어지면\n언제라도 말해줘야 해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}