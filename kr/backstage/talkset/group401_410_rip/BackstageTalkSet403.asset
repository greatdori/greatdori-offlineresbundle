{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet403","backstageTalkSetId":403,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet403-1","talkText":"전 더울 때 토끼를\n끌어안고 자요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet403-2","talkText":"엥~ 그러면\n더 덥지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet403-3","talkText":"행복하니까\n더위도 잊게 돼요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet403-4","talkText":"호~ 좋겠다~!\n나도 시험해보고 싶다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}