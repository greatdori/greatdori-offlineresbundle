{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet784","backstageTalkSetId":784,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet784-1","talkText":"초코소라빵을 초코코로네라고도 하는데\n「코로네」는 대체 뭘까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet784-2","talkText":"그러고 보니 궁금하네……\n찾아볼까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet784-3","talkText":"음~ 이탈리아어로\n뿔피리가 어원인 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet784-4","talkText":"뿔피리라…… 어디서\n연주회 안 할까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet784-5","talkText":"……아무래도\n너무 마니악하지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}