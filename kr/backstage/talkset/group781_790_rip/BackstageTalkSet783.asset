{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet783","backstageTalkSetId":783,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet783-1","talkText":"린코 씨! 아이스크림\n받아 주실래요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet783-2","talkText":"네…?\n그, 그래도 되나요…?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet783-3","talkText":"네, 상점가 사람들이\n가져가라고 했거든요. 드세요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet783-4","talkText":"아, 그리고 젤리랑\n쿠키도 있어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet783-5","talkText":"마, 마음만 받을게요…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}