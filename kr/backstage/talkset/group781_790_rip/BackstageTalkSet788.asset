{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet788","backstageTalkSetId":788,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet788-1","talkText":"저번에 조금 멀리 나가서\n사진을 찍어 왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet788-2","talkText":"그렇군요……\n봐도 될까요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet788-3","talkText":"물론이야!\n이건 아침 공원에서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet788-4","talkText":"예쁘다……\n공기가 맑아서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet788-5","talkText":"(이제부터 시작할 하루를\n애타게 기다리는 것 같아)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet788-6","talkText":"후후, 마음에 들었어?\n그리고, 이건……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}