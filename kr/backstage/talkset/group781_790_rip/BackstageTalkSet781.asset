{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet781","backstageTalkSetId":781,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet781-1","talkText":"하구미 짱한테 문제 드립니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet781-2","talkText":"별이 폭발하면\n어떻게 될 것 같아~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet781-3","talkText":"엥~! 하구미는\n폭발하는 건 싫어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet781-4","talkText":"그러니까… 음…\n정답은 하구미가 슬퍼한다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet781-5","talkText":"아하핫!\n과연, 그런 답을 할 줄이야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}