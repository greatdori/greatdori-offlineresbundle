{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet785","backstageTalkSetId":785,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet785-1","talkText":"다도부의 다과회, 어떤\n과자 낼지 정했어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet785-2","talkText":"글쎄요……\n이건 어떨까요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet785-3","talkText":"와아,\n귀여운 앙금 과자네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet785-4","talkText":"저번에 리포트한 가게의\n간판 상품이라고 해요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet785-5","talkText":"괜찮다면\n나중에 같이 먹어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}