{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet787","backstageTalkSetId":787,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet787-1","talkText":"츠구미가 추천한 소설,\n읽어 봤어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet787-2","talkText":"그 소설 말이군요.\n어떠셨나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet787-3","talkText":"부드러운 문체에\n빨려 들어가는 느낌이라……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet787-4","talkText":"츠구미가 좋아한다고 말한 이유를\n알 것 같아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet787-5","talkText":"후후, 저도 그렇게 생각해요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}