{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet751","backstageTalkSetId":751,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet751-1","talkText":"저번에 동생들과 근처\n마라톤 대회에 나갔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet751-2","talkText":"추웠지만 어떻게든\n다 같이 완주할 수 있었어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet751-3","talkText":"이게 그때 사진이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet751-4","talkText":"오오, 세 자매가 손을 잡고\n골인하고 있잖아~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet751-5","talkText":"(츠~짱……\n누구인지 알아보기 힘들어.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}