{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet758","backstageTalkSetId":758,"snippets":[{"talkId":1,"characterIds":[32],"voiceId":"TalkSet758-1","talkText":"야시오 씨, 문제예요!\n「봄」으로 유명한……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet758-2","talkText":"비발디인가.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[32],"voiceId":"TalkSet758-3","talkText":"어엇!? 지금 그걸로\n아는 건가요!?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet758-4","talkText":"일반상식 범위야.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}