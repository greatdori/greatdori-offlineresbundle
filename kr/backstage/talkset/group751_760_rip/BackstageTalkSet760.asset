{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet760","backstageTalkSetId":760,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet760-1","talkText":"연기에서 중요한 것은, 역할에\n몰입해서 표현하는 것이지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet760-2","talkText":"나도 할 수 있을까…?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet760-3","talkText":"물론이란다.\n한번 해보렴.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet760-4","talkText":"예를 들면 말이지, 사로잡힌\n공주님은 어떨까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet760-5","talkText":"언젠가 왕자님이 나를 구하러\n올 거라고 믿고 잇써요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet760-6","talkText":"기운 넘치는 공주님이군.\n금방 구하러 올 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}