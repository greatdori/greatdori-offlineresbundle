{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet752","backstageTalkSetId":752,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet752-1","talkText":"가게에 장식할 겨울꽃으로\n추천하는 거 있어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet752-2","talkText":"지금이라면 시클라멘이나\n동백꽃도 어울릴 것 같은데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet752-3","talkText":"다음에 가져올게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet752-4","talkText":"정말? 고마워.\n큰 도움이 됐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}