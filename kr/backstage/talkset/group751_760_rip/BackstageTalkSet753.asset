{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet753","backstageTalkSetId":753,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet753-1","talkText":"에취.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet753-2","talkText":"츄, 츄츄 님!?\n설마 감기에 걸린 건가요!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet753-3","talkText":"아니야, 잠깐 코가\n간지러웠을 뿐이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet753-4","talkText":"파를 가득 넣은 전골로 당장\n몸을 따뜻하게 하죠!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet753-5","talkText":"야채는 안 돼.\n몸이 더 안 좋아질 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}