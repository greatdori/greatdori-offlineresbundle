{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet757","backstageTalkSetId":757,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet757-1","talkText":"카오루 씨, 뭐\n읽고 계세요……?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet757-2","talkText":"이거 말이니?\n이건 내 덧없는 시집이란다.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet757-3","talkText":"봄에 딱 맞는 시를\n모아봤지.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet757-4","talkText":"저, 저도 같이\n봐도 될까요……?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}