{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet715","backstageTalkSetId":715,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet715-1","talkText":"팀 저글링입니다.\n그, 그럼 여기……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet715-2","talkText":"신난다~ 대길!\n미사키 선배 덕분이에요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet715-3","talkText":"아니야 뭘, 난\n아무것도 안 했는데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet715-4","talkText":"후후, 연습은 힘들었지만\n즐거웠죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet715-5","talkText":"짜잔~! 어때?\n룽♪ 해지는 기술~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet715-6","talkText":"하하……코코로 말고도\n낙승으로 해내는 사람이 있다니.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet715-7","talkText":"그럼~ 라스트♪\n마시로 짱이 해보자~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet715-8","talkText":"네, 네……\n에, 에잇!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet715-9","talkText":"아깝네, 마시로 짱\n이제 한 발자국이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet715-10","talkText":"응, 열심히 한 성과네.\n올해도 긍정적으로 힘내자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[26],"voiceId":"TalkSet715-11","talkText":"네, 네.\n열심히 할게요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}