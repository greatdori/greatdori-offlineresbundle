{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet719","backstageTalkSetId":719,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet719-001","talkText":"그래서, 이게 심연의 마검!\n멋지지!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet719-002","talkText":"어…?\n시, 심연의……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet719-003","talkText":"한정 어둠 장비로\n완전완전 레어야~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet719-004","talkText":"그 밖에도 명왕의 갑옷이나\n광휘의 기사 같은 것도 있다구~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet719-005","talkText":"광휘의, 기사……\n조금 멋진 거 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet719-006","talkText":"그치~!? 마시로도\n같이 해보자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}