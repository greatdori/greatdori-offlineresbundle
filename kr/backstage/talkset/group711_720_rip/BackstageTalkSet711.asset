{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet711","backstageTalkSetId":711,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet711-1","talkText":"갈게……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet711-2","talkText":"모두 터지면 포즈하는 거야♪\n으~ 두근거려!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet711-3","talkText":"풍선 속에 들어가다니\n처음이라 그런지 즐겁네요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet711-4","talkText":"설마 풍선 속에 있을 줄이야\n아무도 예상 못할걸~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet711-5","talkText":"후후…… 모두\n놀랄 거라고…… 생각해요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet711-6","talkText":"유, 유키나 선배?\n……아직인가요~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet711-7","talkText":"어라~? 반대로\n줄어들지 않았나요~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[25],"voiceId":"TalkSet711-8","talkText":"유키나 씨……\n힘내세요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet711-9","talkText":"미나토 씨~ 귀여운 고양이\n풍선을 만들었어요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet711-10","talkText":"……!　기다리게 했네……\n이걸로 마지막이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1,7,25,28],"voiceId":"TalkSet711-11","talkText":"오예~! 새해 복\n많이 받으세요~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet711-12","talkText":"고양이는?……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}