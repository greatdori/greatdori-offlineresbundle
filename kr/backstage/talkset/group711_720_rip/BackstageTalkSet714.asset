{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet714","backstageTalkSetId":714,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet714-1","talkText":"모두~\n준비 됐어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet714-2","talkText":"완벽해요. 아야 선배.\n활기차게 가요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5,16,27,30,32],"voiceId":"TalkSet714-3","talkText":"새해 복 많이\n받으세요~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet714-4","talkText":"음. 이거야 말로 The 설날!\n괜찮지 않냐?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet714-5","talkText":"기념으로 사진 찍어요~!\n루이, 좀 더 웃어야지~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet714-6","talkText":"딱히 어떤 표정이든\n상관 없을 거 같은데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet714-7","talkText":"우와~ 루이,\n올해도 진짜 너무 고지식하잖아~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[5],"voiceId":"TalkSet714-8","talkText":"자, 잠깐. 새해 첫날부터\n싸우는 건 좀 아니지~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet714-9","talkText":"아뇨?\n딱히 싸우는 게 아니라.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet714-10","talkText":"그렇지! 있지, 모두\n올해의 목표를 써보는 건 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[32],"voiceId":"TalkSet714-11","talkText":"그거 좋네요!\n목표는 크게 크게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet714-12","talkText":"그러네.  그리고\n모두와 사이좋게야♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}