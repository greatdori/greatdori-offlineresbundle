{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet713","backstageTalkSetId":713,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet713-1","talkText":"나에게 깃든 어둠의 힘이여……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet713-2","talkText":"꿰뚫어라!\n카오틱 샷!!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet713-3","talkText":"와, 아코 짱 대단해~\n다음은 마스키 짱 차례야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet713-4","talkText":"카논 선배랑\n부채에 일러스트를 그렸구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet713-5","talkText":"초코 소라 빵과 해파리야♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet713-6","talkText":"윽…… 너무 귀여워서\n맞출 수 없어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet713-7","talkText":"마스킹 씨……\n맞추지 않으면 장기자랑이 될 수 없어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[33],"voiceId":"TalkSet713-8","talkText":"어쩔 수 없구만……!\n해내주겠어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[3],"voiceId":"TalkSet713-9","talkText":"라스트는 히카와 선배네요.\n이, 이렇게 작은 과녁에.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet713-10","talkText":"……「정사필중」. 올바르게\n쏘인 화살은 반드시……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[24],"voiceId":"TalkSet713-11","talkText":"대, 대단해 사요 씨!\n엄청엄청엄청 멋지다~~!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[22],"voiceId":"TalkSet713-12","talkText":"후훗.\n좋은 1년이 될 것 같네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}