{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet720","backstageTalkSetId":720,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet720-001","talkText":"이, 이게 지금 화제인\n디저트……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet720-002","talkText":"뭐랄까\n대단하네요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet720-003","talkText":"이 각도 완전 잘 찍혀~!\n우와, 난 천재라니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet720-004","talkText":"앗, 하지만 이쪽 각도도\n느낌 좋은데?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet720-005","talkText":"으~음, 어떤 사진을\n올릴지 고민되네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet720-006","talkText":"……키리가야 씨, 슬슬\n먹어도 될까요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}