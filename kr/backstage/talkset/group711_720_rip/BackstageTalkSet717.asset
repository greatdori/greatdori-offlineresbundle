{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet717","backstageTalkSetId":717,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet717-001","talkText":"이브 선배의 땋은 머리,\n귀여워요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet717-002","talkText":"저도 봄 느낌으로 스타일링\n해보고 싶어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet717-003","talkText":"머리카락을 굵게 땋아보는 건 어때요?\n아주 쉬워요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet717-004","talkText":"그런가요?\n다음에 가르쳐 주세요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet717-005","talkText":"물론이에요!\n함께 연습해요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}