{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet166","backstageTalkSetId":166,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet166-1","talkText":"(오늘은…… 돌아가면……\n아코 짱이랑 게임……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet166-2","talkText":"어라? 린코!\n엄청 즐거워 보이는걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet166-3","talkText":"그 웃는 얼굴, 멋져!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}