{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet27","backstageTalkSetId":27,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet27-1","talkText":"편의점 디저트는 나날이\n진화하고 있다구요~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet27-2","talkText":"아, 아르바이트하는 데에 히마리가\n좋아할 만한 신제품이 나왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet27-3","talkText":"정말인가요!?\n체크해 놔야 해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}