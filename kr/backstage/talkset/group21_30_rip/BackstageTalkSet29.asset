{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet29","backstageTalkSetId":29,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet29-1","talkText":"언니, 역 앞에\n라멘 가게 봤어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet29-2","talkText":"아니, 못 봤는데,\n뭔가 있었나?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet29-3","talkText":"「본격적 쇼유 돈코츠」를\n기간 한정 판매한대!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet29-4","talkText":"오, 그거 궁금한걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}