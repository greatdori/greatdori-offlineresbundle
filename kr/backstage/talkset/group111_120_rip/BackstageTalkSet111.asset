{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet111","backstageTalkSetId":111,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet111-1","talkText":"저기, 리미.\n하나~둘하고 물어보자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet111-2","talkText":"으, 응……!\n하나~둘……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3,8],"voiceId":"TalkSet111-3","talkText":"카오루 선배는 왜 그렇게\n멋진 건가요!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet111-4","talkText":"카오루 선배는 왜 그렇게\n멋진 건가요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet111-5","talkText":"후후…… 한 마디로\n말하는 건 어렵지만……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet111-6","talkText":"굳이 말한다면 그래……\n덧없기 때문이겠구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3,8],"voiceId":"TalkSet111-7","talkText":"머, 멋져……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet111-8","talkText":"……너희는\n어째서 그렇게 되니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}