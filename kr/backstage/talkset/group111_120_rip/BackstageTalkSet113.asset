{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet113","backstageTalkSetId":113,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet113-1","talkText":"아, 아야 씨랑 카논 씨다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet113-2","talkText":"어라, 토모에 짱이랑\n히마리 짱, 아르바이트는?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet113-3","talkText":"둘 다 오늘 일하는\n날이었지……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8,9],"voiceId":"TalkSet113-4","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet113-5","talkText":"으악~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet113-6","talkText":"완전 까먹고 있었어!\n뛰자, 히마리!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[8],"voiceId":"TalkSet113-7","talkText":"토, 토모에, 기다려~!\n버리고 가지 마~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}