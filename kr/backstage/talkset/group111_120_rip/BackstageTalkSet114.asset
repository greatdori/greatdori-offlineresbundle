{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet114","backstageTalkSetId":114,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet114-1","talkText":"사아야네는\n아르바이트 모집 안 해?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet114-2","talkText":"음~ 있으면 편하긴 하겠지만\n지금은 모집하지 않는 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet114-3","talkText":"그런가~……\n아쉽다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet114-4","talkText":"모카, 직원용으로 나오는\n빵을 얻으려고 하는 거지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet114-5","talkText":"그리고 편의점 아르바이트는\n어떡할 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet114-6","talkText":"우우~\n혼나 버렸어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}