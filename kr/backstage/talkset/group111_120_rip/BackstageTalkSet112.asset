{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet112","backstageTalkSetId":112,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet112-1","talkText":"새로 나온 버거 이름은 다른\n상품이랑 헷갈리지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet112-2","talkText":"맞아! 비슷한 이름이\n너무 많지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet112-3","talkText":"난 항상 틀리지 않았는지\n불안해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet112-4","talkText":"손님들께서도 가끔,\n혼란스러워하시지……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet112-5","talkText":"정말~! 이름 생각한 녀석은\n나와라~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}