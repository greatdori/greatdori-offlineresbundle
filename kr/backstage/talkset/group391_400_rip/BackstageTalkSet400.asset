{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet400","backstageTalkSetId":400,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet400-1","talkText":"선풍기에 아~ 하고 소리 내 본 적\n어릴 때 있지 않았습니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet400-2","talkText":"목소리가 이상하게 들리게 되죠.\n저는 한 적 없어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet400-3","talkText":"하지만…… 히나는 요즘도\n가끔 하고 있어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet400-4","talkText":"아하하……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}