{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet393","backstageTalkSetId":393,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet393-1","talkText":"오늘은 덥네요……\n카오루 선배는 괜찮으세요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet393-2","talkText":"후후, 모든 건\n마음먹기 나름이란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet393-3","talkText":"더울 때는 설산에 있는\n자신을 상상하면 된단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet393-4","talkText":"여, 역시, 카오루 선배……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}