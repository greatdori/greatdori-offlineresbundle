{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet394","backstageTalkSetId":394,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet394-1","talkText":"더워~……\n아이스크림 같은 거 먹고 싶어……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet394-2","talkText":"실은 있지, 우리 가게에서\n빙수를 시작했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet394-3","talkText":"엥, 진짜!?\n무조건 간다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet394-4","talkText":"후훗,\n기다리고 있을게요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}