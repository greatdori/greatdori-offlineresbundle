{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet391","backstageTalkSetId":391,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet391-1","talkText":"저기 있지, 돌아갈 때\n아이스크림 사도 돼?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet391-2","talkText":"용돈이 부족하다고\n하지 않았었나?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet391-3","talkText":"응, 그래서 저기……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet391-4","talkText":"하~…… 하는 수 없네.\n오늘 한 번만이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}