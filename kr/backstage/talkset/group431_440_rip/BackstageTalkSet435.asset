{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet435","backstageTalkSetId":435,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet435-1","talkText":"내일은 하구미 생일이네.\n어떻게 축하해 줄까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet435-2","talkText":"나는 하구미를 위해 장미와\n자작 시를 전할 생각이란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet435-3","talkText":"나는 불꽃놀이랑 퍼레이드로\n축하해 줄 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet435-4","talkText":"그, 그러면 음……\n나는 어떡하지……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet435-5","talkText":"카논 씨, 진정하세요.\n평범하게 축하하자고요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}