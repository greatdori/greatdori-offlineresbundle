{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet438","backstageTalkSetId":438,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet438-1","talkText":"내일은 코코롱의\n생일이네~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet438-2","talkText":"선물,\n기뻐해 줄까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet438-3","talkText":"코코로라면 뭘 받아도\n기뻐할 거예요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet438-4","talkText":"우리의 손으로 최고의 생일을\n연출하도록 하자꾸나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}