{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet437","backstageTalkSetId":437,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet437-1","talkText":"하구미,\n생일 축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet437-2","talkText":"오늘은 하구한테 잔뜩\n대접해줄게~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet437-3","talkText":"대접!?\n뭘까, 기대된다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet437-4","talkText":"우선은 어깨 주물러 주기~\n그리고 나서 같이 놀고~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet437-5","talkText":"배가 고프면 크로켓\n빵도 만들 테니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet437-6","talkText":"굉장하다~! 즐거운\n생일이 될 것 같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}