{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet439","backstageTalkSetId":439,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet439-1","talkText":"코코롱, 생일\n축하해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet439-2","talkText":"자, 여기.\n생일 선물.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet439-3","talkText":"고마워!\n뭐가 들어있을까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet439-4","talkText":"우리의 「웃는 얼굴의 근원」을\n선물로 해봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet439-5","talkText":"나는 「덧없음의 근원」을\n담아봤단다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[11],"voiceId":"TalkSet439-6","talkText":"무척 멋진\n선물이야, 기쁜걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}