{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet432","backstageTalkSetId":432,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet432-1","talkText":"드디어 내일은\n카스미 생일이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet432-2","talkText":"카스미한테 들키지 않았지?\n서프라이즈 말이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet432-3","talkText":"응, 괜찮아. 카스미 짱도\n깜짝 놀라려나?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet432-4","talkText":"선물도\n기뻐했으면 좋겠다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet432-5","talkText":"후훗, 파티 준비도\n이제 조금 남았으니까 힘내자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}