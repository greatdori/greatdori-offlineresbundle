{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet194","backstageTalkSetId":194,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet194-1","talkText":"마야 짱, 기타의\n상태가 좀 이상한 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet194-2","talkText":"넥 조정을\n해 놓겠습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet194-3","talkText":"마야 짱.\n다음 방송 대본이……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet194-4","talkText":"노란색 표지로 된 거지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet194-5","talkText":"마야 씨,\n반창고 가지고 계신가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet194-6","talkText":"가방 속에 있지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[18],"voiceId":"TalkSet194-7","talkText":"(마야 짱이 있어서\n다행이야……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}