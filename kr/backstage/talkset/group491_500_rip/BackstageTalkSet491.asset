{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet491","backstageTalkSetId":491,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet491-1","talkText":"해피 할로윈!\n모두 즐겨보자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet491-2","talkText":"아아, 덧없는 할로윈을\n만들어 보자꾸나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet491-3","talkText":"찬성~!\n하구미는 술래잡기 하고 싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet491-4","talkText":"술래라니…… 전통적 요소가\n좀 세지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet491-5","talkText":"나는 할로윈 과자로\n경단 갖고 왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet491-6","talkText":"그러니까\n전통적 요소가 너무 세다니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}