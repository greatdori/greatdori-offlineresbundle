{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet492","backstageTalkSetId":492,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet492-1","talkText":"내일은 미사키의 생일이군.\n어떻게 축하해 주면 좋겠니.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet492-2","talkText":"미~군이 기뻐할만한\n선물을 주고 싶은걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet492-3","talkText":"나한테 무척 멋진\n생각이 있어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet492-4","talkText":"후훗, 분명 엄청\n기뻐할 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}