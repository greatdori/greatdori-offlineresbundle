{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet500","backstageTalkSetId":500,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet500-1","talkText":"히마리 짱,\n생일 축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet500-2","talkText":"생일 선물이야.\n괜찮다면 받아줘.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet500-3","talkText":"고맙습니다!\n예쁜 하바리움이네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet500-4","talkText":"리미 짱이랑 사러 갔다가\n첫눈에 반했거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet500-5","talkText":"마음에 들었으면\n좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet500-6","talkText":"완전 마음에 들어~!\n엄청 소중히 간직할게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}