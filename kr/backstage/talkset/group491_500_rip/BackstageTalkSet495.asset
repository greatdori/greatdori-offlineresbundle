{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet495","backstageTalkSetId":495,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet495-1","talkText":"내일은 린코 생일이야.\n아코, 선물은?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet495-2","talkText":"완벽해요! 린린이\n분명 기뻐하겠지~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet495-3","talkText":"저도 확인해봤는데\n그걸로 정말 괜찮나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet495-4","talkText":"괜찮다니까요~!\n아코를 팍하고 믿어보세요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet495-5","talkText":"린코가 기뻐하는 선물이라면\n아코한테 맡기는 게 제일이니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}