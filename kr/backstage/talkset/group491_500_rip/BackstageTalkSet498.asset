{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet498","backstageTalkSetId":498,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet498-1","talkText":"훗훗후~ 올해도\n준비는 완벽하구만~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet498-2","talkText":"모카는 히마리 생일이\n되면 생기가 돋는다니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet498-3","talkText":"어떤 의미로는 가장 기대하고\n있는 것 같아……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet498-4","talkText":"아, 아무튼 히마리 짱이\n기뻐했으면 좋겠다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}