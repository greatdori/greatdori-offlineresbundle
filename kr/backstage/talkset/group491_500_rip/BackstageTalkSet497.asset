{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet497","backstageTalkSetId":497,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet497-1","talkText":"시로카네 씨, 생일\n축하드리지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet497-2","talkText":"이건 마야 씨와 둘이서\n고른 선물이에요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet497-3","talkText":"예쁜 펜던트네요……\n정말 받아도 될까요……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet497-4","talkText":"시로카네 씨한테 의상 상담을\n하고 있으니 말입니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet497-5","talkText":"저도 학생회에서 엄~청\n신세지고 있으니까요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[25],"voiceId":"TalkSet497-6","talkText":"고맙습니다……\n소중히 간직할게요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}