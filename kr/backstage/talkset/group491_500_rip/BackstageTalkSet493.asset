{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet493","backstageTalkSetId":493,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet493-1","talkText":"해피 버스데이 미사키.\n우리가 준비한 선물이란다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet493-2","talkText":"고맙습니다.\n아, 이 인형은……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet493-3","talkText":"미사키랑 미셸이야!\n우리가 만들었어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet493-4","talkText":"미셸이랑 미~군은\n엄청 친하니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet493-5","talkText":"역시 양모 펠트는\n깔끔하게 만들기 어렵네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet493-6","talkText":"아뇨, 엄청 잘 만들었어요.\n모두 정말로 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}