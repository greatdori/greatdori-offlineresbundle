{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet496","backstageTalkSetId":496,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet496-1","talkText":"린코~!\n해피 버스데이!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet496-2","talkText":"서프라이즈긴 했는데\n너무 놀래킨 건 아닐까요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet496-3","talkText":"아뇨…… 아니에요……\n기뻐요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet496-4","talkText":"자, 여기! 린린한테 주는\n선물이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet496-5","talkText":"앗, NFO 굿즈……\n나온지 얼마 안 된……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet496-6","talkText":"선물은 아코한테 부탁하고\n케이크는 우리가 만들었어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet496-7","talkText":"케이크도, 맛있어 보여요……\n정말로…… 기뻐요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}