{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet87","backstageTalkSetId":87,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet87-1","talkText":"미셸~!\n어디 놀러 가자!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet87-2","talkText":"아니, 나는\n갈아입고 싶은데……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet87-3","talkText":"그럼 미셸이\n갈아입을 때까지 기다리자꾸나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet87-4","talkText":"그런 게\n아니라고 생각합니다만……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet87-5","talkText":"하구미, 오늘은 밥 먹으러\n가고 싶어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet87-6","talkText":"(빨리 갈아입게 해 줘……)","lipAnimation":"","fontColorType":0,"fontSizeType":1,"balloonType":2}]}}