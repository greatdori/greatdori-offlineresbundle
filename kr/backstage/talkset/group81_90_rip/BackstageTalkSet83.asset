{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet83","backstageTalkSetId":83,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet83-1","talkText":"어라~?\n아야 짱이랑 이브 짱은?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet83-2","talkText":"이브 씨는\n모델 스케줄이지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet83-3","talkText":"아야 짱은 잡지\n인터뷰 스케줄이야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet83-4","talkText":"엥~ 빨리 다섯이서\n연주하고 싶은데~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}