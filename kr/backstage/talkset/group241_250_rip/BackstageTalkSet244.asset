{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet244","backstageTalkSetId":244,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet244-1","talkText":"빵이 좀 남았는데……\n괜찮으시면 좀 드실래요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet244-2","talkText":"고맙구나. 아아~……\n이 얼마나 달콤한 향이니.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet244-3","talkText":"저, 저기……\n카레빵인데요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet244-4","talkText":"후후…… 그럼에도\n달콤한 향이 나는 것이지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}