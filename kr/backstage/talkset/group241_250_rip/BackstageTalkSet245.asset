{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet245","backstageTalkSetId":245,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet245-1","talkText":"아아……\n이 무슨 덧없음인가……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet245-2","talkText":"카, 카오루 씨,\n무슨 일이신가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet245-3","talkText":"아아, 코코로가 소개해 준\n책을 읽고 있었단다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet245-4","talkText":"(우, 울고 있어……\n그렇게 좋은 이야기였구나.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}