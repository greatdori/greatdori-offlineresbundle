{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet259","backstageTalkSetId":259,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet259-1","talkText":"이거 봐봐, 토모에!\n이 옷 귀엽지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet259-2","talkText":"그래, 히마리한테\n잘 어울릴 것 같네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet259-3","talkText":"토모에는 이 옷이\n어울릴 것 같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet259-4","talkText":"또 모두한테\n어울리는 옷이 없으려나~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}