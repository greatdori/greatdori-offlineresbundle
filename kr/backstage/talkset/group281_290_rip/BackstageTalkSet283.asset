{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet283","backstageTalkSetId":283,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet283-1","talkText":"하구미 짱은 좀 더\n하늘하늘한 옷도 어울릴 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet283-2","talkText":"그, 그러려나?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet283-3","talkText":"응, 그럴 거야!\n다음에 같이 사러 가자!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}