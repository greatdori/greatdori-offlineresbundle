{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet284","backstageTalkSetId":284,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet284-1","talkText":"음~…… 그 댄스는\n금방 실패하게 돼……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet284-2","talkText":"하구미 짱,\n요령 같은 거 없어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet284-3","talkText":"그게, 허리를 꾸욱~\n하면 될 것 같아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet284-4","talkText":"좀 더 자세하게\n괜찮을까……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}