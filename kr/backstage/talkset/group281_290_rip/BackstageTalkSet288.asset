{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet288","backstageTalkSetId":288,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet288-1","talkText":"아야, 뭐 보는 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet288-2","talkText":"전에 찍은 사진을\n되짚어 보고 있어. 자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet288-3","talkText":"오, 역시 아야!\n엄청 귀엽게 찍혔네♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}