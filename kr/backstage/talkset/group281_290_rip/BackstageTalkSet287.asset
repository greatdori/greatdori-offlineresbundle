{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet287","backstageTalkSetId":287,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet287-1","talkText":"리사 짱 귀걸이,\n귀여워~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet287-2","talkText":"고마워! 다음에 아야랑\n쇼핑하러 가고 싶은걸~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet287-3","talkText":"와앗!\n가고 싶어, 가고 싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}