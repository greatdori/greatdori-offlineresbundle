{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet281","backstageTalkSetId":281,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet281-1","talkText":"마이크는\n어떤 구조로 된 걸까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet281-2","talkText":"그게 말입니다~\n애초에 소리라는 건……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet281-3","talkText":"자, 잠깐 기다려!\n메모지 준비할게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}