{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet290","backstageTalkSetId":290,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet290-1","talkText":"내일 일정은……\n어라, 프리네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet290-2","talkText":"요즘은 스케줄도 많았으니까,\n드디어 쉬겠다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet290-3","talkText":"바쁜 건 감사하지만\n가끔은 휴식도 가지고 싶지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet290-4","talkText":"맞아~ 맞아~! 내일은\n맘껏 놀 거야~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}