{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet650","backstageTalkSetId":650,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet650-1","talkText":"내일 치사토 짱하고 역 앞의\n카페에 갈 건데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet650-2","talkText":"괜찮으면 사요 짱도\n같이 갈래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet650-3","talkText":"카페…… 괜찮네요.\n같이 가고 싶어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet650-4","talkText":"아야 짱하고 린코 짱한테도\n이야기해 볼게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}