{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet647","backstageTalkSetId":647,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet647-1","talkText":"배경화면이 토끼 사진이네!\n오타에 짱네 아이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet647-2","talkText":"네, 옷짱이에요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet647-3","talkText":"얼마 전까지는\n햄버그 사진이었어요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet647-4","talkText":"나도 언니\n사진을 배경화면으로 해야지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}