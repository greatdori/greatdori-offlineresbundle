{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet468","backstageTalkSetId":468,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet468-1","talkText":"토모에 짱은 오늘도\n기운이 넘치는구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet468-2","talkText":"기운 넘치죠. 세타 선배도\n반짝거리고 있네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet468-3","talkText":"그 반짝거리는 배우에\n흥미는 없는 건가?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}