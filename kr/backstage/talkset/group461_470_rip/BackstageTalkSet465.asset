{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet465","backstageTalkSetId":465,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet465-1","talkText":"모카, 생일 축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet465-2","talkText":"올해 선물은\n차원이 다르다구~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet465-3","talkText":"오오~ 왠지 여러 가지\n만화가 들어있네요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet465-4","talkText":"각자가 가장 추천하는 만화를\n담아봤어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet465-5","talkText":"내 거는 원래 히마리가\n가르쳐 준 거긴 하지만.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet465-6","talkText":"아직 안 읽어봤을 법한 걸\n골라봤는데 어때?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet465-7","talkText":"전부 재밌어 보여~\n모카 짱은 엄청 감사하고 있답니다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}