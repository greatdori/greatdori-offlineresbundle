{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet463","backstageTalkSetId":463,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet463-1","talkText":"가을 옷은 입는 기간이\n너무 짧은 거 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet463-2","talkText":"귀여운 옷이 많아서","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet463-3","talkText":"너무 많이 사게 되는 것도\n있을 것 같아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet463-4","talkText":"맞아! 그렇다니까!\n진짜 늘어나기만 하고……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}