{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet464","backstageTalkSetId":464,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet464-1","talkText":"모카 생일 선물은\n그걸로 괜찮으려나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet464-2","talkText":"괜찮은 거 같지 않아?\n모카도 분명 기뻐할 거야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet464-3","talkText":"응응, 모카가 기뻐하는 표정이\n눈에 선해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet464-4","talkText":"후훗, 맘에 들었으면\n좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}