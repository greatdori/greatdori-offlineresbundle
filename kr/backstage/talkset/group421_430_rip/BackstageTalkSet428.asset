{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet428","backstageTalkSetId":428,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet428-1","talkText":"코코로는 언제나 활기차네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet428-2","talkText":"당연하지!\n활기는 웃는 얼굴의 근간인걸!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet428-3","talkText":"아하하, 그렇네☆\n나도 본받아야 해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}