{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet429","backstageTalkSetId":429,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet429-1","talkText":"하~ 다 같이 쇼핑해서\n즐거웠어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet429-2","talkText":"그런 가게는\n가 본 적 없어서 신선했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet429-3","talkText":"선물 고르는 건 예정보다\n시간이 걸렸네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet429-4","talkText":"아코 짱…… 기뻐해,\n줄까요……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet429-5","talkText":"다 같이 고른 거니까,\n분명, 괜찮다니까☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}