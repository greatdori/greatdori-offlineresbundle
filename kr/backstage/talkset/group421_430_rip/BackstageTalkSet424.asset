{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet424","backstageTalkSetId":424,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet424-1","talkText":"앗! 지금 좋은 느낌의\n소절이 떠올랐어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet424-2","talkText":"기, 기다려, 오타에 짱.\n지금 녹음할 테니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}