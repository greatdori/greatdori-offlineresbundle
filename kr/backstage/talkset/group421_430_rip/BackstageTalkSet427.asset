{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet427","backstageTalkSetId":427,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet427-1","talkText":"고마워, 마야 짱.\n언제나 신세를 지네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet427-2","talkText":"이 정도는\n별거 아닙니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet427-3","talkText":"답례로 차라도 어때?\n가고 싶은 데가 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet427-4","talkText":"좋지 말입니다!\n저도 가고 싶습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}