{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet421","backstageTalkSetId":421,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet421-1","talkText":"이브 짱, 다음 근무시간에\n관한 건데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet421-2","talkText":"기다려주세요,\n지금 수첩을 꺼낼게요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet421-3","talkText":"와~ 일정이 잔뜩이네!\n바쁘구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet421-4","talkText":"네! 하루하루가\n무척 충실해요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}