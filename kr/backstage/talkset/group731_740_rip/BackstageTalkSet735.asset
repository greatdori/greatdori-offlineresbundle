{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet735","backstageTalkSetId":735,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet735-1","talkText":"뭐 읽고 계세요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet735-2","talkText":"그림책이야. 이 이야기는 마음이\n따뜻해지거든~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet735-3","talkText":"와~ 멋지네요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet735-4","talkText":"……아, 이 여자아이\n카논 씨랑 닮은 것 같아요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet735-5","talkText":"우에엥……\n그, 그런가~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}