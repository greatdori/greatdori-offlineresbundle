{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet733","backstageTalkSetId":733,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet733-1","talkText":"이번 가을 축제에서\n가마 짊어지게 됐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet733-2","talkText":"오~ 대단하네.\n열심히 해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet733-3","talkText":"응! 미셸이랑\n같이 열심히 할게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet733-4","talkText":"(앗……\n나도……!?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet733-5","talkText":"아!\n미~군도 오는 건 어때!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet733-6","talkText":"무리야 무리……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}