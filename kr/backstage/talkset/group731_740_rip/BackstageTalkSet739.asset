{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet739","backstageTalkSetId":739,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet739-1","talkText":"뭔가 즐거운 일\n없을까~","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet739-2","talkText":"그렇다면 즐거운 일을\n찾으러 가보자!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet739-3","talkText":"오오~\n모험이 시작될 것 같구만~","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet739-4","talkText":"당장 미셸 기구를\n준비해 올게!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet739-5","talkText":"신난다!\n하늘 여행으로 떠나자~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}