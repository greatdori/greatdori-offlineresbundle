{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet734","backstageTalkSetId":734,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet734-1","talkText":"평소에는…… 어떤 마음으로\n노래하시나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet734-2","talkText":"어떤 마음이라니……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet734-3","talkText":"……딱히 남한테 말할\n정도는 아니야.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet734-4","talkText":"(머, 멋지다……)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}