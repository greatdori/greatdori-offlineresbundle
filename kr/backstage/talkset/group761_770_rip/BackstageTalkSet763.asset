{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet763","backstageTalkSetId":763,"snippets":[{"talkId":1,"characterIds":[31],"voiceId":"TalkSet763-1","talkText":"음…","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[35],"voiceId":"TalkSet763-2","talkText":"What's up?\n무슨 고민 있어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet763-3","talkText":"마스키 케이크에 어울리는\n음료를 생각하고 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[35],"voiceId":"TalkSet763-4","talkText":"좋아하는 걸로 마시면 되잖아.\n…핫 밀크 같은 거.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet763-5","talkText":"후후… 그렇게 할게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}