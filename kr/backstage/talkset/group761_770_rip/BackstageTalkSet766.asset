{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet766","backstageTalkSetId":766,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet766-1","talkText":"토모에 짱,\n뭐 보고 있어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet766-2","talkText":"수족관 사진집이야.\n보면 시원하거든.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet766-3","talkText":"와아, 그러네.\n바닷속에 있는 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet766-4","talkText":"모처럼이니 다른 멤버들도\n불러서 같이 볼까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}