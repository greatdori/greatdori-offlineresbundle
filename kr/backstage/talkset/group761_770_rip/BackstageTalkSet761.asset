{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet761","backstageTalkSetId":761,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet761-1","talkText":"으으~ 훌쩍훌쩍.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet761-2","talkText":"모카 선배\n왜 그러세요~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet761-3","talkText":"좋아하는 만화 연재가\n끝났거든~ 엉엉엉~~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet761-4","talkText":"아, 그 작가는 다른 잡지에서\n새로 연재 시작한 모양이에요~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet761-5","talkText":"뭐, 뭐라고~!?\n나나미 찡은 정보가 밝네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}