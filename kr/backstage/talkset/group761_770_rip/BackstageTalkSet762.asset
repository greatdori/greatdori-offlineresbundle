{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet762","backstageTalkSetId":762,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet762-1","talkText":"나도 하나조노 랜드에\n가보고 싶어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet762-2","talkText":"하나조노 랜드는 떠올리면\n언제든 입장 가능해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet762-3","talkText":"무척 멋지다!\n생각해 볼게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet762-4","talkText":"재미있어 보이는\n롤러 코스터가 있네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet762-5","talkText":"팝콘 가게가 있어!\n저기서는 퍼레이드도 해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}