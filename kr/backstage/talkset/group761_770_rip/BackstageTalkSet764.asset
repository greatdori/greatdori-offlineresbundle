{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet764","backstageTalkSetId":764,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet764-1","talkText":"하아~ 세션\n즐거웠슴다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet764-2","talkText":"네! 땀 좀\n흘렸습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[33],"voiceId":"TalkSet764-3","talkText":"맞다, 끝났으니\n아사히유에 가지 않으실래요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet764-4","talkText":"여름에는 목욕 후의\n라무네가 최고임다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet764-5","talkText":"좋습니다,\n갑시다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}