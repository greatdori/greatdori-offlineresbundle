{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet767","backstageTalkSetId":767,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet767-1","talkText":"…후우.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet767-2","talkText":"오쿠사와 씨,\n기운이 없네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet767-3","talkText":"조금 전에 헬로해피 멤버들하고 유빙을\n보고 왔거든요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet767-4","talkText":"…꽤나 활동감 넘치는\n여름 나기네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}