{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet768","backstageTalkSetId":768,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet768-1","talkText":"이거 봐,\n사진 잘 찍었어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet768-2","talkText":"무슨 사진이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet768-3","talkText":"후~스케가\n수박 먹는 사진!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet768-4","talkText":"진짜 햄스터랑\n똑같다니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet768-5","talkText":"(그러게…\n조금 닮은 것 같아.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}