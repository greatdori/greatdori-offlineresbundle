{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet765","backstageTalkSetId":765,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet765-1","talkText":"저기, 이 밀짚모자\n귀엽지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet765-2","talkText":"그러네, 해바라기\n장식이 달려서 여름 분위기가 나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet765-3","talkText":"어쩌지~\n그냥 살까~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet765-4","talkText":"후후, 그러면 같이\n사러 갈래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}