{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet352","backstageTalkSetId":352,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet352-1","talkText":"……어라?\n이 냄새는……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet352-2","talkText":"앗, 사요 씨!\n같이 드실래요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet352-3","talkText":"……그렇게 말한다면\n조금만 먹도록 할까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}