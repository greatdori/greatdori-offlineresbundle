{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet357","backstageTalkSetId":357,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet357-1","talkText":"오늘 댄스부 연습은\n잘했잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet357-2","talkText":"에헤헤, 정말!?\n……이게 아니라.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet357-3","talkText":"이 몸의 암흑의 힘이 있다면\n그러니까……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet357-4","talkText":"으으~ 좋은 대사가\n안 떠올라~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}