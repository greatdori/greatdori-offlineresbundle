{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet351","backstageTalkSetId":351,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet351-1","talkText":"어제 히나랑\n외출했다면서?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet351-2","talkText":"그렇긴 한데…… 히나한테\n들으셨나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet351-3","talkText":"응, 엄청 크게 말하면서\n몇 번이나 이야기했어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet351-4","talkText":"히나는 정말\n즐거웠나 봐~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}