{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet356","backstageTalkSetId":356,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet356-1","talkText":"리사 언니, 다음 댄스부\n연습은 뭐 하더라?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet356-2","talkText":"분명, 통합 연습이었든가.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet356-3","talkText":"그렇지!\n열심히 해야 해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}