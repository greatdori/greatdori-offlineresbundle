{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet353","backstageTalkSetId":353,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet353-1","talkText":"저번에 언니랑\n놀러 갔어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet353-2","talkText":"엄청 신나고\n즐거웠어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet353-3","talkText":"그래, 잘됐네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet353-4","talkText":"(나도 가끔은 히나랑……\n……어떡하면 좋을까.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}