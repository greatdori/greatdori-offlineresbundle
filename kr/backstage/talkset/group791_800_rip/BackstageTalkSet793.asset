{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet793","backstageTalkSetId":793,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet793-1","talkText":"추울 때는 라이브!\n그렇죠, 유키나 선배!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet793-2","talkText":"…어떤 관계가\n있는 거야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet793-3","talkText":"물론 라이브로 추위를\n날려버리는 거예요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet793-4","talkText":"여름에도 비슷한 소리를\n들은 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}