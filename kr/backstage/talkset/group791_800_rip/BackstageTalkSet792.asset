{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet792","backstageTalkSetId":792,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet792-1","talkText":"루이! 내일 한가해?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet792-2","talkText":"…왜?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet792-3","talkText":"이유는 묻지 말고!\n한가한지 아닌지 물어봤잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet792-4","talkText":"…일정 비었어.\n시간은 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet792-5","talkText":"좋아~ 그러면 내일은 모니카 멤버끼리 전골 파티! 결정!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet792-6","talkText":"…예정이 있던 게\n떠올랐어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet792-7","talkText":"거짓말인 거 알거든!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}