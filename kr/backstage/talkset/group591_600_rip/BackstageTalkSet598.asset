{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet598","backstageTalkSetId":598,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet598-1","talkText":"저기 있지, 이 돌\n토끼처럼 보이지 않아!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet598-2","talkText":"와, 귀엽다!\n만나러 가자! 지금 당장.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet598-3","talkText":"에엥!? 이 공원은\n엄청 먼데!?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet598-4","talkText":"와, 벌써 갔어!\n오타에, 기다려~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}