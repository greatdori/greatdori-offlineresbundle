{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet600","backstageTalkSetId":600,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet600-1","talkText":"이번에 부에서 새로운 공연을\n하기로 했지 말입니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet600-2","talkText":"이번엔\n어떤 이야기야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet600-3","talkText":"외국 유명 밴드를\n모델로 잡았습니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet600-4","talkText":"어떤 연출을 하는 걸까.\n꽤 참고가 될 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}