{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet599","backstageTalkSetId":599,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet599-1","talkText":"이 이후에 츠구미 씨네\n가게에서 아르바이트해요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet599-2","talkText":"부활동도 많이 들어가 있는데\n힘들지 않아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet599-3","talkText":"변신술을 단련한\n미사키 씨 정도는……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet599-4","talkText":"아, 그거 설마\n미셸 말하는 거야……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}