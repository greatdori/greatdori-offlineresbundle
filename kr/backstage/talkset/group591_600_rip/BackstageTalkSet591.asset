{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet591","backstageTalkSetId":591,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet591-1","talkText":"이 봄 원피스\n리미 씨한테 어울리겠어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet591-2","talkText":"그래? 너무\n귀여운 거 아닐까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet591-3","talkText":"아뇨, 무척 잘 어울린다고\n생각해요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}