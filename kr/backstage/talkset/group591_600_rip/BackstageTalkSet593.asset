{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet593","backstageTalkSetId":593,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet593-1","talkText":"지금 정도의 날씨가\n개를 산책시키기에 가장 좋지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet593-2","talkText":"시라사기 씨는 개를 기르고\n계셨었죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet593-3","talkText":"응. 다음에 같이\n산책하러 가지 않을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet593-4","talkText":"……! 제가 방해가\n안 된다면……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}