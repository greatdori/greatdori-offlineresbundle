{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet597","backstageTalkSetId":597,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet597-1","talkText":"츠구! 또 애들이랑\n별 보러 가지 않을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet597-2","talkText":"나, 별자리 책 읽어서\n이것 저것 가르쳐줄 수 있을 거 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet597-3","talkText":"굉장해~!\n나도 읽어봐야지.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet597-4","talkText":"그러면 다음에\n가지고 올게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}