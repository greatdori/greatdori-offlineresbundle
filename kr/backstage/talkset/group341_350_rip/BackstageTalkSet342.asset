{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet342","backstageTalkSetId":342,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet342-1","talkText":"오쿠사와 씨, 양모 펠트\n만들 수 있으시죠……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet342-2","talkText":"만들 수 있어요~ 혹시\n린코 선배도 흥미 있으신가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet342-3","talkText":"네, 네…… 근데……\n어려워 보여서요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet342-4","talkText":"아뇨아뇨, 의상을 만들 정도라면\n완전 식은 죽 먹기라고 생각해요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}