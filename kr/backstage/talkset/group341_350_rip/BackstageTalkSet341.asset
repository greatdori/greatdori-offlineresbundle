{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet341","backstageTalkSetId":341,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet341-1","talkText":"Roselia는 우리랑\n방향성이 정반대네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet341-2","talkText":"어떻게 생각하실지\n솔직히 걱정이에요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet341-3","talkText":"확실히\n방향성은 다르지만……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet341-4","talkText":"그래서 밴드라는 게\n재밌는 거 아니겠어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}