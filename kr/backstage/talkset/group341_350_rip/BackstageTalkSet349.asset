{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet349","backstageTalkSetId":349,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet349-1","talkText":"어때? 다음 의상의\n이미지는 정했어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet349-2","talkText":"이제 곧……\n이미지가 떠오를 것 같아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet349-3","talkText":"그래. 기대하고 있을게.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}