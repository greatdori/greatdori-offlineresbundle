{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet344","backstageTalkSetId":344,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet344-1","talkText":"사요, 빠르네.\n연습은 좀 더 뒤잖아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet344-2","talkText":"개인 연습을 하고 있었어요.\n그러는 미나토 씨는요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet344-3","talkText":"후후, 생각하는 건\n같은 것 같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}