{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet304","backstageTalkSetId":304,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet304-1","talkText":"베이스 줄을 바꿔야 할 때는\n언제려나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet304-2","talkText":"어렵습니다…… 베이스는\n꽤 개인차가 있으니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet304-3","talkText":"자신한테 맞는 타이밍을\n찾는 게 좋을지도 모르겠습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet304-4","talkText":"그런 거구나.\n공부가 됐어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}