{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet305","backstageTalkSetId":305,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet305-1","talkText":"아까 상투를 튼\n사람이랑 지나쳤어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet305-2","talkText":"사극 촬영일까요?\n저도 언젠가 나가고 싶어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet305-3","talkText":"후후, 언젠가\n나갈 수 있으면 좋겠네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}