{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet303","backstageTalkSetId":303,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet303-1","talkText":"마야 짱, 요즘에는\n스케줄을 열심히 하네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet303-2","talkText":"정말입니까? 그렇게 말씀해주시니\n정말 기쁘지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet303-3","talkText":"나도 열심히 해야겠다고\n격려를 받고 있어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}