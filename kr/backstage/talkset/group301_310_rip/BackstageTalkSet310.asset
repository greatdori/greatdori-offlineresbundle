{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet310","backstageTalkSetId":310,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet310-1","talkText":"마야 씨, 오늘은 함께\n식사하지 않으시겠어요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet310-2","talkText":"물론입니다!\n어디로 가실 겁니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet310-3","talkText":"저번에 맛있는 일식\n가게를 찾았어요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}