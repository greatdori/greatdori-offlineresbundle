{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet72","backstageTalkSetId":72,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet72-1","talkText":"요즘에는 좀처럼 부활동에\n나가지 못해서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet72-2","talkText":"파스파레 활동도\n있으니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet72-3","talkText":"다양한…… 부활동에……\n들어가 계셨죠……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet72-4","talkText":"네! 다도부,\n화도부, 검도부예요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}