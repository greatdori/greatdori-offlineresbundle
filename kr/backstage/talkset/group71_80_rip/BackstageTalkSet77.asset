{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet77","backstageTalkSetId":77,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet77-1","talkText":"짠~ 이거 봐봐!\n얼마 전에 구운 케이크!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet77-2","talkText":"히마리 짱, 케이크도\n만들어? 대박……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet77-3","talkText":"아리사도 저번에 초콜릿\n같이 만들었잖아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet77-4","talkText":"엥~ 좋겠다!\n나도 같이 만들고 싶다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet77-5","talkText":"좋다, 좋아!\n다 같이 만들자~☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}