{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet75","backstageTalkSetId":75,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet75-1","talkText":"두 사람 다\n고기 엄청 좋아하는구만~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet75-2","talkText":"응.\n세 끼 식사보다 좋아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet75-3","talkText":"그거, 대단하구만.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet75-4","talkText":"리미는 고기랑 초코 소라빵,\n뭐가 더 좋아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet75-5","talkText":"어, 어느 쪽도\n고를 수 없어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}