{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet522","backstageTalkSetId":522,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet522-1","talkText":"겨울은 단 것들을\n많이 먹고 싶어져.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet522-2","talkText":"저는 단 것을\n좋아하진 않는데요……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet522-3","talkText":"확실히 최근에 비터 초콜릿을\n꽤 먹은 것 같아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet522-4","talkText":"에헤헤, 이 초콜릿도\n비터긴 한데 먹을래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}