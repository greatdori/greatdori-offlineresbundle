{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet525","backstageTalkSetId":525,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet525-1","talkText":"으~ 추워. 이 추위는\n어떻게 좀 안 되는 거냐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet525-2","talkText":"그럴 때는\n달리면 따뜻해져!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet525-3","talkText":"하구미를 따라와!\n에잇……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet525-4","talkText":"뭐!? 어, 어이……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}