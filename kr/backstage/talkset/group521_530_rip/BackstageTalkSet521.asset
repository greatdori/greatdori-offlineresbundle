{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet521","backstageTalkSetId":521,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet521-1","talkText":"무, 당근, 샐러리……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet521-2","talkText":"겨울에도 맛있는 야채가\n가득하지 말입니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet521-3","talkText":"야채스틱으로 만들면\n먹기도 편하니 추천 드립니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet521-4","talkText":"……그렇군요.\n다음에 해 보죠.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}