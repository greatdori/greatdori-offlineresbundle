{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet530","backstageTalkSetId":530,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet530-1","talkText":"크리스마스\n파티를 시작하자~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet530-2","talkText":"평소대로이긴 하지만\n나는 빵 가져왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet530-3","talkText":"나도 내가 추천하는\n초코 소라빵을 가져왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet530-4","talkText":"나는 칠면조 가져왔어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet530-5","talkText":"다들 먹을 것 밖에\n안 가져 온 거냐~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}