{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet327","backstageTalkSetId":327,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet327-1","talkText":"카오루 씨, 저번 연극 무대는\n엄청 좋았어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet327-2","talkText":"주인공 고양이의 마음이\n엄청 와닿았어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet327-3","talkText":"후후, 고양이를 잘 연기한 것\n같아서 안심이구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}