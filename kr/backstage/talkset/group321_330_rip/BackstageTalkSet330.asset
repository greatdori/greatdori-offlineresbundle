{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet330","backstageTalkSetId":330,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet330-1","talkText":"호~ 이렇게\n만드는 법도 있구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet330-2","talkText":"이런, 미사키.\n뭘 찾아보고 있는 거니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet330-3","talkText":"네, 동생이 양모 펠트로\n고양이를 만들어달라고 해서.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet330-4","talkText":"미사키는 동생을 정말\n소중하게 생각하는구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}