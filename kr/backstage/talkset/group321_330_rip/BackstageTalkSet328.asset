{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet328","backstageTalkSetId":328,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet328-1","talkText":"우에엥…… 어떡하지……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet328-2","talkText":"왜 그러니, 카논?\n무슨 고민이라도 있는 것 같구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet328-3","talkText":"가고 싶은 데가 있는데\n멀어서 길 잃을 것 같아서……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet328-4","talkText":"후후, 그렇다면 내가 카논을\n에스코트해주도록 하마.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}