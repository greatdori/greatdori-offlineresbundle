{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50015","backstageTalkSetId":50015,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet50015-1","talkText":"사아야가 선물을\n마음에 들어 할까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50015-2","talkText":"입은 모습을\n빨리 보고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet50015-3","talkText":"분명 사~야한테 어울릴 거야!\n그치, 아리사!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50015-4","talkText":"나, 나한테 묻지 말라니까!\n어울릴 거 같긴 한데……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}