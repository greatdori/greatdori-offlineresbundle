{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50011","backstageTalkSetId":50011,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet50011-1","talkText":"모카 짱의 디자인\n엄청 근사하네!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet50011-2","talkText":"응응! 선물\n분명 토모에한테 어울릴 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet50011-3","talkText":"토모 찡이라고 하면\n이거다 싶지~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet50011-4","talkText":"토모에, 내일\n어떤 반응을 보일까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}