{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50020","backstageTalkSetId":50020,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet50020-1","talkText":"이브 짱!\n해피 버스데이!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50020-2","talkText":"고마워요!\n와아, 옷인가요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50020-3","talkText":"맞아! 이브 짱의\n토탈 코디 세트야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50020-4","talkText":"한 명이 하나씩 어울릴법한\n옷하고 모자를 골라봤어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet50020-5","talkText":"익숙치 않은 일이라\n꽤나 고민했습니다.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet50020-6","talkText":"스타일이 좋아서 뭐든\n소화를 하잖아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet50020-7","talkText":"에헤헤……\n왠지 부끄럽네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50020-8","talkText":"맞아! 이브 짱\n지금 입어 봐!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50020-9","talkText":"알겠어요!\n잠시만 기다려 주세요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[20],"voiceId":"TalkSet50020-10","talkText":"어때요……?\n잘 어울리나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet50020-11","talkText":"머, 멋집니다~!\n과연 모델입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50020-12","talkText":"무척 잘 어울려.\n안심했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}