{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50019","backstageTalkSetId":50019,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50019-1","talkText":"내일은 이브 짱의\n생일! 기대된다~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet50019-2","talkText":"선물도 어떤걸로 할지\n엄청 망설였어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet50019-3","talkText":"하지만 고민한 보람이\n있지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50019-4","talkText":"아야 짱이 고른 거\n엄청 귀여웠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet50019-5","talkText":"야호! 내일 기뻐해\n줬으면 좋겠어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}