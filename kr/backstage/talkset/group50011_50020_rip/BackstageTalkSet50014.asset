{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50014","backstageTalkSetId":50014,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50014-1","talkText":"카논 씨, 이대로\n똑바로 가 주세요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50014-2","talkText":"우, 우에엥……\n뭐, 뭐야……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50014-3","talkText":"네, 도착했어요.\n이제 보셔도 괜찮아요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50014-4","talkText":"카논!\n해피 버스데이!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet50014-5","talkText":"와아! 엄청\n커다란 해파리네……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet50014-6","talkText":"이거 사실은 쿠션\n이야~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet50014-7","talkText":"카논한테 어울릴 거 같아서\n준비했어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50014-8","talkText":"부드럽게 감싸오는 덧없음은\n그야말로 카논같구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[13],"voiceId":"TalkSet50014-9","talkText":"자 자, 카노 짱 선배!\n빨리 앉아봐!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50014-10","talkText":"와아, 진짜 해파리에\n올라탄 거 같아……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[14],"voiceId":"TalkSet50014-11","talkText":"…………쿨.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[15],"voiceId":"TalkSet50014-12","talkText":"자, 잠들었어~~~!?","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}