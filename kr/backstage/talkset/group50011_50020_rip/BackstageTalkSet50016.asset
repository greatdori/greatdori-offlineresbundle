{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50016","backstageTalkSetId":50016,"snippets":[{"talkId":1,"characterIds":[1,2,3,5],"voiceId":"TalkSet50016-1","talkText":"사아야, 생일 축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50016-2","talkText":"앗, 커다란 케이크네!\n모두 고마워.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet50016-3","talkText":"에헤헤, 이 케이크\n엄청 맛있어 보여.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50016-4","talkText":"카스미, 잠깐.\n오늘의 주인공은 사아야라고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50016-5","talkText":"후후, 고마워 아리사.\n그러면 우선 불을……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet50016-6","talkText":"선물도 있어.\n열어봐.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3],"voiceId":"TalkSet50016-7","talkText":"함께 사아야 짱한테\n어울릴만한 걸 골랐어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50016-8","talkText":"헤어 액세서리네!\n……어때? 어울려?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[5],"voiceId":"TalkSet50016-9","talkText":"오, 느낌 괜찮은데.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[4],"voiceId":"TalkSet50016-10","talkText":"후후, 아리사의 별점\n잘 받았어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[5],"voiceId":"TalkSet50016-11","talkText":"노, 놀리지 마~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}