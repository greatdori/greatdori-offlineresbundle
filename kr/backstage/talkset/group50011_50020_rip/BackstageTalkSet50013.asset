{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50013","backstageTalkSetId":50013,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50013-1","talkText":"선물 이야기\n카논 씨한테는 안 했지?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet50013-2","talkText":"옮기는 거 들키면\n아웃이라고.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50013-3","talkText":"무심코 말할 뻔해서\n두근거렸어~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet50013-4","talkText":"아아, 내일은 무척\n덧없는 날이 되겠구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50013-5","talkText":"카논의 웃는 얼굴이\n엄~청 기대돼!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}