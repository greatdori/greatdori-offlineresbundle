{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet40","backstageTalkSetId":40,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet40-1","talkText":"마야, 드디어\n연습의 성과가 나타났단다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet40-2","talkText":"서, 설마 전에 한\n「덧없다」 그거 말입니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet40-3","talkText":"그래, 들어보렴!\n덧없다…… 어떻니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet40-4","talkText":"(지금까지랑 뭐가 다른 건지\n전혀 모르겠어……!)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}