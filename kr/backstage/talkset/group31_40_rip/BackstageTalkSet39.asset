{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet39","backstageTalkSetId":39,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet39-1","talkText":"덧없다…… 아니, 덧없다……\n달라…… 덧없다……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet39-2","talkText":"카, 카오루 씨……\n뭐 하고 계십니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet39-3","talkText":"아아, 마야 아닌가.\n아니, 살짝 연습을.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet39-4","talkText":"무슨 연습입니까……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}