{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet34","backstageTalkSetId":34,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet34-1","talkText":"이거 봐, 미사키 짱,\n대기 화면 바꿨어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet34-2","talkText":"아, 저번이랑\n다른 해파리로 바뀌었네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet34-3","talkText":"에헤헤, 실은 어제\n수족관에서 찍었어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}