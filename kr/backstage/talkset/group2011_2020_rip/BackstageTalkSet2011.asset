{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2011","backstageTalkSetId":2011,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2011-1","talkText":"오, 후~스케.\n뭐 먹어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2011-2","talkText":"샌드위치야!\n이 가게 맛있거든~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2011-3","talkText":"엄청 맛있겠다!\n후~스케, 한 입만 한 입만!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2011-4","talkText":"나 참……\n어쩔 수 없지……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}