{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2019","backstageTalkSetId":2019,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2019-1","talkText":"나나미 짱! 다음에\n소품 만드는 법 좀 가르쳐 줘!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2019-2","talkText":"헤어 액세서리 같은 거\n만들어 보고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2019-3","talkText":"그러면 다음에 같이\n모여서 만들어 볼래?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2019-4","talkText":"찬성! 마시로 짱이랑\n다른 사람한테도 말해 볼게!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}