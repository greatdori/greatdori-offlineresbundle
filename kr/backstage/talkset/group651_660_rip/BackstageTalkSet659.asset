{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet659","backstageTalkSetId":659,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet659-1","talkText":"귀뚜라미 소리를 들으면\n왠지 마음이 편안해져요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet659-2","talkText":"귀뚜라미 우는 소리……\n그리고 은은한 달빛……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet659-3","talkText":"그곳에는 운치밖에 없구나.\n아아…… 덧없구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}