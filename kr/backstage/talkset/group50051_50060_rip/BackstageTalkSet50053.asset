{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50053","backstageTalkSetId":50053,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet50053-1","talkText":"아야 씨한테 줄 선물은\n이걸로 딱이네요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50053-2","talkText":"으으, 가게에 들어가는 거 꽤\n긴장했지 말입니다……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50053-3","talkText":"아하하, 점원 앞에서도\n딱딱하게 굴었지~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50053-4","talkText":"정말, 당일은 아직인걸?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50053-5","talkText":"내일은 아야 짱을 위해\n힘내자.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}