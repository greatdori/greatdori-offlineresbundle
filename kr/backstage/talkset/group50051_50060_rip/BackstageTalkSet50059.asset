{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50059","backstageTalkSetId":50059,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50059-1","talkText":"카오루 씨 생일 선물은\n정말 저걸로 해도 괜찮을까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50059-2","talkText":"하구미는 내가 카오루 군이라고\n생각하면서 골랐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50059-3","talkText":"나도 그래! 그랬더니\n저게 떠올랐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50059-4","talkText":"아하하, 확실히 아주\n덧없는 선물이네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}