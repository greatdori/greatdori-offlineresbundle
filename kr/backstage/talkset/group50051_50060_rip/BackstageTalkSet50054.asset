{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50054","backstageTalkSetId":50054,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50054-1","talkText":"아야 짱!\n생일 축하해~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50054-2","talkText":"파티도 준비했지 말입니다!\n근데 그 전에……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50054-3","talkText":"우리가 아야 짱한테\n메이크업을 해주고 싶어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet50054-4","talkText":"와, 메이크업 신상품 세트!\n몰래 준비했구나~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50054-5","talkText":"파티에는 멋부리는 게\n따라오는 법이잖아?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet50054-6","talkText":"친구한테 받는 건\n조금 두근거리네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50054-7","talkText":"그럼 실례하겠습니다…… 와아!\n아야 씨, 피부가 좋지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50054-8","talkText":"평소에 누군가한테 메이크업을 해준다니\n해본 적 없어서 재밌어~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50054-9","talkText":"다 됐어요! 아야 씨\n어떻나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet50054-10","talkText":"와아, 정말 좋아~!\n바로 셀카 찍어야지!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}