{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50055","backstageTalkSetId":50055,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50055-1","talkText":"츠구미한테 줄 선물은\n이거면 될 거 같네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet50055-2","talkText":"난 꽃말로\n골랐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50055-3","talkText":"오, 좋은데! 나는\n팍하고 직감으로 골랐어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet50055-4","talkText":"이야~ 란 선생님은\n로멘티스트네~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet50055-5","talkText":"그, 그렇게 말하는 거\n지금은 됐으니까!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}