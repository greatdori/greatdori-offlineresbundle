{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50056","backstageTalkSetId":50056,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50056-1","talkText":"츠구미, 생일 축하해.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50056-2","talkText":"선물은 란 의견이고\n귀여운 꽃이야~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50056-3","talkText":"어떤 걸로 할지 다 같이\n한 송이씩 골랐어!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50056-4","talkText":"와, 정말 기뻐!\n어떤 꽃이야?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50056-5","talkText":"나는 마가렛!\n꽃말은 진실한 우정이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50056-6","talkText":"나는 카모마일.\n치유 효과가 있대.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50056-7","talkText":"모카 짱은 라일락.\n란, 이 꽃의 꽃말은~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50056-8","talkText":"「소중한 친구」\n알아보고 골랐으면서.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50056-9","talkText":"아하하~ 모카 짱이\n깜빡해서~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet50056-10","talkText":"마지막은 튤립이야.\n츠구미의 탄생화니까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50056-11","talkText":"가게나 좋아하는 곳에\n꾸며도 돼.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[10],"voiceId":"TalkSet50056-12","talkText":"응, 고마워!\n후후, 향기 엄청 좋아!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}