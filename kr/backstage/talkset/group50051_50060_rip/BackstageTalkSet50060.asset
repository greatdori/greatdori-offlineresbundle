{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50060","backstageTalkSetId":50060,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet50060-1","talkText":"카오루 씨, 생일\n축하해!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50060-2","talkText":"선물은 하구미네가\n생각하는 『덧없는 것』이야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet50060-3","talkText":"고맙구나, 이건……\n스노우돔이니?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50060-4","talkText":"응, 천천히 눈이 흩날리는 모습이\n환상적이고 덧없어 보였어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50060-5","talkText":"게다가 반짝거리니까\n엄~청 예뻐!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[14],"voiceId":"TalkSet50060-6","talkText":"방에 장식하기에도 좋을 것\n같아.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet50060-7","talkText":"아아, 이렇게나 덧없는\n선물이라니……!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50060-8","talkText":"다만, 덧없음을 존중하는\n그대들의 마음이야말로……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[12],"voiceId":"TalkSet50060-9","talkText":"아아, 덧없구나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet50060-10","talkText":"아하하…… 기뻐해\n줘서 다행이야……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}