{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet49","backstageTalkSetId":49,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet49-1","talkText":"린린~!\n지금 바로 편의점에 가자!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet49-2","talkText":"아, 오늘은……\n설마……?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet49-3","talkText":"맞아~! NFO 콜라보가\n시작하는 날이라고~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet49-4","talkText":"우다가와 씨, 너무 허둥대네.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet49-5","talkText":"수량 한정이라서 빨리\n가봐야 한다고요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet49-6","talkText":"……그런 거였군.\n나도 가보도록 할까.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}