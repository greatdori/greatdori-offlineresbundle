{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet47","backstageTalkSetId":47,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet47-1","talkText":"미타케 씨는 의외로 안경이\n잘 어울릴 것 같지 말입니다~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet47-2","talkText":"맞아맞아, 란은 귀여우면서\n멋지니까♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet47-3","talkText":"어, 어느 쪽도 아니에요!\n……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet47-4","talkText":"아하하!\n너무 부끄러워하지 마☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}