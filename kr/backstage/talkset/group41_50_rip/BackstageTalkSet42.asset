{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet42","backstageTalkSetId":42,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet42-1","talkText":"사요 씨, 어제 NFO에\n접속하셨나요?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet42-2","talkText":"그, 그래요, 새로운\n퀘스트가 있어서.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet42-3","talkText":"분명……\n암흑룡 퇴치였든가.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet42-4","talkText":"(엥? 그거……\n상급 퀘스트인데……?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}