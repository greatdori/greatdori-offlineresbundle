{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet312","backstageTalkSetId":312,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet312-1","talkText":"고등학생인데 프로 드러머……\n야마토 씨, 굉장하네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet312-2","talkText":"대, 대단한 것도\n아닙니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet312-3","talkText":"미셸 씨에 비하면\n저따윈……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet312-4","talkText":"아뇨아뇨! 그거야말로\n대단한 게 아니라고요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}