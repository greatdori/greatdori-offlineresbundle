{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet313","backstageTalkSetId":313,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet313-1","talkText":"코코로 씨 주변에는\n검은 옷을 입은 분들이 계시네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet313-2","talkText":"그래! 어려운 일이 있을 때는\n언제나 도움을 줘!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet313-3","talkText":"저분들은……\n분명, 닌자예요!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet313-4","talkText":"닌자!?\n그랬구나!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}