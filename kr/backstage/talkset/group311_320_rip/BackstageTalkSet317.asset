{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet317","backstageTalkSetId":317,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet317-1","talkText":"다음 라이브 아이디어가\n떠올랐어!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet317-2","talkText":"역시, 코코로구나.\n부디 이야기해주지 않겠니.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet317-3","talkText":"밤에 학교 옥상에서\n별과 함께 연주하는 거야!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet317-4","talkText":"밤하늘과 하모니를\n연주한다…… 덧없구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}