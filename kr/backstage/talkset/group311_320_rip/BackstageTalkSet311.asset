{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet311","backstageTalkSetId":311,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet311-1","talkText":"오쿠사와 씨는 DJ 연습을\n어떻게 하십니까?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet311-2","talkText":"설명하기 어렵지만……\n잘하는 사람을 보거나……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet311-3","talkText":"음~…… 보통 수준인 것만\n했을지도 모르겠네요.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet311-4","talkText":"과연! 기본이 가장\n중요하다는 거지 말입니다!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}