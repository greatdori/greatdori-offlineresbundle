{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet318","backstageTalkSetId":318,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet318-1","talkText":"옥상 밤하늘 라이브는\n미사키가 못하게 했어.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet318-2","talkText":"아쉽지만 다른 안을\n생각해 봐야겠구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet318-3","talkText":"카오루는 어떤\n라이브가 하고 싶어?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet318-4","talkText":"그렇군…… 역시\n덧없는 라이브가 좋겠구나.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}