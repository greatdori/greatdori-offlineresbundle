":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event162-03-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"さあ、私のあとに続いて！\n『ああ、ジュリエット！\n恋の翼があれば、こんな塀なんてことないさ』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event162-03-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"ロック","body":"『あ、ああ、……ジュ、ジュリエット……！\n恋の翼があれば、こんな塀なんてことないさ……』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"odoodo02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event162-03-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"六花ちゃん、もっと儚く。\nそして大きな声ではっきりと言ってごらん","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event162-03-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"ロック","body":"は、はい！\nええと……儚く、大きな声ではっきり……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event162-03-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"ロック","body":"『ああ、ジュリエット……！！\n恋の翼があれば、こんな塀なんてことないさ』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event162-03-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"まだまだ儚さが足りていないよ。\nもっと激しく情熱的に！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event162-03-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"ロック","body":"は、はいっ！！\n儚く、大きな声ではっきり、激しく情熱的……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event162-03-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"ロック","body":"『恋の翼があればっ！！　\nこんな塀なんてことな〜〜〜いっっ！！！』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motio