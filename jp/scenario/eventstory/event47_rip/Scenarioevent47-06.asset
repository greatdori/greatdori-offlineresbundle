Sound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"かすみ","body":"ねーねー、はーちゃん？　そのかみって、なーに？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-06-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":308}],"windowDisplayName":"はぐみ","body":"これはねー、たなばたのおねがいごとをかくかみなんだー！\nここにおねがいごとをかくと、かなっちゃうんだって！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":308,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":308,"voiceId":"event47-06-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":307}],"windowDisplayName":"かすみ","body":"えー、すごいねー！\nそれわたしもかきたーい！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":307,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":307,"voiceId":"event47-06-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":308}],"windowDisplayName":"はぐみ","body":"いいよー、いっしょにかこー！\nとーちゃんがおみせにかざってくれるんだってー！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":308,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":308,"voiceId":"event47-06-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenc