{"actionType":6,"progressType":1,"referenceIndex":11,"delay":0,"isWaitForSkipMode":0},{"actionType":6,"progressType":1,"referenceIndex":12,"delay":0,"isWaitForSkipMode":0},{"actionType":0,"progressType":1,"referenceIndex":0,"delay":1.5,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"うわぁ……っ！　おっきなスタジオ〜〜！\nセットもすっごく豪華だし、照明の数もこんなに……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"あ！　ねえねえイヴちゃん！\n審査員席にいるの元アイドルで女優の聖さんじゃない？\nほら、ドームで引退ライブをした……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"イヴ","body":"本当ですっ！　大御所のオーラをバシバシ感じます……！\nあれ？　その隣にいるのは\n作曲家の川井さんじゃないですか……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event231-01-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"え、ミリオンヒットをいくつも出してる、あの！？\nそんな人も審査員なんだ……！　すごいねっ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千聖","body":"２人とも、盛り上がる気持ちはわかるけど……もう少し静かにね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event231-01-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"ナオ","body":"そーそー。あんま、はしゃぐなよなー。\nもしかして自分たちも芸能人だってこと忘れてんのかー？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event231-01-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"……す、すみません。つい","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"でもさースタジオも楽屋も、すーーっごく大きいんだもんっ。\nさすが地上波って感じ！　るんっ♪　てしちゃうよー！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event231-01-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千聖","body":"ええ、全国放送だけでなくネット配信もされることを考えると、\n東京アイドルサミット――TISが本当に\n大規模な番組なのだと実感するわね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event231-01-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"楽屋でも有名なアイドルグループを\nたくさん見かけましたし……\nわかってたつもりですが、なんか心臓がバクバクしてきました……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event231-01-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"うんうんっ。その気持ちわかるよ麻弥ちゃん。\nうぅ〜、なんか手が震えてきちゃった〜〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"ナオ","body":"あはは、そりゃ大変だな丸山。\nなら帰るか？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event231-01-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"ええ〜〜っ！？　か、帰らないですよ〜〜！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"ナオ","body":"ならもっとドンと構えてなって。\nパスパレは……『神話』、になるんだろー？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event231-01-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"はい！　東京アイドルサミットは大きな挑戦ですから。\nパスパレはここから、もっともっと輝けるはず……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event231-01-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"ナオ","body":"うんうん、その調子その調子。\nおっと、お喋りはここまでかな。そろそろ始まりそ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"smile01","expressionN