い人はいつでも自由に観られる、って感じになるよな","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event213-04-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"１、２年生でも、来たい人は来てもいいのよね？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event213-04-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"有咲","body":"それはもちろん大歓迎。\nこの形ならやってもいいって、学校からも許可もらったし","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event213-04-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"それじゃあこのライブは\n『ロッキンスターフェス』と『ハロハピちゃんねる』が\nあったからこそできたライブってことだよね！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event213-04-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"なんでも経験しておくもんだ","tention":0,"lipSyncMode":