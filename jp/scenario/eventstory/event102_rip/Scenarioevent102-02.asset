ata":[{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"え？\n……っていうことはつまり、その音の主は\n有咲のおばあちゃんだったの！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event102-02-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"有咲","body":"ばあちゃんが蔵にブリキのおもちゃを持ってきた時に、\nちょうどお店の方にお客さんが来ちゃったみたいで。\n蔵におもちゃだけ置いていったんだって","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event102-02-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"沙綾","body":"そうだったんだ～。ふふふ、なるほどね～。\nよかった～。\nどんな怖い話かと思って、ドキドキしちゃったよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event102-02-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"けど、有咲ひどいよ～。\n私がやったって決めつけるんだも～ん。\n本当に動かしてないもん！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event102-02-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx