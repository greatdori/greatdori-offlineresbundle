","body":"考えてるのに、頭の中がまとまらなくて。\n解散に向けてなにかしなくちゃって思えば思うほど\n焦ってどうしたらいいのかわからなくなって……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event258-03-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"つぐみ","body":"……モカちゃんは今、何を考えてるの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event258-03-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"あたしも今、どうしたらいいのかわからないのは、つぐと同じ。\nただ、違うところもあって……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event258-03-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"あたしはどちらかと言えば、決勝が終わったら解散するっていう\n蘭の言葉をどう受け止めたらいいのかってこと","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event258-03-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"つぐみ","body":"それは……解散してもいいってこと？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event258-03-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"ううん、そんなことは思ってないよ。\nあたしもAfterglowは\nずっとずっと続くものだって思ってる","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event258-03-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"だからあたしは、蘭と対立することを選んで、\nAfterglowを守るって決めた","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"serious02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event258-03-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"その気持ちを蘭に伝えた時、蘭はあたしの考えを否定しないで\n受け止めてくれたんだ。だったら……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event258-03-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"あたしもそうあるべきだって思うんだ。\n蘭の覚悟をあたしたちの言葉で変えてまで、\n解散をなかったことにするのは、正しいことなのかな？　って","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event258-03-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"つぐみ","body":"……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event258-03-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"つぐみ","body":"それでも……解散するのは、嫌だよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event258-03-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"つぐみ","body":"これまでずっと、５人で一緒にやってきたのに……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event258-03-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"つぐみ","body":"バラバラになっちゃったら、寂しいよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"