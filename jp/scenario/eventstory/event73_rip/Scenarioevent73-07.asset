"body":"初めて聴く人にも、Roseliaを理解してもらえる。\nかつファンを納得させられるようなセットリストを\n考える必要があるわね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event73-07-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"あこ","body":"Roseliaがどんなバンドかわかりやすくて、\n知ってる人もウオーってなるセットリストかー。\nうーん、どんなのがいいんだろ？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event73-07-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"燐子","body":"しっかり考えないと……中途半端なものに、\nなっちゃいそう……だよね……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event73-07-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"ええ。ここは慎重に考えなくては","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"event73-07-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ",