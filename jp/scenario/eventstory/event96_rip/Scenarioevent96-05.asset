01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event96-05-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"イヴ","body":"お願いします！\nきっとファンのみなさんはアヤさんの夢を知りたいと思います！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event96-05-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"イヴ","body":"それに、アヤさんがこんな夢や目標をもって\nがんばっているんだとわかれば、夢を追いかけている\nファンの人達もきっと勇気が湧いてくると思います！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event96-05-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"そ、そっか……\nでも、そんな大げさなことは書いてないんだけど……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event96-05-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"う～〜ん……\n……じゃあ少しだけ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionNam