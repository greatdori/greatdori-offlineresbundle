,"expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event28-01-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"さあ、みんな出発するわよ！\n花音も、奥歯にはさまったお肉のことは忘れた方がいいわ！\nきっといつか取れるもの！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event28-01-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"花音","body":"あ、あの、こころちゃん……\n別に奥歯にお肉ははさまってないよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event28-01-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"それじゃあ奥歯には、何がはさまっているの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event28-01-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"美咲","body":"何もはさまってないから……\nちょっとは話を聞きなって","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event28-01-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"いいわよ！　花音の話なら、たくさん聞きたいわ！\nせっかくなら楽しい話がいいわね！\n花音、楽しい話をお願いね！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event28-01-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"花音","body":"い、いや……楽しい話かどうかはわからないけど……\nこの前ね、美咲ちゃんに羊毛フェルトの作り方を教えてもらって\nちょっと始めてみたんだけど……なかなかうまくいかなくて","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event28-01-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"すごいわっ！　花音は新しいことを始めたのね！\nとっても楽しい話だと思うわ！\nはぐみもそう思うわよね！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event28-01-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"はぐみ","body":"うん！\nかのちゃん先輩が新しいことを始めたって聞いて、\nはぐみも嬉しくなっちゃったよ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motion