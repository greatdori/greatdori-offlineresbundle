ion":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"ごきげんよー！\nあたし達、Morfonicaでーす！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"やー、めちゃくちゃテンション上がってる！　マジで！\nどこまでも青空でいい天気だし、会場もお客さんも超いい感じ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"ちなみに、あたし達のこと知ってる人ー！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"ふんふんふん……なるほどね、このくらいかー。\n初めての人はバッチリ覚えて帰ったほうがいいよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"なんたって、ゴールデンCiRCLE賞を受賞した、\n伝説のガールズバンドと言ったら、あたしらのことだかんねー！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"あ〜、ついに受賞しちゃった","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event165-15-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"本当にいい加減な人ね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event165-15-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"つくし","body":"わ〜〜！　受賞してないしてないっ！\nそんな賞ないです！　信じないでくださ〜い！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"awate03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event165-15-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"あはは！　けど、覚えて帰ってもらいたいのはマジ！\nサイコーのライブするんでよろしくー！！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"というわけで〜……\nボーカルのシロからも一言！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"……うん！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"あの、私……\nたくさんの人に注目されるのって苦手で……\nだから今、ものすごく緊張してます","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"すごく緊張してるんですけど……\nでも、気持ちの半分はワクワクもしてます……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"苦手なことなのに、ワクワクできてることがうれしいです","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"そんなふうに思えるようになったのは……\nバンドの世界と、ここにいる四人と出会えたおかげ……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"今日はその気持ちをこのステージで歌いたいと思います","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"聴いてください……\n『fly with the night』……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event165-15-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"（ルイのこと、得意か苦手かって言ったら間違いなく苦手。\nノリも合わないし、気に入らないこと平気で言ってくるし。\nあいつとバンドで一緒になってから、一生分ムカついてる）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":27,"voiceId":"event165-15-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"（けど、ムカつくことだけじゃないのが、ムカつく……\nあいつと一緒に弾くの、楽しんでる自分がムカつく。もしかして、\nあいつがあたしを変えたのかもしれないのがムカつくよ、ホント）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":27,"voiceId":"event165-15-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"（モニカのみんながいてくれたから、\n自分と向き合うことができた気がする……\n少しだけ自分を好きになることができた気がするよ）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":28,"voiceId":"event165-15-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"（私にとっての輝くものもそれなのかもしれないな。\nしろちゃんと同じように、自分のことを好きになれたこと。\n私もみんなに会えて良かったって、本当に思ってる）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":28,"voiceId":"event165-15-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"つくし","body":"（モニカって、不思議なバンドだなって思ってた。\n性格もバラバラ、やってきたこともバラバラの人達が集まってる。\nどうしてこのメンバーが集まったんだろうって不思議だった）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":29,"voiceId":"event165-15-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"つくし","body":"（でも、一緒にいるうちに、なんとなくわかったよ。\nみんな、好きになれる自分を探してる途中なんだ……\n自分で自分をほめてあげたくなるような、そんな自分を……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":29,"voiceId":"event165-15-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"（またバイオリンを弾いている……\nこんなことを続けていても、自分に失望するだけ……\nだから、音楽から離れたはずなのに）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":30,"voiceId":"event165-15-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"（でも、不思議なものね……\n音の調和の中にいる間だけはそのことを忘れてしまう。\n今はただ、この音楽を理想の形に作り上げたい……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":30,"voiceId":"event165-15-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"（『あなたの輝きが道を照らす』……\n初めは意味もわからずに素敵な言葉だなって思ってたけど、\n今は少しだけわかったような気がする……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":26,"voiceId":"event165-15-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"（自分を信じてみようと思えた気持ちが、\nできなかったことを私にさせてくれた……\n今まで見えなかった道を照らしてくれた……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":26,"voiceId":"event165-15-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"ましろ","body":"（私は信じてる。モニカのみんなと一緒なら……\nこれから先も、新しい道をたくさん見つけていけるって。\nきっと、輝く景色に辿り着くことができるって、信じてる……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":26,"voiceId":"event165-15-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"透子","body":"はぁ、５位かぁ〜。\nもうちょいいけると思ったんだけどな〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event165-15-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"５位でも充分すごいと思うよ。\nバンド、たくさん