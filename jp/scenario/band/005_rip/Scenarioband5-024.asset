],"windowDisplayName":"紗夜","body":"そういうことでしたら、なおさらバンドメンバーの\n私も参加したかったというか……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"event43-04-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"あこ","body":"うう……あこ、どうしてSMSがうまくいかなかったのか、\n未だにわからないんです……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event43-04-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"友希那","body":"（それは……もしかすると）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event43-04-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"うーん……アタシは、自分の技術がまだまだなのかなって\n思ったよ。うまくノレて演奏はできたけど、技術がさ……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event43-04-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜",