HideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千聖","body":"（色のない私に彩りを与えてくれたここがきっと、\n私の原点……今ならそう思えそうな気がする。\n――ありがとう）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event46-15-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"イヴ","body":"（やっぱり、みなさんが大好きです！　だからこそ\nずっとずっとこのまま演奏していたい！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":20,"voiceId":"event46-15-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"イヴ","body":"（ブシに二言はなし！　これからも、私達は\nパスパレですっ！！　パスパレは、永久不滅ですっ！！！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":20,"voiceId":"event46-15-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"（アイドルってなんなのかジブンにはまだわからない。\nどんなアイドルになれるのかも。でも……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event46-15-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"（みなさんがいれば、きっと答えが見つかる！\n答えのわからないものに向かって走っていく強さ……\nそれをくれたこの場所をずっとずっと、大切にしたい！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":19,"voiceId":"event46-15-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCl