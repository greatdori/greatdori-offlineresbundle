{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet357","backstageTalkSetId":357,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet357-1","talkText":"今日のダンス部の練習、\nうまくいってたじゃん","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet357-2","talkText":"えへへ、ホント！？\n……じゃなくて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet357-3","talkText":"我の暗黒の力があれば、\nえっと……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet357-4","talkText":"うぅ～いいセリフが\n見つからないよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}