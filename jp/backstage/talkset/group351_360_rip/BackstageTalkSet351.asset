{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet351","backstageTalkSetId":351,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet351-1","talkText":"昨日、ヒナと\n出かけたんだって？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet351-2","talkText":"そうですけど……日菜から\n聞いたんですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet351-3","talkText":"うん、もう大はしゃぎで。\n何回も聞かされたよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet351-4","talkText":"ヒナ、本当に\n楽しかったんだろうな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}