{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet356","backstageTalkSetId":356,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet356-1","talkText":"リサ姉、今度のダンス部の\n練習って何やるんだっけ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet356-2","talkText":"確か、通し練習だったかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet356-3","talkText":"そうだ！　\nがんばらなくちゃ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}