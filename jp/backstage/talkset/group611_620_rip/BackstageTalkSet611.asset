{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet611","backstageTalkSetId":611,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet611-1","talkText":"今日さ、うちで\n晩ご飯食べてかない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet611-2","talkText":"純と紗南が\n巴に会いたがってて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet611-3","talkText":"いいな、アタシも\n二人に会いたかったし","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet611-4","talkText":"ついでに、借りてた\n雑誌も返しちゃうね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}