{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet517","backstageTalkSetId":517,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet517-1","talkText":"つぐみちゃん、オススメの\n入浴剤ってあるかな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet517-2","talkText":"うん、冬に\nピッタリなのがあるよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet517-3","talkText":"あとでメッセージで\n名前を送るね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet517-4","talkText":"わあ、ありがとう！\n楽しみだなぁ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}