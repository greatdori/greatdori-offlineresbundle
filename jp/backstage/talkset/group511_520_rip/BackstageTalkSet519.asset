{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet519","backstageTalkSetId":519,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet519-1","talkText":"冬のテニスウェアって、\nかわいいよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet519-2","talkText":"新しいの欲しいんだけど、\nでも、今月ピンチだし……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet519-3","talkText":"セールの時期まで、\n待つしかないかもね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet519-4","talkText":"それしかないかぁ～。\nよ～し、バイト頑張ろう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}