{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet512","backstageTalkSetId":512,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet512-1","talkText":"今日も寒いわね。レオンの\n散歩が大変そうだわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet512-2","talkText":"そういう時はオッちゃんを\n抱っこするといいですよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet512-3","talkText":"モフモフで温かいんです。\n今度一緒に散歩しましょう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet512-4","talkText":"そうね……考えておくわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}