{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet513","backstageTalkSetId":513,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet513-1","talkText":"ピザパン、カレーパン、\nグラタンパン～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet513-2","talkText":"冬は美味しいパンが\nいっぱいですね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet513-3","talkText":"あはは、冬じゃなくても\nいつでも美味しいってば","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet513-4","talkText":"確かに～。やっぱり\nパンはすごいですな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}