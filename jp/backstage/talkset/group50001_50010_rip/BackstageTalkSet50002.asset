{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50002","backstageTalkSetId":50002,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet50002-1","talkText":"紗夜ー！\nハッピーバースデー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50002-2","talkText":"プレゼント、みんなで\n選んだんですよー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet50002-3","talkText":"これ……よかったら\n受け取ってください……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50002-4","talkText":"ありがとうございます。\nこれは……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet50002-5","talkText":"……ふふ\nとても綺麗な傘ですね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet50002-6","talkText":"ね、どう？\nちょっと広げてみない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet50002-7","talkText":"ここでですか？\n……そうですね、では","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet50002-8","talkText":"紗夜、本当に\nよく似合っているわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[25],"voiceId":"TalkSet50002-9","talkText":"気に入って……\n頂けたでしょうか……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet50002-10","talkText":"ええ、とても。\n大切にしますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}