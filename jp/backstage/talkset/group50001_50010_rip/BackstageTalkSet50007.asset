{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50007","backstageTalkSetId":50007,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet50007-1","talkText":"明日はチサトさんの\n誕生日ですね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50007-2","talkText":"日菜さんのアイディア、\n上手くいくといいですね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet50007-3","talkText":"うう、今から\nドキドキしちゃう……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet50007-4","talkText":"いっぱい練習したし\n大丈夫だいじょーぶ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50007-5","talkText":"もし失敗しても、それも\n彩ちゃんらしいじゃん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}