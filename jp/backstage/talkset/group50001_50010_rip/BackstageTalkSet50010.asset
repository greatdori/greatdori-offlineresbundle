{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50010","backstageTalkSetId":50010,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50010-1","talkText":"あれ、暗い……\nまだ誰もいないのかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7,8,9,10],"voiceId":"TalkSet50010-2","talkText":"蘭！\nハッピーバースデー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50010-3","talkText":"はいこれ！　愛情たっぷり\nひまり特製ぬいぐるみ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet50010-4","talkText":"あ、ありがとひまり……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet50010-5","talkText":"今年はひまりが\nすごく張り切っててさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50010-6","talkText":"クラッカーとかも\n準備してくれたんだよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50010-7","talkText":"ひーちゃんのアツい想い\n受け取ってあげて～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50010-8","talkText":"う、うん。みんなも、\nその……ありがと","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50010-9","talkText":"蘭、かわいいぬいぐるみ\nよかったねえ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50010-10","talkText":"えっ！　かわいい！？\nよかった～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[8],"voiceId":"TalkSet50010-11","talkText":"実はね、みんなの分も\n作ってきてたんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[8],"voiceId":"TalkSet50010-12","talkText":"これもお守りと一緒に\nおそろいでつけよう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}