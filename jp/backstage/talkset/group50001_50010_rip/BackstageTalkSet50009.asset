{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50009","backstageTalkSetId":50009,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50009-1","talkText":"明日は蘭の誕生日だけど\nみんな準備は大丈夫？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet50009-2","talkText":"せーの！　のタイミングで\nやるんだからね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50009-3","talkText":"任せとけって！\n色々準備ありがとな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50009-4","talkText":"プレゼントも\n用意してくれたんだよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50009-5","talkText":"ひーちゃんのセンス\n期待してるよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}