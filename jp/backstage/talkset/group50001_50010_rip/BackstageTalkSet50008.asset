{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50008","backstageTalkSetId":50008,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet50008-1","talkText":"千聖さん！　お誕生日\nおめでとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50008-2","talkText":"とびきりのプレゼントを\nご用意しました！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50008-3","talkText":"ありがとう。\n一体何かしら？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50008-4","talkText":"アヤさん、ヒナさん！\nお願いします！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50008-5","talkText":"はーい！\n千聖ちゃんおめでとー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet50008-6","talkText":"プレゼントって……\nこの紅茶セット？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50008-7","talkText":"はい！　千聖さんに\nピッタリだと思いまして！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[20],"voiceId":"TalkSet50008-8","talkText":"今日はこれでおもてなし\nさせてください！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[16],"voiceId":"TalkSet50008-9","talkText":"今日のために\nたっくさん練習したんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50008-10","talkText":"千聖ちゃん見ててー！\nせーのっ、よいしょーっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[16],"voiceId":"TalkSet50008-11","talkText":"うわわっ！\nえ、えーいっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50008-12","talkText":"ふふ、すごく驚いたわ。\nみんな本当にありがとう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}