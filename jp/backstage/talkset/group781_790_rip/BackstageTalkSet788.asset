{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet788","backstageTalkSetId":788,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet788-1","talkText":"この前、ちょっと遠出して\n写真を撮ってきたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet788-2","talkText":"そうなんですね……\n見てもいいですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet788-3","talkText":"もちろん！\nこれは朝の公園でね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet788-4","talkText":"キレイ……\n空気が澄んでて……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet788-5","talkText":"（これから始まる１日を、\n待ち望んでるみたい）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet788-6","talkText":"ふふ、気に入った？\nそれから、こっちは……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}