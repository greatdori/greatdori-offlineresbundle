{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet764","backstageTalkSetId":764,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet764-1","talkText":"いやー、セッション\n楽しかったっす！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet764-2","talkText":"はい！　汗だくに\nなっちゃいました！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[33],"voiceId":"TalkSet764-3","talkText":"そうだ、これから\n旭湯に行きません？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet764-4","talkText":"夏は風呂上がりの\nラムネが最高っすよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet764-5","talkText":"いいですね、\n行きましょう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}