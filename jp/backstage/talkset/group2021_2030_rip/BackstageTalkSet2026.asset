{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2026","backstageTalkSetId":2026,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2026-1","talkText":"は～\nもうお腹ぺこぺこだよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2026-2","talkText":"練習のあとって\nお腹すくよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2026-3","talkText":"じゃあ帰りに\nファミレス寄ってく？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2026-4","talkText":"行く行く！　寄ってこ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2026-5","talkText":"ななみちゃん、\n急に元気になったね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[28],"voiceId":"TalkSet2026-6","talkText":"こーゆーの\n憧れてたんだよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2026-7","talkText":"練習帰りにファミレスとか\n普通だと思うけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2026-8","talkText":"普通だから\nいいんだよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}