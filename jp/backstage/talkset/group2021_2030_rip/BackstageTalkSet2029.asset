{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2029","backstageTalkSetId":2029,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2029-1","talkText":"このドーナツ美味しいね。\nどこで買ったの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2029-2","talkText":"えっへん。それは\n私が作ったドーナツです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2029-3","talkText":"マジで！？\n売りものかと思った～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2029-4","talkText":"ホントっ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2029-5","talkText":"けどこれじゃ商品には\nできないかなー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2029-6","talkText":"へえ、なんで？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2029-7","talkText":"見た目が地味だし、\n原材料費も高いし……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2029-8","talkText":"おぉ、つーちゃんが\n商売人の顔になってる……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}