{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet746","backstageTalkSetId":746,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet746-1","talkText":"花音さん、遅いな……\nどこかで迷ってたりして","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet746-2","talkText":"ん？　奥沢さん、\n花音先輩と待ち合わせ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet746-3","talkText":"うん、本当ならもう\n来てるはずなんだけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet746-4","talkText":"……ついさっき駅に\n向かってるの見たけど","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet746-5","talkText":"えぇっ、急いで\n追いかけないと……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet746-6","talkText":"奥沢さんも大変だなぁ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}