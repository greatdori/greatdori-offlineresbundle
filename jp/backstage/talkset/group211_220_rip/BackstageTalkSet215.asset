{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet215","backstageTalkSetId":215,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet215-1","talkText":"ほしのこどーって、\nどういう意味なの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet215-2","talkText":"えっとね－、\nまずキラキラーってして","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet215-3","talkText":"それから、\nドキドキーってするの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet215-4","talkText":"わぁ！　それって……\nすっごくステキだね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}