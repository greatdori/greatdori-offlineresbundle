{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet219","backstageTalkSetId":219,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet219-1","talkText":"リサさん、頼れる\nお姉さんって感じがします","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet219-2","talkText":"あはは、ありがと！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet219-3","talkText":"でもきっと、香澄の妹も、\n香澄の事そう思ってるよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}