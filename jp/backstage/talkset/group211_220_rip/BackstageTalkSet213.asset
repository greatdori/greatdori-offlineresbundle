{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet213","backstageTalkSetId":213,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet213-1","talkText":"アリサさんのお家の蔵は、\nとてもキョウミ深いです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet213-2","talkText":"日本の伝統を感じます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet213-3","talkText":"それに居心地も\nすっごくいいんだよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}