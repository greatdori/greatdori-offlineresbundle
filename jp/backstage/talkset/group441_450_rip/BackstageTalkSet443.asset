{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet443","backstageTalkSetId":443,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet443-1","talkText":"リサさん、誕生日\nおめでとうございまーす","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet443-2","talkText":"あのケーキ用意したんで、\nよかったら食べてください","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet443-3","talkText":"わー、いいの？\n二人ともありがとね♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet443-4","talkText":"蘭が言い出したんですよー\nお世話になってるからって","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet443-5","talkText":"べ、別に言わなくて\nいいじゃん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet443-6","talkText":"照れない照れない♪\nほら、一緒に食べよ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}