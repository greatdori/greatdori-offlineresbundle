{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet442","backstageTalkSetId":442,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet442-1","talkText":"リサ、誕生日おめでとう。\nプレゼントを用意したわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet442-2","talkText":"ピアスとかチョーカーとか\n色々用意してくれたんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet442-3","talkText":"それぞれが今井さんに\n似合うものを選んだのよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet442-4","talkText":"えへへ、あこの選んだやつ\nどう？　カッコいい？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet442-5","talkText":"気に入ったら……\nつけてみてください……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet442-6","talkText":"みんな本当にありがと！\n大事にするね☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}