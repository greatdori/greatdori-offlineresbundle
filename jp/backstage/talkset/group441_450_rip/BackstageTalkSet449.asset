{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet449","backstageTalkSetId":449,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet449-1","talkText":"わあ、綺麗な空の写真！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet449-2","talkText":"ああ、うん。\nさっき撮ってきたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet449-3","talkText":"秋の空って気持ちいいよね\n真っ青で、透き通ってて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet449-4","talkText":"わかる。あたしも\nつい見入っちゃうし","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}