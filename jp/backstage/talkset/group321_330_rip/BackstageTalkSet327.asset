{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet327","backstageTalkSetId":327,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet327-1","talkText":"薫さん、この前の舞台、\nすごくよかったよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet327-2","talkText":"主人公の猫の気持ちが、\nすごい伝わってきた！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet327-3","talkText":"フフ、猫になりきれていた\nようで安心したよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}