{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet330","backstageTalkSetId":330,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet330-1","talkText":"へえ、こういう\n作り方もあるんだ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet330-2","talkText":"おや、美咲。\n何か調べ物かい？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet330-3","talkText":"はい、妹に羊毛フェルトで\n猫作ってって頼まれて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet330-4","talkText":"美咲は妹さんを本当に\n大切にしているんだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}