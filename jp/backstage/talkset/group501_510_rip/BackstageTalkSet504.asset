{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet504","backstageTalkSetId":504,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet504-1","talkText":"どうだった？\n私の誕生日プレゼント","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet504-2","talkText":"ちょっとびっくりしたけど\n有咲なら喜びそうだよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet504-3","talkText":"うん。めっちゃ可愛いの\n見つけられたもんね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet504-4","talkText":"明日の有咲の反応が\n楽しみだな～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}