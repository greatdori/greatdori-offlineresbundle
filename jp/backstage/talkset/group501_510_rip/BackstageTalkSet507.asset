{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet507","backstageTalkSetId":507,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet507-1","talkText":"よーし、これで\n全員揃ったね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet507-2","talkText":"麻弥ちゃんにプレゼント\n買いに行くんだよねー？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet507-3","talkText":"買うものに迷っていたので\n一緒に行けて頼もしいです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet507-4","talkText":"それで、たしか彩ちゃんに\n考えがあるのよね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet507-5","talkText":"うん！　それじゃみんなで\n買いに行こー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}