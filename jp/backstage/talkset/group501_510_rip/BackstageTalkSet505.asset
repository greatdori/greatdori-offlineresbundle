{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet505","backstageTalkSetId":505,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet505-1","talkText":"有咲～！\n誕生日おめでとーっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet505-2","talkText":"うわっ！\nビックリしたー……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet505-3","talkText":"サプライズ成功だね。\n有咲、いい驚きっぷり","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet505-4","talkText":"有咲ちゃん、これ。\n誕生日プレゼント！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet505-5","talkText":"ミニ盆栽じゃん！\nえ、ふつーに嬉しい……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet505-6","talkText":"プレゼントのサプライズも\nうまくいったみたいだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}