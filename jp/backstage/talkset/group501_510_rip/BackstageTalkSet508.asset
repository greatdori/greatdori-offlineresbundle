{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet508","backstageTalkSetId":508,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet508-1","talkText":"麻弥ちゃーん！\n誕生日おめでとーっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet508-2","talkText":"こちらはみなさんと買った\n誕生日プレゼントです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet508-3","talkText":"おぉ、\nありがとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet508-4","talkText":"さっそく開けてみて！\nきっと気に入ると思うんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet508-5","talkText":"ヘッドホンですね、しかも\n欲しかったやつです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet508-6","talkText":"コラムに書いていたのを\n彩ちゃんが見つけたのよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet508-7","talkText":"フヘヘ、嬉しいです！\n大切に使いますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}