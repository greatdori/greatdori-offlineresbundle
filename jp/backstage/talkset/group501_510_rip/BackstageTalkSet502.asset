{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet502","backstageTalkSetId":502,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet502-1","talkText":"友希那さーん！　誕生日\nおめでとうございまーす！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet502-2","talkText":"これ、みんなで選んだ……\nプレゼントです……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet502-3","talkText":"ありがとう。なるほど、\n色々入っているのね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet502-4","talkText":"あこの選んだ超カッコいい\n指輪どうですかっ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet502-5","talkText":"アタシはヘアアクセだよ。\n使ってくれたら嬉しいな☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet502-6","talkText":"私はマフラーを。\n冷えてきたので必要かと","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet502-7","talkText":"ありがとう、どれも大切に\n使わせてもらうわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}