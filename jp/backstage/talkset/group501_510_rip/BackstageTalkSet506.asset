{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet506","backstageTalkSetId":506,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet506-1","talkText":"市ヶ谷さん……お誕生日、\nおめでとうございます……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet506-2","talkText":"誕生日プレゼントも、\n用意してあるよー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet506-3","talkText":"ありがとう。これって\nルームフレグランス？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet506-4","talkText":"そうだよ。\nひのきの香りなんだって","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet506-5","talkText":"優しい香りなので……\n癒されると思います……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet506-6","talkText":"ありがとうございます！\nさっそく部屋に置きますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}