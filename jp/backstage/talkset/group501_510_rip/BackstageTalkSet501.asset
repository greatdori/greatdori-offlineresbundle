{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet501","backstageTalkSetId":501,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet501-1","talkText":"明日は湊さんの誕生日ね。\n宇田川さん、どうしたの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet501-2","talkText":"うぅ……プレゼント\n喜んでくれるか心配で～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet501-3","talkText":"あ、あこちゃん……\n落ち着いて……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet501-4","talkText":"そんなに心配しなくても\nきっと喜んでくれるって☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet501-5","talkText":"あこ、明日まで\n緊張しっぱなしかも……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}