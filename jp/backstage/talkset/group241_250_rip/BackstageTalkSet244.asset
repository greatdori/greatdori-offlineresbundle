{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet244","backstageTalkSetId":244,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet244-1","talkText":"パンが余っちゃって……\nよかったら食べません？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet244-2","talkText":"ありがとう。あぁ……\nなんて甘い香りなんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet244-3","talkText":"あ、あの……\nカレーパンなんですけど","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet244-4","talkText":"フフ……それでも\n甘い香りがするのさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}