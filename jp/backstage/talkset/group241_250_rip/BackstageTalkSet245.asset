{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet245","backstageTalkSetId":245,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet245-1","talkText":"あぁ……\nなんて儚いんだ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet245-2","talkText":"か、薫さん、\nどうしたんですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet245-3","talkText":"ああ、こころに紹介された\n本を読んでいるんだ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet245-4","talkText":"（な、泣いてる……\nそんないい話なんだ）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}