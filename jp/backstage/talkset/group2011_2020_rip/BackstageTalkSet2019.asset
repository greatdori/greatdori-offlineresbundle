{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2019","backstageTalkSetId":2019,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2019-1","talkText":"ななみちゃん！　今度\n小物の作り方教えて！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2019-2","talkText":"ヘアアクセサリーとか\n作ってみたいの","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2019-3","talkText":"じゃあ今度、みんなで\n集まって作らない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2019-4","talkText":"賛成！　ましろちゃん達に\n声かけてみるね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}