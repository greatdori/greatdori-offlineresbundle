{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2001","backstageTalkSetId":2001,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2001-1","talkText":"服のデザインって\nどんな時に思いつくの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2001-2","talkText":"カラオケ行ってる時とか、\nキラプリ撮ってる時とか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2001-3","talkText":"あ、あと友達と\nクレープ食べてる時とか！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2001-4","talkText":"あ、遊んでる時\nばっかりだね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}