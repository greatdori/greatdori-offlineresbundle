{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2007","backstageTalkSetId":2007,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2007-1","talkText":"しろちゃん、しろちゃん。\nこれ、あげる","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2007-2","talkText":"わっ、こんなにいっぱい\nどうしたの！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2007-3","talkText":"オマケがほしくて\n箱買いしちゃったんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2007-4","talkText":"みんなにも\n配ってこよーっと！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}