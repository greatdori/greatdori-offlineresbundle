{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2002","backstageTalkSetId":2002,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2002-1","talkText":"眠そうだね、透子ちゃん","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2002-2","talkText":"マジ眠い。あたしの家、\n毎朝５時起きだからさー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2002-3","talkText":"５時！？\nな、なんのために……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2002-4","talkText":"……なんのためだろ？\n考えたことなかった！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}