{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet342","backstageTalkSetId":342,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet342-1","talkText":"奥沢さん、羊毛フェルト\n作れるんですよね……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet342-2","talkText":"作れますよー。もしかして\n燐子先輩、興味あります？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet342-3","talkText":"は、はい……でも……\n難しそうですよね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet342-4","talkText":"いやいや、衣装作れるなら\n全然楽勝だと思いますよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}