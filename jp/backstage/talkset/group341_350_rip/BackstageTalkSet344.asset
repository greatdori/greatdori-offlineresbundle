{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet344","backstageTalkSetId":344,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet344-1","talkText":"紗夜、早いわね。\n練習はもっと後でしょう？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet344-2","talkText":"自主練習していたんです。\nそういう湊さんは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet344-3","talkText":"ふふ、考えることは\n同じということね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}