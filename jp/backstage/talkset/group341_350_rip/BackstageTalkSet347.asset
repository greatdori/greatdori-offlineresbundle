{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet347","backstageTalkSetId":347,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet347-1","talkText":"あこ、最近ドラムが、\n上達してきたわね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet347-2","talkText":"ホントですかっ！？\nやった～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet347-3","talkText":"まだ上を目指せるはず。\n頑張りましょう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}