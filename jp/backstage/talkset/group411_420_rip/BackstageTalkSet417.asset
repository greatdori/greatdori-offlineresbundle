{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet417","backstageTalkSetId":417,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet417-1","talkText":"今度演劇部で、こんな\n演目を企画していてね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet417-2","talkText":"それなら……衣装の\n色を統一すれば……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet417-3","talkText":"さすが燐子だ。\n詳しく聞かせてくれ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}