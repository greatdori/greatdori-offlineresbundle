{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet500","backstageTalkSetId":500,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet500-1","talkText":"ひまりちゃん、\n誕生日おめでとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet500-2","talkText":"誕生日プレゼントよ。\n良かったら受け取って","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet500-3","talkText":"ありがとうございますっ！\n綺麗なハーバリウムですね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet500-4","talkText":"りみちゃんと買いに行って\n一目ぼれしちゃったの","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet500-5","talkText":"気に入ってもらえたら\n嬉しいな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet500-6","talkText":"超気に入ったよ～！\nすっごく大事にするね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}