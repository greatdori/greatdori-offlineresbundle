{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet492","backstageTalkSetId":492,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet492-1","talkText":"明日は美咲の誕生日だね。\nどんなお祝いにしようか","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet492-2","talkText":"みーくんが喜ぶような\nプレゼントをあげたいな！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet492-3","talkText":"あたしにとってもステキな\n考えがあるの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet492-4","talkText":"ふふっ、きっとすっごく\n喜んでくれると思うな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}