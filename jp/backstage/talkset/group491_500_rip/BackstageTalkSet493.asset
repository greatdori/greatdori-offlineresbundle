{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet493","backstageTalkSetId":493,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet493-1","talkText":"ハッピーバースデー、美咲\n私達からのプレゼントだよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet493-2","talkText":"ありがとうございます。\nあ、このぬいぐるみ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet493-3","talkText":"美咲とミッシェルよ！\nあたし達で作ったの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet493-4","talkText":"ミッシェルとみーくんは、\nすっごく仲良しだもんね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet493-5","talkText":"やっぱり羊毛フェルトって\nキレイに作るの難しいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet493-6","talkText":"そんな、すごく上手です。\nみんなもホントありがと","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}