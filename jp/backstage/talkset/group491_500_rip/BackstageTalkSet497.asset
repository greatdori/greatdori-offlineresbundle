{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet497","backstageTalkSetId":497,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet497-1","talkText":"白金さん、お誕生日\nおめでとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet497-2","talkText":"これ、麻弥さんと二人で\n選んだプレゼントです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet497-3","talkText":"綺麗なペンダント……\n本当にいいんですか……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet497-4","talkText":"白金さんには衣装の相談に\n乗ってもらってますからね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet497-5","talkText":"私も生徒会で、すっげー\nお世話になってるんで","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[25],"voiceId":"TalkSet497-6","talkText":"ありがとうございます……\n大切にしますね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}