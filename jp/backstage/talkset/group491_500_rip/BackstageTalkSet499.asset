{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet499","backstageTalkSetId":499,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet499-1","talkText":"ひまりちゃん！\n誕生日おめでとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet499-2","talkText":"わ～っ！\nみんな、ありがと～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet499-3","talkText":"心優しいあたし達からの\n誕生日プレゼントだよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet499-4","talkText":"あ、これ！\nほしかったキャップ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet499-5","talkText":"この前、気になるって\n言ってたからな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[6],"voiceId":"TalkSet499-6","talkText":"あと、このケーキも、\nひまりの好きなお店のだよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[8],"voiceId":"TalkSet499-7","talkText":"何から何まで……！\nうわーん、ありがとー……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[7],"voiceId":"TalkSet499-8","talkText":"いえ～い。\n今年も大成功～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}