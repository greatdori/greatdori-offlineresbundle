{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet495","backstageTalkSetId":495,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet495-1","talkText":"明日は燐子の誕生日ね。\nあこ、プレゼントは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet495-2","talkText":"ばっちりです！　りんりん\nきっと喜ぶだろうな～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet495-3","talkText":"私も確認したけれど、\nあれで本当にいいの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet495-4","talkText":"大丈夫だって～！\nあこをドーンと信じて！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet495-5","talkText":"燐子が喜ぶプレゼントなら\nあこに頼むのが一番だよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}