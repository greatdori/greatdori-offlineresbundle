{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet498","backstageTalkSetId":498,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet498-1","talkText":"ふっふっふ～。今年も\n準備は完璧ですなー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet498-2","talkText":"モカはひまりの誕生日に\nなると生き生きするよな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet498-3","talkText":"ある意味一番楽しみに\nしてる気がする……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet498-4","talkText":"と、とにかくひまりちゃん\n喜んでくれるといいよね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}