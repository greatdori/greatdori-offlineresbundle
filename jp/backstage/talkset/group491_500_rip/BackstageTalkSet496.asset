{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet496","backstageTalkSetId":496,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet496-1","talkText":"燐子ー！\nハッピーバースデー！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet496-2","talkText":"サプライズだったのだけど\n驚かせすぎたかしら","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet496-3","talkText":"いえ……そんな……\n嬉しいです……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet496-4","talkText":"はい、これ！　りんりんに\nプレゼントだよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet496-5","talkText":"あっ、NFOのグッズ……\nこの前出たばかりの……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet496-6","talkText":"プレゼントはあこに頼んで\nケーキは私達で作ったの","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet496-7","talkText":"ケーキも、美味しそう……\n本当に……嬉しいです……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}