{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet77","backstageTalkSetId":77,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet77-1","talkText":"じゃーん、見て！\nこの前焼いたケーキ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet77-2","talkText":"ひまりちゃん、ケーキも\n作れるの？　すげー……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet77-3","talkText":"有咲だってこの前チョコ\n一緒に作ったじゃん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet77-4","talkText":"えー、いいな！\n私も一緒に作りたーい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet77-5","talkText":"いいじゃんいいじゃん！\nみんなで作ろーよっ☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}