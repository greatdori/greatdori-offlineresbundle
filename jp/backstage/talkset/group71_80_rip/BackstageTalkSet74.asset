{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet74","backstageTalkSetId":74,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet74-1","talkText":"ふふ、二人とはまた\n同じクラスになったね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet74-2","talkText":"知らない人だらけだったら\nどうしようかと思ったよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet74-3","talkText":"でも、それも\n楽しそうじゃない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet74-4","talkText":"あはは、こころらしいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet74-5","talkText":"でも二人と同じクラスで\nとっても嬉しかったわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet74-6","talkText":"うん、私も！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}