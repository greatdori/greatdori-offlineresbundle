{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet331","backstageTalkSetId":331,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet331-1","talkText":"実は、ミッシェルに\n手紙を書いたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet331-2","talkText":"いつもお世話になっている\nお礼をしたためたのさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet331-3","talkText":"よかったら、\n渡してくれないかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet331-4","talkText":"（……どうしよう、\nこれ、読んでいいのかな）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}