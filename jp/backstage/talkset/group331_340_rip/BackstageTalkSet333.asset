{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet333","backstageTalkSetId":333,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet333-1","talkText":"薫、今日の昼休み\n校庭で踊ってなかった？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet333-2","talkText":"次の舞台では、\nダンサーの役だからね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet333-3","talkText":"役になりきるため、\n踊っていたのさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}