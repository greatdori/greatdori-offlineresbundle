{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet602","backstageTalkSetId":602,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet602-1","talkText":"Afterglowは\nいまから練習？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet602-2","talkText":"いえ、この間あこが\n欲しがってた本を届けに","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet602-3","talkText":"……なんか、巴って\nたまに紗夜に似てるよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet602-4","talkText":"あはは……なんとなく\n自覚はあります","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}