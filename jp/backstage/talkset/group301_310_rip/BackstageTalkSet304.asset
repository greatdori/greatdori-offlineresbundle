{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet304","backstageTalkSetId":304,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet304-1","talkText":"ベースの弦の張り替え時は\nいつなのかしら……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet304-2","talkText":"難しいですね……ベースは\n結構人によりますから","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet304-3","talkText":"自分に合ったタイミングを\n見つけるのがいいかもです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet304-4","talkText":"そういうものなのね。\n勉強になったわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}