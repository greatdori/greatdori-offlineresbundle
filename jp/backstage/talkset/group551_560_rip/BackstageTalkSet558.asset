{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet558","backstageTalkSetId":558,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet558-1","talkText":"こころ、どうしよー。\n宿題の問題が難しいよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet558-2","talkText":"そういう時は、\n踊ればいいのよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet558-3","talkText":"楽しくなってきっと\n答えが思い浮かぶわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet558-4","talkText":"そっか！\nじゃあ踊ろう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}