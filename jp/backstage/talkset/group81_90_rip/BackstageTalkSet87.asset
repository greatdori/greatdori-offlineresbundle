{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet87","backstageTalkSetId":87,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet87-1","talkText":"ミッシェル〜！\nどっか遊びに行こうよ！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet87-2","talkText":"いや、あたしは\n着替えたいんだけど……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet87-3","talkText":"それならミッシェルの\n着替えが終わるまで待つさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet87-4","talkText":"そういうことじゃ\nないと思うんですが……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet87-5","talkText":"はぐみ、今日はご飯食べに\n行きたいなー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet87-6","talkText":"（早く着替えさせて……）","lipAnimation":"","fontColorType":0,"fontSizeType":1,"balloonType":2}]}}