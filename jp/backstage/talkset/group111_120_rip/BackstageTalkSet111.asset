{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet111","backstageTalkSetId":111,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet111-1","talkText":"ねえ、りみ。\nせーので聞こうね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet111-2","talkText":"う、うん……！\nせーの……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3,8],"voiceId":"TalkSet111-3","talkText":"薫先輩ってなんでそんなに\nカッコイイんですか！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet111-4","talkText":"薫さんってなんでそんなに\nカッコイイんですか！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet111-5","talkText":"フフ……一言で\n言うのは難しいが……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet111-6","talkText":"強いて言うならそう……\n儚いからかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3,8],"voiceId":"TalkSet111-7","talkText":"カ、カッコイイ……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet111-8","talkText":"……あなた達、\nなぜそうなるの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}