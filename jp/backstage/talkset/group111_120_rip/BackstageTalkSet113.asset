{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet113","backstageTalkSetId":113,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet113-1","talkText":"あ、彩さんと花音さんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet113-2","talkText":"あれ、巴ちゃんと\nひまりちゃん、バイトは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet113-3","talkText":"二人とも今日、シフト\n入ってたよね……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8,9],"voiceId":"TalkSet113-4","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet113-5","talkText":"わぁ～！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet113-6","talkText":"すっかり忘れてた！\n走るぞ、ひまり！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[8],"voiceId":"TalkSet113-7","talkText":"と、巴、待って～！\n置いてかないで～！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}