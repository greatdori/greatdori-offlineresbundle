{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet570","backstageTalkSetId":570,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet570-1","talkText":"薫、ハッピーバースデー！\nお祝いするわよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet570-2","talkText":"子猫ちゃんたち、覚えて\nくれていたんだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet570-3","talkText":"もっちろんだよ！\nはいプレゼント！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet570-4","talkText":"フラワーボックスだよ。\nピッタリだなと思って","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet570-5","talkText":"一応、ミッシェルも一緒に\n選んでましたよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet570-6","talkText":"なんて儚いプレゼント\nなんだ！　大切にするよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}