{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50013","backstageTalkSetId":50013,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50013-1","talkText":"プレゼントの話、\n花音さんにしてないよね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet50013-2","talkText":"運ぶところ見られたら\nアウトだからね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50013-3","talkText":"つい話しちゃいそうで\nドキドキしたよー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet50013-4","talkText":"ああ、明日はとびきり\n儚い日になるね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50013-5","talkText":"花音の笑顔が\nとーっても楽しみだわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}