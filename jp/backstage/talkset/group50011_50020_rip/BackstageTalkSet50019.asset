{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50019","backstageTalkSetId":50019,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50019-1","talkText":"明日はイヴちゃんの\n誕生日！　楽しみだねー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet50019-2","talkText":"プレゼント、どれにするか\nすっごく迷っちゃった","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet50019-3","talkText":"けど、悩んだ甲斐が\nありましたよね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50019-4","talkText":"彩ちゃんが選んだ物\nすごくかわいかったわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet50019-5","talkText":"やったあ！　明日、喜んで\nもらえたら嬉しいな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}