{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50012","backstageTalkSetId":50012,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet50012-1","talkText":"トモちーん\nおたおめ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50012-2","talkText":"これで日本の祭りを\n盛り上げてくだされ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50012-3","talkText":"サンキュー！\n……ってこれ法被か！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50012-4","talkText":"ふっふーん！　なんと\nこれ、手作りなんだよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet50012-5","talkText":"すごいな！　めちゃくちゃ\n凝ってるじゃん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50012-6","talkText":"なあ、今\n着てみてもいいか！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet50012-7","talkText":"うん！　私達も\n早く見てみたいな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet50012-8","talkText":"よっ……\nどうだ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[6],"voiceId":"TalkSet50012-9","talkText":"ま、悪くないんじゃない。\n似合ってるよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet50012-10","talkText":"巴ちゃん\nすっごくかっこいいよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[8],"voiceId":"TalkSet50012-11","talkText":"目線、こっちくださ～い！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}