{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50020","backstageTalkSetId":50020,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet50020-1","talkText":"イヴちゃん！\nハッピーバースデー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50020-2","talkText":"ありがとうございます！\nわあ、お洋服ですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50020-3","talkText":"そうだよ！　イヴちゃん\nトータルコーデセット！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50020-4","talkText":"一人一つ、似合いそうな\n服や帽子を選んでみたの","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet50020-5","talkText":"慣れないことなので\nだいぶ悩んじゃいました","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet50020-6","talkText":"スタイルいいし、何でも\n着こなしちゃうもんね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet50020-7","talkText":"えへへ……\n何だか照れちゃいますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50020-8","talkText":"そうだ！　イヴちゃん\n今着てみせてよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50020-9","talkText":"わかりました！\nしばしお待ちを！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[20],"voiceId":"TalkSet50020-10","talkText":"どうでしょう……？\n似合ってますか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet50020-11","talkText":"す、素敵ですー！\nさすがモデルさんです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50020-12","talkText":"とても似合っているわね。\n安心したわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}