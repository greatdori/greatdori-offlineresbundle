{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50016","backstageTalkSetId":50016,"snippets":[{"talkId":1,"characterIds":[1,2,3,5],"voiceId":"TalkSet50016-1","talkText":"沙綾、誕生日おめでとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50016-2","talkText":"わっ、大きいケーキ！\nみんなありがとね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet50016-3","talkText":"えへへ、このケーキ\nすっごくおいしそうだよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50016-4","talkText":"香澄、待った。\n今日の主役は沙綾だぞ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50016-5","talkText":"ふふ、ありがと有咲。\nそれじゃあまずは火を……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet50016-6","talkText":"プレゼントもあるんだ。\n開けてみて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3],"voiceId":"TalkSet50016-7","talkText":"みんなで沙綾ちゃんに\n似合いそうなの選んだんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50016-8","talkText":"ヘアアクセだ！\n……どうかな？　似合う？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[5],"voiceId":"TalkSet50016-9","talkText":"お、いい感じじゃん","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[4],"voiceId":"TalkSet50016-10","talkText":"ふふ、有咲のお墨付き\nいただきました","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[5],"voiceId":"TalkSet50016-11","talkText":"ち、茶化すなー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}