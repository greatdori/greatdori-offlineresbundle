{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50014","backstageTalkSetId":50014,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50014-1","talkText":"花音さん、このまま\nまっすぐ歩いてください","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50014-2","talkText":"ふ、ふえぇ……\nな、なんだろう……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50014-3","talkText":"はい、着きました\nもう見て大丈夫ですよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50014-4","talkText":"花音！\nハッピーバースデー！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet50014-5","talkText":"わあ！　すっごく\n大きなクラゲ……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet50014-6","talkText":"これね、実はクッション\nなんだよー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet50014-7","talkText":"花音に似合うと思って\n用意したのよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50014-8","talkText":"優しく包み込む儚さは\nまさに花音のようだね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[13],"voiceId":"TalkSet50014-9","talkText":"ほらほら、かのちゃん先輩！\n早く座って！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50014-10","talkText":"わあ、本物のクラゲに\n乗ってるみたい……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[14],"voiceId":"TalkSet50014-11","talkText":"…………ぐう","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[15],"voiceId":"TalkSet50014-12","talkText":"ね、寝たーーー！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}