{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet465","backstageTalkSetId":465,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet465-1","talkText":"モカ、誕生日おめでとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet465-2","talkText":"今年のプレゼントは\n一味違うよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet465-3","talkText":"おぉ～、なんか色んな\nマンガが入ってますな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet465-4","talkText":"みんなでイチオシのマンガ\n入れてみたんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet465-5","talkText":"あたしのは、元々ひまりが\n教えてくれたやつだけど","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet465-6","talkText":"読んだことなさそうなのを\n選んだけど、どうかな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet465-7","talkText":"どれも面白そう～。\nモカちゃん、大感謝だよー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}