{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet464","backstageTalkSetId":464,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet464-1","talkText":"モカの誕生日プレゼント、\nあれでよかったのかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet464-2","talkText":"いいんじゃないか？\nモカ、喜ぶと思うぞ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet464-3","talkText":"うんうん、モカの喜ぶ顔が\n目に浮かぶよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet464-4","talkText":"ふふっ、気に入って\nもらえるといいな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}