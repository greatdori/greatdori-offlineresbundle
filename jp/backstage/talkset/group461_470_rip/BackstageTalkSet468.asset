{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet468","backstageTalkSetId":468,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet468-1","talkText":"巴ちゃんは今日も\n元気そうだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet468-2","talkText":"元気ですよ。瀬田先輩も\nキラキラしてますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet468-3","talkText":"そのキラキラした役者に\n興味はないかい？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}