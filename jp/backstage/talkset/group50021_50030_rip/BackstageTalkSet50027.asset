{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50027","backstageTalkSetId":50027,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50027-1","talkText":"さて、明日の準備は\nこれで問題ないかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50027-2","talkText":"さっき試しに見た時\nすごく綺麗だったよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50027-3","talkText":"はぐみまでドキドキした！\nこころん、喜ぶかな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet50027-4","talkText":"明日はあたし達が\n笑顔にしてあげないとね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}