{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50028","backstageTalkSetId":50028,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet50028-1","talkText":"あら！　あたしが\n一番乗りね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet50028-2","talkText":"何かしら？\n急に暗くなったわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50028-3","talkText":"あら？　今度は\nお星さまが出てきたわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50028-4","talkText":"キラキラしてとっても\nキレイね！　海みたい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12,13,14,15],"voiceId":"TalkSet50028-5","talkText":"こころ\nハッピーバースデー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[14],"voiceId":"TalkSet50028-6","talkText":"みんなでプラネタリウムを\n作ってみたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet50028-7","talkText":"こころんに喜んでほしくて\nがんばったんだよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50028-8","talkText":"この儚い演出は\n気に入ってもらえたかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50028-9","talkText":"えぇ！　この景色\nとってもステキだわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet50028-10","talkText":"はは、こころの目\nすっごいキラキラしてる","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[11],"voiceId":"TalkSet50028-11","talkText":"あたしの目にもお星さまが\nきっと入ってきたのね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}