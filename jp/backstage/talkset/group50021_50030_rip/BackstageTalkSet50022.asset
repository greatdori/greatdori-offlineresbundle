{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50022","backstageTalkSetId":50022,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50022-1","talkText":"あこちゃん……\nお誕生日おめでとう……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50022-2","talkText":"わーい！　ありがとう！\nもしかしてその箱って！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet50022-3","talkText":"すべて宇田川さんへの\nプレゼントですよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50022-4","talkText":"こんなにいっぱい！？\nすっごーーーい！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50022-5","talkText":"さて！　突然ですが\nここであこにクイズ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet50022-6","talkText":"クイズ！？　よーし！\n絶対正解してみせるよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet50022-7","talkText":"このプレゼントはそれぞれ\n誰からの物でしょうか！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet50022-8","talkText":"あこ、あなたならきっと\n正解に辿り着けるわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[24],"voiceId":"TalkSet50022-9","talkText":"は、はい！　頑張ります！\nえーとえーと……っ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50022-10","talkText":"このNFOのぬいぐるみは\n……りんりん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50022-11","talkText":"うん……あこちゃん……\n正解だよ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[24],"voiceId":"TalkSet50022-12","talkText":"やったー！　この調子で\nどんどん当ててくよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}