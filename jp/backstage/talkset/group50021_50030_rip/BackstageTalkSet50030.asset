{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50030","backstageTalkSetId":50030,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet50030-1","talkText":"……あれ、なんかいつもと\n雰囲気違う？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50030-2","talkText":"ふっふっふ……ようこそ\n闇の宴へ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50030-3","talkText":"えっ！？　あこ？\nそれにみんなも……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50030-4","talkText":"今からとっておきの\n闇の力を披露しよう……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50030-5","talkText":"何もない机の上に……\n布を被せます……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet50030-6","talkText":"この布にはタネも仕掛けも\nありません","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet50030-7","talkText":"布をゆっくり\n外していくと……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50030-8","talkText":"何もなかったはずの机に\nプレゼントがどーん！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50030-9","talkText":"闇の宴、マジックじゃん！\nてかこれ、エプロンだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet50030-10","talkText":"リサ、誕生日おめでとう\nプレゼントはどうかしら","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet50030-11","talkText":"めちゃくちゃカワイイよ！\n大事に使うね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}