{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50026","backstageTalkSetId":50026,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50026-1","talkText":"はぐみ、誕生日おめでとう\nプレゼントを用意したよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50026-2","talkText":"プレゼント！？\nやったー！　何だろう？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50026-3","talkText":"それはこの中に入って\nもらえば分かるわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet50026-4","talkText":"わかった！　えいっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet50026-5","talkText":"すっごーい！　はぐみ\n浴衣になってる！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet50026-6","talkText":"ふふ、その浴衣が\nはぐみへのプレゼントさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet50026-7","talkText":"可愛いから絶対似合うって\nみんなで話してたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[13],"voiceId":"TalkSet50026-8","talkText":"ほ、ほんとに似合ってる？\nおかしくない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50026-9","talkText":"今のはぐみ、\nとーっても可愛いわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[13],"voiceId":"TalkSet50026-10","talkText":"えへへ……何だかほっぺた\n熱くなってきちゃった","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet50026-11","talkText":"せっかくだし、このまま\nお祭り行こうよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[13],"voiceId":"TalkSet50026-12","talkText":"うん！　よーっし！\nいっぱい食べるぞー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}