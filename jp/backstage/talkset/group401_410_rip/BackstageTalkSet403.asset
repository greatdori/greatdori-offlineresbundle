{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet403","backstageTalkSetId":403,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet403-1","talkText":"私、暑い時はうさぎを\n抱いて寝るんです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet403-2","talkText":"えー、そんなことしたら\n余計に暑くない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet403-3","talkText":"幸せだから\n暑いのも忘れちゃいます","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet403-4","talkText":"へー、いいなー！\nあたしも試してみたーい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}