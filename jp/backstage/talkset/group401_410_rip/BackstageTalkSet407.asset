{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet407","backstageTalkSetId":407,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet407-1","talkText":"イヴちゃん、\n誕生日おめでとー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet407-2","talkText":"おめでとうございまーす！\nこちらがプレゼントです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet407-3","talkText":"わぁっ、\nありがとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet407-4","talkText":"早く中見てみてよ！\nるんっ♪　ってするから！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet407-5","talkText":"これは……お城の\n模型ですね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet407-6","talkText":"ふふっ、喜んでもらえた\nみたいで良かったわ♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}