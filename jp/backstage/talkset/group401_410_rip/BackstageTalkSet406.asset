{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet406","backstageTalkSetId":406,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet406-1","talkText":"イヴちゃんへのプレゼント\nあれでよかったのかなぁ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet406-2","talkText":"たくさん種類が\nありましたからね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet406-3","talkText":"あまりああいうものは\n買わないから少し不安よね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet406-4","talkText":"えー、絶対るんっ♪　と\nするって！　平気平気！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet406-5","talkText":"そうね、イヴちゃんなら\nきっと喜んでくれるわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}