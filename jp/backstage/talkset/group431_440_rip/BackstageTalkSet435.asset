{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet435","backstageTalkSetId":435,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet435-1","talkText":"明日、はぐみの誕生日だね。\nどうやってお祝いする？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet435-2","talkText":"私ははぐみのためにバラと\n自作の詩を贈るつもりだよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet435-3","talkText":"あたしは花火とパレードで\nお祝いするつもりよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet435-4","talkText":"そ、それじゃえっと……\n私はどうしよう……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet435-5","talkText":"花音さん落ち着いて。\n普通に祝おうね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}