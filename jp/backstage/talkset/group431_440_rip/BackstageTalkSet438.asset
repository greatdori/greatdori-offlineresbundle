{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet438","backstageTalkSetId":438,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet438-1","talkText":"明日はこころんの\n誕生日だねーっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet438-2","talkText":"プレゼント、\n喜んでくれるかなあ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet438-3","talkText":"こころなら、何もらっても\n喜ぶと思いますよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet438-4","talkText":"私達の手で最高の誕生日を\n演出しようじゃないか","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}