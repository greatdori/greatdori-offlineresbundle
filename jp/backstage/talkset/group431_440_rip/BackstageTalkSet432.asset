{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet432","backstageTalkSetId":432,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet432-1","talkText":"いよいよ明日は\n香澄の誕生日だね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet432-2","talkText":"香澄にはバレてないよな？\nサプライズのこと","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet432-3","talkText":"うん、大丈夫。香澄ちゃん\nビックリするかなあ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet432-4","talkText":"プレゼントも\n喜んでくれるといいな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet432-5","talkText":"ふふっ、パーティの準備も\nあと少しだし、がんばろ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}