{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet633","backstageTalkSetId":633,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet633-1","talkText":"今日は打ち上げ花火を\n作ろうと思うの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet633-2","talkText":"す、すごすぎる……\nどんなのにするの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet633-3","talkText":"ミッシェルの\nお顔の花火よ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet633-4","talkText":"そうだわ！　沙綾のために\nパンの花火も作るわね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet633-5","talkText":"あはは、それ\nモカも喜びそう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}