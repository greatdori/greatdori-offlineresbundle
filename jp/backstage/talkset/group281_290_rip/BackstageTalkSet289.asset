{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet289","backstageTalkSetId":289,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet289-1","talkText":"おねーちゃんは、\n犬派なんだよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet289-2","talkText":"千聖ちゃんって、\n犬と猫どっちが好き？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet289-3","talkText":"私は犬派ね。\n日菜ちゃんは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet289-4","talkText":"あたしはー……\nおねーちゃんと同じ派！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}