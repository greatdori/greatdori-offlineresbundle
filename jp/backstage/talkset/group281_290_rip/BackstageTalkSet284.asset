{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet284","backstageTalkSetId":284,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet284-1","talkText":"うーん……あのダンス、\nすぐ失敗しちゃうよ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet284-2","talkText":"はぐみちゃん、\nコツとかないかな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet284-3","talkText":"えっと、腰をギュイーン\nってするといいと思う！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet284-4","talkText":"もうちょっと詳しく\nいいかな……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}