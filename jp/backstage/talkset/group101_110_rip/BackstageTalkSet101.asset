{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet101","backstageTalkSetId":101,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet101-1","talkText":"ふわぁ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet101-2","talkText":"有咲ちゃん、すっごく\n眠そうだけど、大丈夫？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet101-3","talkText":"今……学校で……朝の\n挨拶運動をしていて……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet101-4","talkText":"生徒会は日替わりで参加\nしないといけなくてさ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet101-5","talkText":"うわ～！　大変そう！\nあたし絶対無理だよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet101-6","talkText":"日菜先輩、私達も来週から\nあるんですけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet101-7","talkText":"えー！？　やだよー！　\nつぐちゃんやってよ〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}