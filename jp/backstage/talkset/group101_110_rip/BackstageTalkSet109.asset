{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet109","backstageTalkSetId":109,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet109-1","talkText":"あ、トモちんだ！\n今日は太鼓の練習？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet109-2","talkText":"ああ、今終わったところ。\nもうすぐ本番も近いしな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet109-3","talkText":"ふふ、巴の太鼓って、\n聞くと元気が出るよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet109-4","talkText":"わかるわかるっ！\n気分が明るくなるよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet109-5","talkText":"あははっ、それじゃ本番も\n楽しみにしてくれよな！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}