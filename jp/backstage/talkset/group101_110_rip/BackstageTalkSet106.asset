{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet106","backstageTalkSetId":106,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet106-1","talkText":"紗夜さん、日菜先輩！\nビッグニュースです！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet106-2","talkText":"今、ケーキバイキングで、\n姉妹割引してるんだよ！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet106-3","talkText":"ホントっ！？\nおねーちゃん、行こっ！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet106-4","talkText":"……何も用事が\nなかったらね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}