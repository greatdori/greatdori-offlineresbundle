{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet105","backstageTalkSetId":105,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet105-1","talkText":"あとねー、\nすっごく優しくてー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet105-2","talkText":"わかるわかるっ！\nおねーちゃんもなんだー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet105-3","talkText":"お、二人とも\n何の話してたんだ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet105-4","talkText":"え、ひなちんと、\nおねーちゃん自慢だよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet105-5","talkText":"超盛り上がったよね！\nはー、楽しかった","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet105-6","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet105-7","talkText":"な、なんか、すごい\n恥ずかしいですね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[22],"voiceId":"TalkSet105-8","talkText":"ええ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}