{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50037","backstageTalkSetId":50037,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet50037-1","talkText":"明日は燐子の誕生日ね。\nあこ、色々とありがとう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50037-2","talkText":"えへへ、りんりんに\n喜んでほしくって！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50037-3","talkText":"ふふ、やっぱりあこに\n頼んで正解だったよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50037-4","talkText":"えぇ、明日の白金さんの\n反応が楽しみですね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}