{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50040","backstageTalkSetId":50040,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50040-1","talkText":"蘭ー！　つぐー！\nはい、チーズ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet50040-2","talkText":"わあ、びっくりした！\nち、チーズ……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet50040-3","talkText":"ひまり、さっきから\n何枚も撮ってるね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50040-4","talkText":"もちろん！　すっごく\n嬉しかったんだもん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50040-5","talkText":"モカと巴も！\nはい、チーズ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet50040-6","talkText":"いえ～い、ひーちゃん\nおたおめ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50040-7","talkText":"そうだ、せっかくだし\nみんなで撮らないか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[8],"voiceId":"TalkSet50040-8","talkText":"それ賛成！　みんな寄って\n寄って！　はいチーズ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[10],"voiceId":"TalkSet50040-9","talkText":"プレゼント、気に入って\nもらえてよかった","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50040-10","talkText":"うん！　このトイカメラ\nずっと大事にするね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}