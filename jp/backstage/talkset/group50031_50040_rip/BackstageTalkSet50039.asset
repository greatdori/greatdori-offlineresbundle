{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50039","backstageTalkSetId":50039,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet50039-1","talkText":"ひまりにピッタリなの\n見つかってよかったな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet50039-2","talkText":"思ったより、種類あったね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet50039-3","talkText":"あれで素敵な思い出、\n一緒に残したいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet50039-4","talkText":"ひーちゃん、明日も\nきっと泣いちゃうな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}