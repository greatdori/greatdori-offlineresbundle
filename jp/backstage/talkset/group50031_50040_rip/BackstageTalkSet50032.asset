{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50032","backstageTalkSetId":50032,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50032-1","talkText":"モカ、誕生日おめでとう\nこれ今年のプレゼント","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet50032-2","talkText":"モカが喜ぶもの\nみんなで考えてみたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet50032-3","talkText":"んん～？\nこ、これは……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50032-4","talkText":"超超特大パン！　どう？\nびっくりした！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50032-5","talkText":"ちょーびっくり～長年の\n夢がついに叶ったよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50032-6","talkText":"ジャムも用意してるから\nたくさん食べてね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50032-7","talkText":"これでしばらくパンに\n困ることないだろ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet50032-8","talkText":"それにしても沙綾ちゃん\nかなり驚いてたよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet50032-9","talkText":"こんなに大きなパン初めて\n見たって言ってたもんな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50032-10","talkText":"あはは……ってモカ！\nもう食べ終わったの！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50032-11","talkText":"やっぱり\nこうなると思った……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[7],"voiceId":"TalkSet50032-12","talkText":"あたしの胃袋はもはや\n５次元だからね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}