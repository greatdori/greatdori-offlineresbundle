{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet261","backstageTalkSetId":261,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet261-1","talkText":"遅れてごめんね、\n待った？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet261-2","talkText":"ううん、全然！　でも……\nつぐが遅れるの珍しいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet261-3","talkText":"クッキーがあと少しで\n焼けそうだったから……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet261-4","talkText":"わー、クッキーだ！\nおいしそ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}