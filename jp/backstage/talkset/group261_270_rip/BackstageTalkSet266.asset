{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet266","backstageTalkSetId":266,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet266-1","talkText":"あっ、美咲ちゃん、\nちょうどいいところに！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet266-2","talkText":"あ、上原さん。\nちょうどいいところって？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet266-3","talkText":"この新作スイーツ、\nすごい美味しいんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet266-4","talkText":"よかったら、\n一口食べてみて！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}