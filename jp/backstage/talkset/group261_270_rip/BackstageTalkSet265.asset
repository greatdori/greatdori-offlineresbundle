{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet265","backstageTalkSetId":265,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet265-1","talkText":"今日の部活の練習、\nハードだったよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet265-2","talkText":"テニスってコートの中\n動き回るからねー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet265-3","talkText":"サーブで腕もパンパン\nだし、足もキツくて――","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet265-4","talkText":"あー、すごいわかる。\nめちゃめちゃわかるよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}