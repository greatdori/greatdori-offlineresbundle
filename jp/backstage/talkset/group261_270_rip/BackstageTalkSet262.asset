{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet262","backstageTalkSetId":262,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet262-1","talkText":"みんなで旅行に\n行きたいな～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet262-2","talkText":"そうだね、\n次はどこ行こっか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet262-3","talkText":"まだみんなが行ったこと\nない場所がいいな〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}