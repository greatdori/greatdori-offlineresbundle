{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet228","backstageTalkSetId":228,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet228-1","talkText":"あーちゃんは頭いいから\nすごいなーって思う！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet228-2","talkText":"きゅ、急になんだよ！\nでもありがと……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet228-3","talkText":"はぐみももっとちゃんと\n勉強しないとなー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet228-4","talkText":"わ、私でよかったら、\n勉強教えるけど……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}