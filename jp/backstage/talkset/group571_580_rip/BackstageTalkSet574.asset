{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet574","backstageTalkSetId":574,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet574-1","talkText":"じゃじゃーん！\n福袋買っちゃったー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet574-2","talkText":"おっ、いいねいいね～！\n何が入ってるの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet574-3","talkText":"えっとー……あ、仮面だ！\n友希那さんに似合いそう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet574-4","talkText":"そ、そうかしら……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet574-5","talkText":"次は～……お～水晶玉か～。\nこれは～、りんりん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[25],"voiceId":"TalkSet574-6","talkText":"あ、ありがとう\nあこちゃん……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet574-7","talkText":"随分不思議な物が\n入っているのですね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[25],"voiceId":"TalkSet574-8","talkText":"友希那さん……とても……\n似合ってます","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet574-9","talkText":"ひょっとして\n気に入ってる？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet574-10","talkText":"そ、そんなことは\nないわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}