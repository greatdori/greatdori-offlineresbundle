{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet576","backstageTalkSetId":576,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet576-1","talkText":"ハロハピ獅子舞よ！\nがおー！","lipAnimation":"","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet576-2","talkText":"すごいね！　私、\n獅子舞って初めて見たよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet576-3","talkText":"悪い子はいないか～？\nコロッケ食べちゃうぞー！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet576-4","talkText":"いや、それナマハゲだし\nコロッケ食べないし","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet576-5","talkText":"厄を払い幸せをもたらす。\nああ、儚い……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[11],"voiceId":"TalkSet576-6","talkText":"今度のライブは\n獅子舞で出ましょう！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet576-7","talkText":"さんせー！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet576-8","talkText":"ああ。実に縁起のいい\nライブになりそうだ","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet576-9","talkText":"そしたらつまり、獅子舞と\nミッシェルと、花音さん？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet576-10","talkText":"ふえぇ……\n自信ないよ～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}