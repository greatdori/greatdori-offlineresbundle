{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet543","backstageTalkSetId":543,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet543-1","talkText":"今年もあっという間\nでしたね～、フヘヘ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet543-2","talkText":"ねーねー、\n来年は何やりたい？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet543-3","talkText":"私は、もっと日本文化を\n学びたいです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet543-4","talkText":"来年の話の前に、今年の\n締めくくりをしないとね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet543-5","talkText":"うん！　ファンに向けて\n感謝の動画を撮ろう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet543-6","talkText":"ファンのみなさん、良い\n年末をお過ごしですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet543-7","talkText":"今年も大変\nお世話になりました！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet543-8","talkText":"おかげですっごくるんっ♪\nてする１年だったよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[18],"voiceId":"TalkSet543-9","talkText":"来年は今年以上の\n私達をお見せします","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet543-10","talkText":"来年もパスパレを\nよろしくお願いします！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}