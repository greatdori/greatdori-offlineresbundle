{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet544","backstageTalkSetId":544,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet544-1","talkText":"そろそろ、お部屋の\n大掃除しないとな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet544-2","talkText":"あ～、もうそんな時期かぁ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet544-3","talkText":"あたしはもう終わった～。\nさすがでしょ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet544-4","talkText":"モカって、そういうの\n意外とすぐにやるよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet544-5","talkText":"私も終わってるんだけど、\nお店の方がまだなんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet544-6","talkText":"なら、私達が手伝うよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet544-7","talkText":"賛成～。つぐー、いつ\nお店の掃除するか教えて～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet544-8","talkText":"みんな、ありがとう！\nお母さんに聞いてみるね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet544-9","talkText":"そのあと、ラーメンで\n今年を締めるか！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet544-10","talkText":"おそばじゃないんだ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}