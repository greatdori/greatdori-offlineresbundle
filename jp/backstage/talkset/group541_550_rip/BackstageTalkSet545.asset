{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet545","backstageTalkSetId":545,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet545-1","talkText":"今年ももう終わりだね。\nあっという間だったな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet545-2","talkText":"うんうん！　いろんな\n記念日ができたよね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet545-3","talkText":"来年も今年と同じくらい\n楽しい１年になるといいな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet545-4","talkText":"それなら、今からみんなで\n何をするか考えようよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet545-5","talkText":"来年の予定を先取りって\nことか。いいんじゃね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet545-6","talkText":"うわ～、やりたいことが\nいっぱいで迷っちゃうよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[4],"voiceId":"TalkSet545-7","talkText":"わかるな～。どんどん\n浮かんでくるよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[2],"voiceId":"TalkSet545-8","talkText":"私、\n１００個ぐらいあるんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet545-9","talkText":"私もそれくらいあるよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet545-10","talkText":"それはさすがに\n多すぎるだろっ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}