{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet546","backstageTalkSetId":546,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet546-1","talkText":"見て見て！　この写真の\nあこカッコよくない！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet546-2","talkText":"冥界の番犬、ケルベロスを\n従えてるんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet546-3","talkText":"大きい犬だね！　隣の\nあこちゃんもかわいい","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet546-4","talkText":"か、かわいいじゃなくて\nカッコいいって言ってよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}