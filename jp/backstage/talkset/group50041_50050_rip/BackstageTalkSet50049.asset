{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50049","backstageTalkSetId":50049,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet50049-1","talkText":"おたえのプレゼント\n何とか決まったね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50049-2","talkText":"あんなに種類がある\nなんて知らなかったよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet50049-3","talkText":"普段走ったりしねーから\n選ぶの難しかったな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet50049-4","talkText":"でも、見てるだけで\nワクワクしちゃった！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[1],"voiceId":"TalkSet50049-5","talkText":"私も明日から\n走っちゃおうかな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}