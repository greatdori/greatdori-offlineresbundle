{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50046","backstageTalkSetId":50046,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50046-1","talkText":"誕生日の麻弥ちゃんには\nこれをやってもらうね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50046-2","talkText":"プレゼントを懸けた\nダーツチャレンジです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet50046-3","talkText":"何がもらえるかは当たった\n色によって決まるんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50046-4","talkText":"緑はアロマディフューザー\n赤はパスケース","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50046-5","talkText":"そして青はマグカップね\n麻弥ちゃん、頑張って","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet50046-6","talkText":"は、はい！　頑張ります！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50046-7","talkText":"えいっ！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50046-8","talkText":"おお！　緑だから\nアロマディフューザーだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50046-9","talkText":"マヤさん、すごいです！\n一発で当たりました！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet50046-10","talkText":"ねえ、日菜ちゃん。残りの\nプレゼントはどうするの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[17],"voiceId":"TalkSet50046-11","talkText":"もちろん全部麻弥ちゃんに\nあげるよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[19],"voiceId":"TalkSet50046-12","talkText":"ええ！？　あ、ありがとう\nございます……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}