{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50042","backstageTalkSetId":50042,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50042-1","talkText":"湊さん、お疲れ様です\nこれはお菓子と……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet50042-2","talkText":"はちみつティーです……\nよかったら、どうぞ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet50042-3","talkText":"ありがとう二人とも。\nとてもいい香りだわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50042-4","talkText":"あこは肩を揉みます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50042-5","talkText":"あとこれ！　癒されるって\nウワサの動画だよー☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50042-6","talkText":"（にゃーんちゃんの\n動画集……！？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet50042-7","talkText":"……じゃなくて、今日は\nいったいどうしたの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50042-8","talkText":"友希那さん！　今日、\nお誕生日じゃないですか！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50042-9","talkText":"だから今日は友希那に\nリラックスしてほしくって","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet50042-10","talkText":"パフォーマンスの維持には\n適切な休息が必要ですから","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50042-11","talkText":"してほしいことがあれば、\n言ってくださいね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet50042-12","talkText":"そういうことだったのね。\nありがとう、嬉しいわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}