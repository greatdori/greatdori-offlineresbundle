{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50050","backstageTalkSetId":50050,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet50050-1","talkText":"おたえ、誕生日おめでとう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50050-2","talkText":"これ、プレゼントだよ\nみんなで選んだんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50050-3","talkText":"これは……\nランニングシューズだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet50050-4","talkText":"そろそろ買い替えようと\n思ってたんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50050-5","talkText":"履き心地とかサイズとか\n大丈夫かな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet50050-6","talkText":"最高だよ！　なんだか\nワクワクしてきた！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2],"voiceId":"TalkSet50050-7","talkText":"ちょっと走ってくるね！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet50050-8","talkText":"お、おたえ！？\nちょっと待ってよー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[5],"voiceId":"TalkSet50050-9","talkText":"はあ、はあ……\nぜ、全然追いつけねえ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[4],"voiceId":"TalkSet50050-10","talkText":"さすが、普段から\n走ってるだけあるね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[3],"voiceId":"TalkSet50050-11","talkText":"お、おたえちゃん達\nいつ戻ってくるんだろ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}