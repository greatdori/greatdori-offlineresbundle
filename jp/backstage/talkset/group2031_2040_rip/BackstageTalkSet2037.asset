{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2037","backstageTalkSetId":2037,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2037-1","talkText":"今度こそマジでアガる\nライブ考えよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2037-2","talkText":"前回はみんな途中から\nふざけちゃったからね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2037-3","talkText":"ステージの後ろから\nレーザーが出るとかは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2037-4","talkText":"おっ、いいじゃん！\nカッコいい！　採用〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2037-5","talkText":"煙が出るのも、\nカッコいいよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2037-6","talkText":"それもいいじゃん！\n採用〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[30],"voiceId":"TalkSet2037-7","talkText":"演出より演奏で\n魅せるべきだと思うわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[27],"voiceId":"TalkSet2037-8","talkText":"それ一番カッコいいやつ！\nルイの意見も採用！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet2037-9","talkText":"今のは意見っていうより、\n注意のような気がする……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}