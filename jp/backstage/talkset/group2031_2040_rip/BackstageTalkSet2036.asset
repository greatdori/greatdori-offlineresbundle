{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2036","backstageTalkSetId":2036,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2036-1","talkText":"何かこうもっとみんなが\nアガるライブしたくね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2036-2","talkText":"いいね！　どんなこと\nしたら盛り上がるかな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2036-3","talkText":"んー……シロが\n踊りながら歌うとか！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2036-4","talkText":"えっ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2036-5","talkText":"それならタンバリンとか\n持ってもいいかもね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet2036-6","talkText":"ま、待って……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2036-7","talkText":"あ、マラカスはどう？\n振りながら歌うの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet2036-8","talkText":"つ、つくしちゃんまで！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet2036-9","talkText":"……コミックバンドにでも\nなるつもりなの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}