{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2033","backstageTalkSetId":2033,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2033-1","talkText":"あ、そうだ！\nこれ、みんなにお土産","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2033-2","talkText":"ありがとう、美味しそうな\nチョコレートだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2033-3","talkText":"あ、これ知ってる！\n有名なお店のだよね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2033-4","talkText":"そうだよー、週末に\nベルギー行ったからさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2033-5","talkText":"海外のお土産なの！？\nす、すごい……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2033-6","talkText":"そう？\nま、みんなで食べてよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet2033-7","talkText":"これ、美味しいよね～。\n私も好きなんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[30],"voiceId":"TalkSet2033-8","talkText":"私も来週海外へ行くから\n何か買ってくるわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[26],"voiceId":"TalkSet2033-9","talkText":"みんながお嬢様だってこと\n久しぶりに実感したよ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}