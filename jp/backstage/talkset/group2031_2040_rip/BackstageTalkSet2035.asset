{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2035","backstageTalkSetId":2035,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2035-1","talkText":"いつかみんなで\n合宿とかしてみたいね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2035-2","talkText":"めっちゃ楽しそう！\n今からやろ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2035-3","talkText":"そ、それは急すぎるけど、\n確かにやってみたいかも","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2035-4","talkText":"それでよりよい練習が\nできるなら私も構わないわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2035-5","talkText":"合宿の料理は私に任せて！\n料理には自信あるんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2035-6","talkText":"ふーすけが自信満々だと\nなんか不安になる……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2035-7","talkText":"む〜、そんなこと言うなら\n透子ちゃんはごはん抜き！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}