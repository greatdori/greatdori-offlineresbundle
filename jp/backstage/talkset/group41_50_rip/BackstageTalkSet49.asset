{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet49","backstageTalkSetId":49,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet49-1","talkText":"りんりーん！\n今すぐコンビニ行こっ！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet49-2","talkText":"あ、今日って……\nもしかして……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet49-3","talkText":"そうだよ～！　NFOコラボの\n開始日なんだよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet49-4","talkText":"宇田川さん、慌てすぎよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet49-5","talkText":"数量限定なんで、早めに\n行かないとなんですよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet49-6","talkText":"……そういうものなのね。\n私も行ってみようかしら","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}