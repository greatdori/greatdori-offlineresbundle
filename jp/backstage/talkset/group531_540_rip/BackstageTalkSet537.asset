{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet537","backstageTalkSetId":537,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet537-1","talkText":"タエさん、お誕生日\nおめでとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet537-2","talkText":"プレゼント、ウサギの\nスリッパにしてみたの","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet537-3","talkText":"かわいい！　この色\nオッちゃんにそっくり！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet537-4","talkText":"二人とも、ありがとう。\n大事にはきますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}