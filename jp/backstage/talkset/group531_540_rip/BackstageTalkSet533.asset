{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet533","backstageTalkSetId":533,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet533-1","talkText":"みんな、プレゼント交換の\n準備はできた？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet533-2","talkText":"はい、珠玉の逸品を\nご用意しました！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet533-3","talkText":"あたしもるんっ♪　と\nするやつ持ってきたよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet533-4","talkText":"プレゼントがこれでいいか\n不安になってきました……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet533-5","talkText":"こういうのは気持ちが\n大事なんだから心配ないわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet533-6","talkText":"それじゃ始めるよ……って\n私のプレゼントどこ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}