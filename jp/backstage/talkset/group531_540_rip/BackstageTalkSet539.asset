{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet539","backstageTalkSetId":539,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet539-1","talkText":"彩さん、お誕生日\nおめでとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet539-2","talkText":"今年のプレゼントは\nレッスン着にしたよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet539-3","talkText":"わぁ、かわいい！\nピンク色だ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet539-4","talkText":"彩ちゃんならこれだって\n満場一致で決まったのよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet539-5","talkText":"これでまたみんなで\n練習しましょう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet539-6","talkText":"うんっ！　どーしよう……\n嬉しくて涙出てきたよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}