{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet534","backstageTalkSetId":534,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet534-1","talkText":"こころん、サンタさんに\nお手紙出した？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet534-2","talkText":"ええ、ハロハピの仲間に\nなって！　って書いたわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet534-3","talkText":"サンタさんはみんなを\n笑顔にする同志だからね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet534-4","talkText":"ねえ、花音さん。こころの\nお願いってことは……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet534-5","talkText":"ふふっ、なんだか\n実現しちゃいそうだよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}