{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet540","backstageTalkSetId":540,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet540-1","talkText":"おめでとう、彩ちゃん。\nこれプレゼントだよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet540-2","talkText":"ヘアゴムだ～！　\nキラキラしてる！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet540-3","talkText":"えへへ、彩先輩に\n似てるなーと思って！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet540-4","talkText":"かわいくって\nキラキラしてるから♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet540-5","talkText":"えへへ、照れちゃうな～。\n二人ともありがとね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}