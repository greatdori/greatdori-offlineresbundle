{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet536","backstageTalkSetId":536,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet536-1","talkText":"ハッピーバースデー\nおたえ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet536-2","talkText":"わぁ、みんなありがとう！\n……これ、お肉？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet536-3","talkText":"あったり～！　お肉の\nブランケットだよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet536-4","talkText":"それ、\nすげー探したんだぞ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet536-5","talkText":"絶対喜んでくれると\n思ったんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet536-6","talkText":"うん、嬉しい！　これ\nかけてお肉の夢見るね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}