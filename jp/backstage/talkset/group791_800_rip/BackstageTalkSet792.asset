{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet792","backstageTalkSetId":792,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet792-1","talkText":"ルイ！　明日ヒマ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet792-2","talkText":"……なぜ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet792-3","talkText":"理由とかいいから！\nヒマかどうか聞いてんの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet792-4","talkText":"……空いている\n時間はあるわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet792-5","talkText":"よーし、じゃあ明日は\nモニカで鍋パ！　決定ね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet792-6","talkText":"……予定があるのを、\n思い出したわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet792-7","talkText":"絶対ウソじゃん！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}