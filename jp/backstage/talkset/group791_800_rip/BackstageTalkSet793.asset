{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet793","backstageTalkSetId":793,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet793-1","talkText":"寒いときはライブ！\nですよね、友希那先輩！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet793-2","talkText":"……どういう関係が、\nあるのかしら？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet793-3","talkText":"もちろんライブで寒さを\n吹き飛ばすんですよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet793-4","talkText":"夏にも似たようなことを\n聞いた気がするわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}