{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet38","backstageTalkSetId":38,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet38-1","talkText":"おねーちゃん、一緒に\nギターの弦買わない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet38-2","talkText":"つい最近、\n変えたばっかりよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet38-3","talkText":"えー、それじゃあ予備！\n予備買いに行こーよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}