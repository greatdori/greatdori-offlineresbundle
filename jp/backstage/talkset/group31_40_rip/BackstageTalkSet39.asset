{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet39","backstageTalkSetId":39,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet39-1","talkText":"儚い……いや、儚い……\n違うな……儚い……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet39-2","talkText":"か、薫さん……\n何してるんですか……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet39-3","talkText":"ああ、麻弥じゃないか。\nいや少し練習をね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet39-4","talkText":"何の練習ですか……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}