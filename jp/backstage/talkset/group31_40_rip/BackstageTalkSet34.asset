{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet34","backstageTalkSetId":34,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet34-1","talkText":"見て、美咲ちゃん。\n待ち受け変えたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet34-2","talkText":"あ、この前のと\n違うクラゲになってる","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet34-3","talkText":"えへへ、実は昨日\n水族館で撮ってきたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}