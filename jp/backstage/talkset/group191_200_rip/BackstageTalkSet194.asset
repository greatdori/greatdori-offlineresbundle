{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet194","backstageTalkSetId":194,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet194-1","talkText":"麻弥ちゃん、ギターの\n調子がなんか変かも","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet194-2","talkText":"ネックの調整\nしておきますね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet194-3","talkText":"麻弥ちゃん。\n今度の番組の台本って……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet194-4","talkText":"黄色の表紙のやつですね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet194-5","talkText":"マヤさん、\n絆創膏持ってませんか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet194-6","talkText":"カバンの中に入ってます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[18],"voiceId":"TalkSet194-7","talkText":"（麻弥ちゃんがいてくれて\n良かったわ……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}