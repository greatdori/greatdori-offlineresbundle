{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet271","backstageTalkSetId":271,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet271-1","talkText":"おや、こんなところで\n子猫ちゃんに会えるとはね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet271-2","talkText":"子猫ちゃんって……\nアタシのことですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet271-3","talkText":"アタシは子猫ちゃんって\nガラじゃないですけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet271-4","talkText":"フフ、私から見れば\n誰だって子猫ちゃんさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}