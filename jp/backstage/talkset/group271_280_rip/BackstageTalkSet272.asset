{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet272","backstageTalkSetId":272,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet272-1","talkText":"瀬田先輩が演技の練習\nしてるとこ見ましたよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet272-2","talkText":"あの決闘のシーン、\nすごい熱かったです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet272-3","talkText":"ふふ、ありがとう。\n本番も楽しみにしててくれ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}