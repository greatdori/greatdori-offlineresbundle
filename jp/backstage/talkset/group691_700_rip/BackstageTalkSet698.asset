{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet698","backstageTalkSetId":698,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet698-1","talkText":"冬の動物、っていう\n食玩が今度出るんですよ〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet698-2","talkText":"なにそれー？\nどんな動物が出るの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet698-3","talkText":"キタキツネ、エゾタヌキ、\n秋田犬とかもありますね〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet698-4","talkText":"おねーちゃんが喜びそー！\nプレゼントしたいなー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet698-5","talkText":"私も気になってるので、\n買いに行きませんか〜？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}