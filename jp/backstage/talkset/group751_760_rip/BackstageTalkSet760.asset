{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet760","backstageTalkSetId":760,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet760-1","talkText":"演技で大切なのは、役に\n寄り添い、表現すること","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet760-2","talkText":"私にもできるかな……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet760-3","talkText":"もちろんだとも。\n試しにやってみてごらん","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet760-4","talkText":"例えばそうだね、囚われの\nお姫様はどうだろう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet760-5","talkText":"いつか王子様が私を助けに\n来るって信じてましゅ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet760-6","talkText":"元気がいいお姫様だね。\nすぐにでも迎えが来るさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}