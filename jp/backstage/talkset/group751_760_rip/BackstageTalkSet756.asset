{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet756","backstageTalkSetId":756,"snippets":[{"talkId":1,"characterIds":[34],"voiceId":"TalkSet756-1","talkText":"はあ～。春のイヴちゃんも\nとってもかわいいです～！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet756-2","talkText":"え？　春の私と他の季節の\n私は違うのですか？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[34],"voiceId":"TalkSet756-3","talkText":"もちろんですよ～！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet756-4","talkText":"１分１秒として同じ\nイヴちゃんはいませんっ！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet756-5","talkText":"なるほど……！　諸行無常、\nということですね！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}