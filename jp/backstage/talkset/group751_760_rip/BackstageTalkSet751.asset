{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet751","backstageTalkSetId":751,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet751-1","talkText":"この間、妹達と近所の\nマラソン大会に出たんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet751-2","talkText":"寒かったけど、なんとか\nみんなで完走できたよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet751-3","talkText":"これがその時の写真ね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet751-4","talkText":"おお、三姉妹で手を繋いで\nゴールしてるね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet751-5","talkText":"（つーちゃん……\nどれかわかりにくい）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}