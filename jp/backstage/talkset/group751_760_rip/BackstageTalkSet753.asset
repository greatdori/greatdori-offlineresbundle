{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet753","backstageTalkSetId":753,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet753-1","talkText":"くちゅんっ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet753-2","talkText":"チュ、チュチュ様！？\nまさか、風邪ですか！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet753-3","talkText":"違うわよ、ちょっと鼻が\nムズムズしただけ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet753-4","talkText":"ネギたっぷりの鍋ですぐに\n体をあたためましょう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet753-5","talkText":"野菜はやめて。\nもっと具合が悪くなるわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}