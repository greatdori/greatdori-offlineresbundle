{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50060","backstageTalkSetId":50060,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet50060-1","talkText":"薫さん、お誕生日\nおめでとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50060-2","talkText":"プレゼントははぐみ達が\n思う『儚いもの』だよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet50060-3","talkText":"ありがとう、これは……\nスノードームかい？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50060-4","talkText":"うん、ゆっくり雪が舞って\n幻想的で儚いなあって","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50060-5","talkText":"それに、キラキラで\nとーってもキレイよね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[14],"voiceId":"TalkSet50060-6","talkText":"お部屋にも飾りやすいと\n思うんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet50060-7","talkText":"ああ、なんて儚い\nプレゼントなんだ……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50060-8","talkText":"けど、儚さを尊重する\nみんなの気持ちこそ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[12],"voiceId":"TalkSet50060-9","talkText":"ああ、儚い……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet50060-10","talkText":"あはは……喜んで\n貰えたならよかった……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}