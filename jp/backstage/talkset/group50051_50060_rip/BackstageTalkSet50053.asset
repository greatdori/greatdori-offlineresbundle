{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50053","backstageTalkSetId":50053,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet50053-1","talkText":"アヤさんへのプレゼントは\nこれでバッチリですね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50053-2","talkText":"うう、お店に入るのかなり\n緊張しちゃいました……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50053-3","talkText":"あはは、店員さんの前でも\nガチガチだったもんねー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50053-4","talkText":"もう、本番はまだなのよ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50053-5","talkText":"明日は彩ちゃんのために\n頑張りましょう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}