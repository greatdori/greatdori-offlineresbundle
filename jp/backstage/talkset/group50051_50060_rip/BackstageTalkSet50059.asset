{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50059","backstageTalkSetId":50059,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50059-1","talkText":"薫さんの誕生日プレゼント\nあれで大丈夫だったかな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50059-2","talkText":"はぐみ、自分を薫くんだと\n思って選んだよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50059-3","talkText":"あたしもよ！　そうしたら\nあれが思い浮かんだの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50059-4","talkText":"あはは、確かにすごく\n儚いプレゼントだよね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}