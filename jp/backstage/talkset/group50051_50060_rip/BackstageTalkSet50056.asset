{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50056","backstageTalkSetId":50056,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50056-1","talkText":"つぐみ、誕生日おめでとう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50056-2","talkText":"プレゼントは蘭の提案で\nかわいいお花だよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50056-3","talkText":"どれにするか、みんなで\n一輪ずつ選んだんだ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50056-4","talkText":"わあ、すっごく嬉しい！\nどんなお花かな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50056-5","talkText":"私はマーガレット！\n花言葉が『真実の友情』なの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50056-6","talkText":"アタシのはカモミール\n癒し効果があるんだって","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50056-7","talkText":"モカちゃんはライラック\n蘭、これの花言葉は～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50056-8","talkText":"『大切な友達』\n調べて選んだくせに","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50056-9","talkText":"あはは～、モカちゃん\nうっかり～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet50056-10","talkText":"最後はチューリップ\nつぐみの誕生花だから","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50056-11","talkText":"お店とか、好きなとこに\n飾ってみて","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[10],"voiceId":"TalkSet50056-12","talkText":"うん、ありがとう！\nふふ、すごくいい香り！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}