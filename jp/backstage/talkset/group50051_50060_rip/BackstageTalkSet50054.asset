{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50054","backstageTalkSetId":50054,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50054-1","talkText":"彩ちゃーん！\n誕生日おめでとー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50054-2","talkText":"パーティも準備してます！\nでも、その前に……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50054-3","talkText":"私達で彩ちゃんに\nメイクさせてほしいの","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet50054-4","talkText":"わ、新作のコスメセット！\n密かに狙ってたんだ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet50054-5","talkText":"パーティにはおめかしが\nつきものでしょう？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet50054-6","talkText":"友達にやってもらうのって\nちょっとドキドキするね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50054-7","talkText":"し、失礼します……わあ！\n彩さん、肌綺麗ですね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50054-8","talkText":"普段誰かにメイクなんて\nしないからおもしろーい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50054-9","talkText":"できました！　アヤさん\nいかがですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet50054-10","talkText":"わあ、すっごくいいよ～！\nさっそく自撮りしちゃお！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}