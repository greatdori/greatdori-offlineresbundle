{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet297","backstageTalkSetId":297,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet297-1","talkText":"薫くんは、どうして\n演劇やろうと思ったの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet297-2","talkText":"それはね、舞台が私を、\n呼んでいたからさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet297-3","talkText":"あははっ、やっぱり\n薫くんはおもしろいね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}