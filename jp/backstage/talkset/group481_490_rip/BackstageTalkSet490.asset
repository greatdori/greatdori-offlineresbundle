{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet490","backstageTalkSetId":490,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet490-1","talkText":"街中はハロウィンの\n装飾でいっぱいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet490-2","talkText":"はい！\n街を歩くのが楽しいです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet490-3","talkText":"あ、一緒にハロウィンの\n動画撮ってUPしない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet490-4","talkText":"いいですね！　ファンの方\nも喜んでくれそうです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet490-5","talkText":"すごく、るんっ♪　って\n感じ！　早く撮ろー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}