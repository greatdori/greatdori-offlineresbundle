{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet714","backstageTalkSetId":714,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet714-1","talkText":"みんな〜\n準備はいい？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet714-2","talkText":"バッチリです、彩先輩。\n張り切っていきましょう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5,16,27,30,32],"voiceId":"TalkSet714-3","talkText":"あけましておめでとう\nございま〜す！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet714-4","talkText":"うん。これぞThe正月！　\nいい感じなんじゃねーの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet714-5","talkText":"記念に写真撮りましょ〜！\nルイ、もっと笑えよ〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet714-6","talkText":"別にどんな表情でも\n構わないと思うけれど","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet714-7","talkText":"うっわ〜ルイ、\n今年もマジ頭固すぎ〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[5],"voiceId":"TalkSet714-8","talkText":"ちょ、ちょっと。新年早々\n喧嘩はよくないぞ〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet714-9","talkText":"いえ？　\n別に喧嘩では","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet714-10","talkText":"そうだ！　ねえみんな\n今年の目標書いてみない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[32],"voiceId":"TalkSet714-11","talkText":"それいいですね！　\n目標は、でらでっかく！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet714-12","talkText":"そうだね。それと\nみんな仲良く、だよ♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}