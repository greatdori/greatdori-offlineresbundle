{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet715","backstageTalkSetId":715,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet715-1","talkText":"チームジャグリングです。\nそ、それではどうぞ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet715-2","talkText":"やったー大成功！\n美咲先輩のおかげです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet715-3","talkText":"いやいや、あたしは\nなんにもしてないから","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet715-4","talkText":"ふふ、練習大変だったけど\n楽しかったもんね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet715-5","talkText":"じゃじゃーん！　どう？\nるんっ♪　とする新技〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet715-6","talkText":"はは……こころ以外にも\n楽勝でやれる人がいたとは","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet715-7","talkText":"それじゃ〜ラスト♪\nましろちゃんいってみよ〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet715-8","talkText":"は、はいっ……\nえ、えいっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet715-9","talkText":"おしかったよ、ましろちゃん\nあと一歩だよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet715-10","talkText":"うん、がんばった成果だね。\n今年も前向きにがんばろう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[26],"voiceId":"TalkSet715-11","talkText":"は、はいっ\nがんばります","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}