{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet712","backstageTalkSetId":712,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet712-1","talkText":"ええと、好きなものを\n飾ればいいんだよね……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet712-2","talkText":"えいっ☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet712-3","talkText":"フフ、それっ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet712-4","talkText":"はい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet712-5","talkText":"仕上げは\nイヴさんお願いします！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet712-6","talkText":"お任せください！\nええ〜い！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet712-7","talkText":"完成です〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet712-8","talkText":"まあ、普通ではないけど……\n悪くないね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[12],"voiceId":"TalkSet712-9","talkText":"ああ……なんて美しさだ！\n新年にふさわしい儚さだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[23],"voiceId":"TalkSet712-10","talkText":"好きな物全部盛りって感じ♪\n賑やかな１年になりそう☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[20],"voiceId":"TalkSet712-11","talkText":"はい！　みなさん、本年も\nよろしくお願いします！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}