{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet719","backstageTalkSetId":719,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet719-001","talkText":"でね、これが深淵の魔剣！\nカッコいいでしょ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet719-002","talkText":"え……？\nし、深淵の……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet719-003","talkText":"限定の闇の装備で、\n超超レアなんだよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet719-004","talkText":"他にも、冥王の鎧とか\n輝きの騎士とかもあるよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet719-005","talkText":"輝きの、騎士……\nちょっとカッコいいかも","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet719-006","talkText":"でしょ～！？　ましろも\n一緒にやってみようよ～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}