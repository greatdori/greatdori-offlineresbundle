{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet713","backstageTalkSetId":713,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet713-1","talkText":"我に宿りし闇の力よ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet713-2","talkText":"穿て！\nカオティックショット！！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet713-3","talkText":"わ、あこちゃんすご〜い。\n次はマスキちゃんの番だね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet713-4","talkText":"花音先輩と\n扇にイラスト描いたんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet713-5","talkText":"チョココロネとクラゲだよ♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet713-6","talkText":"くっ……かわいすぎて\n当てられねえ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet713-7","talkText":"マスキングさん……\n当てないと芸になりません","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[33],"voiceId":"TalkSet713-8","talkText":"仕方ねえ……！\nやってやるぜ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[3],"voiceId":"TalkSet713-9","talkText":"ラストは氷川先輩ですね。\nこ、こんなに的が小さい","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet713-10","talkText":"……『正射必中』。正しく\n射られた矢は、必ず……っ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[24],"voiceId":"TalkSet713-11","talkText":"す、すっごーい紗夜さんっ\n超超超カッコいい〜〜！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[22],"voiceId":"TalkSet713-12","talkText":"ふふっ、\nいい１年になりそうですね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}