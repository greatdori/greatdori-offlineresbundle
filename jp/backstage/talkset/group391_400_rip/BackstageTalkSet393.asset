{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet393","backstageTalkSetId":393,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet393-1","talkText":"今日は暑いですね……\n薫先輩は大丈夫ですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet393-2","talkText":"フフ、すべては\n気の持ちようさ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet393-3","talkText":"暑い時は雪山にいる\n自分を想像するといいよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet393-4","talkText":"さ、さすが薫先輩……っ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}