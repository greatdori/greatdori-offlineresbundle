{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet708","backstageTalkSetId":708,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet708-1","talkText":"ワタシがかくし芸を\nやるの！？　Why！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet708-2","talkText":"パレオはチュチュ様と同じ\nチームで嬉しいです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet708-3","talkText":"そんな話はしてない！\nやる必要がないってこと！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[31],"voiceId":"TalkSet708-4","talkText":"ますきとロックのチームは\n順調に進んでる？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet708-5","talkText":"はい！　うちは彩先輩が\n引っ張ってくれて……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet708-6","talkText":"うちのチームも今んとこ\n順調だな","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[34],"voiceId":"TalkSet708-7","talkText":"あの、レイヤさんのチーム\nメンバーって確か……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[31],"voiceId":"TalkSet708-8","talkText":"うん、花ちゃんと一緒。\nだから練習も楽しいよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[31],"voiceId":"TalkSet708-9","talkText":"あとは、\nオッちゃんもいるしね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[34],"voiceId":"TalkSet708-10","talkText":"オッちゃんって、\nあの……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[31],"voiceId":"TalkSet708-11","talkText":"そうそう。\n花ちゃんが飼ってる――","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[35],"voiceId":"TalkSet708-12","talkText":"Stop！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":3,"balloonType":1},{"talkId":13,"characterIds":[35],"voiceId":"TalkSet708-13","talkText":"かくし芸の内容は\nSecretという話よ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[32],"voiceId":"TalkSet708-14","talkText":"チュチュさん……ホントは\n楽しみなんじゃ……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[35],"voiceId":"TalkSet708-15","talkText":"う、うるさい！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}