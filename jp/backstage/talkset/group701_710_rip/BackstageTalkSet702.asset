{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet702","backstageTalkSetId":702,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet702-1","talkText":"お正月のかくし芸大会、\n皆何やるか決まった！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet702-2","talkText":"おい、それ聞かない\n約束だろ～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet702-3","talkText":"そうなんだけど～、\nでも気になっちゃって！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet702-4","talkText":"私達のチームは……ふふ。\n皆びっくりするよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet702-5","talkText":"うん！　特別ゲストも\nいるしね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet702-6","talkText":"めっちゃ楽しみ～。\nうちは和っぽい感じかな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet702-7","talkText":"うちのチームも\nThe正月！　って感じ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet702-8","talkText":"ん～～～、すっっっごく\n気になる～～～！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet702-9","talkText":"まあ、お正月までの\nお楽しみだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[1],"voiceId":"TalkSet702-10","talkText":"うう～、あといくつ\n寝たらいいんだっけ～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}