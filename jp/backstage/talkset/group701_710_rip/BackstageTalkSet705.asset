{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet705","backstageTalkSetId":705,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet705-1","talkText":"あら、もしかして\nかくし芸大会の相談？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet705-2","talkText":"皆さん！\nはい、そうなんです","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet705-3","talkText":"出し物が大掛かりな分\n準備も大変で～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet705-4","talkText":"確かに薫は、突拍子もない\nことを言い出すものね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet705-5","talkText":"いつものことです。\nフヘヘ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet705-6","talkText":"ふふ、みんな楽しそう～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet705-7","talkText":"アヤさんのチームは\n順調ですか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[16],"voiceId":"TalkSet705-8","talkText":"この間皆でリハしたよ～\n日菜ちゃんは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet705-9","talkText":"うちはまだ個人練習中って\n感じかな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet705-10","talkText":"あたしはるんっ♪　とくる\n新技を考えてて～……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet705-11","talkText":"それ以上言うと何やるか\nわかっちゃいますよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[17],"voiceId":"TalkSet705-12","talkText":"あ、そっか。出し物は\nお正月まで内緒だったっけ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}