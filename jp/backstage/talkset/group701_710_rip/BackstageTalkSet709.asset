{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet709","backstageTalkSetId":709,"snippets":[{"talkId":1,"characterIds":[11,13],"voiceId":"TalkSet709-1","talkText":"イエーイ！\nハッピーニューイヤー！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":3,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet709-2","talkText":"行っくぞ〜！\nソイヤ！　ソイヤ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":3,"characterIds":[34,35],"voiceId":"TalkSet709-3","talkText":"おお〜〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet709-4","talkText":"さ、次は私達の番ですよ。\nがんばりましょう♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet709-5","talkText":"や、やっぱり\nちょっと高すぎるわよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[34],"voiceId":"TalkSet709-6","talkText":"大丈夫ですよ♪\nクッションも準備してます","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet709-7","talkText":"大丈夫！　勇気を出せば\nなんでもできるよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[11],"voiceId":"TalkSet709-8","talkText":"そうよ、大事なのは笑顔よ。\nみんないくわよ〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9,11,13],"voiceId":"TalkSet709-9","talkText":"ソイヤ〜スマイル〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":10,"characterIds":[35],"voiceId":"TalkSet709-10","talkText":"Unbelievable……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}