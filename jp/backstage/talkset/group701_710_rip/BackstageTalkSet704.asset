{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet704","backstageTalkSetId":704,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet704-1","talkText":"カオティックショット！\nでどうですか紗夜さん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet704-2","talkText":"何度も言っていますが、\n掛け声は必要ありません","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet704-3","talkText":"ふふ……かくし芸大会の\nお話ですか……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet704-4","talkText":"そう！　すごいのやるから\n期待しててね、りんりん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet704-5","talkText":"うん……わたし達も、\nがんばるね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet704-6","talkText":"ええ。今から肺活量を\n更に鍛えておくわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet704-7","talkText":"い、いえ……空気入れは、\nあるそうです……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet704-8","talkText":"あら、そうだったの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet704-9","talkText":"皆いいな～。同じチームに\nバンドメンバーがいてさ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet704-10","talkText":"リサも楽しそうに\n準備していたじゃない","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet704-11","talkText":"楽しいよ☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[23],"voiceId":"TalkSet704-12","talkText":"うちは特に大掛かりなこと\nやるから、期待してて！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[24],"voiceId":"TalkSet704-13","talkText":"わあ、早くお正月に\nならないかな～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}