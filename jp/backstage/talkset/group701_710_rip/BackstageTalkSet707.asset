{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet707","backstageTalkSetId":707,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet707-1","talkText":"うう、私だけいつまで\nたっても出来ない……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet707-2","talkText":"まだ時間はあるし、\n練習すれば大丈夫！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet707-3","talkText":"あ、かくし芸大会の話～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet707-4","talkText":"うん。私、器用じゃない\nから大変で……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet707-5","talkText":"先輩達も優しく教えて\nくれてるでしょ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet707-6","talkText":"そうだけど～……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet707-7","talkText":"しろちゃん、ファイト～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet707-8","talkText":"るいるいととーこちゃんも\n同じチームだよね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[27],"voiceId":"TalkSet707-9","talkText":"そ！　あたしはリハ完璧！\nルイも目撃したっしょ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[30],"voiceId":"TalkSet707-10","talkText":"あなたが忘れ物をした\nことを除けば","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[27],"voiceId":"TalkSet707-11","talkText":"どうにかなったんだから\n別にいいだろ？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[29],"voiceId":"TalkSet707-12","talkText":"ま、まあまあ\n二人とも……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[28],"voiceId":"TalkSet707-13","talkText":"どっちのチームも\n大変そうだね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}