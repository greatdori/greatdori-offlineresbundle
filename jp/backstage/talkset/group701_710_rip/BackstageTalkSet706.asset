{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet706","backstageTalkSetId":706,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet706-1","talkText":"二人ともかくし芸大会は\nホントに大丈夫なの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet706-2","talkText":"うん！　準備はバッチリ！\nねー、こころん！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet706-3","talkText":"美咲はなにを心配\nしているのかしら？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet706-4","talkText":"あたしとはぐみで\nみんなを笑顔にするわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet706-5","talkText":"こころとはぐみだから\n心配してるの！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet706-6","talkText":"フフ……美咲のその仲間を\n思いやる気持ち……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet706-7","talkText":"あぁ、儚い","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet706-8","talkText":"ふふ……で、美咲ちゃんの\nチームは順調かな？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet706-9","talkText":"まー、うちはなんとか。\nあたしが一応経験者なんで","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet706-10","talkText":"経験者……？\nなにをやるんだろ……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet706-11","talkText":"あ！　いやそれは内緒って\n話なんで……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[11],"voiceId":"TalkSet706-12","talkText":"きっと笑顔が笑顔を呼ぶ\n『笑顔かくし芸』だわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[13],"voiceId":"TalkSet706-13","talkText":"みーくんの笑顔かくし芸、\n期待しちゃうな～～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[12],"voiceId":"TalkSet706-14","talkText":"美咲の抱腹絶倒のかくし芸\n楽しみにしているよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[15],"voiceId":"TalkSet706-15","talkText":"ハードルの上がり方……\n尋常じゃなくない……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}