{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet710","backstageTalkSetId":710,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet710-1","talkText":"えい！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet710-2","talkText":"それ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet710-3","talkText":"えいっ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet710-4","talkText":"じゃ〜ん！\nオッちゃん登場だよ〜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet710-5","talkText":"わっ……\nふふ、すごくかわいい","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet710-6","talkText":"ラストは大技ね。\n二人ともがんばって","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2,8],"voiceId":"TalkSet710-7","talkText":"いくよ〜\nそれ〜〜っ！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet710-8","talkText":"すごいね！　\nいっぱい出てくる","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[18],"voiceId":"TalkSet710-9","talkText":"ふ、二人とも……？\nもういいんじゃないかしら","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet710-10","talkText":"そ、それが……\nと、止まらないのぉ〜〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[2],"voiceId":"TalkSet710-11","talkText":"うん、お正月から景気が\n良くっていいと思う","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[31],"voiceId":"TalkSet710-12","talkText":"ふふ、そうだね。きっと\n実りの多い１年になるね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[8],"voiceId":"TalkSet710-13","talkText":"も〜！　いいから\n誰か止めて〜〜っ！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}