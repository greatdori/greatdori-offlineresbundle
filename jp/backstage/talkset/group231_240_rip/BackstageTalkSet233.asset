{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet233","backstageTalkSetId":233,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet233-1","talkText":"昨日食べた筑前煮、\nすごくおいしかったんだ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet233-2","talkText":"あっ、私も昨日の晩ごはん\n筑前煮でしたよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet233-3","talkText":"偶然ー！　有咲とは\nごはんの好み合いそう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}