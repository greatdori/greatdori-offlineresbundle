{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet429","backstageTalkSetId":429,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet429-1","talkText":"はー、みんなで買い物\n楽しかった～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet429-2","talkText":"ああいうお店には\n行かないから新鮮だったわ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet429-3","talkText":"プレゼント選び、想定より\n時間がかかりましたね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet429-4","talkText":"あこちゃん……喜んで、\nくれるでしょうか……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet429-5","talkText":"みんなで選んだんだし、\nきっと大丈夫だって☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}