{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet421","backstageTalkSetId":421,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet421-1","talkText":"イヴちゃん、次のシフトの\nことなんだけど……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet421-2","talkText":"待ってください、\nいま手帳を出しますね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet421-3","talkText":"わぁ、予定がいっぱいだ！\n忙しいんだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet421-4","talkText":"はい！　毎日が\nとても充実してます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}