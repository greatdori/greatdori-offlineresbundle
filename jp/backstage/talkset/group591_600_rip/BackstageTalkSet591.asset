{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet591","backstageTalkSetId":591,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet591-1","talkText":"この春物のワンピース、\nリミさんにピッタリです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet591-2","talkText":"そうかな？　ちょっと\nかわいすぎない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet591-3","talkText":"いえ、とても似合うと\n思いますよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}