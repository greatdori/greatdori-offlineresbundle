{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet598","backstageTalkSetId":598,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet598-1","talkText":"ねえねえ、この石\nうさぎに見えない！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet598-2","talkText":"わ、かわいい！\n会いに行こう！　今すぐ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet598-3","talkText":"ええっ！？　この公園、\nすごく遠いよ！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet598-4","talkText":"わ、もう行っちゃった！\nおたえ、待ってぇ〜！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}