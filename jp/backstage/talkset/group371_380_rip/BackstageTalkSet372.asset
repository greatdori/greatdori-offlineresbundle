{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet372","backstageTalkSetId":372,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet372-1","talkText":"千聖ちゃんっ、\n誕生日おめでとー！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet372-2","talkText":"これ、みんなからの\n誕生日プレゼントです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet372-3","talkText":"これは……オルゴール？\nすごくかわいいわ……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet372-4","talkText":"よかった！　みんなで\n一生懸命探したんだっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet372-5","talkText":"音色も、とても\n素敵なんですよっ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet372-6","talkText":"早く聴いてみたいわ。\nみんな、ありがとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}