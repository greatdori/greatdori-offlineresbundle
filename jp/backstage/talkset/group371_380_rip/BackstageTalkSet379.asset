{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet379","backstageTalkSetId":379,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet379-1","talkText":"巴、誕生日おめでとう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet379-2","talkText":"このケーキは私達の\n気持ちだよ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet379-3","talkText":"沙綾、瀬田先輩っ！\nありがとうございます！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet379-4","talkText":"そうだ、紅茶を淹れよう。\n少し待っていてくれ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet379-5","talkText":"それじゃ、私は\nマッサージでもしようか？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet379-6","talkText":"あははっ、今日は\n至れり尽くせりだな！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}