quirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"そしたらお昼ご飯食べてー、\nあ、絵手紙教室も行ってみたい！\nその前に散歩もしたいなー","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"お昼ご飯の後に、散歩……\nそのあとで絵手紙教室ね……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":1,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"午後の絵手紙教室は確か１４時からだから……\n昼食を１時間とすると、散歩の時間は３０分ほどかしら……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"あ、あとキャンプもしたいなー！\nその公園って、確かキャンプもできるんだよね？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"あたしが望遠鏡を持って行くから\n夜になったら一緒に星を観るの！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"と、なると泊まりね。\nなら絵手紙の時間はもう少し遅くてもよさそうね……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":1,"soundReferenceIdx":1,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"ん……？\nおねーちゃん、さっきから何書いてるの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"何って、スケジュールよ。\n当然でしょう？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"スケジュールって、なんの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"なんのって、紅葉狩りのに決まっているでしょう。\n大体あなたの希望通りに\n作ってみたけれど、どうかしら？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"あれ……？\nえ、おねーちゃん、もしかしてホントに行ってくれるの！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"え？\nだってあなたが行きたいって言ったんでしょう？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"それよりも、スケジュールはどうかしら？\n何か気になるところがあれば、\n早めに言ってもらえれば改善するわ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"そ、そうだったんだ……！\nわーい、ありがとう、おねーちゃん！\nすぐ確認する！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"……うん、完璧だよ、この流れ！\n今からでも行きたいくらい！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"今からは無理よ、まずスタートの\n営業時間前にカヤック乗り場へ行くことが\n達成できないわ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"それに泊まりにするのなら当日だけでなく、\n翌日のスケジュールも、調整しないといけないでしょう？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"ちゃんと事務所の方に、お休みの日を相談すること。\n日にちが決まってから、細かいところは詰めましょう","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"えー、そんなのいいってー！\nおねーちゃんとの予定の方が大事だもん！\nすぐ行きたーい！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev95-ep5-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"紗夜","body":"日菜……ちゃんとしないとこの話はなしよ、いいわね？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev95-ep5-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"日菜","body":"それはダメ～！\nちゃんと相談しまーす","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motion