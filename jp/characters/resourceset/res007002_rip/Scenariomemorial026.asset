:7,"voiceId":"memorial026-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"わ、めっちゃ荷物多いですね〜","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"そんな{{userName}}さんには、\nあたしが買ってきたパンをあげましょー\nはい、どーぞ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"……んー？　なんで不思議そうな顔、してるんですか？\nあげるって言ったのに、くれてない？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"いやいやー、ちゃんと『上げてる』じゃないですかー","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"なーんてね。\n……うそうそ。これもおしゃれなモカちゃんジョークです","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"このパンはあげられないけど、\nこっちのパンはあげますよー。はい、どーぞ\nこのパンは蘭のだからダメなんです","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"最近の蘭は、すごく練習頑張ってますからね、ライブが\n成功するように差し入れしてあげちゃおうかなーなんて。\nんー、あたしってめちゃ優しいなあ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"モカ","body":"……あ、そうでした。ライブですよ、ライブ\n早く行かないと、リハーサルが始まっちゃう","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"memorial026-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"