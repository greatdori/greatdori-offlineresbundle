erId":23}],"windowDisplayName":"リサ","body":"あはは、それはすごいね……\nでも、そっか。アイドルって、そんなに大変なんだ。\n他には？　どんなこと気を付けてるの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode179-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"日焼けの他？　そうだな～。\nちょっとしたケガにも気を付けてるかな～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"episode179-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"それから、寝る時はちゃんと加湿！\nあと、のどの調子が悪かったら、すぐにマスクをするとかね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"episode179-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"なるほどなるほど。\nたしかにボーカルにとって、のどの保護は大事だよね～。\nウチの友希那もすごく気を使ってるよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode179-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"そうなんだよ〜！\nのどが弱ってると風邪も引きやすいみたいだし！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"episode179-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"しっかし、そんなにいっぱい気を付けなきゃいけないことが\nあるなんて、アイドルってホント大変だね～。\nアタシ、ちょっとそこまではできないかも","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode179-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"なんだか彩のこと、改めて尊敬しちゃったよ！\nすごいね！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode179-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"えへへ、そんなことないよ～。\n習慣になっちゃえば簡単だもん！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"shame01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"episode179-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"あと気を付けてるのはね～、\nチョコを食べるなら食事