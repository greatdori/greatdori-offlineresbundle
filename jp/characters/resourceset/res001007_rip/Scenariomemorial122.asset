:"gattsu01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"星が一番キレイに見える時間まで起きてるのが\nすっごく大変で……ついつい寝そうになっちゃって。\nあはは","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"星が出るまで待っている間、\nみんなに星の鼓動の話をしたんだけど、\n蘭ちゃんもギターをはじめて弾いた時に似た経験をしたんだって！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"何かがはじまる予感がした……って言ってた。\n私と同じだよ！　ふふ、うれしいなあ……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"それからみんなで見た満点の星空はすっごくすっごく\nキレイで……もう眠気なんて一瞬で吹っ飛んじゃった","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"このへんで見るよりも何倍も星がたくさん見えてね、\nその１つ１つが本当に音をたててキラキラ輝いてるように\n見えたんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"……そうそう！　日菜さんから教えてもらったんだけど、\n私達が見てる星の輝きって、何年も何百年も前の光なんだって！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":1,"voiceId":"memorial121-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"それを今の私達が見てるって、なんだかすごくない！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"香澄","body":"なんか、うまくいえないけど、すごいよね！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"memorial121-018","volume":1}],"speed":0,"fontS