"delay":5.800000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":36,"delay":2.5999999046325684,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":37,"delay":4.199999809265137,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":38,"delay":6.800000190734863,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"ね、ねえ、{{userName}}さん。\nあそこで踊ってるの、薫さんじゃない？\n……あ、目が合った！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"やぁ、二人とも。\nこんなところで奇遇だね。どこかへお出かけかな？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"うん、いつもの買い出しだよ。\nそれより薫さん、踊ってたみたいだけど、\n何かいいことでもあったの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"よくぞ聞いてくれた！\n私は今、より美しく儚い踊りを研究していたところなんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"踊りを研究？\nそれってお芝居の練習とか？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"いや、研究していたのはハロハピの曲さ。\nどんな振り付けがより優雅に見えるかと思ってね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"実はこの前、商店街の子ども祭りで、\nステージに立たせてもらったんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"そのステージで、こころが\n素晴らしいアイディアを思いついてね。\n急遽ダンスをすることになったんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"あ〜、あの商店街のお祭りね。\n大盛況だったって聞いたよ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"あぁ、かわいらしい子猫ちゃん達のおかげで、\n素晴らしい盛り上がりを見せてくれたよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"それに、こころ達と曲を演奏するだけでなく、\nどう演出するか、どう子猫ちゃん達を楽しませるかについて、\n深く語り合えたのは何よりも嬉しい体験だったよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"ふふ、みんなで色々アイディアを出し合うのって、楽しいもんね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"……あれ？　でもそれと今の踊りがどう関係するの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"その時は時間の都合で、\nライブ中に１曲しか、ダンスができなくてね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"だから次のステージでは、すべての曲に\n振り付けをつけようと思っていたんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"実は次のステージコンセプトとして、\nハロハピの曲でミュージカル仕立ての一人芝居を\nやってみようかと考えていたんだ、ただ……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"ただ？　何か悩んでることでもあるの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"やはりハロハピのあの元気さや自由さ、明るさは\nさすがの私をもってしても、表現することが難しくてね……\n何かいい考えはないだろうか？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"なるほどね。\nやっぱり五人みんなが揃ってこそのハロハピだもんね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"フフ、六人揃ってこそだよ、まりなさん。\nけれど、みんな揃って、というのは大事なことだね。\nおかげで解決への糸口が見えた気がするよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"ハロハピの魅力を表現するのに、\n私一人で考えていてはいけなかったんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"こころにはぐみ、花音、ミッシェル。そして美咲。\nみんなのアイディアを、聞いてみることにするよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev73-me5-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"まりな","body":"ふふ、悩みが解決できそうならよかったよ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev73-me5-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"フフ、期待に応えるのがこの私、瀬田