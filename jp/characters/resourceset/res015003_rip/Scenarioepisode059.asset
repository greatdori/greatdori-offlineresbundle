","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"ミッシェル","body":"そっ、そうそう！\nそう……なのかな？\n——まあ、そう。大体そんな感じ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"はぐみ","body":"そうなんだ！\nミッシェルはクマはクマでも\n魔法のクマだったんだね！！！！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"ミッシェル","body":"うん！　すごいあっさり信じたね！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"はぐみ","body":"じゃあもしかして、ふつうのクマやはぐみ達とは\nちがう、魔法の世界に住んでるの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"ミッシェル","body":"う、うーん。それもそんな感じかな～？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"はぐみ","body":"じゃあ！\nいつもご飯はどんなもの食べてる？\nねどこは？　空の上だったりする？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf02","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"ミッシェル","body":"えっ。え～。そ、そうだなぁ～。ハ、ハチミツが好きかなぁ？\nそれとぉ～……、ねどこは家……いや、\n木の……そう、木のおうちだよ～？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"m_awate","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode059-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"はぐみ","body":"そうなんだぁ……！\nじゃあピンクでモフモフで、目がくるんとしてて、\n鼻がツヤツヤなのにも、魔法の理由があるのっ？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"episode059-049","volume":1}],"spe