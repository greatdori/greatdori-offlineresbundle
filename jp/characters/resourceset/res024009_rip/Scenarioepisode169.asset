d":0}],"windowDisplayName":"燐子","body":"『……やっぱりこの麦わら帽子、\n期待してた性能には、遠く及ばないね。あこちゃん、\nやっぱり頭の装備、いつもの装備に、戻さない……？』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"episode180-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"燐子","body":"『この帽子にすると、どうしても防御力が弱くなっちゃうし……\n似合う装備を見つけるのも大変だよね……』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode180-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"燐子","body":"『限定っていっても、記念品みたいなものだから。\nクエスト行くなら別の装備で……』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"episode180-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"あこ","body":"『だっ、だめだめ！\nこの装備に意味があるんだもん！』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"angry01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode180-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"あこ","body":"『強さじゃないんだよ！\nりんりんとあこが、リアルクエストでがんばってゲットした、\n大切な思い出の装備なんだからっ！』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motion