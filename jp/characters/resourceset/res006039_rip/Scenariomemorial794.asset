":"ev95-me4-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"うん、あたしも買い物。\n華道の作品に合う花を探そうと思ってさ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"今回は秋らしい作品にするつもりなんだけど、\nなかなかイメージが固まらなくって","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"この前りみに誘われて行った紅葉狩りで\nいろいろ思いついたのはあるんだけど、\nまだ絞り切れてないんだ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"紅葉狩り？　楽しかったよ。\n当日行ったら、湊さんがいたのにはちょっと驚いたけど","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"何、その心配そうな顔。\n大丈夫だったよ、結構楽しめたし","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"正直、集合場所に行った時は\nどうしようとは思ったけどね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"他にも、はぐみと紗夜さんがいてさ。\n珍しいメンバーだよね","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"もしかしたら楽しめたのは、りみとはぐみのおかげかも","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"ほら、はぐみって誰にでもああいう感じでしょ。\n人当たりがいいっていうか、物怖じしないタイプっていうか。\n湊さんみたいな難しい人とも上手につき合ってた","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"りみはお姉さんに送るビデオレターを撮ってたんだけど、\nほら、りみってなんか放っておけないところがあるでしょ？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"それでなんとなく、みんなでりみを手伝う空気になって、\nそのおかげで珍しいメンバーにもまとまりが生まれた気がする","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"紅葉狩りの他にも草笛とかカヤックとか絵手紙の\n体験教室もあってさ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"ああいうところって一人じゃ絶対行かないし、\nやっぱり、あのメンバーで行ったのが良かったのかも","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"紅葉狩りだけじゃなくて、色々できたから\nいい思い出になったよ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"珍しい組み合わせだったから、\nみんなの普段見ないような一面も見られて、悪くなかったかな","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"蘭","body":"……あ、そっか。\nそういうのも面白いかも","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"ev95-me4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talk