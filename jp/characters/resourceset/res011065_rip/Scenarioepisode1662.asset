の！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev208-ep3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"シェイクスピア曰く……人は常に明るく、\n愉快な心をもって人生の行路を歩まねばならない。\nつまり……そういうことさ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev208-ep3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"そうね！\n楽しいことを探すのは、とっても楽しいことだわ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev208-ep3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"薫はお買いものをしていたのかしら？\n何を買ったの？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev208-ep3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"それはね……\n明るく、眩しく、そして儚いもの……つまり、これのことさ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev208-ep3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"あら、本を買ったのね！\nみんな笑顔で、とっても楽しそうな表紙だわ。\nどんなお話が書いてあるのかしら？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev208-ep3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薫","body":"フフ……これはね、こころ。\n儚くも華やかな夢の地、ブロードウェイのガイドブックさ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev208-ep3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"ブロードウェイ！\nお芝居がいっぱいの、とっても楽しい街ね！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev208-ep3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"こころ","body":"薫はお芝居を観に行くのかしら？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":