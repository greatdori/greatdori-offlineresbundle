大丈夫ですよ！\n別に落ち込んでいるわけじゃありませんからっ","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"だからこそ、自分に何か出来ることがないかなーって思って、\nこのお守りを作ったんです","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"みんなで頑張って、ガルジャムが成功しますようにー！　って","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":8,"voiceId":"memorial031-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"でも……ガルジャムに向けて練習してる時、\n色々なことがあったんです","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"serious01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"ああ、ガルジャムというのは\nガールズバンド界隈ではメジャーなイベントなんです！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"それに出られることが決まったんですが、\nつぐが倒れちゃって、蘭と巴がケンカしちゃって……\n一時は出場辞退になるかも！？　なんてことがあったんです","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"sad01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"あはは、驚くのもわかります。\n今まで大きなケンカなんてしたことがなかったですし、\n私もあの時はどうなるかと思いましたしね～","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"……でも、みんなで乗り越えることが出来たんです。\nえへへ、友情パワーってやつですね！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"memorial031-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"ひまり","body":"無事にガルジャムにも出場できましたし、\n大大だ～い成功だったんですよ！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","exp