":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial176-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"そうそう、その３人も一緒にお手伝い！\nみんなで頑張っちゃった☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial176-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"いや～、あれはホントに驚いたよ～。\n休憩しようと思って入った海の家に、\n彩がいるんだもん！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial176-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"アイドルの仕事で、１日店長やってたんだって♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial176-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"リサ","body":"お店もめちゃめちゃ混んでて、\nなんかのゲームのコラボカフェとか言ってたけど……\nアタシ、そういうのはあまり詳しくないから","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":