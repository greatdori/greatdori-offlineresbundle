{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet256","backstageTalkSetId":256,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet256-1","talkText":"Tsugu~,\nare you feeling Tsugurific today~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet256-2","talkText":"Y-yes, I am!\nHow are you feeling?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet256-3","talkText":"I'm pretty Mocatastic myself~.\nLooks like we're on the same page~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}