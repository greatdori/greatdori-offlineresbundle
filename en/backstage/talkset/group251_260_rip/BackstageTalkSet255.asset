{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet255","backstageTalkSetId":255,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet255-1","talkText":"Mrmrmrrr, so hungry~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet255-2","talkText":"I can offer you one\nbite if you'd like~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet255-3","talkText":"Ngh, chocolate cornets have\nso many calories though... But...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet255-4","talkText":"Can Himari Uehara, our star athlete,\novercome this obstacle~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}