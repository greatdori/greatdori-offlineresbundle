{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet260","backstageTalkSetId":260,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet260-1","talkText":"We're gonna do our cheer on three!\nOne... Two... Three! Hey-","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet260-2","talkText":"Soi-soi-soi-soi-soi!\nSoi-ya!!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet260-3","talkText":"Ugh, you know we were supposed\nto go \"hey, hey, hoh~!\"","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}