{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet312","backstageTalkSetId":312,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet312-1","talkText":"A pro drummer as a high-school student...\nThat's pretty amazing, Yamato-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet312-2","talkText":"I-it's no big deal,\nreally!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet312-3","talkText":"I don't even compare to\nbeing Michelle...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet312-4","talkText":"Oh, c'mon! If you wanna talk about something\nthat's not a big deal, that's it right there!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}