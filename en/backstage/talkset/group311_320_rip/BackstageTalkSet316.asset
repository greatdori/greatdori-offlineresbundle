{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet316","backstageTalkSetId":316,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet316-1","talkText":"Eve-chin,\nwhat's bushido?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet316-2","talkText":"There is quite a lot to\nthe idea of bushido...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet316-3","talkText":"If I had to put it into one word, it'd be...\nbushido!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet316-4","talkText":"Ohhh~! Okay~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}