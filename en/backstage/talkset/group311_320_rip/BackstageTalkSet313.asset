{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet313","backstageTalkSetId":313,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet313-1","talkText":"You are always surrounded by people\nwearing black clothes, correct?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet313-2","talkText":"Yeah! They're always there to\nhelp when I need them!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet313-3","talkText":"There is no mistake...\nThose people are... ninjas!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet313-4","talkText":"They are?!\nOkay, yeah! They're ninjas!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}