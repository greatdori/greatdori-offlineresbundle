{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet318","backstageTalkSetId":318,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet318-1","talkText":"Misaki said we can't do the\nrooftop star concert.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet318-2","talkText":"How unfortunate. I suppose we\ncan think of other ideas.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet318-3","talkText":"What kind of show would you\nwant to put on, Kaoru?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet318-4","talkText":"Let's see... Above all,\nit would have to be fleeting.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}