{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet320","backstageTalkSetId":320,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet320-1","talkText":"Ngh... I had too many\ncroquettes before coming.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet320-2","talkText":"I'm gonna go running until\nit's time to rehearse!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet320-3","talkText":"That sounds like fun!\nI'm gonna go with you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}