{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet311","backstageTalkSetId":311,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet311-1","talkText":"Okusawa-san, how do you \npractice as a DJ?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet311-2","talkText":"How? I mean...\nI watch professionals...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet311-3","talkText":"Uhhh... I think I pretty much just\ndo basic stuff, now that I think about it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet311-4","talkText":"Okay! So fundamentals are key!\nNothing beats the basics!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}