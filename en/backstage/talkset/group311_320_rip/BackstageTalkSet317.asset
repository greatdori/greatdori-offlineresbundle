{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet317","backstageTalkSetId":317,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet317-1","talkText":"I thought of a new idea\nfor a concert!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet317-2","talkText":"I expect nothing less from you. Would you\ngrant my ears the pleasure of hearing it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet317-3","talkText":"We can perform on the school roof\nat night alongside the stars!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet317-4","talkText":"A harmonious melody with\nthe starry sky... So fleeting.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}