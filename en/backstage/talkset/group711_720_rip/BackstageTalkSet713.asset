{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet713","backstageTalkSetId":713,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet713-1","talkText":"I call upon you, I dark forces that reside within me...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet713-2","talkText":"Release! Chaotic Shot!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet713-3","talkText":"Wow~, that was amazing, Ako-chan~. Next is Masuki-chan's turn, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet713-4","talkText":"I drew a picture on our fan with Kanon-senpai.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet713-5","talkText":"Look, it's a chocolate cornet and a jellyfish♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet713-6","talkText":"Ngh... It's too cute, I can't do it...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet713-7","talkText":"MASKING-san... It's not a party trick if you don't hit it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[33],"voiceId":"TalkSet713-8","talkText":"Fine... Fine, I'll do it...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[3],"voiceId":"TalkSet713-9","talkText":"And so last up is Hikawa-senpai. Th-this one is really small.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet713-10","talkText":"... \"Perfect form, perfect shot.\" An arrow properly fired will always find its mark...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[24],"voiceId":"TalkSet713-11","talkText":"W-wooow! Sayo-san, that was super-duper, mega cool~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[22],"voiceId":"TalkSet713-12","talkText":"Fufu, I think this year is going to be a good one.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}