{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet711","backstageTalkSetId":711,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet711-1","talkText":"Here I go...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet711-2","talkText":"Remember to pose once it pops, everyone♪ Oh~, I'm so excited~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet711-3","talkText":"This is cool~. I've never been inside a balloon before~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet711-4","talkText":"Nobody could've saw this coming~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet711-5","talkText":"Fufu... I think they'll all... be really surprised...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet711-6","talkText":"Y-Yukina-senpai? ... Are you done yet~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet711-7","talkText":"Huh~? Wait, why is it shrinking~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[25],"voiceId":"TalkSet711-8","talkText":"Yukina-san... You can do it...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet711-9","talkText":"Minato-san~, I made a cute little cat balloon~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet711-10","talkText":"...! Sorry to keep you waiting... Let's end this!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1,7,25,28],"voiceId":"TalkSet711-11","talkText":"Yaaay~! Happy New Year~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet711-12","talkText":"... Where is the cat...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}