{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet717","backstageTalkSetId":717,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet717-001","talkText":"イヴ先輩の三つ編み、\nかわいいですよね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet717-002","talkText":"私も春っぽいアレンジを\nしてみたいなぁ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet717-003","talkText":"編み込みなんてどうですか？\nとっても簡単なんですよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet717-004","talkText":"そうなんですか？\n今度教えてほしいです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet717-005","talkText":"もちろんです！\n一緒に練習しましょう！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}