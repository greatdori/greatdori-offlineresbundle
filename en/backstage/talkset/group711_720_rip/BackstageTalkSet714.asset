{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet714","backstageTalkSetId":714,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet714-1","talkText":"Everybody ready~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet714-2","talkText":"I'm all set, Aya-senpai. Let's get 'em!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5,16,27,30,32],"voiceId":"TalkSet714-3","talkText":"Happy New Year~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet714-4","talkText":"Yup. This is how you celebrate New Year's, alright. Looks pretty good, yeah?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet714-5","talkText":"C'mon, let's get a group picture together~! Rui, smile more~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet714-6","talkText":"I do not think my expression particularly matters, though.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet714-7","talkText":"Ugh~. Rui, you're gonna be stubborn this year too, huh~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[5],"voiceId":"TalkSet714-8","talkText":"H-hey, let's not start the year off with a fight~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet714-9","talkText":"Hm? Were we fighting?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet714-10","talkText":"Oh, that's it! Why don't we all jot down our New Year's resolutions?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[32],"voiceId":"TalkSet714-11","talkText":"I like that idea! Let's make them really large-scale!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet714-12","talkText":"Yeah. But also, let's make sure we all get along♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}