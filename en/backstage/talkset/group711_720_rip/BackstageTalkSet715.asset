{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet715","backstageTalkSetId":715,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet715-1","talkText":"We're going to do some team juggling. U-um, here we go...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet715-2","talkText":"Yay~! That was amazing! Misaki-senpai, this is all thanks to you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet715-3","talkText":"Nah, I didn't do anything special.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet715-4","talkText":"Fufu, practice was hard, but it was fun, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet715-5","talkText":"Ta-dah~! What do you think? It's a super boppin' new trick~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet715-6","talkText":"Haha... I never thought someone besides Kokoro would pick this up so quickly.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet715-7","talkText":"Okay~, last up is Mashiro-chan♪ Go get 'em~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet715-8","talkText":"O-okay... A-ah!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet715-9","talkText":"That was really close, Mashiro-chan! You're almost there!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet715-10","talkText":"It's all thanks to your hard work. Let's keep working hard this year, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[26],"voiceId":"TalkSet715-11","talkText":"O-okay... I'll do my best.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}