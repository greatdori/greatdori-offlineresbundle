{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet720","backstageTalkSetId":720,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet720-001","talkText":"こ、これが今話題の\nスイーツ……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet720-002","talkText":"なんというか\nすごいですね……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet720-003","talkText":"この角度超映える～！\nヤバ、あたし天才じゃん？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet720-004","talkText":"あっ、でもこっちの角度も\nいい感じじゃね？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet720-005","talkText":"う～ん、どの写真\nアップしようか迷うな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet720-006","talkText":"……桐ヶ谷さん、そろそろ\n食べてもいいかしら","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}