{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet576","backstageTalkSetId":576,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet576-1","talkText":"Hello, Happy World! Lion Dance! Roar~!","lipAnimation":"","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet576-2","talkText":"Wow! I've never seen an actual lion dance before.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet576-3","talkText":"Have you been good boys and girls~? If not, I'll gobble up all your croquettes~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet576-4","talkText":"First, that's just superstition. Second, no one has any croquettes.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet576-5","talkText":"The exorcism of evil brings forth new happiness. Ahhh, how fleeting...","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[11],"voiceId":"TalkSet576-6","talkText":"Let's try doing a lion dance at our next show!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet576-7","talkText":"Count me in~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet576-8","talkText":"Ah, yes. That should make for a most memorable performance.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet576-9","talkText":"In that case, it'd be the lion, Michelle, and Kanon-san?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet576-10","talkText":"Fueee... I'm so sure about this~...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}