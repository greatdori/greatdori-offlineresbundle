{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet573","backstageTalkSetId":573,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet573-1","talkText":"One, two! One, two!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet573-2","talkText":"Hah! Hah!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet573-3","talkText":"Whoa... Those two are in perfect sync.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet573-4","talkText":"Mmmrph~.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet573-5","talkText":"Moca~. Eating or talking. Choose one or the other~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet573-6","talkText":"Eating it is, then~. So stretchy, so tasty~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet573-7","talkText":"Yay~! Glad to hear it. All that hard work was worth it, then.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet573-8","talkText":"Alright, you guys are up next. The important thing is keeping a good tempo!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet573-9","talkText":"Okie-dokie~. Leave it to us~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet573-10","talkText":"A-are you sure about this? That kind of speed seems a little much...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}