{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet572","backstageTalkSetId":572,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet572-1","talkText":"Look, look! I found this in the basement!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet572-2","talkText":"Wow~! What a big kite.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet572-3","talkText":"Let's go fly it together.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet572-4","talkText":"And how do you expect us to get that big thing off the ground?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet572-5","talkText":"She's right. We would need a nice breeze to do that~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet572-6","talkText":"Don't worry. If anyone can do it, we can.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet572-7","talkText":"Not sure where all that confidence is coming from...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet572-8","talkText":"Yeah, we've got this! Let's go~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet572-9","talkText":"Ah, wait! Kasumi, O-Tae!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[3],"voiceId":"TalkSet572-10","talkText":"Fufu, this is going to be fun~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}