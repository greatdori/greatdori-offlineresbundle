{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet578","backstageTalkSetId":578,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet578-1","talkText":"Spring is nice because there are so many different flowers that bloom.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet578-2","talkText":"Dandelions, lotus flowers, white clovers...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet578-3","talkText":"They're all foods that rabbits love.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet578-4","talkText":"That's what you meant?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0}]}}