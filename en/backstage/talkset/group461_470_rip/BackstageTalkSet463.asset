{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet463","backstageTalkSetId":463,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet463-1","talkText":"It feels like there is never enough time to wear fall clothes.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet463-2","talkText":"And there are so many cute styles to choose from.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet463-3","talkText":"I often find myself buying far too many outfits!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet463-4","talkText":"I know! See, you totally get it! We get so bogged down...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}