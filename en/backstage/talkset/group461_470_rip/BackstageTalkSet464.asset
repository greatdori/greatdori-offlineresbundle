{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet464","backstageTalkSetId":464,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet464-1","talkText":"Maybe we should have gone with something else for Moca's birthday present.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet464-2","talkText":"Is it really that big of a deal? I think she'll like what we got.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet464-3","talkText":"Yeah, I can already picture how she'll react~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet464-4","talkText":"Fufu, I hope she takes a liking to it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}