{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet468","backstageTalkSetId":468,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet468-1","talkText":"Tomoe-chan, you are as energetic as ever.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet468-2","talkText":"I sure am. And you seem to be your usual sparkling self.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet468-3","talkText":"Has my dazzling visage captured your attention?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}