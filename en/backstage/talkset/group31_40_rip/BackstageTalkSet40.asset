{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet40","backstageTalkSetId":40,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet40-1","talkText":"Maya, my efforts have paid off.\nThe fruits of labor have been picked!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet40-2","talkText":"Y-you're referring to the \"fleeting\"\npractice you were doing before?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet40-3","talkText":"Yes! Lend me your ears!\nFleeting... Now, your impressions.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet40-4","talkText":"(I don't see how this one's different from all the ones that came before it!)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}