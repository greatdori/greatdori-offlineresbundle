{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet38","backstageTalkSetId":38,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet38-1","talkText":"Sis, will you come with me\nto buy guitar strings?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet38-2","talkText":"I recall you buying new ones\nnot too long ago, though.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet38-3","talkText":"Uhhh, okay! Then I'll buy extra!\nC'mon, let's go to the store!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}