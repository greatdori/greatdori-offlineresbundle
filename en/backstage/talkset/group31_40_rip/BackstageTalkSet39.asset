{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet39","backstageTalkSetId":39,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet39-1","talkText":"Fleeting... No. Fleeting...\nThat's not right. Fleeting...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet39-2","talkText":"K-Kaoru-san...\nWhat are you doing...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet39-3","talkText":"Well, if it isn't Maya.\nNothing much. Just practicing a bit.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet39-4","talkText":"... Practicing what...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}