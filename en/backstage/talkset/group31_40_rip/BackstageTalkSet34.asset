{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet34","backstageTalkSetId":34,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet34-1","talkText":"Look, Misaki-chan.\nI changed my screensaver.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet34-2","talkText":"Ah, that's a different jellyfish\nfrom the last one.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet34-3","talkText":"Ehehe. Well, I took this picture\nat the aquarium yesterday.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}