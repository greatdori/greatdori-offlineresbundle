{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet33","backstageTalkSetId":33,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet33-1","talkText":"Kanon-san, do you have\nsome free time today?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet33-2","talkText":"Mhm, I do.\nDo you have something planned?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet33-3","talkText":"Yeah, I was thinking of\nbuying some more felt.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet33-4","talkText":"Ah, I was actually just thinking\nthat I wanted to get more.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}