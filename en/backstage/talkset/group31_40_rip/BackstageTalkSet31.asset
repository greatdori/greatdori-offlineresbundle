{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet31","backstageTalkSetId":31,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet31-1","talkText":"I bought... many of the books...\nI was interested in...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet31-2","talkText":"Rin-rin, what'd you get?\nShow me!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet31-3","talkText":"Okay... If you'd like... to read any...\nyou can borrow them...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}