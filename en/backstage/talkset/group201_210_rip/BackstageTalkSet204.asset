{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet204","backstageTalkSetId":204,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet204-1","talkText":"I made a stop at Yamabuki\nBakery on my way here.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet204-2","talkText":"Everything looked so good,\nI couldn't decide what to buy!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet204-3","talkText":"Fufu.\nThanks for always stopping by.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}