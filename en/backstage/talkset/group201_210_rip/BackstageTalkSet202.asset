{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet202","backstageTalkSetId":202,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet202-1","talkText":"Kasumi, how do you get\nyour hair to do that?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet202-2","talkText":"Are you gonna try\nit out for yourself?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet202-3","talkText":"Nope, I wanted to try\nfor rabbit ears.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet202-4","talkText":"Rabbit ears?!\nLet's give it a shot!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}