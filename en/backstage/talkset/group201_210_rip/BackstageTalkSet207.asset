{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet207","backstageTalkSetId":207,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet207-1","talkText":"Ran-chan, what's this person-thing\non your guitar case?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet207-2","talkText":"It's a charm Himari made.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet207-3","talkText":"She made it? That's amazing~.\nAnd it's so cute.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}