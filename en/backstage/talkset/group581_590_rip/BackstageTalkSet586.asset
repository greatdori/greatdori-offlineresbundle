{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet586","backstageTalkSetId":586,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet586-1","talkText":"Imai-san... Your lipstick... It's different today...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet586-2","talkText":"That's right, it's a new color for spring♪ How do I look? Do I pull it off?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet586-3","talkText":"Yes... It looks... very good on you...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet586-4","talkText":"Ehehe, thanks☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}