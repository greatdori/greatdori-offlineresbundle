{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet588","backstageTalkSetId":588,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet588-1","talkText":"Hagumi, a stray sakura petal has found its way onto your hair.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet588-2","talkText":"Huh? Really? Take it out, take it out~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet588-3","talkText":"No, we should leave it as is. As you are now, it's as if you're a sakura fairy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet588-4","talkText":"Hm... Truly, fleeting...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}