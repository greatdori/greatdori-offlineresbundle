{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet587","backstageTalkSetId":587,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet587-1","talkText":"We're having a sakura-viewing party tomorrow!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet587-2","talkText":"Yeah yeah. So? Where are we gonna have it this time?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet587-3","talkText":"The United States! We're going to go see the National Cherry Blossom Festival!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet587-4","talkText":"No, no, no, hold on... The US? Why can't we go somewhere closer...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}