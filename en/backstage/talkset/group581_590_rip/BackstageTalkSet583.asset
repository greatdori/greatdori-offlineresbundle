{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet583","backstageTalkSetId":583,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet583-1","talkText":"It still gets chilly at night, so make sure you don't catch a cold, okay?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet583-2","talkText":"Got it! Thanks for the warning!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet583-3","talkText":"An idol's body is their most important asset, after all! Health comes first!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}