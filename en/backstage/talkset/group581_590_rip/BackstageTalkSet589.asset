{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet589","backstageTalkSetId":589,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet589-1","talkText":"We've started selling strawberry-flavored desserts at our café.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet589-2","talkText":"Wow, that sounds really good~. Strawberries feel really spring themed, huh?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet589-3","talkText":"Please stop by with Chisato-san again when you have time.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}