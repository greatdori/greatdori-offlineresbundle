{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet581","backstageTalkSetId":581,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet581-1","talkText":"Mmm, this might be bad...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet581-2","talkText":"What's up? If you're worried about something, I'm down to listen.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet581-3","talkText":"I bought too many clothes for spring, and my wallet's in big trouble!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet581-4","talkText":"Tomoe, help~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0}]}}