{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2030","backstageTalkSetId":2030,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2030-1","talkText":"Ehehe~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2030-2","talkText":"You're in a good mood, Tsu-chan! Did something happen, Rui-rui?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2030-3","talkText":"We were asked for directions by a stranger on our way here.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2030-4","talkText":"They asked me! Meaning I look reliable!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2030-5","talkText":"(It was probably because Rui-rui looks scary...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet2030-6","talkText":"...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2030-7","talkText":"Fufu~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2030-8","talkText":"(Well, they say ignorance is bliss.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}