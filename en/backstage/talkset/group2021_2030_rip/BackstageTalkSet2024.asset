{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2024","backstageTalkSetId":2024,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2024-1","talkText":"...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2024-2","talkText":"What is it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2024-3","talkText":"Do you happen to like milk, Rui-san?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2024-4","talkText":"I do not particularly like or dislike it. Why?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2024-5","talkText":"Nothing! No real reason! Ahaha...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[29],"voiceId":"TalkSet2024-6","talkText":"So she didn't grow tall from drinking milk...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[26],"voiceId":"TalkSet2024-7","talkText":"(I know how you feel, Tsukushi-chan...!)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}