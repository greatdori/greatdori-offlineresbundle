{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet659","backstageTalkSetId":659,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet659-1","talkText":"The way that the crickets chirp always relaxes me for some reason.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet659-2","talkText":"Crickets chirping... under the pale moonlight...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet659-3","talkText":"An elegance that cannot be found elsewhere. Ahhh... how fleeting...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}