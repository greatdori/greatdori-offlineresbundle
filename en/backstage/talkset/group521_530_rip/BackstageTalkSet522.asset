{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet522","backstageTalkSetId":522,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet522-1","talkText":"Winter makes you want to eat lots of sweet things, doesn't it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet522-2","talkText":"I don't have a sweet tooth, but...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet522-3","talkText":"I guess I have been eating quite a lot of bitter chocolate recently.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet522-4","talkText":"Ehehe, this is bitter-chocolate flavor. Do you want it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}