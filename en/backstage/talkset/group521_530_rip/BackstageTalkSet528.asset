{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet528","backstageTalkSetId":528,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet528-1","talkText":"My hands have been so dry lately...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet528-2","talkText":"It's hard to wash dishes and such.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet528-3","talkText":"Do you want to try my hand cream? It's pretty good.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet528-4","talkText":"Thank you so much! I'll try it now.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}