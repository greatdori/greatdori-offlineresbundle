{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet149","backstageTalkSetId":149,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet149-1","talkText":"Then, Kasumi, the others and I\nall went, \"Soi-ya!\"","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet149-2","talkText":"Wow, that's great...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet149-3","talkText":"(Please come back.\nYou shouldn't be in their world...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}