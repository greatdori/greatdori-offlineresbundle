{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet393","backstageTalkSetId":393,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet393-1","talkText":"It's very hot today... How are you coping, Kaoru-senpai?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet393-2","talkText":"Fufu, all things change based upon one's perspective.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet393-3","talkText":"When the heat swells, simply imagine yourself on a snowy mountaintop.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet393-4","talkText":"Y-you're so clever, Kaoru-senpai...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}