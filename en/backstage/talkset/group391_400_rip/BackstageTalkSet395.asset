{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet395","backstageTalkSetId":395,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet395-1","talkText":"Ah, aren't those the seasonal sweets from our convenience store?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet395-2","talkText":"Yeah, I've taken a liking to them. I buy some every day!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet395-3","talkText":"They are pretty good! Can't say I blame you~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}