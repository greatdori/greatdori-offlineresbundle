{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet650","backstageTalkSetId":650,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet650-1","talkText":"Tomorrow, Chisato-chan and I will be going to a café near the station entrance.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet650-2","talkText":"Would you like to join us, Sayo-chan?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet650-3","talkText":"A café... Okay. I would be delighted.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet650-4","talkText":"I'll ask Aya-chan and Rinko-chan if they'd also like to come along.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}