{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet647","backstageTalkSetId":647,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet647-1","talkText":"Your wall is covered in rabbit photos! Are those yours, O-Tae-chan?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet647-2","talkText":"Yes, they are pictures of Oddie.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet647-3","talkText":"Before that, I had gone with a Hamburg steak gallery.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet647-4","talkText":"Maybe I'll decorate my wall with pics of Sis!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}