{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2034","backstageTalkSetId":2034,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2034-1","talkText":"I think today's practice went pretty well.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2034-2","talkText":"Oh, now that's something you don't hear Shiro saying every day.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2034-3","talkText":"Still, we do sound much better than we did in the beginning.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2034-4","talkText":"What do you think, Rui-san?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[30],"voiceId":"TalkSet2034-5","talkText":"We still lack proficiency in almost all areas... However.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet2034-6","talkText":"It cannot be denied that we have improved.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet2034-7","talkText":"Those words from Rui's mouth are just as rare!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet2034-8","talkText":"Yes, let's continue to practice hard together...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}