{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2039","backstageTalkSetId":2039,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet2039-1","talkText":"Interestin'. They've got a pretty cushy sofa.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[33],"voiceId":"TalkSet2039-2","talkText":"This tabletop is~... made of glass... I see.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet2039-3","talkText":"Well? How's your live house inspection going?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet2039-4","talkText":"I think Galaxy could do with a room like this!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}