{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2040","backstageTalkSetId":2040,"snippets":[{"talkId":1,"characterIds":[34],"voiceId":"TalkSet2040-1","talkText":"What did you think of CiRCLE's equipment?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[35],"voiceId":"TalkSet2040-2","talkText":"They actually had some high-quality stuff.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet2040-3","talkText":"I think we'd be able to hold a RAS concert here.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet2040-4","talkText":"Then we must do it someday~! I cannot wait~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}