{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2035","backstageTalkSetId":2035,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2035-1","talkText":"I'd love to go to training camp with everyone someday~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2035-2","talkText":"That sounds like heaps of fun! Let's go right away!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2035-3","talkText":"Th-that's a little too sudden, but it would be nice to go when we can.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2035-4","talkText":"If it allows for better practices, I would not mind it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2035-5","talkText":"Leave all the cooking to me! I have confidence in my cooking skills!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2035-6","talkText":"Seeing Fusuke brim with confidence is kinda unnerving...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2035-7","talkText":"Hmph, say things like that and there'll be no dinner for you, Toko-chan!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}