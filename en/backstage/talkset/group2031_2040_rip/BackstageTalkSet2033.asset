{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2033","backstageTalkSetId":2033,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2033-1","talkText":"Ah, before I forget, here are souvenirs for you all!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2033-2","talkText":"Thank you. What delicious-looking chocolate.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2033-3","talkText":"Ah, I know these! They're from a famous shop, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2033-4","talkText":"You know it~! I went to Belgium over the weekend.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2033-5","talkText":"A gift from overseas?! A-amazing...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2033-6","talkText":"Really? Anyway, dig in, everyone.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet2033-7","talkText":"They're luscious, aren't they~? I'm a fan too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[30],"voiceId":"TalkSet2033-8","talkText":"I am heading overseas next week as well. I shall pick something up.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[26],"voiceId":"TalkSet2033-9","talkText":"I almost forgot you were all from high-class families...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}