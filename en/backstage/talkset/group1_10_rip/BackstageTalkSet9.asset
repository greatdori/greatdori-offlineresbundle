{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet9","backstageTalkSetId":9,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet9-1","talkText":"Will your family be holding anymore\ncooking classes, Hazawa-san?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet9-2","talkText":"I sure would like to,\nif we had the chance...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet9-3","talkText":"If you do,\nbe sure to let me know.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}