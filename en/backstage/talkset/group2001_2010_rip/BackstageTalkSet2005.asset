{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2005","backstageTalkSetId":2005,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2005-1","talkText":"Tsukushi-chan, what are you watching on your phone?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2005-2","talkText":"A lesson on how to twirl drumsticks in a cool way.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2005-3","talkText":"Why don't you give it a try, Mashiro-chan?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2005-4","talkText":"Huh? I-I'm okay... It's too embarrassing...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}