{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2008","backstageTalkSetId":2008,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2008-1","talkText":"I wonder if there's a way to stop feeling nervous on stage...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2008-2","talkText":"Maybe it would help if you imagine the audience as vegetables.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2008-3","talkText":"I see... But vegetables aren't really ideal...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2008-4","talkText":"Ah, I forgot you don't like vegetables...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}