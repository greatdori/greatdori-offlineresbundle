{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet386","backstageTalkSetId":386,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet386-1","talkText":"A lot of our work has been outside lately.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet386-2","talkText":"We must try to protect ourselves from the sun's rays!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet386-3","talkText":"Can't forget about heatstroke.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet386-4","talkText":"Of course! We all need to stay on our guard!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}