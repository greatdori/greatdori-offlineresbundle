{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet389","backstageTalkSetId":389,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet389-1","talkText":"Poppin'Party should take part in a summer festival!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet389-2","talkText":"We're nowhere near ready for that kind of event.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet389-3","talkText":"As long as we practice hard, there's nothing we can't do!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet389-4","talkText":"Sigh... You never change, Kasumi.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}