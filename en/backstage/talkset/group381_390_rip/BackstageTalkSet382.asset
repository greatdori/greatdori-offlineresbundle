{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet382","backstageTalkSetId":382,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet382-1","talkText":"Happy Birthday, Kanon-chan!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet382-2","talkText":"Here! We got you some snacks!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet382-3","talkText":"There are more than enough to go around, so let's enjoy them together!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet382-4","talkText":"You brought this much?! Thank you, everyone.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet382-5","talkText":"Here it comes, Kanon-chan! Open wide~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet382-6","talkText":"Try a little of this too, Kanon-san~. So tasty~♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet382-7","talkText":"And a bite from mine! Down the hatch~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet382-8","talkText":"Fueee... I can't eat all of this at once~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}