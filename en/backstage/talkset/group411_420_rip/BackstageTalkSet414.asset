{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet414","backstageTalkSetId":414,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet414-1","talkText":"We certainly do put on a lot of performances, don't we?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet414-2","talkText":"Yeah, it kind of becomes second nature, once you get used to it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet414-3","talkText":"Practice makes perfect, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet414-4","talkText":"Precisely.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}