{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet42","backstageTalkSetId":42,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet42-1","talkText":"Sayo-san, did you log into NFO yesterday?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet42-2","talkText":"I-I did. There was a new quest, so...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet42-3","talkText":"I believe... it was to slay the dragon of darkness.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet42-4","talkText":"(Hm? That's... a high-rank quest... isn't it...?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}