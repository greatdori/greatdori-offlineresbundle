{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet49","backstageTalkSetId":49,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet49-1","talkText":"Rin-rin! Let's go to the convenience store!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet49-2","talkText":"Ah, does that mean... what I think it means...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet49-3","talkText":"Yep! The NFO collab started today~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet49-4","talkText":"Udagawa-san, you're getting too worked up.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet49-5","talkText":"Every store has a limited supply of stuff! We gotta hurry!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet49-6","talkText":"... Is that how it works? I suppose I will join you, then.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}