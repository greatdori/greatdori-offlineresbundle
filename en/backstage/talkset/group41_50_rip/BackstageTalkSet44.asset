{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet44","backstageTalkSetId":44,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet44-1","talkText":"Ah... I think I just came up with a good melody.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet44-2","talkText":"Ah! These lyrics are sparkling and heart-pounding!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet44-3","talkText":"... Ah!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet44-4","talkText":"Did you think of something too, O-Tae?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet44-5","talkText":"I have a feeling today's dinner will be hamburg steak.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet44-6","talkText":"What?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}