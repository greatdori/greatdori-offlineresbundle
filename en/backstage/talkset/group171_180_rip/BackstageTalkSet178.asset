{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet178","backstageTalkSetId":178,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet178-1","talkText":"Wow, everyone who plays the bass is here.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet178-2","talkText":"Maybe we can talk about the stuff we all go through.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet178-3","talkText":"Sounds fun.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet178-4","talkText":"Something we all relate to... Hmmm...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet178-5","talkText":"Ah! When eating croquettes, the area around your mouth gets really oily, and-","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet178-6","talkText":"We're gonna talk about croquettes...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}