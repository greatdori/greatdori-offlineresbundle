{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet232","backstageTalkSetId":232,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet232-1","talkText":"Arisa, the pigtails\nreally look good on you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet232-2","talkText":"Huh?! Uhhh...\nThank you very much...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet232-3","talkText":"Ahaha♪\nAre you embarrassed?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet232-4","talkText":"Y-you wish! Ah...\nI mean, no, I'm not!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}