{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet233","backstageTalkSetId":233,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet233-1","talkText":"I had simmered chicken and\nveggies last night. It was so good.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet233-2","talkText":"Oh, I had the same thing,\nactually.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet233-3","talkText":"What are the chances?! Sounds like\nwe might like the same things!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}