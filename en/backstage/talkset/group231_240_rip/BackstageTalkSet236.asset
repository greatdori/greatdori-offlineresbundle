{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet236","backstageTalkSetId":236,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet236-1","talkText":"Ah, I'm going to stop by your place\non my way home, Saya-chan.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet236-2","talkText":"Fufu, okay, I'll let my dad know\nto have a chocolate cornet ready.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}