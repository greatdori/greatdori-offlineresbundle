{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet239","backstageTalkSetId":239,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet239-1","talkText":"I found this hair accessory today\nthat I think you'd like, O-Tae.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet239-2","talkText":"...!! I know what it is.\nIt's in the shape of a rabbit, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet239-3","talkText":"N-no, sorry...\nIt's guitar shaped...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}