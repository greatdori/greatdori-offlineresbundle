{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet753","backstageTalkSetId":753,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet753-1","talkText":"Achoo.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet753-2","talkText":"CH-CHU²-sama?! Have you caught a cold?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet753-3","talkText":"No, my nose just felt a bit itchy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet753-4","talkText":"We must warm up your body immediately with a hot pot containing lots of green onions!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet753-5","talkText":"Leave out the vegetables, will you? They'll only make me feel worse.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}