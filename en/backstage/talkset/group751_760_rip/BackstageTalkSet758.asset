{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet758","backstageTalkSetId":758,"snippets":[{"talkId":1,"characterIds":[32],"voiceId":"TalkSet758-1","talkText":"Yashio-san, here's a question for you! \"Spring\" is famous for-","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet758-2","talkText":"Vivaldi, most likely.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[32],"voiceId":"TalkSet758-3","talkText":"What?! How were you able to figure it out from just that?!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet758-4","talkText":"I based my reply on common sense.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}