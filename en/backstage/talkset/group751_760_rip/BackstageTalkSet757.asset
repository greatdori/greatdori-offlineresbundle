{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet757","backstageTalkSetId":757,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet757-1","talkText":"What are you reading, Kaoru-san...?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet757-2","talkText":"This? This is an anthology of my fleeting poetry.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet757-3","talkText":"I have gathered together verses that are particularly suitable for spring.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet757-4","talkText":"U-um, do you think it would be okay for me to read it with you...?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}