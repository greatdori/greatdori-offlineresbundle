{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet756","backstageTalkSetId":756,"snippets":[{"talkId":1,"characterIds":[34],"voiceId":"TalkSet756-1","talkText":"Sigh~. You look so cute even in the spring, Eve-chan~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet756-2","talkText":"Hm? Does this mean I look different during other seasons?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[34],"voiceId":"TalkSet756-3","talkText":"Absolutely~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet756-4","talkText":"There is not a single moment where you are the same!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet756-5","talkText":"I see...! You must be speaking of the impermanence of all things!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}