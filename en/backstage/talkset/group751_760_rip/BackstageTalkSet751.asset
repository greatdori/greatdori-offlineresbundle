{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet751","backstageTalkSetId":751,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet751-1","talkText":"My sisters and I ran in the neighborhood marathon the other day.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet751-2","talkText":"It was cold, but we all still managed to finish!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet751-3","talkText":"Here's a photo of that moment!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet751-4","talkText":"Oh~, just look at the way all three of you are holding hands as you cross the finish line~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet751-5","talkText":"(It's so hard to tell which one's Tsu-chan...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}