{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet755","backstageTalkSetId":755,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet755-1","talkText":"Moca-chi! Let's go on a picnic~!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet755-2","talkText":"Nice idea~. But don't forget you can only bring up to 300 yens' worth of snacks, alright~?","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet755-3","talkText":"Okay~! Hey, do croquettes count as snacks?!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet755-4","talkText":"Hmm~...","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet755-5","talkText":"Not if they're croquette buns~.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}