{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet119","backstageTalkSetId":119,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet119-1","talkText":"I wanna put on a concert~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet119-2","talkText":"Sounds good to me~. When?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet119-3","talkText":"Right now!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet119-4","talkText":"Get real!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":5,"characterIds":[1],"voiceId":"TalkSet119-5","talkText":"The most important thing to have is a desire to play!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet119-6","talkText":"I get that, but that doesn't mean you can forget about planning!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1}]}}