{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet111","backstageTalkSetId":111,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet111-1","talkText":"Hey, Rimi, why don't we ask at the same time?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet111-2","talkText":"O-okay...! Ready...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3,8],"voiceId":"TalkSet111-3","talkText":"How did you get so cool, Kaoru-senpai?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet111-4","talkText":"How did you get so cool, Kaoru-san?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet111-5","talkText":"Fufu... The explanation would be quite lengthy. However...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet111-6","talkText":"If I had to answer in one word, it would be... \"fleeting\"...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3,8],"voiceId":"TalkSet111-7","talkText":"S-so cool...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet111-8","talkText":"... What is it that makes you two behave this way?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}