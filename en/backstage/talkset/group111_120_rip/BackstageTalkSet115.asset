{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet115","backstageTalkSetId":115,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet115-1","talkText":"Sigh, I have a shift today...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet115-2","talkText":"Are you working a lot this week?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet115-3","talkText":"I am~... I have another tomorrow too...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet115-4","talkText":"Too much work is unhealthy, you know.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet115-5","talkText":"Hii-chan's feeling Tsugurific~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet115-6","talkText":"I'll take fewer shifts next week...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}