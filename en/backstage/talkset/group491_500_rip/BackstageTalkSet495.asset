{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet495","backstageTalkSetId":495,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet495-1","talkText":"Tomorrow is Rinko's birthday. Ako, how's the present coming along?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet495-3","talkText":"Yes, I would like to know, too. Are you sure what you got will be alright?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet495-2","talkText":"It'll be perfect! I'm sure Rin-rin will be super delighted~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet495-4","talkText":"Everything will be fine~! Just trust me!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet495-5","talkText":"Ako knows best when it comes to picking out a present for Rinko.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}