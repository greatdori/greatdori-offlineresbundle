{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet496","backstageTalkSetId":496,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet496-1","talkText":"Rinko! Happy Birthday!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet496-2","talkText":"I know it's a surprise, but perhaps we went overboard?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet496-3","talkText":"Oh, no... Not at all... I'm just so... happy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet496-4","talkText":"Here you go! It's a present for you, Rin-rin!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet496-5","talkText":"Ah, NFO goods... And they are ones that just came out...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet496-6","talkText":"We let Ako be in charge of the present and we made the cake.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet496-7","talkText":"The cake... looks delicious... I'm... over the moon...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}