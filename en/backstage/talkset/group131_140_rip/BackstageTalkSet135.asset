{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet135","backstageTalkSetId":135,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet135-1","talkText":"Ran-chan, you really do have\nthat \"rock\" feeling to you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet135-2","talkText":"And you have that \"idol\"\nfeeling yourself.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet135-3","talkText":"Ehehe, you think so~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}