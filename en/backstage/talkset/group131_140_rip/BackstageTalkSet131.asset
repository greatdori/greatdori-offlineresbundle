{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet131","backstageTalkSetId":131,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet131-1","talkText":"Kanon-senpai, you're not gonna\nget a jellyfish as a pet?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet131-2","talkText":"I've always wanted\nto get one, but...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet131-3","talkText":"I don't know if I would be able\nto stop myself after the first one...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}