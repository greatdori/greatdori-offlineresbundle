{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50036","backstageTalkSetId":50036,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet50036-1","talkText":"Misaki! Happy Birthday!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50036-2","talkText":"Let's celebrate by dancing, Mii-kun!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50036-3","talkText":"Wait, what?! Dance?! But why?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50036-4","talkText":"Dancing together is fun, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet50036-5","talkText":"We want you to have a great time, Mii-kun!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet50036-6","talkText":"Now, join us, Misaki, and let us dance up a storm!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[15],"voiceId":"TalkSet50036-7","talkText":"Huff, puff... Th-that was tiring...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet50036-8","talkText":"Good job, Misaki-chan. Please have this water.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet50036-9","talkText":"K-Kanon-san~... You're just like an angel...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50036-10","talkText":"We thought very hard about how to make you happy, Misaki-chan.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet50036-11","talkText":"Ahaha... Well, it's the thought that counts.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}