{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50032","backstageTalkSetId":50032,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50032-1","talkText":"Happy Birthday, Moca. Here's your present for this year.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet50032-2","talkText":"We tried to think of something you'd like and came up with this.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet50032-3","talkText":"Hmm~? Th-this is...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50032-4","talkText":"It's a super-duper mega bun! Well? Are you surprised?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet50032-5","talkText":"Super surprised~. My long-held dream has finally come true~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50032-6","talkText":"We have lots of jam prepared, so eat as much as you'd like!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50032-7","talkText":"You shouldn't have to worry about any bread for a while now.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet50032-8","talkText":"By the way, Saya-chan was pretty surprised, wasn't she?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet50032-9","talkText":"She did say it was her first time seeing a bun so large.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50032-10","talkText":"Ahaha... Huh?! Moca, you already ate it?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50032-11","talkText":"I had a feeling this would happen...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[7],"voiceId":"TalkSet50032-12","talkText":"My stomach is no longer bound by the laws of the physical world~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}