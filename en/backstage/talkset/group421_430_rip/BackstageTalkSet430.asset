{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet430","backstageTalkSetId":430,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet430-1","talkText":"Happy Birthday, Ako.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet430-2","talkText":"Whoa~! A surprise party?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet430-3","talkText":"Fufu, everyone pitched in to help set it up♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet430-4","talkText":"And we also... prepared a present for you...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet430-5","talkText":"We were careful in our selection. Hopefully, it is to your liking.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet430-6","talkText":"What a super cool accessory! I love it!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}