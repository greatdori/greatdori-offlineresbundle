{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet81","backstageTalkSetId":81,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet81-1","talkText":"You look so happy, Hina-senpai.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet81-2","talkText":"I am!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet81-3","talkText":"Hina, some space, if you don't mind...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet81-4","talkText":"Fufu, you two get along so well.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}