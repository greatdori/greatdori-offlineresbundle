{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet89","backstageTalkSetId":89,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet89-1","talkText":"I feel rumbling in my tummy~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet89-2","talkText":"Didn't you just eat?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet89-3","talkText":"That was then, and this is now~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet89-4","talkText":"Hey hey~☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[21],"voiceId":"TalkSet89-5","talkText":"So you two decided to come as well.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[6],"voiceId":"TalkSet89-6","talkText":"Hey.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet89-7","talkText":"Oh! Either of you want a cookie?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[7],"voiceId":"TalkSet89-8","talkText":"Wow~! You are a gift from above~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}