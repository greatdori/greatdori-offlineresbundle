{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet633","backstageTalkSetId":633,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet633-1","talkText":"I'm thinking about making some fireworks today!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet633-2","talkText":"W-wow... What kind of fireworks?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet633-3","talkText":"Ones that'll shoot up into the sky and explode in the shape of Michelle's face!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet633-4","talkText":"Oh, yeah! I'll make some bread-shaped ones for you, too, Saya!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet633-5","talkText":"Haha, that sounds like something Moca would like, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}