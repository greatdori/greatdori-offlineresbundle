{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet636","backstageTalkSetId":636,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet636-1","talkText":"NFO is doing... a collaboration with... an ice cream brand... starting today, right...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet636-2","talkText":"Yeah! There's supposed to be serial codes you can redeem for weapons on every package!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet636-3","talkText":"Hopefully... you can get... the necromancer weapon...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet636-4","talkText":"If I get the wizard one, I'll give it to you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}