{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet324","backstageTalkSetId":324,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet324-1","talkText":"Making your nails all\nsparkly looks like fun!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet324-2","talkText":"Are you talking about nail polish?\nYeah, I love doing my nails.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet324-3","talkText":"Maybe I can do yours\nfor you sometime.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}