{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet328","backstageTalkSetId":328,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet328-1","talkText":"Fueee... What am I'm going to do...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet328-2","talkText":"Whatever is the matter, Kanon? It seems\nsomething weighs heavy on your mind.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet328-3","talkText":"This place I have to go is so far.\nI'm afraid I'll get lost...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet328-4","talkText":"Fufu. In that case,\nallow me to lead the way.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}