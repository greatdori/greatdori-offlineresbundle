{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet330","backstageTalkSetId":330,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet330-1","talkText":"Oh, wow. So you can make them\nlike that, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet330-2","talkText":"Oh, Misaki.\nDoing a little research?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet330-3","talkText":"Yeah. My little sister asked me\nif I could make her a felt cat.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet330-4","talkText":"You certainly hold your sister\nnear and dear to your heart.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}