{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet765","backstageTalkSetId":765,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet765-1","talkText":"ねぇ、この麦わら帽子\nかわいくない？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet765-2","talkText":"ほんとだ、ひまわりの\n飾りが夏っぽいね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet765-3","talkText":"どうしよ～、\n買っちゃおうかな～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet765-4","talkText":"ふふ、それじゃあ一緒に\n買いに行っちゃう？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}