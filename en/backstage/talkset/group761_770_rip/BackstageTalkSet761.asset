{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet761","backstageTalkSetId":761,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet761-1","talkText":"うう～、しくしく","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet761-2","talkText":"モカ先輩\nどうしたんですか～？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet761-3","talkText":"好きなマンガが打ち切りに\nなったんだよ～ヨヨヨ～～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet761-4","talkText":"あ、その作者、別の雑誌で\n新連載始まるみたいですよ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[7],"voiceId":"TalkSet761-5","talkText":"な、なんだって～！\n七深ちんは情報通だなあ～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}