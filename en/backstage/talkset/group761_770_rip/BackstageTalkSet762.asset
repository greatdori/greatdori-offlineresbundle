{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet762","backstageTalkSetId":762,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet762-1","talkText":"あたし、花園ランドに\n行ってみたいわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet762-2","talkText":"花園ランドは、思い描けば\nいつでも入園可能だよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet762-3","talkText":"とっても素敵ね！\n考えてみるわ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet762-4","talkText":"楽しそうなジェット\nコースターがあるのね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet762-5","talkText":"ポップコーンの屋台だ！\nあっちではパレードも！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}