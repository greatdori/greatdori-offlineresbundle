{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet766","backstageTalkSetId":766,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet766-1","talkText":"巴ちゃん、\nなに見てるの？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet766-2","talkText":"水族館の写真集。\n見てると涼しくなるぞ","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet766-3","talkText":"わぁ、ほんとだ\n海の中にいるみたい","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet766-4","talkText":"せっかくだから、蘭たちも\n誘ってみんなで見るか","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}