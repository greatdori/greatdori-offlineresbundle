{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet744","backstageTalkSetId":744,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet744-1","talkText":"何見てるんですかー？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet744-2","talkText":"ぬいぐるみの写真だよ。\n色々探しててさー","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet744-3","talkText":"今度美咲と一緒に作る時、\n何作ろうかな～って","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet744-4","talkText":"なるほど……それなら、\nマリーがオススメですよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet744-5","talkText":"あ、商店街のうさぎの子？\n難しそうだけどアリかも！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet744-6","talkText":"完成したら絶対私にも\n見せてくださいね！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}