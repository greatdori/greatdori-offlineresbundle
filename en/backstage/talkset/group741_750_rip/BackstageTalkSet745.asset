{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet745","backstageTalkSetId":745,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet745-1","talkText":"ラウンジって\nホント居心地いいよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet745-2","talkText":"私も、練習ない日でも\nたまに来ちゃいます","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet745-3","talkText":"……あ、そうだ！\n学校にも作っちゃおうよ！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet745-4","talkText":"……えぇっ！？\n絶対無理ですって～！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}