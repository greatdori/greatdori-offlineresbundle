{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet747","backstageTalkSetId":747,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet747-1","talkText":"あ、蘭さん！\nちょうどいいところに！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet747-2","talkText":"な、何……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet747-3","talkText":"実は今新しいTシャツの\nデザインで悩んでて……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet747-4","talkText":"胸のとこにいい感じの花\n入れたいんですよね～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet747-5","talkText":"ふーん……\nスズランとかは？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet747-6","talkText":"それ採用！\nさすが蘭さん、マジ天才！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[6],"voiceId":"TalkSet747-7","talkText":"……別に\n大したことじゃないし","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}