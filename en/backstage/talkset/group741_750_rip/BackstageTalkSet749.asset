{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet749","backstageTalkSetId":749,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet749-1","talkText":"Doesn't riding a bike in winter feel cold?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[33],"voiceId":"TalkSet749-2","talkText":"Yeah, but the air feels real crisp and nice.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet749-3","talkText":"Oh! I wonder how that feels~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet749-4","talkText":"Lemme give you a ride sometime.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet749-5","talkText":"Really?! Yay~! I can't wait~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}