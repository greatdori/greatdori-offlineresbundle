{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet612","backstageTalkSetId":612,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet612-1","talkText":"I'm being filmed tomorrow, so I should avoid eating too many snacks today...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet612-2","talkText":"Ooh, there is no greater luxury than freshly baked bread~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet612-3","talkText":"Aya-san, would you like one~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet612-4","talkText":"Eek...! ... Just one won't hurt...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}