{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet349","backstageTalkSetId":349,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet349-1","talkText":"How are things coming along? Have you decided on an image for our next outfits?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet349-2","talkText":"I think... I'll be able...\nto come up with something... soon.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet349-3","talkText":"I see. I'll be looking forward to it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}