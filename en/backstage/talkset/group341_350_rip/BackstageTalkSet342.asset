{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet342","backstageTalkSetId":342,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet342-1","talkText":"Okusawa-san... You know... \nhow to make felt dolls... right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet342-2","talkText":"Yes, I do. Why?\nAre you interested?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet342-3","talkText":"Y-yes... but...\nit seems somewhat difficult...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet342-4","talkText":"No way. You can put an entire outfit\ntogether. Felt would be a piece of cake.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}