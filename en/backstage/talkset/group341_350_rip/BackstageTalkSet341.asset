{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet341","backstageTalkSetId":341,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet341-1","talkText":"My band and yours are complete opposites.\nOur goals and way of thinking are nothing alike.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet341-2","talkText":"To be honest, I worry a bit about\nwhat other people think of us...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet341-3","talkText":"Yeah,\nthey are very different, but...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet341-4","talkText":"Isn't that what makes\nbands so interesting?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}