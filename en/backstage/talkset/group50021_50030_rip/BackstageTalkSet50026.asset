{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50026","backstageTalkSetId":50026,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50026-1","talkText":"Happy Birthday, Hagumi. We have prepared you a gift.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50026-2","talkText":"A present? Hooray! What is it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50026-3","talkText":"It's right over here! Go inside and see!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet50026-4","talkText":"Okay! Woo!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet50026-5","talkText":"Amazing! It's a yukata just for me!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet50026-6","talkText":"Fufu, it is but a small token of our love.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet50026-7","talkText":"We all thought it was pretty and just perfect for you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[13],"voiceId":"TalkSet50026-8","talkText":"D-does it really suit me? It doesn't look weird?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[11],"voiceId":"TalkSet50026-9","talkText":"You look super-duper cute, Hagumi!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[13],"voiceId":"TalkSet50026-10","talkText":"Ehehe... My cheeks are starting to get kinda hot.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet50026-11","talkText":"Let's take this opportunity to head straight to the festival.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[13],"voiceId":"TalkSet50026-12","talkText":"Yeah! Sounds good! I'm gonna pig out~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}