{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50024","backstageTalkSetId":50024,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet50024-1","talkText":"Ah~! That cake was yummy~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet50024-2","talkText":"Thank you very much for the present too!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet50024-3","talkText":"We're so glad you liked it~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet50024-4","talkText":"Still, it's too bad that kusudama wouldn't open.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet50024-5","talkText":"That thing wouldn't budge no matter how many times we pulled it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet50024-6","talkText":"Can you imagine if it split open when we least expect it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[1],"voiceId":"TalkSet50024-7","talkText":"... Wah!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[2],"voiceId":"TalkSet50024-8","talkText":"... It really opened.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet50024-9","talkText":"Ahaha! Talk about a surprise~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet50024-10","talkText":"... Well, at least she's enjoying herself.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}