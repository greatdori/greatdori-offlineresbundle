{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50023","backstageTalkSetId":50023,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet50023-1","talkText":"It's Kasumi's birthday tomorrow.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50023-2","talkText":"I hope she likes the present we chose.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet50023-3","talkText":"And the other thing we prepared is on standby. How exciting.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50023-4","talkText":"That thing is a pain to carry around~...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}