{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50025","backstageTalkSetId":50025,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet50025-1","talkText":"It's Hagumi's birthday tomorrow!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50025-2","talkText":"I'm so happy we were able to find a lovely design.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet50025-3","talkText":"Yes, our sweet Hagumi is sure to look precious in it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet50025-4","talkText":"They're holding a festival nearby tomorrow. We should go.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}