{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50022","backstageTalkSetId":50022,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50022-1","talkText":"Ako-chan... Happy Birthday...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50022-2","talkText":"Yippee! Thank you! Could those boxes be...?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet50022-3","talkText":"They're all presents for you, Udagawa-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50022-4","talkText":"You're giving me this many?! Cool!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50022-5","talkText":"Now! It's time for your pop quiz, Ako!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet50022-6","talkText":"A quiz?! Alright! Just watch me ace it!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet50022-7","talkText":"Can you guess who each of these presents is from?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet50022-8","talkText":"If anybody can answer correctly, it's you, Ako.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[24],"voiceId":"TalkSet50022-9","talkText":"S-sure! I'll do my best! Hmm...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50022-10","talkText":"This NFO plushie is from... Rin-rin!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50022-11","talkText":"Yes... Ako-chan... You're right...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[24],"voiceId":"TalkSet50022-12","talkText":"Yay~! I'm totally gonna crush this quiz!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}