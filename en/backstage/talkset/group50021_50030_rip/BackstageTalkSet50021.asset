{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50021","backstageTalkSetId":50021,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50021-1","talkText":"Tomorrow is Udagawa-san's birthday.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet50021-2","talkText":"I wonder if Ako will score full marks on our little quiz.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet50021-3","talkText":"Knowing Ako-chan... she's sure to do well...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet50021-4","talkText":"Yes. After all, she's watched us closely for a long time.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}