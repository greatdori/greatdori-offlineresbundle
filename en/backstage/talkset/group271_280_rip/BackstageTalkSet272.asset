{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet272","backstageTalkSetId":272,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet272-1","talkText":"Kaoru-senpai, I saw you\nduring theater rehearsal.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet272-2","talkText":"That battle scene was\nsuper intense!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet272-3","talkText":"Fufu, I appreciate those words.\nI hope you will look forward to the show.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}