{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet278","backstageTalkSetId":278,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet278-1","talkText":"Finland is one of the biggest\nconsumers of coffee around the world!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet278-2","talkText":"It is?! Fufu, that kind of\nmakes me happy to hear.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}