{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet274","backstageTalkSetId":274,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet274-1","talkText":"I had this burger the other day.\nMan, that thing was good.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet274-2","talkText":"Udagawa-san... Excessive\nsalt intake is quite unhealthy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet274-3","talkText":"... By the way...\nWhere is that store located?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}