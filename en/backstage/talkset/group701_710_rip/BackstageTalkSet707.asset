{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet707","backstageTalkSetId":707,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet707-1","talkText":"Ugh... I'm the only one that can't get this right...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet707-2","talkText":"We've still got time! You'll be fine if you practice!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet707-3","talkText":"Ah, is this for the talent show~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet707-4","talkText":"Yeah. I'm not really that good at this sort of stuff, so it's not going great...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet707-5","talkText":"But haven't your seniors been super nice when they're teaching you?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet707-6","talkText":"Yeah, they are, but~...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet707-7","talkText":"You've got this, Shiro-chan!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet707-8","talkText":"Rui-rui and Toko-chan are on the same team, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[27],"voiceId":"TalkSet707-9","talkText":"Yup! And I've already got my part down perfectly! Rui, you saw how good I was, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[30],"voiceId":"TalkSet707-10","talkText":"If we ignore everything you forgot, then I suppose that would be right.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[27],"voiceId":"TalkSet707-11","talkText":"Whoa, it all worked out in the end, so isn't that good enough?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[29],"voiceId":"TalkSet707-12","talkText":"H-hey, you two...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[28],"voiceId":"TalkSet707-13","talkText":"Everyone sounds like they've got it tough...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}