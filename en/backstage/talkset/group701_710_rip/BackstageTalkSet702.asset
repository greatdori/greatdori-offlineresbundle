{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet702","backstageTalkSetId":702,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet702-1","talkText":"So what is everyone gonna do for our New Year's talent show?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet702-2","talkText":"Hey, you promised you wouldn't ask us that, didn't you~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet702-3","talkText":"Yeah, but I'm just so curious~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet702-4","talkText":"Our team is... Fufu, you're all gonna be so surprised~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet702-5","talkText":"Yeah! We've got a special guest, after all!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet702-6","talkText":"I'm super looking forward to it~. I guess ours is sort of Japanese-themed.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet702-7","talkText":"Ours is basically the quintessential New Year's talent, I suppose.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet702-8","talkText":"Oh~, I'm even more curious now~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet702-9","talkText":"Well, I guess that's just more reason to look forward to New Year's.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[1],"voiceId":"TalkSet702-10","talkText":"Nnngh~, how many more days do I have to wait~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}