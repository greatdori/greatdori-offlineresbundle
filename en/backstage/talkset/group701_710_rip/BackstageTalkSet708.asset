{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet708","backstageTalkSetId":708,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet708-1","talkText":"I'm doing the talent show?! Why?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet708-2","talkText":"I'm so happy I'm on the same team as you, CHU²-sama!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet708-3","talkText":"That's not the issue here! There's no reason I should be doing it in the first place!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[31],"voiceId":"TalkSet708-4","talkText":"Masuki, LOCK, your teams are doing pretty good, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet708-5","talkText":"Yes! Aya-senpai has been really fired up...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet708-6","talkText":"Yeah, I think my team's doin' fine, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[34],"voiceId":"TalkSet708-7","talkText":"Um, LAYER-san, if I remember right, your team has...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[31],"voiceId":"TalkSet708-8","talkText":"Yeah. I'm together with Hana-chan. So practice has been a lot of fun.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[31],"voiceId":"TalkSet708-9","talkText":"Ah, and there's Oddie, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[34],"voiceId":"TalkSet708-10","talkText":"Oddie? Do you mean...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[31],"voiceId":"TalkSet708-11","talkText":"Yeah, Hana-chan's pet-","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[35],"voiceId":"TalkSet708-12","talkText":"Stop!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[35],"voiceId":"TalkSet708-13","talkText":"You're not supposed to let the other teams know what you're planning, remember?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[32],"voiceId":"TalkSet708-14","talkText":"CHU²-san... Are you actually looking forward to this...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[35],"voiceId":"TalkSet708-15","talkText":"Sh-shut up!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}