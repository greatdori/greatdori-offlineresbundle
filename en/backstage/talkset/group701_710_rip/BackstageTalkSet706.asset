{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet706","backstageTalkSetId":706,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet706-1","talkText":"Are you two really going to be okay for this talent show?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet706-2","talkText":"Yup! We're all set! Right, Kokoron?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet706-3","talkText":"Why are you so worried, Misaki?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet706-4","talkText":"Hagumi and I are going to bring smiles to everyone!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet706-5","talkText":"It's because it's you two that I'm worried!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet706-6","talkText":"Fufu... Misaki, that loving care and compassion you show for your comrades...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet706-7","talkText":"Ah~, how fleeting.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet706-8","talkText":"Hehe... So, how is your team doing, Misaki-chan?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet706-9","talkText":"Eh, it's going alright, I guess. I'm pretty used to what we're doing, anyway.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet706-10","talkText":"You are...? I wonder what you're planning...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet706-11","talkText":"Ah! That's gotta be a secret, so...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[11],"voiceId":"TalkSet706-12","talkText":"I'm sure it's going to be a smile-giving \"Smile Trick\" that'll be delivered with a smile!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[13],"voiceId":"TalkSet706-13","talkText":"I'm really excited to see what you've got planned, Mii-kun~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[12],"voiceId":"TalkSet706-14","talkText":"I cannot wait to be filled with laughter upon witnessing what you have in store.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[15],"voiceId":"TalkSet706-15","talkText":"That's... an interesting way of setting the bar high...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}