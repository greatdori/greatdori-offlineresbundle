{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet709","backstageTalkSetId":709,"snippets":[{"talkId":1,"characterIds":[11,13],"voiceId":"TalkSet709-1","talkText":"Yay~! Happy New Year!!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":3,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet709-2","talkText":"Let's go~! Soi-ya! Soi-ya!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":3,"characterIds":[34,35],"voiceId":"TalkSet709-3","talkText":"Wow~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet709-4","talkText":"Okay, we're next. Let's do our best♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet709-5","talkText":"Th-this really is way too high for me!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[34],"voiceId":"TalkSet709-6","talkText":"You'll be fine♪ We've got a cushion for you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet709-7","talkText":"You've got this! With a little bit of courage, anything is possible.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[11],"voiceId":"TalkSet709-8","talkText":"She's right. The most important thing is to smile. Okay, everyone!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9,11,13],"voiceId":"TalkSet709-9","talkText":"Soi-ya~! Smile~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":10,"characterIds":[35],"voiceId":"TalkSet709-10","talkText":"Unbelievable...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}