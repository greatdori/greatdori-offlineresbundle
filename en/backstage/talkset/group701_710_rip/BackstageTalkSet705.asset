{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet705","backstageTalkSetId":705,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet705-1","talkText":"Oh, are you all talking about the talent show?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet705-2","talkText":"Hi, everyone! Yes, we are.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet705-3","talkText":"It's been pretty tough preparing everything we need~...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet705-4","talkText":"I do remember Kaoru saying she wanted some pretty outrageous things.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet705-5","talkText":"I'm used to it. Huhehe.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet705-6","talkText":"Fufu, you all look like you're having so much fun~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet705-7","talkText":"Aya-san, how is your team doing?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[16],"voiceId":"TalkSet705-8","talkText":"We just had rehearsal the other day~. How are things going with you, Hina-chan?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet705-9","talkText":"We're all still practicing on our own~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet705-10","talkText":"I came up with this super boppin' new move♪ You see~...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet705-11","talkText":"If you say any more, you'll end up revealing what you're doing!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[17],"voiceId":"TalkSet705-12","talkText":"Oh yeah. It's supposed to be a secret, huh?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}