{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet785","backstageTalkSetId":785,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet785-1","talkText":"茶道部のお茶会、どんな\nお菓子を出すか決めた？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet785-2","talkText":"そうですね……\nこちらはいかがでしょう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet785-3","talkText":"わぁ、\nかわいい練り切りだね","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet785-4","talkText":"この前レポートしたお店の\n看板商品だそうです！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet785-5","talkText":"よかったら、\nこのあとご一緒しましょう","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}