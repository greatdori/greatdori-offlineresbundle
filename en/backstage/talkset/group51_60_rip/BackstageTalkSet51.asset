{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet51","backstageTalkSetId":51,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet51-1","talkText":"It has been a while since we've had a day-long lesson.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet51-2","talkText":"Yeah, tomorrow's probably going to be rough...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet51-3","talkText":"The first half is for one-on-ones, and the second half is for the group, correct?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet51-4","talkText":"I have a job I need to do before the second half starts...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet51-5","talkText":"Wow, you're one busy bee, Aya-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}