{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet60","backstageTalkSetId":60,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet60-1","talkText":"Words cannot express how much I appreciate Yamabuki Bakery~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet60-2","talkText":"I wish I had a chocolate cornet...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet60-3","talkText":"Ahaha, thank you for always coming by.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet60-4","talkText":"All hail the bakery~.\nAll hail the bakery~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}