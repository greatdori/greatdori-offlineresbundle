{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet630","backstageTalkSetId":630,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet630-1","talkText":"In the near future, the curtains shall rise upon a BBQ party at my residence.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet630-2","talkText":"Would you be interested in joining us?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet630-3","talkText":"... Yes, that sounds nice. I'll bring Leon with me.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}