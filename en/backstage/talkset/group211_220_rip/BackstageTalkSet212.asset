{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet212","backstageTalkSetId":212,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet212-1","talkText":"It seems like you'd be able to see the stars really easily in Finland.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet212-2","talkText":"They are quite pretty!\nAnd you can see the Northern Lights!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet212-3","talkText":"What?! That's awesome!\nI'd love to take a trip and see for myself!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}