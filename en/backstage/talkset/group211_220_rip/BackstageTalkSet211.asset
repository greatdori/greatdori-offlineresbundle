{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet211","backstageTalkSetId":211,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet211-1","talkText":"Kasumi-chan, are you studying?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet211-2","talkText":"Ngh, yeah... I have some\nmake-up classes coming up...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet211-3","talkText":"I wish I could help you, but I don't\nthink I have the grades for that...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}