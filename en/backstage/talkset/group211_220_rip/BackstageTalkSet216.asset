{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet216","backstageTalkSetId":216,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet216-1","talkText":"Yukina-senpai! What do I\nneed to become good at singing?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet216-2","talkText":"Hard work. There are no shortcuts\nwhen it comes to music.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}