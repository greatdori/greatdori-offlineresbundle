{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet304","backstageTalkSetId":304,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet304-1","talkText":"When is an appropriate time\nto change one's bass strings?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet304-2","talkText":"That's a tough one... The answer tends\nto be very different depending on the person.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet304-3","talkText":"It would likely be better if you\nfound what timing works best for you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet304-4","talkText":"So that's how it works.\nI'll try to remember that.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}