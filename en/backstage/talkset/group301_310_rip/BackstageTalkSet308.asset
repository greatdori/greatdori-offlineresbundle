{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet308","backstageTalkSetId":308,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet308-1","talkText":"Someone told me about this\nwonderful café.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet308-2","talkText":"We should make plans to go.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet308-3","talkText":"Yeah! And make sure not\nto get lost on the way!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}