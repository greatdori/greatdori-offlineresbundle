{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet301","backstageTalkSetId":301,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet301-1","talkText":"As gifted by the darkness of the abyss,\nmy power will... uhhh, will~...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet301-2","talkText":"Will become boppin'♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet301-3","talkText":"Nooo~, not that~!\nThat doesn't bring it together~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}