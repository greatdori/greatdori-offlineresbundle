{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet305","backstageTalkSetId":305,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet305-1","talkText":"I just walked by someone with\na samurai topknot!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet305-2","talkText":"Maybe they're shooting for a historical\ndrama. I wish I could be in one!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet305-3","talkText":"Fufu. Hopefully, one day your\nwish will come true.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}