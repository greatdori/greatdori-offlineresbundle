{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet309","backstageTalkSetId":309,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet309-1","talkText":"There are guitar makers in\nFinland as well!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet309-2","talkText":"They're not very well-known,\nbut their products are high-quality!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet309-3","talkText":"Wow! Impressive as always,\nMaya-san! I had no idea!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}