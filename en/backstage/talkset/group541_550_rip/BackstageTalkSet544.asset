{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet544","backstageTalkSetId":544,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet544-1","talkText":"Looks like cleaning season is finally here.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet544-2","talkText":"Man, so it's already that time of year, huh.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet544-3","talkText":"I'm already done~. Go me, right~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet544-4","talkText":"Moca, you're always surprisingly diligent about that kind of stuff.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet544-5","talkText":"Things are good on my end too, but the store still needs some work.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet544-6","talkText":"Hey, maybe we can help you out!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet544-7","talkText":"Reporting for duty~. Tsugu, fill us in on your cleaning schedule~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet544-8","talkText":"Thanks, everyone! I'll ask my mom!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet544-9","talkText":"And when we're done, we can close out the year with some ramen!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet544-10","talkText":"It's supposed to be soba...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}