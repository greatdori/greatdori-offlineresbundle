{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet546","backstageTalkSetId":546,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet546-1","talkText":"Look, look! Don't I look so cool in this picture?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet546-2","talkText":"I'm commanding Cerberus, guardian of the Underworld!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet546-3","talkText":"What a big doggie! You look so cute next to it, Ako-chan.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet546-4","talkText":"Y-you're supposed to say I'm cool, not cute~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}