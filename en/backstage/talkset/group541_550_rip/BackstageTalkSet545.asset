{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet545","backstageTalkSetId":545,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet545-1","talkText":"The year is finally over. It sure did go by fast~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet545-2","talkText":"Uh-huh! Think of all the new memories we made!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet545-3","talkText":"I hope next year will be as exciting as this one was.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet545-4","talkText":"Well, then let's discuss what we'd like to do.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet545-5","talkText":"Planning it out ahead of time, huh. Sure, why not?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet545-6","talkText":"Wow, but it's hard to decide when there is so much I want to do~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[4],"voiceId":"TalkSet545-7","talkText":"For real~. The ideas just keep pouring in.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[2],"voiceId":"TalkSet545-8","talkText":"I'm already up to one hundred and counting.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet545-9","talkText":"Hey, that's about as many as I've got!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet545-10","talkText":"Why don't you both dial it back some?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}