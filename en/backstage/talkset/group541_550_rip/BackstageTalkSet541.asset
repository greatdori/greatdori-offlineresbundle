{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet541","backstageTalkSetId":541,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet541-1","talkText":"New Year's is finally here. Things sure have been hectic~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet541-2","talkText":"I'll say~. I just hope we can finally relax and...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet541-3","talkText":"Since we're all here, let's find something exciting to do together!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet541-4","talkText":"That's what I mean, Hagumi!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet541-5","talkText":"I suggest we have a poem recital.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet541-6","talkText":"My fleeting lyrics will seize the hearts of all who listen.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet541-7","talkText":"I want to have a snowball fight!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[13],"voiceId":"TalkSet541-8","talkText":"Softball is the way to go!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[14],"voiceId":"TalkSet541-9","talkText":"Fufu... So much for a relaxing New Year's.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[15],"voiceId":"TalkSet541-10","talkText":"Just think of it as the final stretch. We can do it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}