{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet542","backstageTalkSetId":542,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet542-1","talkText":"The year is almost at an end.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet542-2","talkText":"Yep! Hey, let's have our own New Year's party!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet542-3","talkText":"I'm down~! I want to do one of those hot pots in the dark!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet542-4","talkText":"In the dark...? So long as everything we add is edible.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet542-5","talkText":"It should be fine if we limit the ingredients to standard items...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet542-6","talkText":"In that case, why doesn't everyone bring their own stuff to add?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet542-7","talkText":"Wow, that sounds like so much fun!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[22],"voiceId":"TalkSet542-8","talkText":"An array of meat and vegetables should make for a balanced meal.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[21],"voiceId":"TalkSet542-9","talkText":"Agreed. That does seem best.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[25],"voiceId":"TalkSet542-10","talkText":"(Having a hot pot together... does sound like fun...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}