{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50043","backstageTalkSetId":50043,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50043-1","talkText":"Tomorrow is finally the day...! Ooh, I feel nervous~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50043-2","talkText":"I hope Arisa will see how much she means to us.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50043-3","talkText":"Just write down your true feelings and it will be fine.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet50043-4","talkText":"O-Tae's right! Hang on tight, Arisa~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}