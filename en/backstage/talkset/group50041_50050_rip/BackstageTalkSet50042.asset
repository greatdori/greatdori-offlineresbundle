{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50042","backstageTalkSetId":50042,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50042-1","talkText":"Have a seat, Minato-san. Here are some sweets and...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet50042-2","talkText":"Honey tea... They're for you...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet50042-3","talkText":"Thank you both. They smell wonderful.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50042-4","talkText":"I'll massage your shoulders!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50042-5","talkText":"There's also this! They say this video is really soothing~☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50042-6","talkText":"(A kitty cat video montage...?!)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet50042-7","talkText":"... Wait, what exactly has gotten into you all today?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50042-8","talkText":"Yukina-san! It's your birthday today!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50042-9","talkText":"That's why we wanted you to relax, Yukina.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet50042-10","talkText":"After all, taking routine breaks is necessary to maintain peak performance.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50042-11","talkText":"Please let us know if there's anything you'd like us to do...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet50042-12","talkText":"So that is what's happening. Thank you. I'm flattered.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}