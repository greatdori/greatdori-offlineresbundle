{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50045","backstageTalkSetId":50045,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50045-1","talkText":"Phew~, we're all ready for tomorrow~! I can't wait!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50045-2","talkText":"I am sure Maya-san's skills will be on full display with this!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50045-3","talkText":"I can't believe you prepared something like this, Hina-chan...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet50045-4","talkText":"Ahaha... Still, I kinda want to give it a try too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}