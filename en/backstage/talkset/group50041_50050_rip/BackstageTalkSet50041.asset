{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50041","backstageTalkSetId":50041,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50041-1","talkText":"Tomorrow... is Yukina-san's birthday. How exciting...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50041-2","talkText":"Uh-huh! Lisa-nee's idea is really cool!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50041-3","talkText":"Y-you think so? I hope Yukina likes it~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50041-4","talkText":"I think it's an excellent way to celebrate.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}