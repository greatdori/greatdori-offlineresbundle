{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50044","backstageTalkSetId":50044,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50044-1","talkText":"Arisa-chan, Happy Birthday!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet50044-2","talkText":"Here, Arisa! We made you a message board!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50044-3","talkText":"We all wrote down how we felt about you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50044-4","talkText":"Th-thank you... This is kinda embarrassing...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50044-5","talkText":"This message board is Kasumi's idea.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet50044-6","talkText":"You always do your best, despite being busy with student council.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2],"voiceId":"TalkSet50044-7","talkText":"And you never give up on learning difficult phrases.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50044-8","talkText":"Not to mention, you're always looking out for us.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet50044-9","talkText":"Thanks for taking care of Poppin'Party!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet50044-10","talkText":"... Well, obviously I care about you guys.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1],"voiceId":"TalkSet50044-11","talkText":"Whoa! Arisa's being honest!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[5],"voiceId":"TalkSet50044-12","talkText":"Sh-shut up! I can be straightforward once in a while!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}