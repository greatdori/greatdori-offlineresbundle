{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet501","backstageTalkSetId":501,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet501-1","talkText":"Tomorrow is Minato-san's birthday. What's wrong, Udagawa-san?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet501-2","talkText":"Ohh... I'm just worried that she won't like the present~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet501-3","talkText":"A-Ako-chan... Relax...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet501-4","talkText":"You don't need to be so worried. She'll definitely like it~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet501-5","talkText":"I think I'm just gonna be nervous about it until tomorrow...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}