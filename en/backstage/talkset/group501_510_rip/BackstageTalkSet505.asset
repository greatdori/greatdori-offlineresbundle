{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet505","backstageTalkSetId":505,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet505-1","talkText":"Arisa~! Happy Birthday~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet505-2","talkText":"Oh, whoa! That freaked me out...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet505-3","talkText":"The surprise was a success. Arisa, your reaction was priceless.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet505-4","talkText":"Here you go, Arisa-chan. It's a birthday present for you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet505-5","talkText":"It's a mini bonsai! Wow, I'm really happy...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet505-6","talkText":"Looks like the present was a good surprise, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}