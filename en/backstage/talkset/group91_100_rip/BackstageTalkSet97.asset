{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet97","backstageTalkSetId":97,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet97-1","talkText":"Tomo-chin, you play the taiko, right?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet97-2","talkText":"Yup, and it's awesome! Lots of fun!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet97-3","talkText":"And you yell \"soi-ya,\" right?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet97-4","talkText":"Ooo! I like it! Soi-ya~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet97-5","talkText":"Soi-ya~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet97-6","talkText":"Soi-ya~!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet97-7","talkText":"G-guys... What's going on?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}