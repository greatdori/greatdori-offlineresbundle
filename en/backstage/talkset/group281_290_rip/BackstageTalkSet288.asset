{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet288","backstageTalkSetId":288,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet288-1","talkText":"What are you looking at, Aya?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet288-2","talkText":"I'm just looking back on some photos.\nCheck this one out.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet288-3","talkText":"Wow, just what I'd expect from you!\nThis photo is super cute♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}