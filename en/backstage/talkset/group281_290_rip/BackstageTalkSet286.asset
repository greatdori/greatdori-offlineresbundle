{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet286","backstageTalkSetId":286,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet286-1","talkText":"Pastel＊Palettes has very\nfrilly outfits.\nThey're all very cute.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet286-2","talkText":"The frills remind me of jellyfish.\nJust seeing them relaxes me.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet286-3","talkText":"(Uhhh...\nI think that's supposed to be a compliment.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}