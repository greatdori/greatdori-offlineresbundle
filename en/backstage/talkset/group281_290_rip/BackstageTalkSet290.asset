{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet290","backstageTalkSetId":290,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet290-1","talkText":"What's on the schedule for tomorrow?\nOh, looks like I'm free.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet290-2","talkText":"You finally got a day off!\nYou've been working a lot lately!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet290-3","talkText":"I'm grateful that I can be busy,\nbut yeah, I'd like to rest once in a while.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet290-4","talkText":"Exactly! You gotta have as much\nfun as you can tomorrow!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}