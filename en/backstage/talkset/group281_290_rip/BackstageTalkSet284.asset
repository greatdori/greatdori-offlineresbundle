{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet284","backstageTalkSetId":284,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet284-1","talkText":"Hmm... I think I would mess up\nthose dance moves right away...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet284-2","talkText":"Are there any tricks to\ngetting it right, Hagumi-chan?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet284-3","talkText":"I think you should take your\nlower back and go \"squish-squish\"!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet284-4","talkText":"Could you maybe put it in\nsimpler terms for me...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}