{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet263","backstageTalkSetId":263,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet263-1","talkText":"Wow! This selfie you\ntook is so cute, Aya-san!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet263-2","talkText":"If I had to tell you one thing to keep\nin mind, it would be the angle of your shot!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet263-3","talkText":"Oh!!\nDuly noted!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}