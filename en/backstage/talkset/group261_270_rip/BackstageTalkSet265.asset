{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet265","backstageTalkSetId":265,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet265-1","talkText":"Today's club practice was so tiring~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet265-2","talkText":"It can be pretty tough running\naround a tennis court.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet265-3","talkText":"All those serves gave my arm a\nreal workout, and my legs are so sore.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet265-4","talkText":"Yep, I get you. I know that\nfeeling all too well.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}