{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet298","backstageTalkSetId":298,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet298-1","talkText":"Kaoru-kun, what's your favorite\nShakespeare book?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet298-2","talkText":"Fufu, allow me to ponder that... They are\nall so fleeting. How can one choose?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}