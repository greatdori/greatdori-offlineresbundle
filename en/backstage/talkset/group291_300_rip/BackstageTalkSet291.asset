{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet291","backstageTalkSetId":291,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet291-1","talkText":"Ah! Hina-san, did you change\nthe strings on your guitar?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet291-2","talkText":"Ehehe, I got ones that\nmatch my sister's.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}