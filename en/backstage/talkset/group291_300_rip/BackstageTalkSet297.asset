{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet297","backstageTalkSetId":297,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet297-1","talkText":"Kaoru-kun, what made\nyou wanna get into acting?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet297-2","talkText":"It was not I who chose it.\nIt was the stage that called out to me.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet297-3","talkText":"Ahaha, I always knew\nyou were an interesting one.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}