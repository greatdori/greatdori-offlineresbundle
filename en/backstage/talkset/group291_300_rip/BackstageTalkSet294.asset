{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet294","backstageTalkSetId":294,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet294-1","talkText":"Hina-san, let's head to\nwork together tomorrow.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet294-2","talkText":"Sounds good to me! 'Kay,\nlet's meet in front of the station!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}