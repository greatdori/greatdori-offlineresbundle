{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet21","backstageTalkSetId":21,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet21-1","talkText":"Man, I could go for\nsome ramen right now.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet21-2","talkText":"Tomo-chin, you're all about\nthat ramen, aren'tcha?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet21-3","talkText":"Yeah, but your love for\nbread takes the cake.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}