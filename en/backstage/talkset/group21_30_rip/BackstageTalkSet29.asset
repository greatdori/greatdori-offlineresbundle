{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet29","backstageTalkSetId":29,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet29-1","talkText":"Sis, did you see that ramen\nshop in front of the station?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet29-2","talkText":"Nah, I didn't.\nWhy? What's up?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet29-3","talkText":"They have a limited-time\npork and soy sauce ramen for sale!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet29-4","talkText":"Dude! You know I gotta check that out!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}