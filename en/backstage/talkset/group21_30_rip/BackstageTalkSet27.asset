{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet27","backstageTalkSetId":27,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet27-1","talkText":"The sweets at the convenience store\nare always getting better and better!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet27-2","talkText":"Oh, I saw something new during my\nshift that I think you would like.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet27-3","talkText":"You did?!\nI gotta check it out!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}