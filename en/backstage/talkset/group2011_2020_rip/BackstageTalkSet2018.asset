{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2018","backstageTalkSetId":2018,"snippets":[{"talkId":1,"characterIds":[30],"voiceId":"TalkSet2018-1","talkText":"Hiromachi-san, I have been meaning to ask you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2018-2","talkText":"Hm? What is it, Rui-rui?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2018-3","talkText":"Why do you call me Rui-rui?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2018-4","talkText":"Huh? Rui-rui is Rui-rui, you know...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[30],"voiceId":"TalkSet2018-5","talkText":"... Never mind.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}