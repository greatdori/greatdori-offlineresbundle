{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2019","backstageTalkSetId":2019,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2019-1","talkText":"Nanami-chan! Could you teach me how to make accessories?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2019-2","talkText":"I'd like to try making hair accessories and other things.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2019-3","talkText":"Then how about we get everyone together for a DIY accessory party?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2019-4","talkText":"Perfect! I'll let Mashiro-chan and the others know!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}