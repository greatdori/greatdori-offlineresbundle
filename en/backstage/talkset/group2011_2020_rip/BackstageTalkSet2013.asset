{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2013","backstageTalkSetId":2013,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2013-1","talkText":"The candy you gave me the other day tasted awful, Nanami!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2013-2","talkText":"What~? But it looked so cute...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2013-3","talkText":"I'll refrain from trying it then.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2013-4","talkText":"You mean you haven't even eaten it yourself~?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}