{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50006","backstageTalkSetId":50006,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet50006-1","talkText":"Rimi-rin~! Happy Birthday~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50006-2","talkText":"Wow! A horror-movie DVD!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50006-3","talkText":"It's the one you've been wanting for so long.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet50006-4","talkText":"Every place was sold out, but Arisa managed to find a copy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet50006-5","talkText":"I-I mean, I just sort of came across it and all.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet50006-6","talkText":"Thanks! I'd love to watch it with you all someday.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2],"voiceId":"TalkSet50006-7","talkText":"Out of the question. Because we're watching it right now.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50006-8","talkText":"Alright, the show is about to begin~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[3],"voiceId":"TalkSet50006-9","talkText":"Whoa...! It's like we're in a movie theater!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet50006-10","talkText":"Kasumi... I hope you're ready for this.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1],"voiceId":"TalkSet50006-11","talkText":"Th-the others are here, so I'll be fine...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}