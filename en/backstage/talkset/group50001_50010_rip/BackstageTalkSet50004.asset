{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50004","backstageTalkSetId":50004,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet50004-1","talkText":"Happy Birthday, Hina-chan.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet50004-2","talkText":"We have a present for you! Please open it!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50004-3","talkText":"Wow~! Thanks, guys! Look at all this stuff!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50004-4","talkText":"This stealthy wardrobe was proposed by Aya-san!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet50004-5","talkText":"First comes the hat, which is from Eve-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[20],"voiceId":"TalkSet50004-6","talkText":"And the clothing is from Chisato-san and Maya-san!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[16],"voiceId":"TalkSet50004-7","talkText":"The sunglasses are just like the ones I have!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet50004-8","talkText":"We are famous now, so it may not be a bad idea to go incognito.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet50004-9","talkText":"I don't really care about being found out or whatever~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50004-10","talkText":"But these seem really cool, so I'll try them on right now!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[17],"voiceId":"TalkSet50004-11","talkText":"Bam~! So, how do I look?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet50004-12","talkText":"Wow~! A truly fitting attire!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}