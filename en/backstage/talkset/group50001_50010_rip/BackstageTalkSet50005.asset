{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50005","backstageTalkSetId":50005,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet50005-1","talkText":"Rimi-rin's birthday is only a day away!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50005-2","talkText":"Thanks for scoping out the present for us, O-Tae.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50005-3","talkText":"No, no. It was Arisa who found it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50005-4","talkText":"Touching that thing gave me the creeps...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[1],"voiceId":"TalkSet50005-5","talkText":"And the venue is already set up! Tomorrow is going to be a blast!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}