{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50008","backstageTalkSetId":50008,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet50008-1","talkText":"Happy Birthday, Chisato-san!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50008-2","talkText":"We prepared an exceptional present just for you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50008-3","talkText":"Thank you. Now what is it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50008-4","talkText":"Aya-san, Hina-san, that is your cue!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50008-5","talkText":"Okay~! Happy Birthday, Chisato-chan~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet50008-6","talkText":"Is this tea set my present...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50008-7","talkText":"Yep! We thought it suited you perfectly!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[20],"voiceId":"TalkSet50008-8","talkText":"Now, please let us serve you some tea!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[16],"voiceId":"TalkSet50008-9","talkText":"We've been practicing a whole bunch for this day!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50008-10","talkText":"Watch this, Chisato-chan! And~... Go!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[16],"voiceId":"TalkSet50008-11","talkText":"Wah! H-hey~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50008-12","talkText":"Fufu, what a surprise. Thank you, everyone.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}