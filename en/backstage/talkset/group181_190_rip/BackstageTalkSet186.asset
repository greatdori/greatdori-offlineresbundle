{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet186","backstageTalkSetId":186,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet186-1","talkText":"Now to pick something to eat for our meeting~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet186-2","talkText":"I will have the gratin.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet186-3","talkText":"A parfait and... some fries for me.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet186-4","talkText":"I'd like some pasta and... fries.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet186-5","talkText":"I'm in the mood for... some fries...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet186-6","talkText":"(Are they doing this for me...?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}