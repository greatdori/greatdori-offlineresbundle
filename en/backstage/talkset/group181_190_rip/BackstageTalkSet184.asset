{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet184","backstageTalkSetId":184,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet184-1","talkText":"There you are, Michelle!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet184-2","talkText":"We have been searching for you, little kitten.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet184-3","talkText":"Wait, where did Mii-kun go?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet184-4","talkText":"Misaki-chan had to go run an errand~.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet184-5","talkText":"Oh no! I needed her help with something.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet184-6","talkText":"...?!","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet184-7","talkText":"(Poor Misaki-chan.)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}