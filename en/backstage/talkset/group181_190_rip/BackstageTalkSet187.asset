{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet187","backstageTalkSetId":187,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet187-1","talkText":"Lisa-nee's cookies really are the best~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet187-2","talkText":"A flavor that never fails to satisfy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet187-3","talkText":"Is there some sort of... secret ingredient?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet187-4","talkText":"Maybe it's... my love for all of you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[22],"voiceId":"TalkSet187-5","talkText":"I see...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet187-6","talkText":"Don't act like that was a serious answer! You're embarrassing me~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}