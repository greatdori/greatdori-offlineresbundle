{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet185","backstageTalkSetId":185,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet185-1","talkText":"What are you doing, Minato-san?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet185-2","talkText":"This notification will not go away. I wonder why.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet185-3","talkText":"What could be causing that? I can look online for you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet185-4","talkText":"I'll check and see what I can find too!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet185-5","talkText":"As will I...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21,22,24,25],"voiceId":"TalkSet185-6","talkText":"...","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet185-7","talkText":"(What is this...? Everyone's staring at their phones...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}