{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet181","backstageTalkSetId":181,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet181-1","talkText":"How about this day for our next performance?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet181-2","talkText":"Ah, I have a match that day~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet181-3","talkText":"For softball?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet181-4","talkText":"Alright, we'll aim for a different date then.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet181-5","talkText":"In that case, we can go cheer her on at her game!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet181-6","talkText":"What a magnificent idea, Kokoro!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}