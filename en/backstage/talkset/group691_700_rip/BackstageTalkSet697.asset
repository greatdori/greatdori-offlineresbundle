{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet697","backstageTalkSetId":697,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet697-1","talkText":"I'm craving warm chocolate cornets...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet697-2","talkText":"What's that?! I wanna eat one too~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet697-3","talkText":"Hey, I bet they'd be even yummier if we deep fry 'em!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet697-4","talkText":"A deep-fried chocolate cornet... That sounds delicious...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet697-5","talkText":"Rimi-rin, let's drop by my place on the way home and give it a try!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}