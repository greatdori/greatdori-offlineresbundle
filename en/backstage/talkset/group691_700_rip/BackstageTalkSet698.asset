{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet698","backstageTalkSetId":698,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet698-1","talkText":"There's going to be this new snack called Winter Animals that comes with toys~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet698-2","talkText":"Really? What animals are gonna be included?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet698-3","talkText":"I know there's going to be an Ezo red fox, an Ezo raccoon dog, and an Akita~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet698-4","talkText":"It sounds like something my sister might like~! Maybe I should get some for her~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet698-5","talkText":"Would you like to go buy some together~? I'm curious about it too~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}