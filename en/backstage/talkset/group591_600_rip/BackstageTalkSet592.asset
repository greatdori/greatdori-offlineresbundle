{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet592","backstageTalkSetId":592,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet592-1","talkText":"I've been seeing a lot of people wearing facemasks around town lately.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet592-2","talkText":"Is hiding your identity supposed to be a new fashion trend or something?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet592-3","talkText":"Um... Isn't it because they probably just have allergies...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}