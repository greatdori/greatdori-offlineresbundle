{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet598","backstageTalkSetId":598,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet598-1","talkText":"Hey, don't you think this rock looks like a rabbit?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet598-2","talkText":"Oh, it's adorable! Let's go see it! Right now.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet598-3","talkText":"Wh-what?! But this park is on the other side of town!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet598-4","talkText":"Ah, there she goes! O-Tae, wait for me~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}