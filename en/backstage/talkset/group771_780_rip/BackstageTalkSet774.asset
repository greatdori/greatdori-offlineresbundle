{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet774","backstageTalkSetId":774,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet774-1","talkText":"みて！　このカフェ\n秋メニュー始まったって！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet774-2","talkText":"あら、美味しそうね。\n駅の近くのところだったかしら？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet774-3","talkText":"うん！　あ、テラス席も\n紅葉が見頃だって！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet774-4","talkText":"ふふ、それじゃあ今度、\n一緒に行ってみましょうか","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet774-5","talkText":"やった〜！\n来週の練習前はどう？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}