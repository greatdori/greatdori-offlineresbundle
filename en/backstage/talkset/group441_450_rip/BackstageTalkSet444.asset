{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet444","backstageTalkSetId":444,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet444-1","talkText":"It's getting cooler by the day.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet444-2","talkText":"Yes, I agree... The mornings and evenings are especially chilly.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet444-3","talkText":"We have to make sure to bundle up and stay warm.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet444-4","talkText":"Yeah, you're right. Wouldn't want to catch a cold or anything.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}