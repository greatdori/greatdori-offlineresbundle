{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet449","backstageTalkSetId":449,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet449-1","talkText":"Wow, what a beautiful photo of the sky!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet449-2","talkText":"Oh, thanks. I took it a little while ago.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet449-3","talkText":"I love how the fall sky looks: a deep blue without a cloud in the sky.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet449-4","talkText":"Yeah, I hear you. I catch myself staring at it often.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}