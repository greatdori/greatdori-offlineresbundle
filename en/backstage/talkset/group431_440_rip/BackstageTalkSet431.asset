{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet431","backstageTalkSetId":431,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet431-1","talkText":"Happy Birthday, Ako!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet431-2","talkText":"Here, we got you a present~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet431-3","talkText":"Wow! Thanks, you guys! I wonder what's inside?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet431-4","talkText":"... Ah! Manga, CDs... All sorts of stuff are in here!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet431-5","talkText":"It's made up of all the stuff that we think is \"cool.\"","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet431-6","talkText":"Sweet! Hehehe, I'll go through it all later~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}