{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet434","backstageTalkSetId":434,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet434-1","talkText":"Happy Birthday, Kaa-kun!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet434-2","talkText":"We'll spend the whole day doing whatever you want!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet434-3","talkText":"In that case... I want to play with you guys!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet434-4","talkText":"What a wonderful idea!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet434-5","talkText":"Hey, we should invite everyone else to join in!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet434-6","talkText":"Works for me~! Alright, let's get this party started!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}