{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet438","backstageTalkSetId":438,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet438-1","talkText":"Tomorrow is Kokoron's birthday~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet438-2","talkText":"Do you think she'll like the present we got for her?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet438-3","talkText":"I think Kokoro would like anything wrapped up with a bow.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet438-4","talkText":"It is through us that the ultimate birthday shall be born into this world.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}