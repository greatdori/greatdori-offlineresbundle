{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet435","backstageTalkSetId":435,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet435-1","talkText":"It's Hagumi's birthday today. How should we celebrate?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet435-2","talkText":"I plan to bestow upon her a bouquet of roses and a poem by yours truly.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet435-3","talkText":"I'm going to put on a parade and fireworks show for her!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet435-4","talkText":"W-wow... Uh-oh... What should I do, then?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet435-5","talkText":"Calm down, Kanon-san. We can do something simple.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}