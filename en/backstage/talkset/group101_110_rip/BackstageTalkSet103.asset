{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet103","backstageTalkSetId":103,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet103-1","talkText":"Ah, Kokoron! Michelle's here!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet103-2","talkText":"Oh, she is! Are you taking a break too, Michelle?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet103-3","talkText":"Y-yeah, that's right~. Keep up the good work, everyone.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet103-4","talkText":"Same to you, Okusawa-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":1,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet103-5","talkText":"Thank you very much, Arisa-chan~.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet103-6","talkText":"She's completely in character...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}