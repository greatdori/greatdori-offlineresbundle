{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet107","backstageTalkSetId":107,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet107-1","talkText":"Sis, can you eat this for me~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet107-2","talkText":"Alright, but this is the last time, got it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet107-3","talkText":"Yay~! Thanks!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet107-4","talkText":"(...! That's it! I just thought of a great idea!)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet107-5","talkText":"Hey, Sis! There's something I wanna ask you...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet107-6","talkText":"... I'm not going to eat that.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet107-7","talkText":"Awww~! How did you know what I was gonna ask?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}