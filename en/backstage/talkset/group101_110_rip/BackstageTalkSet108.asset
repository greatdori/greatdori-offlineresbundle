{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet108","backstageTalkSetId":108,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet108-1","talkText":"Ahhh, what a fun softball game~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet108-2","talkText":"Fufu, nice work out there. We were watching.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet108-3","talkText":"Yep. You made some big plays out there!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet108-4","talkText":"Watching just makes me wanna get in there myself.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet108-5","talkText":"Yeah?! Alright, then let's play!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet108-6","talkText":"You mean right now?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[4],"voiceId":"TalkSet108-7","talkText":"Ahaha, Hagumi sure has a lot of energy!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}