{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet104","backstageTalkSetId":104,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet104-1","talkText":"Kokoron, what are you gonna do over the break?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet104-2","talkText":"I'm gonna go overseas! Michelle and I are taking a trip!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet104-3","talkText":"I'm sorry...? This is the first time I'm hearing about this...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet104-4","talkText":"Lucky~! I wish I could go~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet104-5","talkText":"Wh- Kasumi! Don't get carried away!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet104-6","talkText":"Oh, right, I don't even have a passport!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet104-7","talkText":"That's not the issue here!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":8,"characterIds":[15],"voiceId":"TalkSet104-8","talkText":"Hold on, Kokoro! What is this trip you're talking about?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}