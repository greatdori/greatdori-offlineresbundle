{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet72","backstageTalkSetId":72,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet72-1","talkText":"I have not been able to go to my club activities lately...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet72-2","talkText":"It's pretty hard when you\nhave Pastel＊Palettes' \nstuff to do.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet72-3","talkText":"And... you're part of... a lot of clubs...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet72-4","talkText":"That's right! I do tea ceremony, flower arranging, and kendo!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}