{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet485","backstageTalkSetId":485,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet485-1","talkText":"Look, Kaoru-san! Here's my impression of you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet485-2","talkText":"How fleeting... Well, how did I do?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet485-3","talkText":"Ahhh, Kasumi-chan. What a fleeting performance.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}