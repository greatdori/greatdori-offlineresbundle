{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50014","backstageTalkSetId":50014,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50014-1","talkText":"Kanon-san, please continue walking in that direction.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50014-2","talkText":"F-fueee... Wh-what's going on...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50014-3","talkText":"Okay, we're here. You can look now.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50014-4","talkText":"Kanon! Happy Birthday!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet50014-5","talkText":"Wow! What a huge jellyfish...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet50014-6","talkText":"It's actually a big cushion~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet50014-7","talkText":"We thought it would be perfect for you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50014-8","talkText":"The fleetingness so affectionately enveloped within resembles you, Kanon.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[13],"voiceId":"TalkSet50014-9","talkText":"Come on, Kano-chan-senpai! Try sitting on it!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50014-10","talkText":"Wow, it's like being on a real jellyfish...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[14],"voiceId":"TalkSet50014-11","talkText":"... Zzz.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[15],"voiceId":"TalkSet50014-12","talkText":"Sh-she fell asleep~?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}