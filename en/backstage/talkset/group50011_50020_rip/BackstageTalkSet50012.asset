{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50012","backstageTalkSetId":50012,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet50012-1","talkText":"Happy Birthday, Tomo-chin~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50012-2","talkText":"May this gift help you liven up the festivals of Japan~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet50012-3","talkText":"Thanks! ... Wait, is this a happi coat?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50012-4","talkText":"Fufu~! That's right, and it's handmade!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet50012-5","talkText":"No way! You really outdid yourselves with this gift!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50012-6","talkText":"Can I try it on right now?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet50012-7","talkText":"Of course! We want to see you wear it too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet50012-8","talkText":"Okay... What do you think?!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[6],"voiceId":"TalkSet50012-9","talkText":"Hey, not bad. It looks good on you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet50012-10","talkText":"You look so cool, Tomoe-chan!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[8],"voiceId":"TalkSet50012-11","talkText":"Look over this way~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}