{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50016","backstageTalkSetId":50016,"snippets":[{"talkId":1,"characterIds":[1,2,3,5],"voiceId":"TalkSet50016-1","talkText":"Happy Birthday, Saya!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet50016-2","talkText":"Wow, what a big cake! Thanks, guys.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet50016-3","talkText":"Hehehe, it does look pretty tasty.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50016-4","talkText":"Hold it, Kasumi. This is Saya's birthday, you know.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50016-5","talkText":"Fufu, nice save, Arisa. Okay, now to blow out the candles...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet50016-6","talkText":"We got you a present too. Go ahead and open it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3],"voiceId":"TalkSet50016-7","talkText":"We tried to get something that would look good on you!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50016-8","talkText":"Accessories! Well...? How do I look?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[5],"voiceId":"TalkSet50016-9","talkText":"Oh, very nice.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[4],"voiceId":"TalkSet50016-10","talkText":"Fufu, the Arisa seal of approval.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[5],"voiceId":"TalkSet50016-11","talkText":"Kn-knock if off~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}