{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50020","backstageTalkSetId":50020,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet50020-1","talkText":"Eve-chan! Happy Birthday~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50020-2","talkText":"Thank you so much! Wow, you got me new clothes?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet50020-3","talkText":"Uh-huh! A total Eve-chan wardrobe!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50020-4","talkText":"We took our time in picking out the hats and clothes that fit you best.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet50020-5","talkText":"Which wasn't easy, as I am unaccustomed to such things.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet50020-6","talkText":"They're stylish and can go with pretty much anything.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet50020-7","talkText":"Hehehe... I can feel myself blushing.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[17],"voiceId":"TalkSet50020-8","talkText":"Hey! Why not go ahead and try them on!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet50020-9","talkText":"Okay! Please wait a moment!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[20],"voiceId":"TalkSet50020-10","talkText":"How do I look...? Does it suit me?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet50020-11","talkText":"W-wonderful~! You truly are a model!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50020-12","talkText":"Positively splendid. Phew, what a relief.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}