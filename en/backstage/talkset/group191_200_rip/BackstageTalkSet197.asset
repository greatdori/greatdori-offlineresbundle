{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet197","backstageTalkSetId":197,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet197-1","talkText":"I was on fire in rehearsal today~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet197-2","talkText":"You were so full of energy, Tomoe-chan.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet197-3","talkText":"Tomoe, you were even cooler than usual!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet197-4","talkText":"Tomo-chin was Tomoexcellent.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet197-5","talkText":"Another word from the Moca dictionary.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}