{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet194","backstageTalkSetId":194,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet194-1","talkText":"Maya-chan, I think there's something wrong with my guitar.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet194-2","talkText":"Here, allow me to adjust the neck.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet194-3","talkText":"Maya-chan. Which is the script for the next show...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet194-4","talkText":"It's the one with the yellow cover!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet194-5","talkText":"Maya-san, do you have a bandage?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet194-6","talkText":"They're in that bag!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[18],"voiceId":"TalkSet194-7","talkText":"(Thank goodness Maya-chan is around...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}