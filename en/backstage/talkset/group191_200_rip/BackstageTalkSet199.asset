{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet199","backstageTalkSetId":199,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet199-1","talkText":"Weizenbrot!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet199-2","talkText":"Wh-what?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet199-3","talkText":"... It's a type of bread, apparently.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet199-4","talkText":"That actually sounds pretty cool.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet199-5","talkText":"What kind is it, anyway?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet199-6","talkText":"Hard to guess from only that...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet199-7","talkText":"I wonder if there are other fun bread names out there♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}