{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet196","backstageTalkSetId":196,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet196-1","talkText":"Wow, look at the time!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet196-2","talkText":"It really does fly by when you're with friends.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet196-3","talkText":"There's still so much to talk about.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet196-4","talkText":"We can continue the convo somewhere else, then~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[6],"voiceId":"TalkSet196-5","talkText":"Can we use your place, Tsugumi?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet196-6","talkText":"Of course! We always appreciate the business!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}