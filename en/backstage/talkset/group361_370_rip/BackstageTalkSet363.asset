{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet363","backstageTalkSetId":363,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet363-1","talkText":"Happy Birthday, Sayo-san!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet363-2","talkText":"This is from... all of us...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet363-3","talkText":"Are these... cookies?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet363-4","talkText":"Yup! Even Yukina helped!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[21],"voiceId":"TalkSet363-5","talkText":"... I hope you like them.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet363-6","talkText":"Thank you. I'll savor every last one.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}