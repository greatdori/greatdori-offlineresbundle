{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet552","backstageTalkSetId":552,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet552-1","talkText":"Kaoru-san, I read your poetry collection!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet552-2","talkText":"You honor me. May I ask what you thought of my humble works?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet552-3","talkText":"The third poem reminded me of Oddie.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet552-4","talkText":"Hm, fascinating... Tell me more.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}