{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet553","backstageTalkSetId":553,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet553-1","talkText":"Look, look! Isn't it pretty?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet553-2","talkText":"What a lovely flower. It's so white and fluffy.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet553-3","talkText":"It's so cute, just like you, Rimi-rin~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet553-4","talkText":"(I-I can't talk about how pretty the flower is anymore...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}