{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet165","backstageTalkSetId":165,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet165-1","talkText":"The other day, Hina came\nstargazing with me!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet165-2","talkText":"Oh, she did?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet165-3","talkText":"All she did was talk\nabout you the whole time!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet165-4","talkText":"Oh... Sh-she did...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}