{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet163","backstageTalkSetId":163,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet163-1","talkText":"Phew, that was nice!\nI really worked up a sweat today!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet163-2","talkText":"Did you have... Kendo Club...\nWakamiya-san...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet163-3","talkText":"Nope! I had Flower Arranging Club!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet163-4","talkText":"Is arranging flowers... that intense...\nof an activity?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}