{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet166","backstageTalkSetId":166,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet166-1","talkText":"(I'll go home... and Ako-chan and I... will play video games... together...)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet166-2","talkText":"Oh? Rinko!\nYou look excited!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet166-3","talkText":"That's a lovely smile on your face!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}