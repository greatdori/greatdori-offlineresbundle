{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet164","backstageTalkSetId":164,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet164-1","talkText":"Happy! Lucky!\nSmile! Hooray!!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet164-2","talkText":"Tsurumaki-san?\nWhat's gotten into you?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet164-3","talkText":"That's what I felt like shouting,\nso I did it!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet164-4","talkText":"She's even more free-spirited\nthan Hina is...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}