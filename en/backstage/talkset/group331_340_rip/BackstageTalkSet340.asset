{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet340","backstageTalkSetId":340,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet340-1","talkText":"Misaki, you wear hats\npretty often, huh?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet340-2","talkText":"It's a really nice style for you.\nIt looks good, and it's very fitting.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet340-3","talkText":"Huh?! Th-thank you.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}