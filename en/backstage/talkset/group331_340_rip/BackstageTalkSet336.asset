{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet336","backstageTalkSetId":336,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet336-1","talkText":"Mii-kun, Mii-kun!\nCome here!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet336-2","talkText":"Hm? What's up?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet336-3","talkText":"Kokoron said we're gonna have\na performance right now!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet336-4","talkText":"What?! Don't you think\nthat's just a little too sudden?!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}