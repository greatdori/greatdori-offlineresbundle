{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet331","backstageTalkSetId":331,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet331-1","talkText":"So, I have written\na letter for Michelle.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet331-2","talkText":"It is a token of my gratitude,\nas she is always there for us.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet331-3","talkText":"I hope you wouldn't mind\nhanding it to her?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet331-4","talkText":"(... Is it okay for\nme to read this?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}