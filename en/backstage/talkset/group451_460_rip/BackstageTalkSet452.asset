{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet452","backstageTalkSetId":452,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet452-1","talkText":"This book was really interesting!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet452-2","talkText":"Here... This is, um... my way of saying thanks...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet452-3","talkText":"Is this... a bookmark...? The fall leaf pattern is so pretty...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[25],"voiceId":"TalkSet452-4","talkText":"Thank you very much... I'll take good care of it.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}