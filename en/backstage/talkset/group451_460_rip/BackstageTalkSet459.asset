{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet459","backstageTalkSetId":459,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet459-1","talkText":"Sweet osmanthus flowers have such a nice smell~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet459-2","talkText":"They have begun to bloom in my neighborhood, as well.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet459-3","talkText":"I never grow tired of their fragrance... Ahhh... How fleeting...!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}