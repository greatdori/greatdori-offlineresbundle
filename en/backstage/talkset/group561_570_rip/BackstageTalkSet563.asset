{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet563","backstageTalkSetId":563,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet563-1","talkText":"Tsugumi, what do you think I should get at your place?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet563-2","talkText":"Probably the cake set. But the café au lait is good, too.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet563-3","talkText":"A stupendous idea! I'm sure they'll both bring a smile to my face!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}