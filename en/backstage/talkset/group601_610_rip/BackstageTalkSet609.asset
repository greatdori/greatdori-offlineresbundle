{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet609","backstageTalkSetId":609,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet609-1","talkText":"I almost fell asleep during afternoon classes...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet609-2","talkText":"After lunch... it's hard to stay awake...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet609-3","talkText":"And I was up until late last night...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet609-4","talkText":"I wish our school day included a nap time.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}