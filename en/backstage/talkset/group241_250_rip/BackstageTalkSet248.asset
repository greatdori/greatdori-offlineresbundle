{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet248","backstageTalkSetId":248,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet248-1","talkText":"Now, what should I do for\nthe lyrics of our next song...?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet248-2","talkText":"Hmmm... I know!\nWhy don't you do a festival theme?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet248-3","talkText":"And then, instead of the normal drum set,\nI can try playing the taiko!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet248-4","talkText":"Hm... Yeah, let's not do that.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}