{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet247","backstageTalkSetId":247,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet247-1","talkText":"\"Ran\" and \"bun\" are kinda similar\nwords, don'tcha think~?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet247-2","talkText":"Don't compare me to bread.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet247-3","talkText":"What~? That's like one of the best\ncompliments you could get~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}