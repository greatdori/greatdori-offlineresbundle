{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet244","backstageTalkSetId":244,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet244-1","talkText":"We have some extra bread...\nYou could have some if you'd like.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet244-2","talkText":"Very much appreciated. Ah...\nSuch a sweet fragrance.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet244-3","talkText":"But, uhhh...\nIt's curry bread...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet244-4","talkText":"Fufu... Nevertheless, its aroma\nis the sweetest.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}