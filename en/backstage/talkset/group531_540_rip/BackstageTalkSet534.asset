{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet534","backstageTalkSetId":534,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet534-1","talkText":"Kokoron, did you send your letter to Santa already?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet534-2","talkText":"Yep! I asked if he wanted to be a member of Hello, Happy World!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet534-3","talkText":"Santa wishes to put a smile on everyone's face as we do.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet534-4","talkText":"Hey, Kanon-san. Kokoro's the one asking for it so...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet534-5","talkText":"Fufu, yeah. It feels like it might actually come true.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}