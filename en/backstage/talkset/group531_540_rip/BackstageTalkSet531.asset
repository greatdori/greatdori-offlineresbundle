{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet531","backstageTalkSetId":531,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet531-1","talkText":"Alright~, I'm going to assign everyone's task for this year's Christmas!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet531-2","talkText":"Great~, I volunteer for the task of eating~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet531-3","talkText":"No. Moca and I will do the shopping.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet531-4","talkText":"Okay, I'll decorate the tree then.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet531-5","talkText":"I guess that means Himari-chan and I will be cooking!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet531-6","talkText":"Let's have ourselves another fun year~! Hey, hey, hoh~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}