{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet228","backstageTalkSetId":228,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet228-1","talkText":"Aa-chan, you're so amazing\nwith your big ol' brain!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet228-2","talkText":"Wh-what?! That's so random!\nThanks, I guess...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet228-3","talkText":"I need to do more studying.\nAnd I need to do it right.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet228-4","talkText":"I-if you want...\nI could help you out with that...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}