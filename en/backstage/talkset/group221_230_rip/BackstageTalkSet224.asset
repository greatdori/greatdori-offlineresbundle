{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet224","backstageTalkSetId":224,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet224-1","talkText":"Arisa-san, what are you reading?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet224-2","talkText":"This magazine has a special article\non bonsai this month, so, you know...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet224-3","talkText":"Bonsai!\nI can sense the Japanese spirit!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}