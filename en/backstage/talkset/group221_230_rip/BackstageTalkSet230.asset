{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet230","backstageTalkSetId":230,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet230-1","talkText":"Ah, it's Michelle.\nHey, Okusawa-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet230-2","talkText":"...","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet230-3","talkText":"Uhhh, hello~?\nMaybe she's not in there.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet230-4","talkText":"... Ah!\nIt was too warm. I fell asleep.","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}