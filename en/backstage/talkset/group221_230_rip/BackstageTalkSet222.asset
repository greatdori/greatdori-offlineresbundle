{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet222","backstageTalkSetId":222,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet222-1","talkText":"Kasumi and the others are taking forever. It's like they made a stop or something.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet222-2","talkText":"Fufu, if you're worried,\nyou should try calling them.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet222-3","talkText":"Th-that's not what I meant!","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}