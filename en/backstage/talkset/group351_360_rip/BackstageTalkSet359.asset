{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet359","backstageTalkSetId":359,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet359-1","talkText":"...","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet359-2","talkText":"Rinko, you've been staring at your\nphone for a while. What's up?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet359-3","talkText":"I'm... about to make... a phone call...\nI'm... just not ready yet...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet359-4","talkText":"C'mon~! There's no way you should\nbe that nervous to make a phone call!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}