{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet360","backstageTalkSetId":360,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet360-1","talkText":"I'm not the same Moca-chan\nI am every day~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet360-2","talkText":"Huh? What do you mean...?\nLike you did your hair differently?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet360-3","talkText":"Womp womp~. Nope. The right answer\nwas that I'm more Mocatastic than usual.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}