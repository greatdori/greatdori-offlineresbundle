{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet355","backstageTalkSetId":355,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet355-1","talkText":"Thank you... for the cookies...\nthe other day.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet355-2","talkText":"It's of no concern... I'm pleased\nto hear you enjoyed them.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet355-3","talkText":"Of course... I did...\nThey were... very good.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}