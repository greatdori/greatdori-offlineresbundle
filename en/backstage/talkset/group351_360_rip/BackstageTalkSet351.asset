{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet351","backstageTalkSetId":351,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet351-1","talkText":"I hear you and Hina\nhung out yesterday.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet351-2","talkText":"Yeah...?\nDid Hina tell you that?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet351-3","talkText":"Yep. Seemed like a pretty big deal to her.\nI can't tell you how many times she told me.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet351-4","talkText":"I'm sure she really\nenjoyed herself.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}