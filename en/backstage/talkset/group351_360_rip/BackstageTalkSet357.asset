{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet357","backstageTalkSetId":357,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet357-1","talkText":"Today's dance rehearsal\nwas pretty good, wasn't it?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet357-2","talkText":"Ehehe, you think so?!\n... Wait, no.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet357-3","talkText":"It is with the power of darkness\nthat we were... Uhhh...","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet357-4","talkText":"Oh man~... I can't come up with\nanything good to finish the sentence~!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}