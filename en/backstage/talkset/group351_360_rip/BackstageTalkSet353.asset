{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet353","backstageTalkSetId":353,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet353-1","talkText":"The other day, my sister\nand I hung out!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet353-2","talkText":"We had a blast!\nIt was awesome!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet353-3","talkText":"Did you now? That's great.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet353-4","talkText":"(I suppose an occasional outing with Hina\nwouldn't hurt... But how do I go about it?)","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}