{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50059","backstageTalkSetId":50059,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50059-1","talkText":"I'm not so sure about the birthday present we got Kaoru-san.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50059-2","talkText":"I tried to imagine that I was Kaoru-kun when we made our choice!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50059-3","talkText":"Me too! And that's how we thought of it!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50059-4","talkText":"Ahaha, well, it is a very fleeting gift.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}