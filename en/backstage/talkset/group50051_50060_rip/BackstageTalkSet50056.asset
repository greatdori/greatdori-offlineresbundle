{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50056","backstageTalkSetId":50056,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50056-1","talkText":"Happy Birthday, Tsugumi.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50056-2","talkText":"Ran was the one who suggested we get you some pretty flowers~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50056-3","talkText":"We each picked one!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50056-4","talkText":"Wow, you have no idea how happy this makes me! I can't wait to see them.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50056-5","talkText":"I chose a marguerite! It's supposed to mean true friendship!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50056-6","talkText":"I went with chamomile. It's supposed to help you relax.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50056-7","talkText":"I got a lilac. Hey, Ran, what are lilacs supposed to represent?","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50056-8","talkText":"\"Precious friend.\" I know you looked it up before getting it though.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50056-9","talkText":"Ahaha~, oopsie~.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet50056-10","talkText":"I got you a tulip because it's your birthday flower.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50056-11","talkText":"You can probably put them wherever you want. Maybe in the café even.","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[10],"voiceId":"TalkSet50056-12","talkText":"I will, thank you! Fufu, they smell so nice!","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}