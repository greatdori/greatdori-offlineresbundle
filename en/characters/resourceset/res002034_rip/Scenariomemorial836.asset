equirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Ah, you don't have to act that surprised.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"You see, Poppin'Party went to a toy museum the other day.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"It was a lot of fun, and we saw all sorts of old toys.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"That's true. It's not a place you'd stop by normally, is it? Actually, it was kind of a coincidence that my bandmates and I ended up at the other place too...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"We found this old tin wind-up rabbit toy in Arisa's basement.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"It actually turned out to be part of a three-piece set, but Arisa only had one.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Kasumi was saying how she wanted to find its friends.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"We were told that they had a whole bunch of old toys at this toy museum, so we ended up popping over there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"What about its friends? We found them. Both of them.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"We donated the one from Arisa's place, so now the three of them are on display together.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"And on our way out the museum, that toy bunny moved a little bit...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Fufufu. You think I'm kidding? Who knows.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"I realized something while I was looking around the museum.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"There are a lot of toy instruments, aren't there?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"You know, like toy versions of instruments or little dolls holding instruments.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Our little bunny was holding onto a drum, and its friends had a guitar and piano, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"So I was wondering if there were still toys like that in stores today...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Yeah! There were!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Looks like they're still pretty popular among kids.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev102-me4-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDispla