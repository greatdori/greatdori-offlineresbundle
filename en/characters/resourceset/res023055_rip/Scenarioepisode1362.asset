}],"windowDisplayName":"Lisa","body":"I feel like I always got excited for Christmas back then.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev170-ep3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Don't get me wrong, I still do. But when I was little, I kinda felt something amazing was gonna happen every Christmas.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev170-ep3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"As Christmas gets closer, the city becomes so much more colorful. It's kinda like all the pretty lights in the world are being put on display here...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"ev170-ep3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"I think you're exaggerating there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev170-ep3-026","volume":1}],"speed":0,"f