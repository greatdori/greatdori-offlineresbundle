,"progressType":1,"referenceIndex":15,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":23,"delay":2.299999952316284,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":24,"delay":4.800000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":16,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":25,"delay":3.4000000953674316,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":26,"delay":2,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":27,"delay":4,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":28,"delay":7,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":18,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":29,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":19,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Hello, LAYER-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah, Marina-san, {{userName}}-san. Hello, pardon the intrusion.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Sorry that I'm using the café without even booking a studio...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Don't worry about that. You're welcome to it! Were you taking a break?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yes. I just had practice with RAS. I thought I'd do some reflection.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I see. RAS practices at CHU²-chan's penthouse, right? That's quite impressive.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ahaha... I was also surprised at first. But I'm used to it now. We have good equipment and a nice working environment, so I'm grateful.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Aww... You should use CiRCLE sometime though, okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Fufu. Yes, we will.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"But reflection, huh? This might sound rude saying it to a pro like you, LAYER-chan, but I love how dedicated you are!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"RAS is the first band I've been a part of where I'm an official member. I want to give it my best.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"... Ah, but that doesn't mean I wasn't giving it my all up until now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, I know, I know. I can see how serious you are about music just from watching you perform, LAYER-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Thank you very much. But it's not enough to just be serious. RAS is aiming for something much higher than that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"It can be quite hard, but having the entire band aiming for the same goal is new to me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I see. You've worked for many different bands up until now, haven't you, LAYER-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yes. That's why I feel like I am finally in a band for real.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"A band that discusses everything together, sometimes butting heads... but is always moving forward regardless. That's the kind of band I want us to become.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Yeah, yeah! I'm looking forward to your future with RAS!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"memorial-r-layer-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yes. Please do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"memorial-r-layer-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffs