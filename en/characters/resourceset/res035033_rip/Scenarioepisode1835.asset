35}],"windowDisplayName":"CHU²","body":"You make it sound like I'm always hanging around other people. I'm just on my way home after taking care of some business.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Oh, I see! Hey, hey, we're on the way to do some karaoke right now~♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"We invited Rokka, too, but she said maybe some other time 'cause she has some practicing to do on her own.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Huh, you don't say.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Oh, and about the karaoke place, high schoolers get two free hours~! Can you believe it?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"If you're free, CHU², we should go together! You guys don't mind, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"What?! O-oh, um... s-sure, I don't mind...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev237-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"I think it's a great idea. We'd love to have you if you want to come.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"No thanks. I've got better things to do than karaoke. Besides... I'm not in the mood right now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Oh, okay. Let's go together when you feel like it then!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"... Hmph. If I ever do, why not.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf_right01","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"The promo's supposed to last for a while anyway. I'm so glad I'm a high schooler~. It lets me get free hours!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Yes. There are even supposed to be free drinks.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev237-ep1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"This is definitely one of those moments where it feels great to be a student.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"I know, right~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"... It sure must be nice to be so carefree. Just look at all of you. You're all getting excited over being treated like kids.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Ako & Mashiro & Asuka","body":"Hm...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"surprised01","expressionName":"default","timingSyncValue":0},{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"ev237-ep1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Sure, the perks you get may be nice, but they're also a sign that you're being looked down on because of your age.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Not once has that ever made me happy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf01","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Hmm~, so are you saying you don't like being treated like a kid, CHU²? As much as I like free stuff, I don't like being so obviously treated like a kid either.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"Tell me about it. My mom and stuff tell me I can't go too far on a trip or stay overnight until I'm an adult.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"It's not like I'm that much of a kid anymore, you know?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I know what you mean...! My mom still treats me like I'm little.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev237-ep1-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"The other day, she got me these fuzzy pajamas that she thought would look good on me, but they're like the ones that babies wear. She didn't even ask me first.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev237-ep1-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"Ahaha... Well, based on what I've seen of you usually, Mashiro-chan, I can't say I blame your mom too much, honestly.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"What?! Wh-why...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev237-ep1-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"At least it's not as bad when it's coming from your parents. I get the kid treatment from MASKING and PAREO, and they're practically the same age as me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Those two do look after others a lot.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"What they do goes way beyond looking after. Who do they think I am, seriously?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf01","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Don't even get me started on the shopkeepers downtown. They give me snacks even when I'm just walking around minding my own business...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"It's definitely a nice gesture, but it's also one that causes mixed feelings for sure.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I have no mixed feelings. I don't like it, period. I've told them I'm not a little kid over and over, but they still keep doing it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"It kind of can't be helped though. I mean it's true that we're not adults yet.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"...! I guess, but still...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Hmm~, when another person sees you that way, though, don't you think it's a chance for you to surprise them a whole lot?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"...? What do you mean...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf03","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev237-ep1-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Like, if someone thinks I'm a kid, they're gonna be super surprised when I put on an awesome performance!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"I feel like the adults we started working with ever since going pro have taken really good care of us.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"But sometimes, when we've been with people we haven't spoken to much, I've gotten the feeling that we were being seen as just a student band or a bunch of kids.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf01_openeye","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"So when we'd get serious and play, their eyes would become all super wide with surprise, and the vibe they were giving would totally change instantly!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Whenever that'd happen, I'd get this \"Did you just see how good we are~? It doesn't matter if we're adults or kids\" kind of feeling!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"Fufu, that's so you, Ako.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"... I've never thought of it that way. I guess random chit-chatting pays off sometimes.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Huh? Where are you going, CHU²? That way's the station.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Change of plans. If I show up soon enough, I should be able to cram in a meeting with another company.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Okay. I don't really get what you're talking about, but I hope things work out!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I'll make it work.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Oh, I just remembered. Be sure you all go home before it gets dark, okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Hey~! You just treated us like kids, didn't you~?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"ev237-ep1-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":214}],"windowDisplayName":"Asuka","body":"Fufu. Whatever the case, it looks like you're feeling better now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":214,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":214,"voiceId":"ev237-ep1-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Maybe, maybe not. Anyway, I need to go. Bye.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev237-ep1-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom"