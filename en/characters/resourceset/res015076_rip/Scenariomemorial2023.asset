{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"6adbc306fd0be204"},"m_Name":"Scenariomemorial2023","scenarioSceneId":"memorial2023","storyType":0,"appearCharacters":[{"characterId":15,"costumeType":"015_casual_summer-2023"},{"characterId":201,"costumeType":"201_casual-2023"}],"firstLayout":[],"firstBgm":"29_Normal_2","firstBackground":"bg00017","firstBackgroundBundleName":"bg/scenario1","snippets":[{"actionType":6,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":1,"delay":1.5,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":1,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":4,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":5,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":6,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":7,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":4,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":8,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":5,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":9,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":10,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":6,"delay":5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":11,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":12,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":13,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":14,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":7,"delay":6,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":15,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":8,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":16,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":18,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":19,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":9,"delay":5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":20,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":21,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":10,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":11,"delay":7.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":25,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":12,"delay":7,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":26,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":13,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":27,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":14,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":28,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":29,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":15,"delay":2.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":30,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":31,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Phew... Oh, Marina-san, {{userName}}-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Hello, Misaki-chan! On your way to a Hello, Happy World! thing?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ah, no. our Hello, Happy World! meeting wrapped up this morning. I'm heading home now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Got it. Good work today. Hope you get some rest.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Yeah, about that... not quite.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"This afternoon I’ve got a meeting at the next live venue, and after that we’re heading to Kokoro’s place for practice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Sounds like a lot... Are you holding up okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahaha, I’m still fine. But yeah, things have been pretty hectic lately.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"That kindergarten live went over well, so now we’re doing one at an elementary school next, and there’s talk of doing another at a hospital too...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Come to think of it, didn’t you all do a show at your school recently too?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Yeah, for the Closing Ceremony. Prepping for that one was seriously rough, but it went over so well that it felt totally worth it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, you’ve got such a bright smile right now, Misaki-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Haha... Not that I’m thrilled about it, but maybe being too busy suits me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"...Oh, right. I still need to finalize the new song plans.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"You’ve really got your hands full...! But I’m looking forward to the new Hello, Happy World! song. Have you decided on what kind of song it’ll be yet?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"More or less... I mean, we only have the drawing so far. I’ve got a photo on my phone—here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"This... is one of Kokoro-chan’s drawings, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Exactly. She came up to me with her sketchbook saying, “Misaki! This is our next Hello, Happy World! song!”","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I’m not totally sure what’s going on in the drawing, but it looks like a lot of fun. What kind of song is it supposed to be?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"I think the melody’s upbeat, and the chorus is going to be chaotic and cheerful, like our usual Hello, Happy World! style... or something like that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"You can tell all that just from this drawing!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Well, I’ve gotten used to it... So now it’s just a matter of turning this into something real.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"“Just turning it into something” sounds way harder than you’re making it out to be... You’re amazing, Misaki-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Thanks. I’ve developed some weird skills thanks to Hello, Happy World!.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Though actually... this drawing’s a little easier to understand than usual. After everything that happened with Misono-san, I feel like Kokoro’s changed a bit.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Like... she’s actually thinking more about others now, maybe. Or it could just be a fluke this time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"If Kokoro-chan really has changed, maybe it’s because of everything she’s been doing with the rest of Hello, Happy World!.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahaha, maybe. If that’s true, then maybe I’ve contributed a little to it too... to Hello, Happy World!’s mission to “fill the world with smiles.”","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"...Ugh, that’s not like me at all. Forget I said that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"shame03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Huh? Why? I thought it was lovely. You sounded really happy—","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev265-me2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahh—ahh! Seriously, it’s fine! But thank you!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Sorry for keeping both Marina-san and {{userName}}-san. I’ll see you around.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev265-me2-032","volume":1}],"speed"