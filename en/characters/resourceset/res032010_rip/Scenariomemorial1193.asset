essType":0,"referenceIndex":18,"delay":2.299999952316284,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":19,"delay":4.800000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":21,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":20,"delay":2,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":21,"delay":5.699999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":22,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":23,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":24,"delay":2.700000047683716,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Ah, Marina-san, {{userName}}-san. Hello, are you shopping?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Mm-hmm, there are some things we need. What about you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"I just got done with work, so I'm on my way to CHU²-san's place.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I guess that means you've got band practice now. It must be pretty tiring after work.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Oh, no. We don't have practice today. I'm just going to use CHU²-san's studio to practice on my own.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"I usually go to Galaxy when I need to use an amp, but Galaxy is booked, so...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Normally, I'd give up and play at home without an amp.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"But I thought about how motivated LAYER-san has been, and I have this urge to play my guitar with sound.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, have fun. I heard LAYER-chan has been working really hard.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Yes! She's always so focused during practice, but it's like she's into music even more now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, so that's why you're on fire, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Exactly! I just want to play as hard as I want without worrying about the volume or other people.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"LAYER-chan has been on a roll lately. The concert where she helped that professional band was a huge success.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"She was super awesome!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"... But she also had to practice our new song, so the schedule was tough. I could tell she had to push herself pretty hard too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"odoodo02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I heard about how difficult things were.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"For her, yes, but not for me... Well, I did worry about her a lot...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I see...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"And I don't know if it's because of how things were when she had to practice, but I get this feeling that she's changed a bit ever since that concert.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Changed? In what way?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"It's not something I can really put into words. Whenever I see her play, I can't help but feel this need to work harder!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Ah, it's always been like that, but the feeling's somehow stronger now...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"And LAYER-san's passion has everyone so motivated at the moment too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev150-me3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Even more than usual? I can't wait to see what the result of that is going to be like.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev150-me3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Fufufu. I'm sure our next live performance is going to be incredible!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":