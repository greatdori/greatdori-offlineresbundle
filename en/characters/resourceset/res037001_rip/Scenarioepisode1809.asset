ody":"I'm also in charge of the band's social media. I'll be posting lots of pictures and videos, so please follow us!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"introduce-anon-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I also design costumes for the band. The brand name is \"ANON TOKYO\"!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"introduce-anon-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I hope you'll take special note of it at the live show!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"introduce-anon-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"... Ah, yes. I forgot something important!\nTo be honest, I'm also the founder of MyGO!!!!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"introduce-anon-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"req