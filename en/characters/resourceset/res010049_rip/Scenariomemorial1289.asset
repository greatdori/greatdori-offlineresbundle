Index":20,"delay":1.7999999523162842,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":21,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":20,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Hello, {{userName}}-san!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Are you shopping too? Fufu, so am I.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"You know about our band trip? I'm glad we managed in the end.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"It must've been very busy at CiRCLE without Marina-san. Were you okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"That's good...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Was Marina-san the one who told you about our first band trip?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Fufu, you could say that. It was one problem after another, so we had a pretty... no, very difficult time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Right as we were about to arrive, I even found out that I'd forgotten my new bag at home together with the outfit inside it... I really panicked.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"And it was going to be our big concert, but we all ended up bringing different outfits too...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"That was a real shocker. Our plan to wear matching outfits was ruined, so we didn't know what to do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"But we still managed thanks to Himari-chan!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"You should've seen her. She was so amazing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"At the time, I was too disappointed with myself for having forgotten my outfit even after how much I had prepared.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"And all I could do was feel miserable... But then Himari-chan spoke up.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"She said we should just get on the stage and perform anyway... And then everyone started getting behind her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Fufu, I had my doubts for a while... so I'm glad we were able to make the concert work.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... I still think it's important to learn from our mistakes and be prepared, though. There's a lot to take in from both the successes and the failures of our recent challenge.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf04","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Many things still need to be done, so I feel like I'm going to have to work even harder!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Thank you very much! I'll try even more, so I hope you'll support me!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Ah, I'm sorry for keeping you! You're in the middle of shopping, aren't you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Anyway, thank you for listening. Bye!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev161-me4-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"010_casual_summer","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"smile02","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0