":26,"voiceId":"ev111-ep5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"(But it's a lot redder than any sauce I know...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Hey, Nanami-chan. Could I take a look at that sauce?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Of course~! Here you go!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev111-ep5-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Thanks. Let's see, ah, it's from overseas.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"(I can't read what it says, but knowing Nanami-chan, this sauce could be a foreign delicacy...!)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"You're looking at that bottle pretty closely. Let me guess, you want to try some, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev111-ep5-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Y-yeah... Erm, may I?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Go right ahead. It's so good, it'll make your mouth tingle~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev111-ep5-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Thanks. Then I'll put some on this croquette and... Hm?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"O-ouch...! Ouch, ouch, ouch~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"ev111-ep5-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Huh? What's going on...? Sh-Shiro-chan, what's the matter?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev111-ep5-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"M-my eyes are burning~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"charact