-ep1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Yes... I'm sorry. It was my turn to make breakfast today. I'll cook the rest.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev219-ep1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Oh, it's alright. It's almost ready, so please have a seat.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev219-ep1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"But...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev219-ep1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Besides, you switched with me the other day to clean the bathroom. Now we're even.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev219-ep1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"So please don't worry, okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev219-ep1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"O-okay.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev219-ep1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Do you have rehearsals today?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev219-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Yes. I'm thinking of going to the studio early and doing some solo practice...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"