nFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"I agree... At first, I was pretty terrified... since there were so many people involved... But now I'm excited... I can't wait to see... what kind of song it'll turn out to be...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Fufu, you're right about that♪ Though, I hope Yukina makes an effort to get along with everyone...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"I'm sure... she'll be fine...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Yeah, she's the one who willingly said she'd represent Roselia! I was ecstatic when she volunteered~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Yes... Yukina-san... had an entirely different expression... on her face than usual... I'm confident they'll write.... a wonderful song...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Since Yukina is working so hard as the rep for Roselia, we need to do our best too☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"It'd be nice if we could raise the hype during our joint performance... Any ideas of how we can do that?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Right... What do you think of... making something that would... have us all match...? Like costumes... Something like that...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Matching outfits? Ooo~! That's a great idea! You're amazing, Rinko. Exactly the kind of idea I'd expect from Roselia's costume maker!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"But... I'm afraid we might not have enough time... to make outfits for all five bands... starting from scratch...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Now that you mention it... that's true. \nIt was such a good idea, though...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Oh! ... I've got it!\nHow about we make concert T-shirts then?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Concert... T-shirts...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Yeah! Matching concert T-shirts for everyone! We can think up a design and everyone can wear it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"That would be... much less time consuming... than making everyone's costumes... from square one...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Right? I feel like this could actually go well! Alright! Now that it's settled, we have to come up with a design♪ Rinko, could you give me a hand with it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Yes... but of course... If there is anything... I can help with, that is...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Thanks, Rinko~! We have formed Team Outfits! I wonder who else could help us out~. I'll try asking on the group chat~♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"I hope we... can come up with... something wonderful...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Me too! An awesome T-shirt will surely hype everyone up. It'd be even better if we could make a design everyone will like!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Fufu... Imai-san, you're so... into this idea...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Ahaha, I guess I am~? But maybe I just like thinking about things like this~☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Yukina-san did say... you have very strong... communication skills...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"You become even more animated... once you start considering... other people...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"You're making me feel a little embarrassed! But since we get the opportunity to do this, let's make the T-shirt as awesome as can be!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Okay, as long as we make the order by this date... we should be able to have them in time for the concert!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Now... for the design...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Yup! So I tried coming up with some while taking into account the advice you gave me... But I feel like something is missing...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"It must be hard... to think up a design... that suits everyone... Every band is so unique...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Can't disagree with you there. Poppin'Party is energetic! And Pastel＊Palettes gives off the fluffy, cute vibes...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Afterglow is so rockish, they can heat up the place, while Hello, Happy World! makes you feel like you're at an amusement park...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"And then you add us, Roselia, to the mix... The more I think about it, the more it feels like our bands' personalities are completely different~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I was trying to make a T-shirt that can unify all of our bands' unique characteristics together into one...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"I understand... how you feel...\nLet me... do some thinking, too...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Thanks, Rinko~! I'll try to come up with a couple more designs, then.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Okay... I look forward... to seeing them...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"fes-RS-part1-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Argh... This isn't working~! The more I try to think about it, the further away I feel like I'm getting from the design I want...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Let's see, a T-shirt that works for everyone... Oh, but to begin with, I can't even imagine Yukina or Sayo wearing a T-shirt!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"We'd need a design that is stylish, cool, cute, and energetic...\nThat way, it would match Roselia, Poppin'Party, Pastel＊Palettes, Afterglow and Hello, Happy World!... Match everyone... Hm~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"... Oh, I know! Why don't I consult Team Outfit?!\nI'll just send a message in our group chat...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"By hearing their ideas, I bet I'll be able to think of something good- Oh, there's already a reply♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":1,"soundReferenceIdx":1,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"It's from Himari. Let's see... \"One that we could normally wear would be nice♪\" I totally get that~. If it's stylish, you'd want to wear it offstage, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"\"What matters most is that it's cool!\" ... Ahaha! That's Ako for you♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Eve's message says... \"One that emanates the bravery of a warrior!\" ... A warrior?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"So now we need a T-shirt that can be worn offstage, must be cool, with the bravery of a warrior... and still needs to suit everyone... Huh? ... How am I going to do that~?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"fes-RS-part1-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":23,"costumeType":"023_school_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":25,"costumeType":"025_school_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":23,"costumeType":"","motionName":"nf03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0