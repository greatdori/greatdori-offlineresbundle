":20,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"fes2-MY-part2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"Maya","body":"We had fun playing with you! We should be thanking you...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"fes2-MY-part2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Child 3","body":"I told everyone I'm not fast or strong, and they said we could do something I can also play from now on.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Child 3","body":"I was able to speak with them because of you and Eve-chan. That's why I wanted to say thank you.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"Maya","body":"...! I... I'm really touched to hear that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"fes2-MY-part2-031","volume":1