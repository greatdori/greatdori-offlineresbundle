9999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":12,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":13,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"My name is Himari Uehara~! I'm a first year high school student~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I am a part of the tennis club, and I also work part-time at a fast food restaurant.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"And, and! I play the bass for Afterglow!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I'm also kind of the band's leader, too.Though I may not look too reliable…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Our band is made up of a group of childhood friends. I don't know if I'd say we don't work well together or if we just like to do our own thing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Actually, it's really just two people.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"The other day they were late, and their excuse was \"the bread shop was having a sale, so we had to take a look...\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"... Ah, sorry. I shouldn't be complaining.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"We have some trouble here and there, but actually we always have a good time. Really really!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I said we do our own thing, but when the sound of our instruments come together, strangely enough, we have a lot of fun.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"So we can probably forgive those who are a bit more free-spirited... Hehehe.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Mmm~. I get kinda excited just talking about it! Alright! Here we go!! Hey, hey, hoh~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"... Ah! I'm cheering all by myself...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Ahh, I'm so embarrassed... Delete that one! Take two please~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"episode029-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":8,"costumeType":"008_casual","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"ch