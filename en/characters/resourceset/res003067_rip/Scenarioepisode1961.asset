dowDisplayName":"Kaoru","body":"Hehe... To think I’d have the chance to meet you, little kitten.\nAh, what incredible fortune...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Oh, I’m the one who’s lucky...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"shame02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(Just getting to see Kaoru-san after so long was already wonderful,\nbut to be able to have a conversation like this...!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"So, the magazine you were looking at... was this one?\nHere, allow me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Thank you so much!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(That's right...! It's a rare chance to meet Kaoru-san, so I want to tell her I’m considering studying abroad...!\nIf I tell her, I might even get some courage from her...!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"U-um! Kaoru-san!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"What’s the matter?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Uh... well... um...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(Ugh... my heart’s racing so much that I can’t speak properly...\nI managed to tell everyone in Poppin'Party just fine, though...)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"odoodo02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"...Studying abroad is indeed a fleeting thing.\nI’ve experienced it myself, so I understand how you feel.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Eh, Kaoru-san, you’ve studied abroad before?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah, just a little, at Broadway.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(I didn’t know that... When did she go there?\nOh, maybe it was before she became a high school student...!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Broadway is the place where they perform lots of musicals and plays, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Indeed. It’s a place where countless artists and countless audiences gather.\nA city of dreams and entertainment that feels like one big stage!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Wow...!\nTo think you studied abroad in a place like that... as expected of Kaoru-san!\nYou must have had so many incredible experiences, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Truly, everything that happened there was an irreplaceable experience.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"There were language barriers, but what truly matters is your heart.\nAs long as you have sincerity, your feelings will be conveyed—that's something I came to understand firsthand.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Um... but wasn’t it hard being apart from everyone?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Of course, being separated from my friends was painful.\nThe pain of feeling like my heart was being torn apart is something I’ll never forget.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"But all of them supported me wholeheartedly.\nIt was because I didn’t want to waste their support that I was able to spread my wings and soar, even in a foreign land.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I see... so that's how it was...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"There were mornings when loneliness shook me, and nights when it felt like I might be swallowed by fierce waves. But living through those fleeting days filled with entirely new encounters became an irreplaceable experience in my life.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Through my journey in a foreign land, I was able to meet a new version of myself, allowing Kaoru Seta to evolve more than ever before.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(That's amazing...!\nI really want to study abroad too and meet a new version of myself!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(Even though I feel anxious...\nI still want to grow more and more...!)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(...I want Kaoru-san to hear these feelings too...\nBut to share this with someone like Kaoru-san, who's already achieved so much,\nI feel like I haven’t taken even the first step yet... So...)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Um, excuse me!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"What’s the matter?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"...If I ever figure out the path I want to take in life,\nwould you be willing to listen to my story?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Of course. I’ll be waiting eagerly to hear what you have to share, little kitten.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Thank you so much!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Sorry to keep you waiting, Kaoru-san. I thought I overheard something about studying abroad?\n...Huh? Rimi?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Misaki-chan!\nKaoru-san really is incredible, isn’t she...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Eh? Uh... yeah?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Like Kaoru-san, who confidently accomplished studying abroad on her own,\nI want to become someone with that kind of determination and initiative...\nNo, I’ve decided—I will!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Kaoru-san, thank you so much for sharing your valuable experiences!\nI’ll do my best! Well, see you later!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev254-ep2-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh...? Accomplished studying abroad...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"No, no, her 'studying abroad' was just a one-week trip! Hey, Rimi! Wait—!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Oh dear, she’s already gone so far away. Haha, such an energetic little kitten.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"...She definitely didn’t hear that, did she?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"So, what now? Looks like Rimi misunderstood something, though.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Hehe, as Shakespeare once said: 'Send your adorable children off to see the world.'","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Wait, isn’t that not a Shakespeare quote? Kaoru-san, next time you meet her, make sure to explain properly!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nnf03","expressionName":"sad03","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev254-ep2-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Hehe... The one who’ll be talking next time isn’t me.\nIt’ll definitely be... the kitten herself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev254-ep2-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":3,"costumeType":"003_casual-2023","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":3,"costumeType":"","motionName":"nf_right01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":3,"costumeType":"","motionName":"nf_left01","expressionName":"default","moveSpeedType":0},{"type":3,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":3,"costumeType":"","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual-2023","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":3,"costumeType":"","motionName"