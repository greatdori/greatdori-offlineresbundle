racterId":20}],"windowDisplayName":"Eve","body":"Is there some sort of ascetic training going on?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev56-ep2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"So, now that everyone's here, there's something really important I have to tell all of you!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev56-ep2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"H-Hina-chan...?\nWh-what's going on?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev56-ep2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"Eve","body":"S-something you'd like to tell us...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev56-ep2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{