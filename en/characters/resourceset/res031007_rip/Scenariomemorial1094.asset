ayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"LAYER-chan! Hi. Oh, Happy New Year.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Happy New Year. Are the two of you on your way to work?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"We are. CiRCLE's already open for business. What about you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":201,"voiceId":"ev137-me4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I'm on my way to practice with RAS.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"It sounds like you guys are already fired up right from the start of the new year~. You know, it happens every year, but New Year's sure does fly by.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Did you have a chance to go anywhere?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I did a New Year's shrine visit with LOCK and Masuki. It was my first time going with friends, so it all felt so new.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, I'd imagine so~. New Year's shrine visits are already exciting enough as it is because of all the people there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yes. We went to a nearby shrine, and it was really nice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"There were a lot of stalls because it was a large shrine. They even had an assortment of events. It was very lively.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"We were constantly talking about where to go next. Fufu...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah, we offered our prayers as well, of course. Standing before the spirits was really inspiring... It made me want to work hard again this year.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I see. That's how I felt when I went. There's something special about shrines, huh~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Oh, I also ran into Arisa-chan and Minato-san.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I heard about that. They did some work as shrine maidens, didn't they?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yes. I also ran into the members of Hello, Happy World! and Morfonica's Mashiro-chan and Tsukushi-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Wow, it sounds like you got to meet a lot of people right at the start of the New Year!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I did. I even got to chat with some of the girls I've never really talked to before.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Actually, before becoming a member of RAS, I never really had much of a chance to talk to people my age...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"That's what made this year's New Year's shrine visit feel so new. I got to speak to everyone and experience things I hadn't expected...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I hope I get to chat like that with more people this year.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah... I just realized I've been saying some pretty embarrassing things.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Not at all! I hope you can become closer with everyone.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Same.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Oh, I should get going. Goodbye, Marina-san, {{userName}}-san. I look forward to seeing more of you this year.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev137-me4-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Same here! Let's both make this year a fun one!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev137-me4-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutDa