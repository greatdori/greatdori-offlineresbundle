,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":45,"delay":4.400000095367432,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":46,"delay":8.300000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":39,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":47,"delay":2.5999999046325684,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":48,"delay":6.300000190734863,"isWaitForSkipMode":0},{"actionType":4,"progressType":1,"referenceIndex":49,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":40,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":50,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":41,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":51,"delay":4.699999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":42,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":52,"delay":2.5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":53,"delay":6.800000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":43,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":44,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":54,"delay":3,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":55,"delay":6,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":45,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":46,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":56,"delay":4.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":47,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":57,"delay":4.300000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":48,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":49,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Okusawa-san, great job at the Halloween event the other day.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Oh, were you at the show? Thanks for the encouragement. It makes it all worth it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"O-Tae and Kasumi were freaking out about going. Still, I must admit every performance exceeded my wildest expectations.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Ah, including Hello, Happy World!'s opening act, of course! How should I put this? It was the kind of show I'd expect from you guys.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"You went full throttle right from the beginning. I mean, you fired on all cylinders... Anyway, the crowd was really charged up.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Thanks. I guess that's kind of our specialty.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Man, it was awesome... A circus stage must feel pretty different from a regular stage, right? Was it hard to adjust?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"You could say that. The concert itself was a bit different from usual, but it was actually the lead-up to the show that was stressful...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Ahaha... I bet the circus would send Tsurumaki-san and the others into a frenzy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Well, actually... This time it was me who got us into hot water.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Huh? Really? That's hard to imagine...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"We decided to try making our own costumes, but I went ahead without properly checking everyone's sizes...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"On the day of the show, we realized Kaoru-san's measurements were wrong, and she probably couldn't wear it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"So we were stuck figuring out what to do. In the end, Kanon-san managed to take care of the problem for us.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"That does sound stressful...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"We make our outfits too, but it doesn't always go smoothly, so I know how it feels...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Still, it's a good thing it all worked out in the end.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Hmm, yeah, eventually. Nonetheless, I'm doing some serious reflecting.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"I'm worried I dumped the problem onto Kanon-san to fix...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"She had her hands full with the giant Michelle costume I requested, so it was on me to support her properly. I could've confirmed our sizes and done more...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"I've gotta be careful so we don't have blunders like that again.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"I see~... Hmm, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh? What? Did I say something weird?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Well, properly reflecting on stuff is very much like you, Okusawa-san. However... I don't think it's on you to shoulder all the responsibility.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh...? Y-you think so?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Poppin'Party has its fair share of problems, so I kinda get how you feel.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Sometimes, I think we could've avoided sticky situations if I'd just done a better job.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"But when troubles arise, our members come together to face them...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"We get through it because we have each other... Ah, you better not tell the others I said that!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Together...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Yeah. That's why I don't think you need to carry this alone, Okusawa-san.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Our bands are similar in that way. Although, I think Kasumi relies on everyone a little too much.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahaha. Our three dummies don't think too far ahead either. It makes me anxious at times.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"In our case, O-Tae will jump on board, and if Saya and Rimi follow suit, then it's out of my hands.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"I feel you... When those guys are in cahoots, they don't just add up, they multiply...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"That being said... I do feel less tense lately. Kokoro and the others are optimistic about any problems that come up.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"I was feeling guilty about the mistake... But maybe it's not good to be too down about it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Exactly! Being gloomy doesn't achieve anything! This stuff always works out in the end!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahaha, I guess you're right. It may be hectic, but it all works out somehow. Not to mention, we have Kanon-san on our side.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"When we're in a jam, she tackles it head-on. When I see her giving it her all... it gives me the motivation to do my best too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Maybe the reason we've triumphed so far is that my Hello, Happy World! bandmates are those kind of people.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Hm. I guess it wouldn't hurt to follow their example every now and then. I'm talking once in a blue moon here, except for in Kanon-san's case.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"That's one way of looking at it... But I think your practical point of view is really important as well, Okusawa-san.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh? Really?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Definitely. If everyone's going full throttle, you need someone to act as the brakes.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"People like me and you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahaha, that's true. If I let Kokoro and the others run wild, it'll end in mayhem.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Yeah, without a doubt. So let's keep working hard in our own way.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Okay. We'll remember to pump the brakes, just like we're supposed to do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev164-ep3-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Yep. The Break Alliance must stand its ground.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev164-ep3-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":5,"costumeType":"005_school_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":5,"costumeType":"005_school_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"015_school_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":15,"costumeType":"","motionName":"smile03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":