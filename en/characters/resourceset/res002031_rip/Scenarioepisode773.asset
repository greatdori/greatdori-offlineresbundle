":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Okay, let's rest for fifteen minutes, then get back to practicing!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"ev92-ep5-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"We said we were just gonna try and get through the new song before taking a break, but we really blew right through it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev92-ep5-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Yeah, we did. I'm so exhausted~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev92-ep5-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"But we sounded pretty good, don't you think?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev92-ep5-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Yeah! It felt like we were equally ready to take it on! Or that we had the same vibe going at the least!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"ev92-ep5-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Yeah, I know what you mean. It was kind of like at the parade the other day.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev92-ep5-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Ah, that's what I was thinking too. Like I was enjoying myself and didn't want it to end~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev92-ep5-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Ehehe, so you got the parade vibes? That's what I was going for~.","