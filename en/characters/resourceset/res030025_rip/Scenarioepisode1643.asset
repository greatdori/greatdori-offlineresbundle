,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":80,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":81,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":82,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":26,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":83,"delay":2.5,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":84,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":85,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":27,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":86,"delay":2,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"Rui-san, Happy Birthday! We all made a feast, so please eat lots!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"2022birthdayStory-030-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"... Come to think of it, today is my birthday. I had forgotten.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Ahaha. It's just like you were saying, Toko-chan~. Our surprise was a success~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayStory-030-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Right~? I figured she was gonna say that! By the way, I'm the one who made the simmered sea bream!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"2022birthdayStory-030-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"I have already prepared lunch for myself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Huh? Did you make your lunch...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"2022birthdayStory-030-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"In that case, you can just lay it out with the food we made, right? What'd you bring?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"2022birthdayStory-030-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"I have been having this for lunch as of late.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"\"Perfect Bread\"...? Ah, is this one of those nutritionally balanced meals? The ones where you can get all your nutrients for a single meal with just this...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"2022birthdayStory-030-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"Correct. Obtaining my required nutrients while reducing my meal time is a large merit.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Well, just forget that whole time reduction thing for today! Give the simmered fish I made a try! I'll try out that hard-looking bread.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"2022birthdayStory-030-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"I believe I said that aside from the time reduction, my goal is to get my required nutrients.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"If I share this with you now, it will cause an offset in my targeted nutrients for the day. As such, I have no intention of trading it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Don't worry about that! Today's your birthday, after all! Okay, I'll trade you my simmered fish for it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"2022birthdayStory-030-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"... It would seem you are failing to grasp my intent.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"2022birthdayStory-030-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Ahaha... So, Toko-chan. How does the Perfect Bread taste~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayStory-030-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Ugh, it's so hard! What is this?! It's seriously like steel! The flavor isn't bad, but it's kinda dry. Here, Shiro. Have a taste.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"surprised02","expressionName":"default","timingSyncValue":0}],"voices":[{