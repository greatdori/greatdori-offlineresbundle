Name":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"......","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"serious01","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"They say there's only two types of true artist out there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf04","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"One type is infatuated with just one single aspect. They spend all their time on it, and can do it and it alone. They cannot live without the music.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"serious01","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"The other type has abilities in all kinds of creative fields, and brings them together with their music to create their own unique world.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf02","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Rinko. I believe you are the latter.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf04","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Th-that's... I'm...!\n I'm... just...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"odoodo02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"episode098-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"It's rude to bring yourself down in front of people who truly recognize your ability, you know.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf01","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"I... I'm sorry...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"episode098-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"I hear you're quite the reader, too. You might well be the most creative mind in our band, you know.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"serious01","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rinko","body":"(I'm happy to receive these compliments, but... I'm just not sure it's true... But if I say that, she'll get mad again...)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":0,"voiceId":"episode098-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"... All I have is singing.\n There's no other way for me to express myself...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"sad01","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"To be honest... I felt a little envious when I saw these outfits. I was completely speechless.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf01","expressionName":"default","timingSyncValue":0},{"characterId":25,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode098-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"I'm sorry if... that gave you the wrong impression.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile03","expressionName":"default","timingSyncValue":0},{"characterId":25,