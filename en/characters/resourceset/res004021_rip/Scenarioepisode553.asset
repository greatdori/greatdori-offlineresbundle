renceIndex":40,"delay":2.200000047683716,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":41,"delay":4.400000095367432,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Here you are, Saya-chan.\nOne café au lait.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"... Ahhh, Hazawa coffee's café au lait is practically therapeutic~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Hehehe, thank you.\nDid you have band practice today?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Yep, and everyone was really fired up.\nWe didn't even finish until a short while ago.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Poppin'Party is like that, too? Our practice sessions have slowly been getting longer and longer as well.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Remember how I told you about our joint concert with Roselia? Since that day, it's as if a switch was flipped in all of our heads...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Oh yeah! You guys did have a show like that, didn’t you?\nI wasn't able to go, but... I really wanted to~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"There was no way of getting out of store duties that day. Sorry about that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I'm just glad to hear that you wanted to come! If we decide to do it again, I'll be sure to invite all of Poppin'Party.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"What about your band? Any performances scheduled?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Not any actual plans at the moment, no, but we've been discussing it since we have a new song we want to perform.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"You mean the downtown rally song?\nI've heard nothing but praise for it.\nAnd I'm a big fan, myself!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Fufu, hearing you say that means a lot.\nRimi-rin poured her heart into that song.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"It's not only me who thinks so.\nOur customers sometimes talk about it, too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Really?! That's great~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Things were different this time around. It was a song for the downtown district, not just a Poppin'Party song. Rimi-rin seemed a tad stressed out by it...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"So what you said is a huge relief.\nI'd better let Rimi-rin know~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Everything from the melody to the lyrics perfectly captured how much you all treasured each part of the downtown district when making the song!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Hahaha, Kasumi stopped by every day right up until the track was finished.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"My mother mentioned that, actually. \"I've seen Kasumi-chan around here every day lately...\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Oh, really? Hahaha, you could say Kasumi sightings have been on the rise around these parts.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"I'll have you know that her knowledge of this area had me shocked.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"The way she perceives things, everyday sights and sounds, is completely different from those of us who live here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"It's hard to say exactly how, but I've grown somewhat envious of her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Uh-huh, yeah. I think I know what you mean.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"The very fact that this is our home makes it so that we don't notice some of the things going on around us.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Say! How about the three of us take a walk through downtown sometime?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"That way, she can tell us about all the things we didn't realize we've been overlooking. Sound good? I think it might be interesting.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Oh, that does seem like a lot of fun!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Doesn't it? What would you say to inviting Tomoe and Hagumi, as well?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Mhm, those two would probably be interested!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Feels like some sort of downtown tour service.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Kasumi the Tour Guide~. That's one tour guaranteed to be filled with non-stop laughs.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Yeah, I could see it being a real treat.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Makes you wonder what Kasumi-chan's always looking at, doesn't it? I can't wait to find out!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Fufu, here's to working hard to uncover the secret of Kasumi's mystery downtown knowledge.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"ev61-ep2-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Okay! A few of those places are sure to be ones that we already know about too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev61-ep2-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx