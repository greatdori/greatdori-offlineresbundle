imingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"ev42-me1-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Oww~. Are you alright~? I'm so sorry. I couldn't see anything with all these books in the way~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"No, it's my fault for not watching where I was going... Wait, Moca-chan?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Huh~? Marina-san? {{userName}}-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"I'm really, really sorry~. Are you hurt~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"No. What about you, Moca-chan? I'm sorry. Now your books are all on the floor...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"It's not your fault. I was carrying way too many. I should have grabbed a basket~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Hang on, we'll help you pick them all up! {{userName}}-san, give me a hand!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Sorry for the trouble~. You didn't have to help me pick them all up, let along help me carry them home.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Don't worry about it. Books are heavy, after all. Besides, we're going in the same direction anyway, so let us help! Even if it is only halfway.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"You sure bought a lot though, and it looks like it's mostly manga. What's with the sudden shopping spree?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Ah, you see~, everyone in Afterglow was talking about manga the other day~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"And after hearing everyone talk about their favorite genres, I thought it'd be a good idea to expand my horizons and try reading something different for a change~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Like this sparkly shojo manga. Something like this is completely new territory for me~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"This here's more Tsugu's taste~. It's kinda refreshing, in a way.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Isn't that... about a girl aiming to be a manga artist? I've been hearing a lot about it recently.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Yup, that's the one. A story about a girl who, despite the uncertainties, tries creating an entertaining manga with the help of her trusted friends~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Wow~! Ah, now that I think about it, I heard from Himari-chan that you all tried to make your own manga.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"It's like you girls came straight out of that story!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"So you think so too, Marina-san~? Boy, who'd of thought that there'd be a manga about me before I even finish writing my own~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"By the way, I didn't just get shojo manga. I grabbed a few books that are a little more my style, like this one~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Ah, I'm reading that one too! The latest volume was so good!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Really~? I haven't read it yet, but now I'm even more excited~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"So you like that genre, huh? In that case, I've got a couple recommendations, although they're not super recent...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"I never thought I'd be able to talk about manga with you guys~. You both sure know your stuff~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Thank you for all your help. Sorry you ended up carrying these all the way to my house~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"It's fine! It was fun talking with you!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Ah, Marina-san! Any chance I could borrow that manga you were telling me about earlier~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Okay~. I'll bring it with me to CiRCLE so you can grab it whenever you'd like. Ah, did you want to borrow it too, {{userName}}-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev42-me1-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Yeah~, then we can talk about it together~. I can't wait.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"ev42-me1-031","volume":1}],"speed":0,"fon