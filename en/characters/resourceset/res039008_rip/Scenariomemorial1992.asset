:30,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":31,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":32,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":31,"delay":0,"isWaitForSkipMode":0},{"actionType":6,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":33,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":34,"delay":0,"isWaitForSkipMode":0},{"actionType":6,"progressType":1,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":0,"progressType":1,"referenceIndex":0,"delay":1.5,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Aww, I really wanted that surprise to work...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Still going on about that? You managed to do everything you planned, so that should be enough, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf04","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"If the person you're surprising already knew, doing what you planned doesn’t count as a success!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"I mean... was there really any need to make it a surprise in the first place?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Ugh, you don’t get it at all, Soyo-rin.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Surprises make everything more exciting.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"...You mean for you, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"For everyone! Everyone!\nBut maybe it was too hard for Rana-chan to keep it secret...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Was it really just Rana-chan’s fault? I’m pretty sure you were a big part of the problem too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Who was it that kept blabbing all the details of the surprise, hmm?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Ugh—th-that was...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"But like, even if you do notice the surprise, couldn’t you at least pretend you didn’t?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Haaah...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf04","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I mean, it was a birthday surprise, you know?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"It’s not every day someone does something like that for you, right? Would it kill you to play along just a little?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"...Listen, Anon-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"If you'd pulled it off a bit better, I might have pretended not to notice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"But with how obvious everything was? Yeah, that wasn’t happening.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf04","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Besides, I’d rather not be seen as someone who’d fall for something that blatant.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf05","expressionName":"serious03","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Yeah... fair enough...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I dunno, though—feels like none of us are really cut out for being the ones behind a surprise.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"At the very least, I can say for sure that Tomori-chan and Rana-chan aren’t.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Ah, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"thinking03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"...Hmm?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"You’d be so good at surprises, Soyo-rin!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Eh, really...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"I don’t really think I’m that kind of person...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"2024birthdayMemorial-39-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"No, no—I'm sure of it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"You’re totally the type! I mean, you lie so naturally!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"2024birthdayMemorial-39-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"A