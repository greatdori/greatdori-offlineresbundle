ya","body":"I'm Saya Yamabuki.\nI'm Poppin'Party's drummer.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"It's been some time since our band was created, but we have such a good time when we're together.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"We may be the upperclassmen now that we've moved up a year, and we might end up busier than we were before, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Besides that, I think everyone's pretty much the same.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Fufu, I mean that in a good way, of course.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"I've had another chance to think about this with everything changing around us, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"It's actually amazing that we can continue to spend time together like we always do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"So I wanna cherish this time from the bottom of my heart! ... Heh, I'm just playing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"That'll be all. Again, I'm Saya Yamabuki from Poppin'Party!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"introduce-saaya-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":4,"costumeType":"004_school_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":4,"costumeType":"","motionName":"nf04","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":4,"costumeType":"","motionName":"nf05","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":4,"costumeType":"","motionName":"nf03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":4,"costumeType":"","motionName":"nf05","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":4,"costumeType":"","motionName":"smile04","expressionName":"default","moveSpeedType":0}],"specialEffectData":[{"effectType":8,"stringVal":"Riverside","stringValSub":"","duration":0,"animatio