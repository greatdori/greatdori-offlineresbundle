"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev237-ep3-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"I have to get my act together by the concert, or else I really will end up being a burden to everyone.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev237-ep3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"(... What can I do though...? There simply is no way I can talk about my feelings to anyone... or CHU²-sama for that matter...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev237-ep3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Heya~, PARE-PARE!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"ev237-ep3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"What? Macchii-san!","tention":0,"lipSyncM