ype":1,"referenceIndex":0,"delay":2.299999952316284,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"MASKING & LAYER","body":"Hey, 'sup.\nMorning.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":31,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"ev163-ep4-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Morning. You two are pretty early.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Just woke up earlier today. Figured since I was already up, I'd get here before practice and play a little.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Same here. CHU², you're early, too, aren't you? You're usually sleeping right up until practice starts.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I thought of something I'd like to try in our next show. I'll tell you about it later.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"C'mon, what's so important that you can't tell us now? Hehe. Now I'm really excited for practice!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah, that reminds me... CHU², have you seen this?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"... That's the article about Roselia signing with a music agency, right? Yeah, I've seen it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Hey, I thought you two were going to put in some extra time before practice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I'm going to be working on something until practice starts. Let me know when LOCK and PAREO get here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"MASKING & LAYER","body":"...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"serious01","expressionName":"default","timingSyncValue":0},{"characterId":31,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"ev163-ep4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"What? Why are you looking at me like that?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Guess I was expectin' something else...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yeah. I thought for sure you'd be really angry hearing that Roselia joined an agency.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I couldn't care less. RAS does its own thing, and so can Roselia.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"The only thing we need to focus on is performing our music.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"... Are you sure you're okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Drop it already. I'm fine.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Yeah, right. Quit lyin' through your teeth, Choo-choo~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I-I told you to never call me that!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"So, how do you really feel about it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Like I said, I do not care...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"... Well, I'm certainly not happy about it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"See~? I knew it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"That Yukina Minato turned down my offer to produce Roselia!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"And then she goes off and gets somebody else to produce the band... What the heck kind of sense does that make?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Oh~, so that's what's eatin' you, eh?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Roselia pickin' someone over you to produce them has got you all jealous.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"No! I am not jealous! I just don't like it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Well, you've got us, so quit your poutin'~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"If I have to tell you one more time~...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Enough about me. Roselia is trying to become a professional band. Do you have any idea what that means?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Roselia is probably-... No, most definitely will knock the quality of their performances up a notch or two!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf05","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Most likely. You can't put on half-hearted shows if you want to survive as a professional artist.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"To crush Roselia, RAS is going to have to work harder than ever.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Our next show is going to be our first step toward doing that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Our next performance will have so much impact that Roselia's major debut show won't even be a blip on their radar. The whole world is going to know RAS's name!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yeah, we'll make it an epic show.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Right on! Let's do this!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":33,"voiceId":"ev163-ep4-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Good. I thought you'd say something like that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"But still.. Fufu... CHU², you really do like Roselia, don't you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"What?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"You said you don't care about them, but it sounds like you believe that Roselia will make it as a professional band.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev163-ep4-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I don't believe that!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Don't misunderstand me. Now that Roselia has stepped into the arena with all the other major bands, they're going to-","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"ev163-ep4-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Good morning~♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev163-ep4-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"G-good morning. Um, is everything okay...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev163-ep4-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"I could hear CHU²-san's voice from the other side of the door...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"ev163-ep4-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"No fighting, okay~? We'll be in big trouble if CHU²-sama's cute voice gets scratchy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev163-ep4-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"Nobody's fightin'.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"ev163-ep4-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,