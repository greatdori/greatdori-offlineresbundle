referenceIndex":33,"delay":4.199999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":27,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":34,"delay":1.7999999523162842,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":28,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":35,"delay":1.7000000476837158,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Ah, hey there, Misaki-chan~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ah, Marina-san. Hello.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu. It's nice to see you in a good mood again.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"...? What do you mean?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Ah, sorry! I was just thinking how much happier you look than the last time I saw you here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh? Was I really that gloomy?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Yeah, {{userName}}-san and I were kinda worried something happened.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Is that so...? \nI'm sorry about that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Oh, no, it's fine!\n... Can I ask if something happened though?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Well... I had a fight with my mom that day.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Gotcha... Did you already make up?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Yeah, we're fine now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"She mistakenly donated a book of mine to the library. And it just so happened to be a book very important to me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"I see... That would certainly cause a fight.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"It was partially my own fault, though. I just had it lying around. It makes sense that she thought it was something I didn't need.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"At the time though, I really didn't want to go home, so I asked Kaoru-san if I could stay at her place.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Kaoru-san's, huh...? I wouldn't expect you to go there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahaha, neither would I. \nKaoru-san didn't say a word though.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Everyone was really concerned. Which I'm glad to know they care, but it kinda made things harder for me....","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Yeah~... When you're feeling down like that, it's hard to deal with people worrying about you all the time. Sometimes you just want someone who will let you be.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Exactly. I think that's the kind of person I needed in that moment.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"And that just so happened to be Kaoru-san. She'll be whatever someone needs or wants of her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, I'm sure that's part of Kaoru-san's appeal.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Yeah, I think you're right.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"She really helped me out this time. I should find some way to thank her, but I don't know... It's kinda embarrassing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu, well, I hope someday you can tell her how you feel.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"It might take me a while, but I'll try... Ah, sorry, I didn't mean to keep you for so long.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Don't worry about it. Feel free to talk to me anytime.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev67-me2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Will do. Thanks for listening.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev67-me2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":201,"costumeType":"201_casual","motionName":"","expressionName":"default","moveSpeedType":0},{"type":1,"sideFrom":0,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":201,"costumeType":"201_casual","motionName":"","expr