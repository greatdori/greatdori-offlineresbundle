":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":21,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":18,"delay":2.4000000953674316,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":19,"delay":6.199999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":20,"delay":3.5999999046325684,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":21,"delay":3.5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":22,"delay":5.5,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":25,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":25,"delay":3.4000000953674316,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":26,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":27,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":26,"delay":2.200000047683716,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":28,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":27,"delay":2.5999999046325684,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":29,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":28,"delay":2.4000000953674316,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":30,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":31,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":32,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":33,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Ah, Arisa-chan! On your way to rehearsal?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Marina-san, {{userName}}. Hey. I was about to do some shopping.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"What a coincidence~. We're on our way to do the same thing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Oh, how about that. Since you're together... does that mean you're buying something studio related?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Correct! We have many items that need restocking due to maintenance and other things.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"On a separate note, Arisa-chan, you're part of the student council now?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Wh-wha-...?! H-how did you...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Misaki-chan told us~. About how hard you're working and whatnot.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"I wouldn't go that far...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Fufu. Come now, don't be modest. The student council is pretty tough, isn't it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"You could say that... Every day is way more exhausting than I thought it'd be.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"And it's not only the work. Being surrounded by unfamiliar faces makes me nervous...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Ah, I can understand that. Trying to open yourself up to others in a new environment can be stressful.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"But wait, isn't Rinko-chan the student-council president?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"You both play the keyboard in a band, so I figured that'd help you adjust quickly.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Nope, that was no picnic, either.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Huh? Really?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Yes, really. Whether it was because we're shy or we were being too careful with our words, we just couldn't speak to each other normally...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"But thanks to Sayo-senpai, Kanon-senpai, and Okusawa-san, it somehow worked out.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Then again... I guess I still get a little nervous occasionally.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"It takes time. So long as you're able to speak more calmly than before, that should be good enough.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Thank you for saying that. I think you're right... After what happened, I feel like I understand Rinko-senpai a little better than I used to.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"I've come to find that she takes things very seriously and never gives up...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"She's an amazing person who will always confront what she views as her own shortcomings.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"If I were put in the same position, I doubt I could do that... Still, I intend to do everything I can to help her out.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"... What a wonderful relationship. I'm certain that Rinko-chan harbors the same feelings for you, Arisa-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"That sure would be nice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Once I've become a little less nervous around her, I'd like to try talking to her about music.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"Marina","body":"Sounds like a good idea! Come tell us all about it once you do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev76-me1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"I will. Promise. Not sure when that'll happen, though.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"ev76-me1-030","volume":1}],"speed":0,"fontSize":0,"whenFin