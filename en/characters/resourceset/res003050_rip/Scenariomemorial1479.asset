ame":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"I knew it~! That's Honetsuki Karubi-chan, isn't it~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayMemorial-003-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Wait, you know, Nanami-chan...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Yes, because I just started collecting it~. It's interesting to see meat as characters, don't you think~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayMemorial-003-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Wow...! I recently got into collecting the series too! Honetsuki Karubi-chan was the only one I couldn't get...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"shame02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"I see~, you finally completed the series then~! Congratulations~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayMemorial-003-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Ehehe, thank you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"shame02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"This one's a bit special for me because it was the last one I needed... but that's not the only reason.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"You see, it was my birthday the other day... so my bandmates helped me get it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Oh~! Then that makes it a symbol of your friendship and high school life~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayMemorial-003-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Fufu, I guess so. Maybe I got it thanks to everyone.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"shame02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"I'm sure they're the reason~! And on your birthday too! It feels like destiny~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayMemorial-003-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Yes, I think you're right...! I was so happy. That's why I'm hanging it from my bag.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"shame02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I have to say, though, I never thought the day would come when I would be into capsule toys.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"2022birthdayMemorial-003-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"... Hm? That's a capsule toy?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"2022birthdayMemorial-003-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"What do you mean? There should be capsule toy machines here and downtown...","tention":0,"lipSyncMode":1,"