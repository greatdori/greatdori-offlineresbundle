"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":51,"delay":2.4000000953674316,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":29,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":52,"delay":4,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":53,"delay":6.300000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":30,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":54,"delay":2.4000000953674316,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":31,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":55,"delay":3.299999952316284,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":56,"delay":6.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":32,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":57,"delay":2.200000047683716,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":58,"delay":4.099999904632568,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":59,"delay":6.300000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":33,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":60,"delay":5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":34,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":35,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":61,"delay":2,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":62,"delay":5.300000190734863,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":63,"delay":7.599999904632568,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":36,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":64,"delay":4.199999809265137,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":37,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":38,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":39,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":65,"delay":3.700000047683716,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":40,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":41,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":66,"delay":2,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Wow~, I can't believe there are this many types of roses~! Gardening is so interesting~... Wait, this isn't right.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I got completely distracted by this gardening stuff... But, hmm~... This isn't really doing it for me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"... Yes? Someone said my name...? Oh, {{userName}}-san!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"What a coincidence, seeing you here~♪Here to buy some band magazines?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"bye01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Oh, this? It's a magazine on how to grow roses. It caught my eye, so I gave it a quick read, but it seems to be a bit different than the image I was hoping for☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Yeah... Well, actually... It's not so much that there's something I'm looking for. It's more like I'm looking for something that I want to look for, I guess...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"But I can't really find anything that makes me think, \"This is it!\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I did think that this might be the one after seeing the picture of the rose on the front cover. Sigh, time to look for a different book...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"... Ah, sorry. I know all of that probably sounded odd to you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"The truth is I tried my hand at writing lyrics the other day, but I was worried about what theme I would use if I decided to write another song.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Ah, surprised, huh? Ahaha, of course you are! Here I am, suddenly writing lyrics☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"One of the reasons I decided to give it a shot was that I thought it was a way for me to support Yukina... and Roselia more.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Though, when I actually tried, I couldn't even write a word~! It was super hard!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Have you ever written lyrics? No? Yeah~, I hadn't either!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"That's why I went around asking people how they go about writing theirs. I talked to Ran, Kasumi, Kokoro and Misaki!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"As for Yukina... I didn't want to rely on her. Depending on the person you want to help is just... kinda wrong, don't you think?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"But actually, it wasn't only Yukina I didn't tell. I kept it a secret from everyone in Roselia. Yep, the main reason was that I wanted to surprise them! Ahaha♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"The way everyone writes lyrics? So Ran, Kasumi, and Kokoro and Misaki all have completely different methods~! Isn't that interesting!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"So I thought I'd figure out my own way of doing things by learning from them♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Kind of like the best of all worlds, ahaha☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"And with that, I kept in mind everything I heard from them, and I was able to finish a song...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I took that song and entered it into a contest... Hm, wait... I didn't mention the lyric-writing contest?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I just happened to come across it when I was looking up how to write lyrics on the internet! Apparently, it's a relatively competitive international competition.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Though~... I did end up losing...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Oh man, I didn't even stand a chance. I took a look at the winner's submission afterward, and it was amazing. My lyrics were nowhere as good.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"But writing itself was really enjoyable, so I'm glad I did it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Huh? No, there's nothing incredible about that! Besides, isn't trying out new things fun?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"If you seriously challenge yourself, you can discover so many new things♪ Wouldn't we call that growth? And it really gets the blood pumping, doesn't it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"That's why I think just challenging yourself is really important!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"That's what I felt when I tried writing lyrics. And for that reason, I want to keep writing as well!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Even Yukina said she'd like to see me continue trying♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Ahaha, thanks for your support~♪ I'm gonna keep doing my best so that one day, we'll be able to perform a song that I wrote!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"And I'll show you! I'll create something that the members of Roselia, other bands, the contest judges, and even you acknowledge☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"But first, I need a little help, {{userName}}-san. What do you think would make a good theme for my next song?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Ah~, yeah. I already used Roselia as the theme for my first song...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Ah, yeah! Different faces of Roselia... For example, where we're headed or something like that could be interesting!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Alright, then what about forming of friendships...? In which case, short novels about youth would be a good reference point!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Thanks, {{userName}}-san~! That was a really helpful hint!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I'm gonna go take a look!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"The bookstore in front of the station will have so many more books than this place!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"I'm sure if I go there, I'll be able to find something☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"You were a big help today! Thanks! Alright, see ya later!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"wink01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"memorial221-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundRefe