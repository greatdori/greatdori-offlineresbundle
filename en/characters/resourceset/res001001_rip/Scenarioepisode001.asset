speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"We have Rimi-rin on the bass, Saya on the drums, Arisa on the keyboard, and O-Tae on the guitar.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"And me? I am a guitarist and lead singer!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"You know, when I was younger I used to look up at the night sky, and I could hear the beating of the stars.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"I thought, \"I want to have that sparkling and heart-pounding feeling one day!\" I felt that way for a long time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Then, the first live show I ever saw was so sparkling.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"And I thought to myself, \"I want to be in a band too!\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Which is why I enjoy being a part of Poppin'Party so much!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Then I can be all like bwoww! With Random Star, my red hot guitar.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"We'd love for you all to come and see our performance!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Hope you'll always support me and Poppin'Party!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"episode001-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":1,"costumeType":"001_casual","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":1,"costumeType":"001_casual","motionName":"nf04","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":1,"costumeType":"001_casual","motionName":"jaan01","expressionName"