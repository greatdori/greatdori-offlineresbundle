erenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"What's wrong, Kanon-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"urafes-KR-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Oh, no. We forgot to buy drinks...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"urafes-KR-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"I'll go buy some for everyone! There's a store over there!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Five drinks for one kitten would be far too much a burden. Let me accompany you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Thanks, Kaoru-kun!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah... Such towering, gorgeous clouds grasping towards the heavens... And radiant shades of autumn foliage beneath our feet... How fleeting...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Hah! Hmph! Yah! ... Ehehe, I got one!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ahh... The sight of Hagumi, trying her hardest to capture the leaves as they dance so mischievously around her is also quite fleeting...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... Hm? Oh, my...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"What is it, Kaoru-kun?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Gaze upon this, Hagumi. A chestnut.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Wow, you're right. They really hurt if you pick one up and get poked by the thorns~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Hm. Indeed, their rather fearsome appearance does dissuade one from attempting to near, but beneath that thorned shell lies a kindly, sweet interior.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Ah...! You're right, chestnuts do taste really good, huh?! I really like eating chestnut rice!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Yes. That gentle, warm-hearted flavor of chestnut rice is completely at odds with the rather rugged individual before us now... But that bashful nature of yours is also so fleeting.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Oh, I get it~. So they're just shy! I never knew~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Letting my imagination run wild at the thought of such fleetingness, hidden from the naked eye... Yes, that is how I, Kaoru Seta, enjoy autumn.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Wow, wow! I never thought about having fun like that!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu... Fleetingness is found in the little things, after all.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah... And what do we have here? Hagumi, do you see what is hidden underneath this fallen leaf?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"It's... a mushroom? Is it a matsutake? Or maybe it's a shiitake.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"No matter what kind of fungi it may be.. It is quite yellow, is it not?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Yeah! It's super yellow!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"It takes quite a long time for a mushroom to be able to gain such a deep shade of ochre.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Perhaps this little kitten also wished to become as beautiful as the leaves cascading around it someday... and we are witnessing the fruits of its efforts now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah... To think of all the blood, sweat, and tears, all of the time this little mushroom spent... It sends the heart aflutter.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Oh, totally! I tried really hard for a long time to get to the point where I could fry croquettes the same golden-brown color as my dad! I know just how this mushroom feels!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... Gasp! Hagumi! Just now, the muses have deigned to strike me with poetic inspiration. Would you lend me your ear?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Sure! Go for it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"\"Through fields of gold I walk with a friend\nWhere a single beautiful blossom is found\nA croquette-colored mushroom so fleeting...\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Wow, wow wow~! I'll think of a poem, too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"\"Mushrooms really like, hiding under fallen leaves, that is where they grow!\"\n\"My dad's croquettes and all the leaves around us are, pretty golden-brown!\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ahhh... Such fleeting verses... Hagumi, you are truly a wonderful poet.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Really?! Yay~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"With each little piece of autumn we discover, I feel ever more fleeting and fleeting. Wouldn't you agree?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Yeah! It's like when I'm with you, fall is way more fun than ever!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu... You honor me with your words.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Oh, I've got an idea! As thanks, I'll teach you one of my favorite things about fall, too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Uh~, let' see~... Ah! Over there!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Hagumi? Where art thou headed?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Found some~! Okay, get ready, aaand~...! Jump~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Yaaay~! It's so soft~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu... What a mischievous kitten you are. But come now, you will dirty your clothes. Can you rise?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"C'mon, Kaoru-kun! You too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Huh? Wha- Wh-whoa?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"See? Doesn't this feel good?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... Yes. Yes, it does. Fufufu.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"If you lie down like this on a nice soft bed of leaves, it really makes it feel like fall's here!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Indeed... It is almost as if one is experiencing autumn's presence with the whole of their body.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"The gentle caress of the sun's rays... The sea of blue sky above... it all feels for some reason greater, vaster than when we were simply strolling around.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Yeah! It's nice and cushiony, like we're floating in the sky.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Yes... It's quite invigorating... I've not experienced this side of autumn before.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu. Being with you makes autumn much more enjoyable for me, as well.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Really?! Ehehe, that makes me really happy to hear~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"C'mon you two~, what are you doi-... Whoa, what're you lying there for?! That's the ground, you know?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"urafes-KR-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Why, we are experiencing autumn together. Would you care to join us?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"urafes-KR-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Oh, that sounds great! Sure, I'm in! Yay~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"urafes-KR-063","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Wow, all the leaves are falling down like snow! Come on, Kano-chan-senpai! You too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"urafes-KR-064","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Ah, Hagumi-chan, don't pul-... F-fuee...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"urafes-KR-065","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"H-hey, Kanon-san, are you alrig-... Wahh?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"urafes-KR-066","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"You were right! Looking up at the sky together with everyone like this is a lot of fun!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":11,"voiceId":"urafes-KR-067","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu. Kokoro, it seems a strikingly crimson leaf has found its way atop your precious little nose.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-068","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Oh?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":11,"voiceId":"urafes-KR-069","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Pfft. What the-... Ahaha!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":15,"voiceId":"urafes-KR-070","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Kokoron, you look like a reindeer!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":13,"voiceId":"urafes-KR-071","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Fufu... You really do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":14,"voiceId":"urafes-KR-072","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah... Truly, autumn is many times more pleasant when I am with all of you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":12,"voiceId":"urafes-KR-073","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_kirameki_festival","motionName":"","ex