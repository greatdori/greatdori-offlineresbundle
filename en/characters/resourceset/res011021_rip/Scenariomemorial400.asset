otions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"I'm right in the middle of looking for someone who fits that description!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"And I thought since they look like me, they would obviously be in the park! So here I am!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Huh? Why am I looking?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Well~, I heard that someone who looks exactly like Misaki came to our last show!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"I didn't see her, but Hagumi and the others said they did!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"After hearing that, I wanted to meet a clone of my own.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"{{userName}}, have you ever met someone who looks like you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"I'm pretty sure they say that we all have a bunch of look-alikes around the world.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"And still, I haven't met anyone who looks like me. Not once!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Now I really wanna meet them!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"jaan01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Yeah, of course I know what we'd do if we found each other!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"I have the greatest plan for us.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"This other person and I will take the stage and perform together!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"They do look like me, right? So they must be thinking the same thing—that they want to put on a show with me!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Exactly right! The person who knows the most about someone who looks like me... is me!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev36-me4-019","volume":1}],"speed":0,"fontSize":0,"whe