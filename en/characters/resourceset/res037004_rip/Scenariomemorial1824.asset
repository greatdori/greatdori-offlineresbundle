terId":37,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Anon-chan? What's wrong with you, staring at your phone?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Wah! Ah... Ririko-san and {{userName}}-san! Please listen to me~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Fufu, what's wrong?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I want to make our costumes gorgeous and celebrity-like this time, but Rikki and Soyorin shot down all my design ideas.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I was looking for a design that they would be okay with. What do you think about something like this?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Let's see...? Wow, the back is so bold and open, it's really nice!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Right!? I think I'd look great in this type of dress.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"This kind of design is great, but I also really like the outfits you all wore at the live show.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"It was casual, but it was very cool and unique.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Ehehehe, thank you very much! I designed that one myself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"wink01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"At first, I was told that it was unnecessary, or that it was impossible when I proposed the design.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"But I thought it would be better to have a costume! That was one thing I couldn't compromise on.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"The production period was very short, and it was a lot of work. But we talked with everyone and managed to complete the costume.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Afterglow even praised our costumes on the day of the show, so I'm really glad we made it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"smile02","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Yes, it really was perfect, I think it left a strong impression on everyone.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"I think it was Anon-chan's policy of not compromising that made it a great costume.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Yes, yes, that's right! There are so many points of particularity in the costumes.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf02","expressionName":"kime01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-ssr-anon-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"I hope you will continue to pursue your ideals with a firm policy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"memorial-ssr-anon-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"r