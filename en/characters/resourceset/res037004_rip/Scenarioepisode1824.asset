rePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"......","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Can't we do better like, makeup and stuff?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... What?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"That's what you wanted to talk about?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"serious03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"episode-ssr-anon-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Sigh... What a waste of our time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"sigh02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"No, no, no, it's an important topic! We got a really cute outfit, but we need to work on the makeup to go with it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf01","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"If we want more people to notice us, I think it's important to look good on stage.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"If we're going to spend time on that, I'd rather we practice more.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"episode-ssr-anon-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"I'm not in this band to get compliments on my appearance.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"That's true, but!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Tomori, you don't need to listen to Anon so seriously. Let's go practice. And eat your parfait quickly, Stray Cat.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I want to listen. If that's what Ano-chan has been thinking about, I'd like to hear it...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"episode-ssr-anon-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Tomorin~! You're the only one who gets it~\nYeah, yeah, Tomorin is the best!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"kandou01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"So, let's get to the recommended cosmetics,\nNyamuchi made a video of her latest cosmetic recommendations, which you can watch for your reference...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Nyamuchi? Who is that? Is that a name?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nnf03","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"What, you don't even know Nyamuchi!?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"She's the girl who often posts makeup videos. My classmate said she was into it and showed it to me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"episode-ssr-anon-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"As expected of Soyorin. She's been really popular these days. You should remember that, Rikki.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Tch...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nnf_left01","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"She clicked her tongue! How scary!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"What kind of cosmetics do you recommend?...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf04","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"episode-ssr-anon-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I'd start with the base. The one from this manufacturer. It's a cheap price, but it doesn't fall apart easily, and it's waterproof. It can also be used to tone up the skin!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Next is mascara! This is also waterproof, so it seriously won't come off even with sweat or anything! But it can be removed with hot water, so it looks easy to use.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"And then there's this fixing mist! If you put this on your face after putting on makeup, it makes a big difference in the resistance to breakdown!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"As someone who performs on stage, it's important to keep your makeup from falling off. It's so hot on stage that you get sweaty.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"I've been wondering about this fix mist myself. I heard it's recommended by Nyamuchi, so maybe I'm a good judge!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... Stop.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nnf04","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-ssr-anon-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"What? What's wrong?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-ssr-anon-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Look at Tomori-chan's face.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"episode-ssr-anon-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Water... inexpensive, tone up...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"sad04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"episode-ssr-anon-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundR