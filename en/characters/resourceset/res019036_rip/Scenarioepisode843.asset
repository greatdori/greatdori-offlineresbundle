ult","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev104-ep1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"Um, aren't we going to the buffet place and the boomin' burgers place? I hope there's something fun we can do nearby~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev104-ep1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"Maya","body":"That's what I was thinking, so I started looking into it, but... I haven't found anything worth mentioning.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev104-ep1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"And we can look at clothes in the mall whenever we want anyway.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev104-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"Eve","body":"Since we are all going out together for the first time in a while, it would be nice to go somewhere different for a change.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev104-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Then why don't we broaden our search a little? We might find something good.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev104-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"Yeah, let's do that! Err... Ah, what about this?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev104-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"Here, look at this website! It says you can make your own accessories.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev104-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"Maya","body":"Like an accessory workshop? These kinds of activities are pretty fun to do every once and a while.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev104-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"Eve","body":"Nice one, Aya-san! I want to make matching accessories with you all!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"ev104-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"I'm glad I could be helpful~. So, if Hina-chan's okay with this, should I book it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev104-ep1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"It does look rather interesting, but... it's a little far.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev104-ep1-021","volum