:0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Hello, Tomori-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"bye01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Hello, Ririko-san, {{userName}}-san...\nUmm... We're having practice, afterwards.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I got here a little early. I'm just waiting for everyone...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Now you mention it, you did have a booking today. Good luck.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Thank you very much...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"By the way, it's raining again today. It's been hard lately with so much weather like this.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Rain...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Um, Ririko-san, do you like... rain?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Hmm. I have to use an umbrella so one hand gets taken up, and my feet get wet, so I don't really like it. What about you, Tomori-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I don't... I don't like it either.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Rain... I don't have very good memories of it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"sad03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"I see... So that's why you hate rain.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nnf03","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I was talking about that with Soyo-chan the other day... And she said... she felt the same way.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"That made me feel a little bit happy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Soyo-chan is very human to me. She has many different versions of Soyo-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Many different versions of Soyo-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"A kind Soyo-chan, an angry Soyo-chan, a Soyo-chan who is good at playing Old Maid, a Soyo-chan who is bad with something... But her many different characters, is what makes her human.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Among those things, she has a bad memory of rain, so there is a Soyo-chan who hates rain.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I was so happy... to know that we felt the same way.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"I see. So you and Soyo-chan were able to empathize with each other.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Yes. And besides, I had a thought.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I feel like... I could sympathize not only with Soyo-chan, but with everyone at MyGO!!!!! as well…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I'd be happy if I could find more and more... about such parts.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"Yeah yeah. As you get to know everyone else's different sides, you could understand each other in a way you never expected.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":225}],"windowDisplayName":"Ririko","body":"If you continue to build on that, I guess you can become an even better band than you are now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":225,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":225,"voiceId":"ev250-me2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Yes, I... think so too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I want to search for everyone else more and more.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"ev250-me2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1