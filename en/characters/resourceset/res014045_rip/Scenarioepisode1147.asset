:0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":39,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":109,"delay":3.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":40,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":110,"delay":1.7999999523162842,"isWaitForSkipMode":0},{"actionType":4,"progressType":1,"referenceIndex":111,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":41,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":112,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":42,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":113,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":114,"delay":0,"isWaitForSkipMode":0},{"actionType":7,"progressType":0,"referenceIndex":1,"delay":0,"isWaitForSkipMode":0},{"actionType":0,"progressType":1,"referenceIndex":0,"delay":1,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Everyone, the park owner got us all some juice. He said that we did great today and that our show was wonderful.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"My! I was just thinking about how I was a little thirsty! Let's all tell him thank you later!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev145-ep5-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Yeah... But first, I need a break... Ah~, this bottle feels so cold... I feel like I'm being brought back to life...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Like a rainstorm blessing the parched earth with its grace. What other words are there with which I can describe this, other than supreme bliss...?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev145-ep5-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Yay~! I wanna drink, too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev145-ep5-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Seriously though, when you said you wanted to do something here after our show, I wasn't expecting us to do a talent show for everyone...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Ahaha... Still, Kokoro-chan's skills were one thing, but you're getting pretty good too, Misaki-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Yeah, I managed to juggle five balls at once, even inside Michelle... What am I doing with my life, honestly...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Well then. Post-intermission, I was thinking of performing a show... How does some improv theatre sound to everyone?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev145-ep5-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"I'm in! And after that, I want to have a softball tournament!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev145-ep5-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Those are fantastic ideas, you two! I'm sure they'll bring lots of smiles to our guests!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev145-ep5-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Sigh... You're all still full of energy, huh...? No one would ever guess that we just finished a concert...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Ahaha... But it was a good show, wasn't it? We managed to entertain so many people.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"True... It was so packed, you'd never believe that this place used to be almost deserted.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Yeah. It was featured in a magazine before, too. This place has really become popular.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"And all of the park attendees have positively glowing smiles on their faces now compared to the days of old.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev145-ep5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Yes! No matter where you look now, it's become a park full of smiles!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev145-ep5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"When I saw all the kids having fun riding the horses on the merry-go-round, it put a big smile on my face too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev145-ep5-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu. It is a merry-go-round of fleetingness, after all. I'd expect nothing less from it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev145-ep5-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"It's really something to actually see that we're making even a little bit of a difference here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Fufu, I know what you mean.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"When I was making the Hello, Happy World! Smile Map, it reminded me of all the things we've done so far.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Like the Fluffy Mascot Competition, or when we all helped Hagumi-chan with her softball practice...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"We even helped an entire country celebrate their festival, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Fufu, we've been through a lot, but no matter what, when I see everyone's smiles in the end...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"It makes me glad that Hello, Happy World! exists.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"I will admit, looking at this map, our strange adventures did make for some fun memories.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"I think so, too! Doing our best to bring smiles to everyone ends up making us smile, too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev145-ep5-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"That's why I want Hello, Happy World! to keep on helping everyone smile!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"ev145-ep5-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu, truer words have never been spoken. And there is no doubt in my mind that there are still countless kittens out there waiting for us.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev145-ep5-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Our job isn't changing anytime soon. Hello, Happy World! is going to keep going until we bring smiles to the entire world!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev145-ep5-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"The entire world, huh...? Considering what happened with the Kingdom of Happinelle, that's beginning to sound less and less unrealistic.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Fufu, the next Smile Map I make might actually end up being a world map.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"What's scary is that's actually believable...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Mmm! Looking at Kanon's map has got me feeling all bubbly inside!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"oowarai01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev145-ep5-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"Let's go, everyone! Follow me!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"ev145-ep5-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"Hagumi & Kaoru","body":"Yeah!!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile02","expressionName":"default","timingSyncValue":0},{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"ev145-ep5-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh? Wh-, hey, you three! Where are you going...?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Ahhh, and they're already gone... Looks like Kokoro's extra motivated today... Hm? Wait, no, she's always like that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Fufu, let's follow them, Misaki-chan! They'll leave us behind at this rate.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"ev145-ep5-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"... Wait, what? Kanon-san, you seem extra motivated today...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Hmmm... Well, whatever. I guess I can follow along for today. Let's go, Kanon-san.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"ev145-ep5-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"s