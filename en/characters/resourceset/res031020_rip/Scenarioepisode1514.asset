eWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Look, I got some instant yakisoba.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Oh, how nice! Sometimes I get the urge to eat yakisoba~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Same here. There's still some time before rehearsal starts, but do you mind if I eat here?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Of course not. I was just thinking of getting some refreshments myself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Why don't we share this instant yakisoba, then? It's a bit too much just for me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah, maybe CHU² would like some too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"CHU²-sama said she would be napping until it is time to start our rehearsal. It may be best not to wake her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Oh, okay. It'll be just us, then.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Thank you. I would love to share it with you♪ I will go and boil some water.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"... That was good.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Sigh~, it was delicious~. Now I think I will have the energy to play until nighttime♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"You look so happy. I didn't think you would like stuff like yakisoba and fried rice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Why is that...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I just always imagined you eating nothing but macarons and strawberry shortcake.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Because, well... everything about you is so cute.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"I am so honored that you think that♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"But, you know, I think it is difficult to imagine what you would normally eat from the impression you give off on stage, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Because on stage, you are RAS's ever-so-cool LAYER-sama♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"LAYER-sama...? I guess it's nice if our fans do see me that way, though.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah... That reminds me, I wanted to ask your opinion about my performance.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"If it pleases you, I would be more than happy to offer you my opinion!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Thanks. Give me a sec. It'll help if you see a video of one of our recent rehearsals...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"... Hm? What is it, PAREO? Is there something on my face?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Ah, no...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"I was just thinking to myself how I am truly happy that we were wrong about you leaving the band...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Oh, you mean when you thought I was joining Walhalla?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Yes.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"The thought of you leaving RAS had never even crossed my mind.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"You care so deeply for RAS... Did you meet with Saki-san on your own because you did not want to trouble us?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Yeah, I guess so... It's a little embarrassing to hear you say it out loud, though...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"But the same goes for you and LOCK, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Yes. At first, we both worried about this matter on our own. I am sure you felt the same.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"And because we shared similar concerns, I understand how much you cherish RAS.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I guess there's no fooling you, PAREO...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"You're right. RAS is very important to me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"A lot happened before I joined RAS, but since then, there have been many times when I've felt glad that my journey brought me here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"And during every show or rehearsal we have, I have the same thought.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I'm so happy... I joined RAS.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"LAYER-san...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"And that's enough of this conversation!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"The others will be here soon, so let's clear the table.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Okay. I will wash the dishes♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I wonder if we'll have another intense rehearsal today.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Well... CHU²-sama said she has a special schedule for us today.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"ev187-ep2-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Ah, that sounds tough. I'd better psych myself up for it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"ev187-ep2-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"I'm probably going to sweat like crazy. Maybe I should've brought an extra towel with me.","tention":0,"lipSyncMode":1,"motionChangeFacto