{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"6adbc306fd0be204"},"m_Name":"Scenariomemorial1702","scenarioSceneId":"memorial1702","storyType":0,"appearCharacters":[{"characterId":12,"costumeType":"012_casual_winter"}],"firstLayout":[],"firstBgm":"44_evening","firstBackground":"bg00017","firstBackgroundBundleName":"bg/scenario1","snippets":[{"actionType":6,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":1,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":1,"delay":2,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":2,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":3,"delay":2,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":4,"delay":5.5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":5,"delay":8,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":4,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":5,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":6,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":7,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":6,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":8,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":7,"delay":6,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":8,"delay":8,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":9,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":9,"delay":3.5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":10,"delay":8.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":10,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":11,"delay":5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":12,"delay":7,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":11,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":12,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":13,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":13,"delay":5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":14,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":14,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":15,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":15,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":16,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":16,"delay":3.5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":17,"delay":6,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":18,"delay":4.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":18,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":19,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":19,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":20,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":20,"delay":4.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":21,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":21,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":22,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":23,"delay":4,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":24,"delay":7,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":25,"delay":12,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":25,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":26,"delay":4,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... Most certainly! Upon my return, you shall see a Kaoru Seta that has grown and become ever more fleeting...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I bid you farewell... Ah, {{userName}}-san. I planned to make my way to CiRCLE once I finish here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"How fleeting it is for our paths to have crossed here of all places...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I have been paying my respects to the good people here for the day when I depart to study abroad nears, and I wish to take care of what unfinished business I have.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... Indeed, it is all for the sake of preparing to set foot on the next stage.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"During my time atop that stage known as Haneoka Girls' Academy, I was given the role of a student.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"With no script or plot to be followed, truly was I free to do as I saw fit.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Classmates, friends, compatriots of the theater club... Every day, I spent my time surrounded by fellow cast members.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Every day, the time I spent was fleeting, dramatic, and entertaining. So much so that I wished to remain on that stage for eternity.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Alas, such a wish was a wish that was not meant to be. The curtain has fallen after three years, a time all too long and short, and I make my way to my next stage.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Having fulfilled my role of Kaoru Seta as a student at Haneoka, I shall set foot on my next stage and take up my role as a college student once I have studied abroad.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"What Kaoru Seta will I become? What cast members will I perform alongside?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ahh, the mere thought of what awaits makes it all but impossible to contain the anticipation overflowing within my heart...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... However, no matter how many stages I am called to act atop, I have one role that shall be never-ending.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"That eternal role is my role as the guitarist of Hello, Happy World!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I truly could not have foreseen that I would join that band. That day, my fate changed dramatically.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"In doing so, I found myself irreplaceable comrades: Kokoro, Hagumi, Misaki, Kanon, and Michelle...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Not a single memory with them can I forget, for each one I consider a treasure.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"And just as they have given me treasures, I, too, wish to be a friend capable of bestowing treasures upon them.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I wish to shine on stage forever as Kaoru Seta of Hello, Happy World!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... Fufu, I seem to have gotten carried away. You have my thanks for lending me your ear, {{userName}}-san.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah, I have a humble token of my appreciation... that I have been meaning to give you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"It is a second button from my jacket, proof of my time at Haneoka, and most importantly, a sign of my gratitude toward everyone.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Anyhow, once I have made my rounds here, I shall make my way to CiRCLE so that I may also give to Marina-san this sign of my gratitude.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf_right01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"As Shakespeare himself did say, \"All the world's a stage, and all the men and women merely players.\" We are but actors playing the roles of ourselves... It is, but that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"And so, I ask that you continue to watch over me as I live out the role of Kaoru Seta.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev215-me3-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFro