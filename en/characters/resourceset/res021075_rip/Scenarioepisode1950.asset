":1,"progressType":1,"referenceIndex":34,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":25,"delay":3.700000047683716,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":35,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":26,"delay":4.300000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":36,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":27,"delay":2.299999952316284,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":37,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":28,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":38,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":29,"delay":2.299999952316284,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":39,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":30,"delay":1.899999976158142,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":40,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":31,"delay":2.200000047683716,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":41,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":32,"delay":3.200000047683716,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":42,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":33,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":43,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":34,"delay":3.700000047683716,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"It's gotten quite late, hasn't it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Yes. The meeting at the agency lasted longer than I had planned.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nod01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"sigh01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Sayo?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Sorry. I couldn't help thinking about the request to perform at All Music Fes.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"That's understandable. Perhaps what you're concerned about is the 2nd album?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"That's right... When I think about the schedule, I couldn't come to a conclusion so easily...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"As for the lyrics, Lisa said she would help me with that, and you don't have to worry too much.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Minato-san... did you know that Imai-san was continuing her lyricist studies?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"serious02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Why?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I felt like you asked her to write lyrics more easily than I had expected. Besides, you were smiling at that time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Yes, I did. I've known it since a long time ago.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"She didn't think I was aware of it, though...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Fufu, that's very typical of Imai-san. The way she works hard behind the scenes, and the timing of when she asked you to be allowed to write lyrics.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Yeah, even though she knew her own production schedule would be tight, she brought it up at a time like that...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"She can't help but reach out when someone is in need. That's typical of Lisa.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"That's right. I, too, have been helped by that aspect of Imai-san many times.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"We both owe Lisa a lot.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Indeed...I hope Imai-san's lyrics go well. Both for your sake, as well as hers.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Don't worry. Lisa will give us something worthy of release.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nod01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Though it may not be easy, in the end, I'm sure she will.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"You're sure of that, aren't you, Minato-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Yes... Because no matter what, Lisa's not a quitter.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"She's not a good quitter... That may be true. Especially when it's for someone else.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Yes. She usually seems to be very understanding, but Lisa won't give up on something she's set her heart on.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"When I once tried to push her away, that was also the case...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"thinking03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Just as she clung onto me no matter what that time, Lisa never backs down when the moment calls for it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"That's right. No matter how harsh Minato-san and I say things, Imai-san never tried to quit Roselia.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"... Now, I can only thank her for that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"That's why I accepted her proposal. I'm sure Lisa will desperately try her best to bite the bullet this time, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"That's the kind of person Lisa is, so I'm sure she'll come up with something satisfactory in the end.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Otherwise, I wouldn't have left it to her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Fufu, I see.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Is there anything wrong with that...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"No. I just thought it was a very convincing reason.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I think Minato-san trusts her, including her unwillingness to give up.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Yes, I think I've seen Lisa's reluctance to give up even more than Sayo and the others.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Fufu, I feel a bit envious of your childhood friendship.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"You're smiling, but Sayo, your reluctance to give up is considerable, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"That's ...... certainly undeniable.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Not just Imai-san and myself, I feel like I can say that about all Roselia members.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev252-ep3-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"That's true too. Ako, Rinko, and myself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"But that's why I'm here with you guys, and I believe no matter what happens in the future, we can move forward.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"In any case, let's make a choice we have no regrets about. All of us together.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"ev252-ep3-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":22,"costumeType":"022_casual-2023","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":21,"costumeType":"021_casual-2023","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":21,"costumeType":"","motionName":"smile03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":21,"costumeType":"","motionName":"nnf03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":22,"costumeType":"","motionName":"sigh01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"cha