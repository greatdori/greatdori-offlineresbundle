:"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"I wonder if there's anything else around here that's boppin'♪.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Ah! Hey, what's this?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Oh, looks like a movie script. It was very popular a long time ago. You've never seen it before?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Nope. Never!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"I-I see...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Oh, hey. There's a signature here too. Do you know this person?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Yes, looks like the leading actress for the movie. She won a very large award for her role in this film, then she became famous.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Whoa, neat!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Still, an autographed script...? It doesn't really do it. Something like this just isn't very boppin'♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Hm? Why not? It's a rare piece, and I'm sure it's very valuable.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Well, yeah, but... Doesn't the fact that this is autographed mean that this actress gave it to someone as a present?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Yes, that's true. So?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Then isn't it kind of sad that it's being sold here?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"ev39-ep5-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"That's certainly one way to look at it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"At the same time though, the fact that it's being sold means the autograph has value to it. That would make anyone in the entertainment industry happy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"ev39-ep5-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"