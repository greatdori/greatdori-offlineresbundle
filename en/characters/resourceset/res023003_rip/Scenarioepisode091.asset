","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode091-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Hey, what's that face for?\n You're gonna hurt poor Lisa-chan's feelings~♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode091-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"I'm in high school.\n I think I can survive one night alone by myself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode091-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Nope nope nope. Your parents said if you're gonna stay here for rehearsals while they're on vacation, you have to stay together with me. Right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf01","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode091-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"And anyway, we both know you can't do anything around the house.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode091-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"What...?\n We each have our duties. My mother is in charge of all the cooking.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode091-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Hmm~? So what do you do, then?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode091-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"... I clean the dishes... sometimes.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode091-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Well, whatever. I'm gonna cook you your most favorite meal tonight, okay? You're gonna love it♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"episode091-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"Lisa, I keep telling you...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":21,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"episode091-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","