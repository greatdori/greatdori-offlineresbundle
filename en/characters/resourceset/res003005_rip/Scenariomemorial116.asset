nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Oh, me? Uhm. Well, I...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"We don't have rehearsal today, so I thought I would try to find a present for my sister again...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Mhm, yeah! Her birthday just passed.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"... Everything seems like such a good choice, though. I can't decide…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"But we did have a concert by Glitter*Green on the day of her birthday…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"That show was full of excitement! Lots of people, like friends and classmates, came to celebrate, and there was a performance...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Yeah, Poppin'Party played too!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I was nervous about being on the same stage as such a high-level band, but... I wanted to create a song to give as a present.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I talked with the girls in Poppin'Party, and I made the song... I even wrote the lyrics, which I never do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I had to make sure my sister didn't hear it before the party, so I was stuck in the studio... Ahaha.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"It was asking for a lot, but since it was a song for my sister, I wanted to write the lyrics myself, and Kasumi-chan let me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Thinking of the words for a song is really hard...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"But I think I was able to say everything I wanted with what I wrote.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"It was pretty tough, but everything was ready by the day of the party.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Even with no time to spare, the rest of the band learned the song... Words can't express how grateful I am to them.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"And on the day of the show, we gave it everything we had, and everyone was happy with what we were able to do!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"After the show, my sister told me it was the best birthday present she ever received!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"And she said she could tell that I worked really hard... I was so happy because... I want to be just like her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Actually, I was too happy, and I started crying.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Ehehe...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"To see my sister smile while hearing our song... And everyone in the crowd, too... All of that filled my heart with joy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Of course, I also appreciate my friends in Poppin'Party.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"They put up with all of my selfishness, made me chocolate cornets and Go-Go Bread, they cheered me on and supported me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"And when it came time for the show, they played with smiles on their faces...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I feel so blessed...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Now I want to find something I can help them all with.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"You think I can do it...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Thank you. When you say that, I feel a little more confident.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"{{userName}}-san, thank you so much.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I like that my sister enjoyed herself, but I'm also glad we decided to take part in the concert.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"I was able to learn something during that time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"At first, I created the song only thinking about my sister.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"But that's not enough.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memorial116-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Sure, it's important to perform for someone. But I learned it's also important to perform for everyone.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"memor