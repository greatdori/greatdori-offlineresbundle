e":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"episode-r-anon-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Hmmm...","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-r-anon-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"If you think I'm lying, why don't you take a look at my assignment? I mean, look! The one that my teacher praised me so much for!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf02","expressionName":"kime01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-r-anon-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"There's still some time before our studio booking.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"episode-r-anon-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"I don't want you to teach Tomori something weird. Give it to me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-r-anon-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"What is the theme of this assignment?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"episode-r-anon-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"It was an assignment to write an essay on a theme that the teacher had chosen! This time, the theme was \"Environmental Issues\".","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-r-anon-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"There are many different types of environmental issues, right? I did mine by writing an essay on a cosmetic packaging, a topic that I am familiar with.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-r-anon-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"No matter how big the theme is, if you think of something familiar to you as a subject, it's unexpectedly easy to write an essay.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"kime01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-r-anon-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"All you need to do is to apply the structure of the editorial properly.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"episode-r-anon-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":".......","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nnf02","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"episode-r-anon-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"You certainly wrote your conclusion and its reasons properly. The examples about cosmetics packaging are also easy to understand.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf03","expressionName":