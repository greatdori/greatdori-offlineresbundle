eIndex":70,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":71,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":56,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":72,"delay":2.799999952316284,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":57,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":73,"delay":2.0999999046325684,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":74,"delay":4,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Hm? Udagawa-san? \nGood afternoon.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ah, if it isn't Sayo-san! \nYou doing some shopping?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Yes, my parents sent me on an errand. I'm on my way home now.\nWhat about yourself?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"I promised Ako we'd hang out, \nso that's the plan for today.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I see. You two really are close.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Well, you know how it is. Hard times bring people closer.\nBy the way, thanks again for your help back then!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ever since all of that happened, I've really wanted to have a big-sister talk with you! Do you have time right now?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"A-a 'big-sister talk'...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"You know, a little heart-to-heart conversation about how hard it is being the older sibling.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"simizimi01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"... Okay.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"I bet you got told this a lot, right?\n \"You're the big sister.\"\nMy parents were always reminding me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Like when we'd play games together, I would always win, so Ako would start crying.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"My parents would see that and go,\n\"You're the big sister. Go easy on her.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Even as a kid, I never got that.\nI wanna win too!\nHave you ever had that happen to you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I don't think... that's ever happened to me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"... Really?\nIt must be because you and Hina-senpai are twins.\nKinda hard to imagine someone telling you that in your situation.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Agreed. I don't remember my parents ever saying anything like that to me. However...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I have thought it to myself.\nHow I'm the older one...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"You mean... You'd tell yourself that?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I'm the big sister, so I need to look after Hina...\nI'm the big sister, so I can't behave selfishly...\nI'm the big sister, after all...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I feel like that's all I ever thought about.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"You know...\nWhen you think about it, that's... almost tougher than being told the same thing by someone else.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Looking back on it now, there was no reason for me to get all worked up about it, but that's just the type of person I am.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Sigh~. Little sisters have it easy when it comes to that stuff~.\nThey don't know anything about our struggles, they just wanna play.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"... Hm? Isn't this something people mention a bunch? \nWhat was it again? I can't quite remember...\nSomething about... only a sister being able to understand...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I think you mean when mothers and fathers say, \"You'll understand when you're a parent,\" correct?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ah, so it's parents, huh?\nStill, don't you think it works for big sisters too?\nWe go through a lot without them realizing!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Fufu.\nI suppose you're right.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Hey, Sayo-san, can I ask you something?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"What is it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"If you could be born again...\nWould you want to be the big sister or the little sister?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"If I was reborn, huh...?\nWell...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"I'd have to go with... the big sister.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ahaha!\nSomehow, I knew you were gonna say that!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Same goes for me. Big sister all the way.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":22}],"windowDisplayName":"Sayo","body":"Fufu.\nYou're perfect for that role.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":22,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":22,"voiceId":"ev51-ep1-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"I'm glad to hear it!\nI can't picture you as anything else either.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"ev51-ep1-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePla