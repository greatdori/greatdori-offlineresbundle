{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"6adbc306fd0be204"},"m_Name":"Scenarioselfintroduction012-1","scenarioSceneId":"selfintroduction012-1","storyType":0,"appearCharacters":[{"characterId":12,"costumeType":"012_casual"}],"firstLayout":[],"firstBgm":"03_Normal","firstBackground":"bg00042","firstBackgroundBundleName":"bg/scenario4","snippets":[{"actionType":2,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":1,"delay":4.400000095367432,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":1,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":2,"delay":5.300000190734863,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":4,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":5,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":6,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":7,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":3,"delay":4,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":8,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":4,"delay":3.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":9,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":10,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":11,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":5,"delay":6.5,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Good day, my little kittens. You wouldn't mind if I state my name, would you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Kaoru. Seta Kaoru. I wield the guitar for Hello, Happy World!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"…So fleeting...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Ah, please forgive my rudeness. Allow it to escape your memory. I cannot resist being awe-struck by that which is fleeting...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"This small flower, blossoming in the field. We crossed paths earlier and now it refuses to leave my mind...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"It is one of Seta's principals to never let private matters slip through these lips, but for the sake of Hello, Happy World!, I must...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Allow me to shed a glimmer of light on the existence of the human that is yours truly.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I participate in the theater club. My heart tells me that through such theatrics we can one day arrive at the truth.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Hm? What is \"the truth?\" As the great bard once said, \"... till truth makes all things plain...\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"That is what we mean when we say, \"the truth.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"... That's too hard to understand?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I see. Allow me to explain... In other words, it is... exactly how it sounds.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"kime05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"episode045-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual","motionName":"kime01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual","motionName":"kime01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual","motionName":"kime05","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual","motionName":"kime01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":12,"costumeType":"012_casual","motionName":"kime04","expressionName":"default","moveSpeedType":0}],"specialEffectData":[],"soundData":[],"needBundleNames":[],"includeSoundDataBundleNames":[]}}