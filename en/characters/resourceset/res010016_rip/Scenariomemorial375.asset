Type":0,"referenceIndex":16,"delay":2.299999952316284,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":21,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":17,"delay":3.299999952316284,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":22,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":18,"delay":3.0999999046325684,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":23,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":24,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":25,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":19,"delay":3.0999999046325684,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":26,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":20,"delay":3.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":27,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":21,"delay":3.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":28,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":22,"delay":2.700000047683716,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Ah, {{userName}}-san! Good Afternoon!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Me? I have band practice soon! If we need any help today, we'll be sure to let you know!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Oh, that reminds me... This is kind of sudden, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Here you go! Please take this!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"It's a little late, but I wanted to say thank you for all you've done for us!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Yep! I thought I'd give some to you and Marina-san, so I brought it with me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Ehehe... I made it myself... so I hope you like it...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Ah, that's right! Did you hear that Arisa-chan made homemade chocolates this year?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Right? I never would have guessed Arisa-chan would do something like that. That doesn't seem like her at all.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"You thought so too, {{userName}}-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"But, when I first heard about it, I couldn't help but remember the first time I made chocolates.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I mean, that was a long time ago, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Before that, I would take the chocolates my mom made for the shop and give those to everyone in Afterglow.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Everyone always looked like they really enjoyed them...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I remember thinking, \"Next time I'll make something myself, and really surprise everyone!\" And so I did. I made everything from scratch for the very first time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Fufu. This really brings back memories.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I remember my heart pounding as I handed everyone their gifts...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I was terrified they wouldn't like it, but at the same time, I really wanted them to eat it. It was a pretty strange feeling...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Hm? What was everyone's reactions?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Uhm~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Looking back, I don't think the chocolate I made was very good...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"But when I told everyone I made it myself, they all told me how tasty it was...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Moca-chan even went as far as eating all the extras I'd made!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Seeing that, I was so relieved, and excited...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... Fufu. I'm lucky to have such considerate friends.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I bet Arisa-chan felt the same way as I did back then.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"That fear of failure, and that excitement at seeing their reaction... It's a very unique feeling...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... No, I haven't heard how Poppin'Party reacted yet.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I'll have to ask the next time I see her! Fufu... I can't wait...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"ev32-me4-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"010_casual_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"nf04","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"nf02","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"smile01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"smile03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"nf03","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":10,"costumeType":"","motionName":"smile01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffset