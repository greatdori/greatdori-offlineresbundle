ceIndex":6,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Himari, you were really fired up for the graduation ceremony rehearsal. Your movements were so sharp that I thought you were some martial artist.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"area5427-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"H-hey, Tomoe~. Don't talk about graduation so suddenly~! Whenever I hear that word, it makes me well up with tears...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"area5427-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ahaha, what an exaggeration...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"area5427-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"It is not. Kaoru-senpai, Lisa-senpai, and the others leaving Haneoka is way too sad... Ngh~. Talking about it is making me cry again~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"area5427-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ahh~, sorry for teasing you. I really know how you feel.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"area5427-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"But I think our seniors would be happy knowing they've got juniors who'd be sad enough to cry. Let's send them off on the day with lots of energy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"area5427-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Yeah... You're right!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"area5427-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthTy