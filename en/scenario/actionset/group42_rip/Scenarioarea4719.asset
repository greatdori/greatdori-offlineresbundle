gressType":0,"referenceIndex":46,"delay":3,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":47,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":48,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":17,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":49,"delay":4,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":50,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":18,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"It's a good thing Marina-san was holding onto the box!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"area4719-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"What a huge relief~...! Thanks so much, everyone! I'm super grateful!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"area4719-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"I enjoyed it! It was like a treasure hunt~! If anything, I wanna thank you~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"area4719-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Same here since I got the chance to ask Marina-san for Christmas party advice!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"area4719-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"Tsugumi-senpai and the rest of Afterglow will be there though. And so will Poppin'Party, and Hello, Happy World! I have to make sure I don't do anything improper...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"area4719-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Just take it easy. It'll be fine☆ Ah, I'm also looking forward to playing against RAS in the band battle by the way~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"area4719-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"O-oh?! CHU²-san already brought it up?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"area4719-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"She was talking about it with Yukina-chan earlier~! She said she'd show everyone that your band is the strongest~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"area4719-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"What a boss! Fusuke, should we make some kinda declaration too?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"area4719-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"I say there's a declaration you need to make first though... About not losing things anymore!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"area4719-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"Ahaha...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"area4719-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"But I enjoyed the search, and we've even got party plans and a band battle now. This might be thanks to Toko-chan losing the box!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"area4719-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"I-I suppose so... And I did get to make plans to hang out with everyone, so maybe it wasn't such a bad thing...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"area4719-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Fufu. In a way, you could say Toko losing the box brought us all these Christmas presents☆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"area4719-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"That's a wonderful way to put it! I can't wait for the Christmas party and the band battle...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"area4719-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Hey, I know! Let's have a mini Christmas party right now! We can order special seasonal cakes and drinks at the café!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"area4719-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"Seconded~! We might as well also take a group photo! Hey, everyone~! Gather round for a picture~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"area4719-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Is everyone here? Okay, I'm gonna take it~!  Three, two, one...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"area4719-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"All","body":"Merry Christmas!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"area4719-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":32,"costumeType":"032_casual","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":27,"costumeType":"027_casual_winter","motionName":"","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":27,"costumeType":"","motionName":"smile01","expressionName":"default","moveSpeedType":0},{"type":0,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":27,"costumeType":"","motionName":"smile02","expressionName":"default","moveSpeedType":0},{"type":3,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":32,"costumeType":"","motionName":"","expressionName":"default","moveSpeedType":0},{"type":3,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":27,"costumeType":"","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideT