{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"6adbc306fd0be204"},"m_Name":"Scenarioarea2355","scenarioSceneId":"area2355","storyType":0,"appearCharacters":[{"characterId":12,"costumeType":"casual_season"},{"characterId":15,"costumeType":"casual_season"}],"firstLayout":[],"firstBgm":"","firstBackground":"","firstBackgroundBundleName":"","snippets":[{"actionType":2,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":0,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":1,"delay":5.199999809265137,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":2,"progressType":0,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":1,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":2,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":4,"delay":5.5,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":5,"delay":11,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":3,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":6,"delay":4.400000095367432,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":4,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":7,"delay":3.200000047683716,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":5,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":8,"delay":3,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"To be that one... or to be this one...\nThat is the question...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"hallo-area10-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Kaoru-san, what are you doing?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"hallo-area10-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"My dear Misaki. I am befuddled as to which Halloween costume to don. You see, it must be appropriately fleeting to properly satisfy my little kittens... Alas, I am perplexed...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"hallo-area10-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Oh, so that's what's going on. Well, how about the phantom thief outfit you wore before? It suited you rather well.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"hallo-area10-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharact