otionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"... Ako-chan? What makes you say that...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Oh... So right now... you're thinking over the meaning... of the word \"cool,\" correct?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Mhm. Moca-chin has been helping me out, but it hasn't gone very well so far.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Ako-chan... Do you remember... when you started finding cool stuff so appealing?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Hmmm... Well, I've always wanted to be like my sister, ever since I was really little. She's so nice, and she would help me when I needed her, and she's cool...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Ah! Now that I think about it, I might have picked up the word from her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"She used to say that a bunch of things were cool when she was younger.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"What kind of things?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Like~... the color red!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Do you know what Nin-Vincible is, Rin-rin?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Mhm... I watched it sometimes as a kid... It was one of those hero shows, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Yeah! Sis used to talk about how cool Invinci-Red was! Same for the color!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Fufu.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Oh, but I liked Invinci-Black! Do you know that character?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Sorry... I didn't watch it that often...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Invinci-Black was super cool! That character joins the team later in the show, but before that, no one knows anything about Invinci-Black!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Red and the others are in a corner, and Black shows up to help them out and has a bunch of info on the enemies...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"It turns out that Black was a spy sent by the enemy but couldn't fight the feelings that had grown for Red and the others while watching out for them, so they all stay friends!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Even though they were fighting for justice, Black worried about using dark powers to battle enemies. I thought that was so cool~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Oh... So that must be why... you chose the class in NFO... related to darkness...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Ah...! Yeah, that might be why! Maybe the color is one of the reasons I thought the necromancer was cool.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Ah, but you know, I came to think that black is cool like my sister thought red was cool, so...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"I thought that maybe if I find a bunch of cool stuff, that I could become like my sister.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"And to me, that meant jumping into different game worlds, the color black...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"And that's... how you came across NFO...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Mhm! I found the necromancer class in NFO, I went wild with the power of darkness, and then I found you, Rin-rin!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"You unlocked the power of darkness that was inside of me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Huh?! I-I did...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"When I mentioned how cool I thought it was, you taught me about black magic and all types of mythological stuff like that!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"If I hadn't been looking for cool stuff, I would have never met you, and my dark powers would have never awakened! And I don't think I would be a part of Roselia either!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"So I'm very grateful to my sister for showing me what \"cool\" is, and I'm grateful to you for teaching me everything you've taught me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Ako-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"And since so much effort went into teaching me the idea of cool, I wanna be able to tell people about it and have them understand me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"If it's too hard to put into words...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Why not try a different way...? Like putting what you feel... into a musical performance...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"A different way...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Yeah! That could work! I'll create something filled with all the stuff I think is cool! That should make it really easy to understand, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Mhm! I have a hard time... using my words to explain things too...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"So... I've put my thoughts and feelings... into performances... and costume designs...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event78-04-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":24}],"windowDisplayName":"Ako","body":"Rin-rin, you're always so smart! Thanks!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":24,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":24,"voiceId":"event78-04-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"I'm glad... I can help...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"charact