aracterId":37}],"windowDisplayName":"Anon","body":"Then the only other song we can do is...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-35-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"We're not going to do “Haruhikage\".","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-35-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... The only thing we can do is... play a new song.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-35-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"A new song...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-35-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisp