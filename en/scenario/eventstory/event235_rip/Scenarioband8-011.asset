}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"To have one built... what kind of big house do you live in...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-11-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":338}],"windowDisplayName":"Mutsumi","body":"Saki's house is a mansion.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":338,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":338,"voiceId":"event235-11-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Seriously...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-11-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... I mean, why karaoke? How can it be we're planning to practice here?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-11-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Yeah, Saki-chan talked to me about it, so I thought of a way to make Tomori-chan less nervous.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-11-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"This is a good place to practice singing in front of people. It'll be less stressful than a studio, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"thinking02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-11-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Yes, I think it's a great idea.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-11-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"This is my first time at karaoke, but Tomori will enjoy practicing here, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-11-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I have no idea... But the machine at the entrance was awesome......","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-11-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":338}],"windowDisplayName":"Mutsumi","body":"The drink bar?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":338,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":338,"voiceId":"event235-11-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Oh, that was amazing to me too! I didn't know you could just push a button and a drink would come out...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-11-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"And there were so many kinds! What did you choose?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-11-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"I didn't look properly... but I think it was juice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-11-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Then you'll have to taste it soon!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-11-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"You two are too excited...  We haven't sung yet.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"sigh01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-11-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"You're right, let's sing quickly. What are you going to sing, Mutsumi-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-11-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"Wait, why are we just trying to sing normally?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-11-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Because Tomori-chan will get nervous if she is asked to sing out of the blue, won't she?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-11-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"So, please choose a song, everyone. I think I'll sing “Luminous Once More”.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"wink01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-11-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound"