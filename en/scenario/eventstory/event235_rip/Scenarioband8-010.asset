Tomori-san. Let me introduce you all.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Soyo-san is the bass player. She plays double bass in Tsukinomori's brass band.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"The other day at the Tsukinomori Music Festival, she put on a wonderful performance, so I asked her to join our band,","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"I was so surprised when she asked me all of a sudden.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-10-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"This is Mutsumi. She's been playing the guitar since she was a child, so you can count on her.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":338}],"windowDisplayName":"Mutsumi","body":"... Er, no, no.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":338,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":338,"voiceId":"event235-10-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"No need to be shy, Mutsumi... You need to have more confidence in yourself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"Are you both Sakiko-chan's friends?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-10-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Mutsumi is my childhood friend. Soyo-san is my classmate...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"This is practically the first time we've talked like this.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-10-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"As for the other one, the drummer, we've never met before.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... I'm Shina.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-10-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-10-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"I've been friends with Taki-san's older sis for a while. That's why I asked her to join us this time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Taki-san's older sis is the head of the Haneoka brass band. She is also an accomplished musician who has achieved excellent results in individual competitions. Lately, I hear, she has been active in the local orchestra.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... Is that relevant now?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-10-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Excuse me. Let me back up.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Ahem... Once again, thank you very much for coming together today.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"I have been looking forward to meeting you all.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"From now on, we are a band...\nWe're destined to play music together!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"We're destined...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-10-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Yes, isn't it nice?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":338}],"windowDisplayName":"Mutsumi","body":"... What kind of music are we supposed to play?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":338,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":338,"voiceId":"event235-10-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Good question. Do you know the band called Morfonica? It's a band of Tsukinomori seniors...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Yes, I know of them. They played at the last Tsukinomori Music Festival, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-10-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Yes, I was at that festival too, listening to Morfonica's performance.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"They conveyed the strength hidden within the elegance of the music, the joy of playing in a band above all...  I was very impressed.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"So, my hope is that we'll play a song by Morfonica, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"We'd aim to play our original songs in the future.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"What? Our original?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-10-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"We haven't even played together yet. Isn't it too ambitious?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-10-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"No, not at all. I'll write the music score...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"Above all, Tomori-san here is a genius at writing lyrics.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-10-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"...!? What...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-10-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"This girl is...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-10-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectRefe