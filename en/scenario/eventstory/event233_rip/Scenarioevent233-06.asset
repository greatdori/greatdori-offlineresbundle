ogressType":1,"referenceIndex":0,"delay":1.5,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Hey, look. The first band's already rehearsing!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event233-06-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Whoa, those are some flashy outfits... They're fired up, alright~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"I bet it feels so good to play the guitar under the blue sky...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event233-06-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Interesting~. That band has three guitarists. Hey, Rimi-rin! Let's all go take a closer look.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event233-06-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"O-okay...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event233-06-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"(... I still can't shake off this feeling... Our concert is coming up though... I need to stop dwelling on it...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event233-06-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Huh, I only expected people who were here for the music festival, but it looks like there are regular parkgoers as well.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Probably because only part of the park seems to have been reserved for the event. There are also stages that are open to the public.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event233-06-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Quite a few people are checking out the rehearsals.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event233-06-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"Hey, that person over there. They're the one that sold us soft serve yesterday. Wow, they sure seem to be having fun dancing to the song!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"event233-06-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Over there too. There are some little kids staring at the stage. I wonder if they're interested in the performance. Just look at the way their eyes are sparkling.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event233-06-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"You know, it feels kind of crazy to see music getting to be a part of the cityscape like this.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"... Yeah, it's incredible. Really incredible.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":1,"voiceId":"event233-06-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"It's like it's spreading!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event233-06-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Spreading...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nnf03","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event233-06-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"The power of music. Instead of going inward, it's like it's spreading outward more and more...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event233-06-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"I feel like music is something that can connect even more people and become an even bigger circle than I'd imagined...! Mmm~, I'm getting so excited now!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event233-06-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"???","body":"... Hm? Hey, are you guys Poppin'Party?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"...? Oh, wait. You're one of the bands that's performing today...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":1,"voiceId":"event233-06-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band A","body":"Wow, you actually recognize us! That's so cool! There's somethin' we've wanted to say to you all if we ever managed to meet.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Say to us?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event233-06-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band A","body":"That Rocking Star Festival stream was a real killer!","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band A","body":"It gave us shivers to know that there were high schoolers in Tokyo who had spirit like us! Anyway, I'm sure we ran into each other for a reason, so good luck to us both!","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Wow, thanks! Yeah, let's put on a good show!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event233-06-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band B","body":"Ah, Poppin'Party! You mind givin' us some time?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band C","body":"We got to see your stream in one of the live houses around here~! Seein' high schoolers like us doin' what you guys did was real encouragin'~!","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Looks like even more bands are starting to gather around us, huh?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event233-06-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Y-yeah...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nnf04","expressionName":"surprised01","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band B","body":"You're Arisa-chan, the keyboardist, right? I like your sound a whole lot~! Hey, you think we can exchange contact info or somethin'?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Y-you what? Sure... I don't mind...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band B","body":"Great! Hope you enjoy performin' in Osaka! People here love havin' a good time, so you've got nothin' to worry about, alright?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Band C","body":"Oh yeah! Seein' that stream of yours is what got us streamin' our shows! Here's a link. Come check us out! Anyway, we gotta go rehearse! Later!","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Okay! We'll take a look for sure! See you later in the dressing room!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"event233-06-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Fufu, how nice~, Arisa. They said they like your sound.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event233-06-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"N-not another word, alright...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"But well... I guess getting that kind of praise wasn't too bad...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event233-06-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"...","tention":0,"lipSyncMode