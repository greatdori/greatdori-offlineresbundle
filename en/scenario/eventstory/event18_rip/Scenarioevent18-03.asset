 known how much fun it could be to be in a band, or the joy I would feel from putting smiles on people's faces.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event18-03-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"So I...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event18-03-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":11}],"windowDisplayName":"Kokoro","body":"That's it, a song that makes the world bigger! Let's do it!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":11,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":11,"voiceId":"event18-03-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"A song that makes the world bigger... Ooh, that's awesome!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event18-03-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkC