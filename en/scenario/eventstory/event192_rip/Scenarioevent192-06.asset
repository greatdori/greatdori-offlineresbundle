":"... Grandma, you liar! You said we could go out together on our next day off!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"angry04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event192-06-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Arisa's Grandma","body":"I'm sorry, Arisa. Something suddenly came up that Grandma has to take care of...","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Arisa's Grandma","body":"So, you should go and play with those friends that invited you befo-","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":332}],"windowDisplayName":"Arisa","body":"I'm not going! Forget it! I don't care about you anymore...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event192-06-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Arisa's Grandma","body":"Arisa...","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindo