"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Rui's on my case about redoing it~. I wanna show the chairwoman who's boss as soon as possible. Help a girl out!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event234-07-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"Hey! Quit being so selfish! Mashiro-chan's here now, so come on and get ready!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event234-07-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"No way! If school's not fun, I can't get motivated to practice!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event234-07-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"U-um! Everyone...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"Kurata-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event234-07-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I have something I want you all to hear. I was thinking yesterday...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Oh, what is it~? Quit beating around the bush and tell us already.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event234-07-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"So, uh...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I want to give back to Tsukinomori.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"...? What do you mean?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event234-07-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I've had no self-confidence for the longest time, right? Ah, I don't have any now either...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"But I've gradually increased the number of things I can do, and I feel like I'm different from before...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I think that's all because I enrolled at Tsukinomori.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I mean, thanks to that, I was able to meet Morfonica.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"Mashiro-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"smile05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event234-07-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I love Tsukinomori... I love this place that gave me a chance to have self-confidence.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"That's why... I want to give back to Tsukinomori.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"For the Tsukinomori Music Festival, I want to put on a concert that can cheer up the depressed Tsukinomori...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"Tsukushi & Toko","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":900000,"voiceId":"event234-07-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"And that might not make the current Tsukinomori go back to being what it was before, but... for just that moment, the entire school will be able to smile.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I want to have that kind of concert to give back to the school.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Huh... Shiro, that's pretty cool. You clearly said what you wanted to do for once...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event234-07-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Mhm. I really felt that~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event234-07-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"You said it~. I felt zapped by that just now! In fact, I'm super fired up...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event234-07-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"Our goal for the Tsukinomori Music Festival is decided. While illogical, it has given me an image.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event234-07-063","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"A concert where our performance influences the audience... As I recall, we saw one such performance up close recently.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"thinking01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event234-07-064","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"So a concert like Afterglow did that one day, huh~? That seems like it will be hard~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event234-07-065","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Don't worry! That'll be a cinch for us! Alright. How about we start practicing? It's to pump up Tsukinomori!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event234-07-066","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Right...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-067","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Ahaha. Toko-chan's burning with passion~. It looks like she's forgotten about the presentation.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event234-07-068","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"... It's just like you said, Nanami-chan. Mashiro-chan really was okay.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event234-07-069","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"Nanami","body":"Fu, fu, fu~. She's gotten stronger again when you weren't aware of it~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event234-07-070","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"(It happened when I didn't know...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":29,"voiceId":"event234-07-071","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"(I still don't know how to deal with the current Tsukinomori, but Mashiro-chan...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":29,"voiceId":"event234-07-072","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"Oh man~. I never would've thought you'd be the one to get me motivated, Shiro~. Way to go, girl~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName"