timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"You gave me your copies of Melody Musix! Thanks to that, the interview's going great!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"I read a bunch of people's interviews, and I realized there's lots of ways to explain how the audience becomes one with your music.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"It really helped!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"So that's why you were using words you don't normally use.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Oh, it's you two...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ah, CHU²!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"What are you doing out here? What about your interview?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"We're on a break right now. How 'bout you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"My appointment has ended.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"We had the most superb discourse. That live house has some good personnel.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Right. Ah, if you've got time, come watch the rest of my interview. My break's almost over anyway.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":9,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I'm fine. There's no merit in listening to such a boring interview.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Huh...?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Am I wrong? Nothing you said in there were your own words.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"My own words...? What're you talking about? I said every single one of 'em!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"The drummer is the unsung hero of the band.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Hm?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"A steady rhythm is what makes a performance come to life. \"The enthusiasm created by our music spread throughout the whole venue.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I have read all of these phrases in past interviews with Melody Musix.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Huh...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":9,"voiceId":"event136-05-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"It is not a bad thing to study up for an interview.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"But any words you borrow will, of course, be fake. They do not hold enough vigor to touch the hearts of readers.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"... I see. So that's what that feeling was...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Tsugu...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Sorry, Tomoe-chan... To tell you the truth, I felt like something was off that whole time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"During your interview, it sounded like you were borrowing someone else's words...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Even though you were the one speaking them, it's like I was hearing someone else say them...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"N-no way...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I'm so sorry... It must be because I told you to look at what other people had said in their interviews... So it's not your fault, Tomoe-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"I see... So I've been using someone else's words all this time...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"That's so uncool of me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Afterglow's performance at Girl Jam was splendid.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Huh... You saw it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"A performance at an event as big as Girl Jam? Of course I checked it out.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I could feel the audience's excitement through the screen. I felt my chest swell as I imagined... how far this band could go.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"And yet... one of the band members can't even answer interview questions in her own words...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"It seems like that performance was a one-time-only miracle. I can't believe I couldn't see through such a facade.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"...! A facade? Are you talking about us...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf03","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Yes. Who else would I be referring to?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"D-don't mess with me! Afterglow is not fake! Take it back...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf02","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"You can say what you want about me... but I'll never forgive you for making fun of Afterglow!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nnf01","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"That is fine. I don't particularly need your forgiveness.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Anyhow, I must be taking my leave. Farewell.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf03","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event136-05-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"W-wait... Argh!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event136-05-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Tomoe-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event136-05-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"side