s":[{"characterId":6,"voiceId":"event36-04-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Ran, don't tell me you meant to keep that a secret from us...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event36-04-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"... Yeah...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event36-04-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Jeez~, you can at least be a little more sly about it~. Everyone already knows~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event36-04-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"It just... has this weird power or something... At least, it feels that way, so...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"surprised01"