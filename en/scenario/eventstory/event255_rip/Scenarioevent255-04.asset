:1,"progressType":1,"referenceIndex":36,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":37,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":38,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":39,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":40,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":41,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":42,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":43,"delay":0,"isWaitForSkipMode":0},{"actionType":4,"progressType":0,"referenceIndex":13,"delay":2.5,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":44,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":45,"delay":0,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":46,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Um, it looks like Misaki-chan is nearby... If you could just drop me off there, I'll be fine.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"I see. Then I'll take care of you up to there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"What on earth were you thinking, following me to a place you don't know when you have a poor sense of direction?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"sigh01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"I was so desperately searching for Charlotte-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"I had to talk to you, no matter what...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"serious02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"Don't make me say the same thing over and over. I have nothing to talk about with you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Well, I heard you've been absent from school...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"odoodo02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"Yeah, of course. I no longer have any reason to go there.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"What do you mean?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"The reason I came to Japan in the first place was to take revenge on Kokoro. I joined Hanasakigawa Girls Academy as an exchange student to find out what Kokoro was up to.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"I have a better understanding of your band's inner workings and your weaknesses, and now that I've revealed my purpose, it doesn't make sense to continue as an exchange student.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Won't your parents and teachers be worried...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"Humph, I could cover that up any way I want.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"My parents tolerate what I do, and with the power of the Misono family, the school won't complain either.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Oh, I see...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"But what about your friends...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"You came to Japan and became friends with your classmates, right? I think they'd be worried if you suddenly stopped coming to school...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event255-04-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":228}],"windowDisplayName":"Charlotte","body":"... They're nothing more than casual acquaintances. I told you I came to Japan for revenge.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":228,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":228,"voiceId":"event255-04-021","volume":1}],"speed":0,