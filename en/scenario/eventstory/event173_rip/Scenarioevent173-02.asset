dex":14,"delay":2,"isWaitForSkipMode":0},{"actionType":2,"progressType":1,"referenceIndex":134,"delay":0,"isWaitForSkipMode":0},{"actionType":0,"progressType":1,"referenceIndex":0,"delay":2.5,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"What did you think of the All Fun and Games idol trainee special today, Aya-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event173-02-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"Aya","body":"I can't believe I had to eat something so spicy~. My mouth's still on fire~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event173-02-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":17}],"windowDisplayName":"Hina","body":"Ahahaha, that face you made when you were trying not to show it, Aya-chan! Didn't she look just like a shrine lion-dog?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":17,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":17,"voiceId":"event173-02-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"Maya","body":"Huhehe, no comment on her face, but I am really glad you were the host today, Chisato-san~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event173-02-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"Eve","body":"I agree! Anyone else would likely have been unable to handle such a large quantity of people!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event173-02-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"Fufu, thank you, you two. Well, that's it for today's All Fun and Games! See you again next time~♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event173-02-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Sigh~, this is definitely the way to go~. She's so calm and intellectual. It's exactly the kind of emceeing I wanna do~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Watching All Fun and Games again, Himari? Weren't you watching that the whole time during break?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event173-02-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I did get picked to emcee the New Year's singing contest, so I want to make absolutely sure it goes well!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Thanks again for agreeing to do it, Himari-chan. The woman who runs the fish shop was really grateful.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event173-02-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Not just her. All the old folks downtown are real happy that the contest isn't gonna be canceled. They've been looking forward to it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event173-02-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"The fate of the downtown shopping district's profit margins next year will be determined by your emceeing, Hii-chan~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Gee... Thanks for making me feel the pressure...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Oh, I know~! Maybe you could give me a hand, Moca? Please?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Not a chance~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"bye01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Aw~! Then, how about you, Ran?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"You know the answer to that one. I'm not good at stuff like that...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event173-02-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Then Tomoe! If you do this for me, I swear I'll never ask you for another favor for the rest of my life~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Er... I sorta have other plans...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event173-02-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Do you have any idea how many times you've played that card, Hii-chan~? You'd have to be reborn at least ten times for that one to work again~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":7,"voiceId":"event173-02-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I mean, I know I said I'd do it, but I've been super stressed out since yesterday!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"And after watching how Chisato-san does things in this video, I'm not sure I'd be able to do it like her~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"The way she managed everything was pretty incredible. It was like she was somehow in full control of all those people...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event173-02-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Hey, didn't you say you'd be seeing Shirasagi-san after this and having her teach you the secret to emceeing or something?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event173-02-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I know, but~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Ah, why don't you try copying her~? You know how they say trying to look the part is a good way to start out.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Wait, you mean like doing an impression?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Yeah, since you happen to be good at that stuff too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"O-okay~... Well, that's it for today's New Year's Singing Contest! See you again next time~♪","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Oh~, I'd say you nailed the essential characteristics~. Looks good enough to me~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Really?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I don't know. I feel like that's kind of missing the point.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event173-02-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Yeah. It's not gonna do you any good.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event173-02-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Ahahaha~. Your impressions are always so funny, Hii-chan~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Hey, Moca~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Anyway, you alright for time? Don't you have to go see Shirasagi-san?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event173-02-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Oh yeah! Wouldn't want to keep her waiting! Gotta go! See ya!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event173-02-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Ahaha~, no rest for the wicked, as they say~. So, what now for the rest of us?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Ah... I've got something I need to take care of...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":9,"voiceId":"event173-02-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Same here, actually. Sorry...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event173-02-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Is that so~...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event173-02-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"You two wouldn't happen to be hiding something now, would you?","tention":0,"lipSyncMod