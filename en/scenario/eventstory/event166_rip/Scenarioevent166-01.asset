Mode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event166-01-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":331}],"windowDisplayName":"Rei","body":"It was no fun... again...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":331,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":331,"voiceId":"event166-01-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":331}],"windowDisplayName":"Rei","body":"Oh, there's a new one on the board. \"This month's Best Effort Award goes to Arisa Ichigaya-chan...\" Look at all those star stickers...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":331,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":331,"voiceId":"event166-01-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":332}],"windowDisplayName":"Arisa","body":"Goodbye, teacher. See you next week.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event166-01-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Friend","body":"You got another star sticker today from the teacher, Arisa-chan! You're so amazing!","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":332}],"windowDisplayName":"Arisa","body":"No, I'm not~. I'm just doing what I'm told and playing what's on the sheet music.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event166-01-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Friend","body":"That's the hard part~.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":332}],"windowDisplayName":"Arisa","body":"It is~? I don't really get it...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event166-01-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":331}],"windowDisplayName":"Rei","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":331,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":331,"voiceId":"event166-01-041","v