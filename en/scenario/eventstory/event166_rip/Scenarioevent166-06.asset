ting there? Are you feeling sick?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event166-06-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":331}],"windowDisplayName":"Rei","body":"Nuh-uh, I'm okay... You see, I'm moving away today.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":331,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":331,"voiceId":"event166-06-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":332}],"windowDisplayName":"Arisa","body":"Oh, really. Then what about music school...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":332,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":332,"voiceId":"event166-06-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":331}],"windowDisplayName":"Rei","body":"I didn't want to, but I had to quit...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":331,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":331,"voiceId":"event166-06-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":332}],"windowDisplayName":"Arisa","bod