PlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"True, that is a big responsibility to shoulder~. Especially since you're so kind.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event149-01-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Huh...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event149-01-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":23}],"windowDisplayName":"Lisa","body":"You always consider how the other side feels, you know? I mean, you're super aware of that kind of stuff.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":23,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":23,"voiceId":"event149-01-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"How the other side... feels...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event149-01-037","volume":1}],"