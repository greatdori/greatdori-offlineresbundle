 something happen?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"Seeing your face made me think of yesterday's City of Solitude... and it made me feel really sad...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Sad? But why? The show had a happy ending, didn't it?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"But...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Fufu, have you forgotten how it went? Oh, I know. Why don't we try re-enacting the final scene? That should help you remember.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"What?! I can't do something like that~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Don't worry. I'll take the lead, and it's alright to make mistakes. You can just do the parts that you remember, okay?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"O-okay...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"... \"Hurry up and leave the city. There's nothing here anymore.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"U-um... \"W-wait! What about you...? Aren't you coming?!\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"\"How ridiculous. Why would I want to go with all of you? Now get out of my sight.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf01","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"... What's wrong? It's your line next.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"This is the part where the main characters turn around and run off without ever looking back. Don't you remember?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"... B-but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"Are you really okay with that...?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"... Oh, Kao-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"\"In that case... will you stay with me?\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"...! \"Yeah, of course!\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"... Fufu. If that had been for the show, our ad-libbing would have been considered a blooper.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"Really?! Bloopers are bad, though, right...?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Yes... So it would've likely been rejected during actual filming.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"... Fufu... I don't mind this alternate version though.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"That's why this'll be our little secret. We'll be the only ones who know this version of the story. Okay, Kao-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event206-01-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"... Okay!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event206-01-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(... Well, I certainly seem to have gone quite a ways down memory lane.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(I suppose this is what it's like to become susceptible to distractions when there's something especially important that needs to be done.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(I've heard of people who end up cleaning their room or reading manga...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(... Looks like I'm no different. I ended up going through an old photo album.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(... It's all because of this. This ticket...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"\"Before I graduate, I wish to offer the little kittens a most fabulous Christmas present.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event206-01-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"\"It shall take the form of a Christmas play organized by none other than myself. I would very much like for you to attend. Will you, Chisato?\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event206-01-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(... You're supposed to have entrance exams just like the rest of us... Not to mention, you already got your farewell performance in fall.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(How very typical of you.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"And you've even remained that way right up to the end...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(... What am I saying. The Kaoru from back then is gone. I thought I accepted that already.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(People change and move on. Aya-chan, everyone else in the band, and even myself.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(Of course, Kaoru is no exception... Although, in her case, I feel the change has been somewhat extreme.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(Which isn't to say I dislike the way she is now. The person she's become is what made our current relationship possible.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(That's why I shouldn't be thinking about the way things used to be. The old Kaoru is gone.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(If I keep dwelling on it, I'll be left behind. By everyone in the band, Kaoru, and even the rest of the world.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(That's why...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(It's about time I also graduate and move on.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"... Isn't that right, Kao-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(I've taken a long enough break. I need to get back to studying.)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(Applying for comprehensive selection admission doesn't mean I don't have to study for general selection admission...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(I could fail Yotsuba Women's University's comprehensive admission or decide not to submit this application even...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event206-01-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(Yotsuba's Faculty of Humanities... The higher-rated Keiho Women's University's Faculty of Letters... Even Yotsuba's Faculty of Arts...)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(... Multiple paths lie before me.)","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":18,"voiceId":"event206-01-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"(And there's no way to tell where each one leads...)","tention":0,"