ndow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Piano Teacher","body":"Amazing, Rinko-chan! You can already play that difficult of a piece?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"Yes... I practiced very hard...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Piano Teacher","body":"Fufu, you really do love the piano, don't you? Seeing you play with such enthusiasm makes it fun for me, too.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"Ehehe...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Piano Teacher","body":"If you can handle something like this, then I think you're ready to enter much bigger competitions. Would you like to give it a try?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"B-but competitions... are...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Piano Teacher","body":"Don't worry. You've already won awards at smaller events, so you'll be fine with stepping up onto a larger stage.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"O-okay...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"That's a tad surprising. I assumed you would've been more hesitant about participating.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event70-03-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"It's not as though I was on board with it... Thinking of all those people watching me... had me terrified, even back then...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event70-03-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"But thinking of how proud everyone would be... had I entered... My mother and father... even my piano teacher...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event70-03-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"Nothing could have made me happier... And so, in spite of my fears... I agreed to participate...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event70-03-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":21}],"windowDisplayName":"Yukina","body":"I follow you so far...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":21,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":21,"voiceId":"event70-03-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"But I was young... and I had no idea what it really meant... to be under such a big spotlight...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event70-03-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":25}],"windowDisplayName":"Rinko","body":"My mother brought me... to a huge venue, as big as a concert hall... and that's where I was to play...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":25,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":25,"voiceId":"event70-03-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"(This place... is a lot bigger than the other ones...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"","expressionName":"default","timingSyncValue":0},{"characterId":315,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"(There are so many people... and they're all staring at me...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Staff","body":"... Shirokane-san? Rinko Shirokane-san?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"Huh...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event70-03-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Staff","body":"The judging has commenced. Please begin playing.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"sou