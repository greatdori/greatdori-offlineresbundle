eday...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":334,"voiceId":"event190-03-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Congratulations, Rin-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"Thank you... Rui-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"I know other people got a gold prize too, but you were the best.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"N-not really... Lots of people... were better than me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Nuh-uh, you were the best.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"I can tell how fun the piano is for you when you're playing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"And that lets me have fun too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"... B-but... your playing's the same way...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"The way you play the violin sounds very nice... I like it a lot...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"nnf04","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Thank you... That makes me very happy.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"But I wish I could get a gold prize just like you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"You should be able to... soon...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"I've got a good feeling too... I got a bronze prize today, but it's better than before.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"And I asked my mother to let me take more violin lessons, so I think can get a gold prize next time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"You'll be back for next month's competition, right? Will you come see me play?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf03","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"Of course... I can't wait...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"Rui, we need to go home soon.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Already...? But I want to talk with Rin-chan more.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"Rinko-chan's mother said they're going out to eat, remember?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"And you still have homework left. You promised you would study hard even with more lessons.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"... Okay. Bye, Rin-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":315}],"windowDisplayName":"Rinko","body":"... Goodbye...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":315,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":315,"voiceId":"event190-03-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Mom, can I practice the violin when we get home? I promise I'll study too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"Sure. You really love the violin, don't you?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"I love it a lot. It sounds so pretty.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Just listening to its pretty sound makes me want to keep playing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"Is that why you practice from day to night when you don't have school?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Night just sneaks up on me, but it's still lots of fun.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf05","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Mom, I'm going to get a gold prize because I want to be number one at the violin.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"nnf02","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"I see... Well, it is nice to get first place for something you love.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rui's Mother","body":"Good luck. I hope you can get that gold prize.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":334}],"windowDisplayName":"Rui","body":"Me too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":334,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":334,"voiceId":"event190-03-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":29,"costumeType":"029_school_summer","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffset