ed01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event111-05-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"I thought you were older than me! Wow, you really seem like an adult!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event111-05-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"Is that so? Thank you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event111-05-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Hey, hey, how tall are you, Rui-rui? You look really tall. Did you drink lots of milk?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event111-05-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"... No, I did not.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event111-05-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"E-erm, Hagumi-chan. You shouldn't bother Rui-chan with so many questions.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event111-05-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"... Was my school level the only thing you wanted to know?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event111-05-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Yeah, I was wondering what year you were. I just had to ask.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event111-05-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"I see. Well, I have answered your question, so I'll be going now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event111-05-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Huh? Go where?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event111-05-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"To see Minato-san. I have a few questions I would like to ask her about bands.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event111-05-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":13}],"windowDisplayName":"Hagumi","body":"Questions? I can answer them for you!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":13,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":13,"voiceId":"event111-05-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"...","tention":0,"lipSyncM