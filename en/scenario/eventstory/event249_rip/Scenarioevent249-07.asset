erenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Eh..! How do you know?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event249-07-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Momoka","body":"I guess us vocalists just get each other~ Fufufu.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Rio","body":"Sorry, LAYER-chan. She has a strangely good intuition.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"No, no…","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nnf04","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event249-07-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Momoka","body":"And here's a word of advice from a senior frontman~.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinis