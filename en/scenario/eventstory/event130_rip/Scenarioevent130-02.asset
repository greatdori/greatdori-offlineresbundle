,"volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"I wasn't trying to, but you were all talking so excitedly, so it was kind of hard not to.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Yeah, I guess you're right... Fufufu.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"So you're making a pamphlet, huh? Sounds like fun.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"It was like there was a Kasumi motivation explosion, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"It looked more like you were all bursting with motivation, not just Toyama-san. You seem pretty pumped too, Saya.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Could you tell...? That's because when all is said and done, I love Hanasakigawa.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nnf03","expressionName":"smile02","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"Considering we've been enrolled since middle school, we have been here for pretty long.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Ah! Do you want to make the pamphlet with us?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"Nah, if all of you are making it, it seems like it'll turn out pretty interesting. So I'll just look forward to seeing it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Whoa, did you just raise the bar for us?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"Of course not. I really meant it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"Let me know if there's anything I can help with. I love Hanasakigawa just as much as you do, after all.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Yeah, thanks... Ah, I got a message from Kasumi. Sorry, I'll see you later!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"See ya. Good luck with making the pamphlet.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-02-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Yeah! Expect something good!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-02-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"