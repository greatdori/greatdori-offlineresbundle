acterId":304}],"windowDisplayName":"Natsuki","body":"Well, I think that amount of greed is just right for you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-06-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Think so?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"event130-06-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"Definitely. I've known you since middle school, so there's no doubt about it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-06-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":304}],"windowDisplayName":"Natsuki","body":"Ah, I almost forgot. I told my other friends to write their recommendations too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":304,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":304,"voiceId":"event130-06-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundR