aracterId":5}],"windowDisplayName":"Arisa","body":"(What should I do...? I'd love to call out to them, but Kasumi and the others aren't here, so I don't know what to say...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event58-01-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"(Shoot~... I don't even know if we're all that close either. Will Ran-chan get mad if I try talking to her?)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event58-01-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"Arisa-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"event58-01-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"H-hey, Ran-chan~. Looks like you're in a good mood~... Hmm~, no good. What about-","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"event58-01-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":