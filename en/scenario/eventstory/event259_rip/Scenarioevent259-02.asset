event259-02-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"I agree.\nThe director may be strict, but she’s a fair person.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event259-02-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"Even if a student does something that goes against her wishes,\nas long as it follows the rules, she’ll respect it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event259-02-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Even so...\nyou can’t help but think, ‘What if?’","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Even if you know it’s fine, there’s always that ‘What if something happens...?’","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I know how that feels too...\nso I really understand where you’re coming from.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"uziuzi01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Tsukinomori Student B","body":"...Hey, are you guys planning to keep collecting signatures?","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"Y-Yeah, we are...\nbecause we want the Tsukinomori Music Festival to happen. Don’t you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event259-02-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Tsukinomori Student C","body":"I get how you feel, but... everyone’s really anxious.\nA lot of people besides us are already planning to return their signature sheets.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Tsukinomori Student B","body":"If this causes the rules to get even stricter... that would be awful. Please,\njust consider how this might end up causing trouble for everyone.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"――――","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Tsukinomori Student A","body":"We don’t want to make it any harder to live our school lives.\nWell then...","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"Trouble...\nIs that really what everyone thinks?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event259-02-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":27}],"windowDisplayName":"Toko","body":"That makes no sense! Of course, things happen when you try to do something!\nBut if you’re too scared to take action, then nothing’s ever going to change!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":27,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":27,"voiceId":"event259-02-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"Not everyone can think that way, you know.\nAnyway, we need to come up with some kind of solution.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event259-02-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"People are scared that by supporting the signature campaign,\nthey might end up on the director’s radar.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event259-02-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"Rui","body":"If we can’t address that fear, the Tsukinomori Music Festival won’t be able to happen.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event259-02-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"(...I thought everyone wanted the Tsukinomori Music Festival to happen.\nBut...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"(Does it really make sense to do something no one wants...?)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":29}],"windowDisplayName":"Tsukushi","body":"(Mashiro-chan...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":29,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":29,"voiceId":"event259-02-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"Teacher","body":"Kurata-san, thanks for your hard work as today’s class rep.\nTake care on your way home.","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Yes... excuse me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Good day, Kurata-san.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"C-Chairwoman-sensei...\nG-Good day...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"You’re not with Yashio-san and the others?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I was today’s class rep, so I’m by myself...\nUm... excuse me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Wait a moment.\nWhy are you holding the signature campaign?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"I have no ulterior motives. It’s just a genuine question.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Well...\nI wanted to bring energy back to Tsukinomori and everyone here.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Even if just for one day, I wanted the school to feel like it used to...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"I see... So it’s a temporary effort, without consideration for the future.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"... Let me share a bit of my own story.\nI believe I mentioned that I wasn’t originally a student of Tsukinomori.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Y-Yes...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"So, why did I transfer to Tsukinomori? The reason is—","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"I lacked confidence and couldn’t take the first step forward.\nI wanted to change that about myself.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Wait... you lacked confidence?\nYou, Chairwoman-sensei?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Surprised?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"Very... I’ve always thought of you as someone brimming with confidence.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"So, my reason was the same as yours...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"When I first transferred, it was a difficult time.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"The other students were incredibly talented, on a completely different level from other schools.\nAnd the solemn traditions and strict rules that Tsukinomori values...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Being in that environment, I came to realize how small I really was.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"I understand...\nI felt the same way...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"But even so, I wanted to change myself.\nAnd as I poured my heart into living my school life...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Before I knew it, my timid self was gone.\nEvery new thing I accomplished filled my heart with pride.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"The confidence I gained from overcoming these strict rules gave me a sense of radiance and pointed me toward the future I should strive for.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"...Your radiance will light the way...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event259-02-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Kurata-san, here’s my advice to you.\nI strongly suggest you stop the signature campaign immediately.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"Wanting to bring energy back to Tsukinomori is a commendable goal.\nHowever, that alone will not have any lasting impact on the future.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"What you should focus on now\nis upholding the solemn rules and embracing the pride of Tsukinomori’s spirit.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":227}],"windowDisplayName":"Chairwoman","body":"It is from that pride that your true radiance will emerge,\nguiding you toward the future you are meant to pursue.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":227,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":227,"voiceId":"event259-02-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"(No one at Tsukinomori wanted this...\nAnd the chairwoman said it was meaningless...)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":26,"voiceId":"event259-02-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"(Then...\nis there even a need to hold the Tsukinomori Music Festival?)","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":26,"voiceId":"event259-02-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"That's why... I want to give back to Tsukinomori.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":26,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":26,"voiceId":"event234-07-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":26}],"windowDisplayName":"Mashiro","body":"For the Tsukinomori Music Festival, I want to put on a concert that can cheer up the depressed Tsukinomori...!","tention":0,"lipSyncMode":1,"motionChangeFact