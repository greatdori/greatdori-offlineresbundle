,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Alright, I'll tell everyone you're coming too, Kao-chan!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"O-okay...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"\"The City of Solitude\" gained more and more attention as it aired, and went on to be recognized as an award-winning drama...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Your acting prowess was then acknowledged, which led to you receiving countless other roles.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"You remember it better than I do.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"pui01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event100-05-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu, that is because you are my cherished childhood friend. And then, on one fateful day, you took on the role of a kind-hearted and righteous detective.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Although it was the polar opposite of your character in \"The City of Solitude,\" I remember how you played it spectacularly and changed the opinions of our peers.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"It's not right. Ever since \"Mako the Kid Detective\" began, everyone has suddenly decided you're cool again.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf03","expressionName":"default","timingSyncValue":0},{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"I just... don't understand how they could do that...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"It doesn't matter anymore, Kao-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"Huh...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"It doesn't matter.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"I have you, Kao-chan, and Mama, my little sister, and... Leon. As long as all of my favorite people know who I am, that's enough for me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Regardless of what other people think of me, I'm an actor, and I am me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"Chii-chan, what's wrong? You seem different from before...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"I was starting to wonder what I should do if I stopped feeling sad, and it scared me...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"But I can use this feeling, and every other emotion I've ever felt, in my acting. That way, I have nothing to be afraid of.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"What do you mean... Chii-chan? Where are you going?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"You're so kind, Kao-chan.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Don't ever forget that this kindness is part of who you are.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"Chisato","body":"Fufu, you can be a little bit of a coward, and you let Leon pull you around, but that is who you are.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"Kaoru","body":"Chii-chan...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Our friendship has continued to live on even to this very day. However, I believe that day was a turning point for you, one at which you became a professional actor.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"...","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event100-05-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu, how nostalgic. You were like a bird leaving the nest.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"... Now that you mention it, we've been through a lot together.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event100-05-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"But you know, it was just as shocking for me when you suddenly became the Kaoru Seta we all know now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event100-05-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"I have always been my authentic self.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"Chisato","body":"If you say so.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event100-05-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"Kaoru","body":"Fufu... Shall we continue reminiscing a little while longer then?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"event100-05-045","volume":1}],"speed