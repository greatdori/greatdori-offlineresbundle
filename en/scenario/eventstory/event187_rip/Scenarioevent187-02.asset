cterId":34,"voiceId":"event187-02-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Calm down, you two. Anyone could tell that our performance was vastly superior.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event187-02-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":33}],"windowDisplayName":"MASKING","body":"You say that, but you've been pacin' back and forth over there too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":33,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":33,"voiceId":"event187-02-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I-I have not! Our electrifying performance will earn us a win easily!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event187-02-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"CHU²-sama, please do not lose your temper...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"event187-02-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Ouchhh! Who put a folding chair here, of all places~?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event187-02-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":34}],"windowDisplayName":"PAREO","body":"Are you okay?! Did you hurt yourself?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":34,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":34,"voiceId":"event187-02-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"I'm fine!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"nnf_left01","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":35,"voiceId":"event187-02-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"You don't need to be so worried. Our hard work has gotten us this far, so let's believe in that.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event187-02-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"LOCK","body":"You're right...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":32,"motionName":"nnf05","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":32,"voiceId":"event187-02-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":31}],"windowDisplayName":"LAYER","body":"Mhm... We'll be okay.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":31,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":31,"voiceId":"event187-02-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"MC","body":"Walküre High Light and RAISE A SUILEN! After careful consideration, the band that will proceed to the finals is...","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":35}],"windowDisplayName":"CHU²","body":"Here it comes...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":35,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"chara