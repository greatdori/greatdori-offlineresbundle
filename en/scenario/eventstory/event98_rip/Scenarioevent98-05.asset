ow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"What are we gonna do? They're serious. They're actually expecting Santa to show up!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"It seems like it, doesn't it...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"And he's probably... No, definitely not coming.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Don't you think we should set things straight while we still can?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Set things straight? What do you mean?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"What do you mean, what do I mean?! You know, Santa, he's not-","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"No, Santa is real.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Huh? K-Kanon-san, not you too...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Fufufu, don't worry. I think the Santa I'm referring to is a little different from the Santa that Kokoro-chan and Hagumi-chan are talking about.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"What do you mean?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"It sort of came to me when I heard Hagumi-chan's story before... I think there might be a bunch of Santas, all over the world.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"... What?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"All of that love and kindness that we receive on Christmas... Don't you think the people that deliver those feelings to us could be called \"Santa?\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"All the love that we receive on Christmas... Huh.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"In that case, wouldn't it be fine if Hagumi's Santa smells like croquettes?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"That's why I think Santa is real. Anyone can meet him, and anyone can become him, too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName":"Misaki","body":"Hagumi's... Santa, huh...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":15,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":15,"voiceId":"event98-05-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":14}],"windowDisplayName":"Kanon","body":"Besides, remember what she said? Her father's coming today...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":14,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":14,"voiceId":"event98-05-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":15}],"windowDisplayName