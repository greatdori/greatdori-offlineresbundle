fectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Despite everyone's encouragement, my fate was to melt away... The end.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Moca~, don't you dare melt~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-01-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Guys, you're stifling me here. Quit it already.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I saw on the news this morning that it's forecast to get even hotter. Anything hotter than this will be tough to bear...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"...! Times like these call for... the beach! We absolutely have to go to the beach~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"There is it. Hii-chan's invitation to take a dip in the ocean~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Hahaha. You know summer's begun when Himari starts inviting us to the beach!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-01-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"It's that time of the year already, huh~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Hey! Stop referring to it like it's some seasonal tradition~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Pass. I think I've said this before, but beach trips aren't my thing.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"You're always so quick to say no. Help me persuade her, Tsugu~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Fufufu, okay. We're about to arrive at CiRCLE, though, so how about we continue this conversation during our practice break?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Will Hii-chan be granted her wish to go to the beach~? What does destiny have in store...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Gosh~! I'll convince you. Just you wait and see!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Back to our conversation about the beach from earlier...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"You were thinking about that all throughout practice, weren't you, Hii-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"I was focused on practicing, thank you very much~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Now, now... Let's listen to what Himari-chan has to say.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"You're my only ally, Tsugu~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Anyway, when it's this hot every day, isn't it normal to wanna pour water over yourself or play around in it~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"That's where the beach comes in! It'll make all your desires come true! The slick sprays of water! The dazzling summer sun! Riding a float while gazing at the horizon!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"... You're starting to get the urge to go to the beach! Right?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Nope.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Whaaat~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"I don't really fancy sitting under the dazzling summer sun~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"On hot days, it's better to sit quietly inside an air-conditioned room.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"But it's summertime! It's our chance to enjoy the hot weather!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Besides, all we've got planned this summer are band practice and concerts! Is that really all there is to being a high school girl? That's just sad!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"What does this have to do with being a high school girl~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"... Huh? Sorry, I'm getting a phone call. I'll be right back~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Gosh, Moca, you always do everything at your own pace~. Tsugu~, back me up here~!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"I... don't think it's a sad life for a high school girl...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"However, I do want to go to the beach with you all. We couldn't join the last time you invited us.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Yeah, I'm down. I wanna see the sunset with everyone again.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-01-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Tsugu~, Tomoe~! So I can count you two in. Now all I need is for you guys to say yes, Ran, Moca...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"I'm not going.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Why not~?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"I'm back~. So? Did Hii-chan manage to persuade you guys~?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"bye01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Nah, Ran's a tough nut to crack.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-01-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"If you wanna go that badly, just go without me and Moca.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Then there's no point! I want us all to go together-","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"awate01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"If you're that insistent...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"... Huh?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Looks like I've got no choice. Guess I'll join you at the beach-.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":900000}],"windowDisplayName":"Ran, Tsugumi, Himari & Tomoe","body":"Whaaat?!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":900000,"voiceId":"event191-01-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"A-are you serious? This is the beach we're talking about! The beach! With the dazzling summer sun!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"I know, I know. Oh? Did you want me to turn down your invitation instead?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"O-of course not!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"In that case, count me in~.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"niyaniya01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"That's one down... What about you, Ran-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"I...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"... Hey, Ran. This summer of ours, it only exists right now.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"When our summer as second-years comes to an end, there won't be another one like it.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Moca...! What an insightful thing to say! That's it! That's exactly what I was trying to tell you all!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"What's gotten into you, Moca? You're like a different person all of a sudden...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-01-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":7}],"windowDisplayName":"Moca","body":"Not at all~... I was simply moved by the passionate cries of Hii-chan's soul.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":7,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":7,"voiceId":"event191-01-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Moca~, thank you~! Now we're just waiting on you, Ran! Give in, already!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Sigh~... Fine. If you really want me to go that badly.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"sigh01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Yippee! Then it's decided! Let's decide on a date that suits us all later!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"When we reach the beach, first, we need to change into cute swimsuits. Then we'll build sandcastles, play in the water, and take lots of cute pictures! After that...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-063","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":10}],"windowDisplayName":"Tsugumi","body":"Himari-chan, that's one big to-do list.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":10,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":10,"voiceId":"event191-01-064","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"Himari","body":"Sure is~! I wanna eat a ton of yummy food at a beach hut, too~! And finally, at the end of the day, I wanna shout at the sunset together!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"event191-01-065","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":9}],"windowDisplayName":"Tomoe","body":"Haha, they did that in a television series, recently, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":9,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":9,"voiceId":"event191-01-066","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":6}],"windowDisplayName":"Ran","body":"Okay, that's enough about the beach. Let's continue practicing...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":6,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":6,"voiceId":"event191-01-067","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0}],"selectableData":[],"layoutData":[{"type":2,"sideFrom":4,"sideFromOffsetX":0,"sideTo":4,"sideToOffsetX":0,"depthType":0,"characterId":7,"costumeType":"007_school_summer_s2","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":3,"sideFromOffsetX":0,"sideTo":3,"sideToOffsetX":0,"depthType":0,"characterId":6,"costumeType":"006_school_summer_s2","motionName":"","expressionName":"default","moveSpeedType":0},{"type":2,"sideFrom":7,"sideFromOffsetX":0,"sideTo":7,"sideToOffsetX":0,"depthType":0,"characterId":7,"costumeType":"007_school_summer_s2","motionName":"","expressionName":"default","moveSpe