artHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Can't we name the band some other time? I think it's time for everyone to go home.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-15-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Oh, that's right. It's already this late...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-15-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... And we haven't decided on anything after all.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-15-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"Anon","body":"Isn't it because you're always complaining, Rikki?\nTomori-chan even said she'd do her best on the tambourine.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf03","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"event235-15-061","volume":1}],"speed":0,"fontSize":0,"wh