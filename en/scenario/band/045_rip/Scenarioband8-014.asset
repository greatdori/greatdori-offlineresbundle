fect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"You think so too, don't you, Taki-chan?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-14-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"What?...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-14-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"... Even when we started gathering less and less, Taki-chan has always been waiting for you to come to practice.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-14-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"... Are you not angry with me?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-14-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCl