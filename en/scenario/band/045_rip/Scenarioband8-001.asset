ideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"... Tomori asked you a question. Why aren't you answering?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-01-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Taki-chan, don't --","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-01-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"I mean, isn't that irresponsible? You've stood us up so many times for practice, and then you'll quit without any explanation....","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-01-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":40}],"windowDisplayName":"Taki","body":"If you're going to quit, can you quit without causing us trouble?\nEven today, we were waiting for you--","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":40,"motionName":"angry04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":40,"voiceId":"event235-01-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":39}],"windowDisplayName":"Soyo","body":"Taki-chan!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":39,"motionName":"nnf02","expressionName":"angry01","timingSyncValue":0}],"voices":[{"characterId":39,"voiceId":"event235-01-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"... You could have practiced without me, couldn't you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"angry02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-01-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":341}],"windowDisplayName":"Sakiko","body":"There's no rule that says you can't do it unless everyone's here. Don't pin the blame on me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":341,"motionName":"angry03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":341,"voiceId":"event235-01-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":36}],"windowDisplayName":"Tomori","body":"But without Saki-chan--","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":36,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":36,"voiceId":"event235-01