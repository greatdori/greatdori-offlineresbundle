tartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Don't cry...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Just so you know, we were already aware from the beginning that the rest of us are better musicians than you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"And we didn't let that bother us. We just kept pushing forward. Why do you care about that now?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Did someone say something to you?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"remakestory-24-038","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"The owner told me that I don't understand the people around me or myself...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-039","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"... She's not wrong.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-040","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Once you decide to do something, you just do it without listening to a thing we say. When we get dragged into something, we get hurt too.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-041","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Ohhh...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"But it's not all bad. I won't deny that it's annoying sometimes, but I felt like I should work harder because you were pushing me.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Arisa...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"cry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"At first, I was really surprised when you said you would audition at SPACE. You only just managed to play a beginner's version of Twinkle Twinkle Little Star...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"remakestory-24-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"But you told me, \"I'm not sure, but I can work really hard!\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"remakestory-24-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"You're not sure...?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile01","expressionName":"default","timingSyncValue":0},{"characterId":5,"motionName":"angry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"... I was blinded by your brilliance. I love how you were firm with your words.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"remakestory-24-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"I still thought it was too early for us to get up on that stage, but I was okay with giving it our best shot.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"remakestory-24-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"That time when you ran on stage with nothing in your hands was the moment you truly shone for me!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"remakestory-24-050","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"It was amazing... That's how I found the courage to jump in too. I wanted to be \"sparkling and heart-pounding,\" just like you.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"remakestory-24-051","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Like... me?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-052","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"I think you really shine when you're chasing after something. I don't know if that's necessarily the 'sparkling' you're looking for, but...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"remakestory-24-053","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"Seeing you do that made me feel jealous. All I could do for so long was stand still.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"remakestory-24-054","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"But then you came and pulled me along with you... You asked me to join you, Arisa, Rimi-rin and O-Tae... You asked me to be a part of the band!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"remakestory-24-055","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Nnn, that's just because I wanted us to play together...!","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"cry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-056","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"And that's good enough, isn't it? You're overthinking things. Forget about not being good and not being able to pass the audition. Forget that stuff.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-057","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"It was you who told me those sweet words, wasn't it? That I don't have to worry about things on my own. \"Let us figure this out together.\"","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"remakestory-24-058","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Saya...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"cry01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-059","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"Rimi","body":"When the owner said you don't understand yourself, I think she was talking about your skill level.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"remakestory-24-060","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":2}],"windowDisplayName":"Tae","body":"If you don't know where you fall short, it's impossible to know how to improve.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":2,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":2,"voiceId":"remakestory-24-061","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"Saya","body":"But now you know what you're missing, right?","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"remakestory-24-062","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":1}],"windowDisplayName":"Kasumi","body":"Mhm... Lots of things...","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":1,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":1,"voiceId":"remakestory-24-063","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":5}],"windowDisplayName":"Arisa","body":"Ah... I have a suggestion.","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":5,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":5,"voiceId":"remakestory-24-064","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"