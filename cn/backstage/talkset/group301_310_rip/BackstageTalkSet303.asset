{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet303","backstageTalkSetId":303,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet303-1","talkText":"小麻弥，\n最近你工作很努力呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet303-2","talkText":"是吗？很高兴\n听到你这么称赞我呀！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet303-3","talkText":"这样的你使我深受鼓舞，\n我也不得不继续努力呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}