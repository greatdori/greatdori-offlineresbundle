{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet301","backstageTalkSetId":301,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet301-1","talkText":"犹如深渊般黑暗的祝福啊，\n把吾之力量……呃……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet301-2","talkText":"把吾之力量\n噜♪出来吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet301-3","talkText":"呃，噜♪的话\n感觉太随意了~！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}