{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet310","backstageTalkSetId":310,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet310-1","talkText":"麻弥同学，\n今天要不要一起去吃饭？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet310-2","talkText":"好啊！\n去哪吃？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet310-3","talkText":"前段时间，我发现了一家\n很好吃的日料餐厅哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}