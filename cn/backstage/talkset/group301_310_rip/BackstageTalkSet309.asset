{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet309","backstageTalkSetId":309,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet309-1","talkText":"芬兰也有\n吉他的生产商哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet309-2","talkText":"虽然不是很有名，\n但做工还是很精细的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet309-3","talkText":"哦哦，不愧是麻弥同学！\n我都不知道呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}