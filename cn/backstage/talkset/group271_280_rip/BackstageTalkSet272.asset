{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet272","backstageTalkSetId":272,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet272-1","talkText":"濑田学姐，我去看了\n你的演技练习哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet272-2","talkText":"那个决斗的场景，\n真的好激烈啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet272-3","talkText":"呵呵，谢谢。\n敬请期待正式演出吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}