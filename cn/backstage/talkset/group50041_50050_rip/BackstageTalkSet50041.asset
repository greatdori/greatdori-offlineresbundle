{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50041","backstageTalkSetId":50041,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50041-1","talkText":"明天……是友希那同学的生日，\n真期待呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50041-2","talkText":"嗯，毕竟莉莎姐的提议\n是真的很棒呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50041-3","talkText":"是、是吗？要是能让友希那\n开心就好了~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50041-4","talkText":"我觉得这种庆祝方式\n也很不错哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}