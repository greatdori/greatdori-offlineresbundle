{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50044","backstageTalkSetId":50044,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet50044-1","talkText":"小有咲，\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet50044-2","talkText":"给，有咲！这是我们\n亲手做的的留言板哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet50044-3","talkText":"大家写了好多\n想传达给有咲的心意哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50044-4","talkText":"谢、谢了……\n感觉有点害羞呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet50044-5","talkText":"是香澄提议\n做这个留言板的哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet50044-6","talkText":"虽然平时处理学生会的工作很辛苦，\n你也总是很努力呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2],"voiceId":"TalkSet50044-7","talkText":"即便碰到很难的乐句，\n你也绝对不会轻言放弃","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet50044-8","talkText":"不管在什么方面，\n你都总是很照顾大家呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet50044-9","talkText":"谢谢你这么珍视\nPopipa！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet50044-10","talkText":"……这种事\n不是应该的吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[1],"voiceId":"TalkSet50044-11","talkText":"哇啊！有咲好坦率！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[5],"voiceId":"TalkSet50044-12","talkText":"啰、啰嗦！\n偶尔这样一次也没问题吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}