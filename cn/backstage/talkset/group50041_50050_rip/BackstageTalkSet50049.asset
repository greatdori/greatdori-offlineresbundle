{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50049","backstageTalkSetId":50049,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet50049-1","talkText":"总算决定好送给\n惠惠的礼物了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50049-2","talkText":"我都不知道\n种类居然那么多~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet50049-3","talkText":"我平时也不会跑步，\n所以很难抉择呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet50049-4","talkText":"不过，光是看着\n就让人不由得兴奋呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[1],"voiceId":"TalkSet50049-5","talkText":"我也从明天\n开始跑步吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}