{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50042","backstageTalkSetId":50042,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50042-1","talkText":"凑同学，辛苦了\n这是点心和……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet50042-2","talkText":"蜂蜜茶……\n如果不嫌弃的话，请用……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet50042-3","talkText":"谢谢你们。\n味道很香呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50042-4","talkText":"亚子来给你揉揉肩！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50042-5","talkText":"还有这个！据说这个视频\n可以治愈心灵哦☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50042-6","talkText":"（小猫咪的\n视频合集……！？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet50042-7","talkText":"……不是，今天\n到底是怎么回事？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50042-8","talkText":"友希那同学！\n今天不是你的生日吗！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50042-9","talkText":"所以我们希望友希那今天\n能放松一下","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet50042-10","talkText":"为了维持良好的状态，\n适度的休息是很有必要的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50042-11","talkText":"要是有什么需要我们做的，\n请告诉我们哦……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[21],"voiceId":"TalkSet50042-12","talkText":"原来是这样啊。\n谢谢你们，我很开心哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}