{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet729","backstageTalkSetId":729,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet729-1","talkText":"啊！\n是烤红薯的摊贩吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet729-2","talkText":"我刚才听到了\n叫卖烤红薯的声音哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet729-3","talkText":"呵呵，是在往\n这附近走吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet729-4","talkText":"肯定是的哦！\n我们去迎接他吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet729-5","talkText":"等、等一下，\n小香澄~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}