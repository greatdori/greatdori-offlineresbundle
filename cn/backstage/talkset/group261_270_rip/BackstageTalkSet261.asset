{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet261","backstageTalkSetId":261,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet261-1","talkText":"抱歉，我来晚了，\n等很久了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet261-2","talkText":"没有呀！但是……\n鸫鸫竟然会迟到，好少见啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet261-3","talkText":"因为出门的时候\n饼干还差一点才能烤好，所以就……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet261-4","talkText":"哇，是饼干！\n看起来好好吃~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}