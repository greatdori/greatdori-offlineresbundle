{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet265","backstageTalkSetId":265,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet265-1","talkText":"今天社团的练习\n好辛苦啊~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet265-2","talkText":"因为打网球要不停\n在场上跑来跑去嘛","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet265-3","talkText":"发球发得我手很酸，\n脚也很痛——","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet265-4","talkText":"啊，我懂。\n真的真的懂","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}