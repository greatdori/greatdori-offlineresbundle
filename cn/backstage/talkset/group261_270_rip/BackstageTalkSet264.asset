{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet264","backstageTalkSetId":264,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet264-1","talkText":"之前我买的杂志里\n刊登了彩同学的照片哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet264-2","talkText":"身上的衣服装饰什么的\n都超级可爱！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet264-3","talkText":"真的吗！？谢谢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[16],"voiceId":"TalkSet264-4","talkText":"很高兴能从朋友口中\n听到这种话呀~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}