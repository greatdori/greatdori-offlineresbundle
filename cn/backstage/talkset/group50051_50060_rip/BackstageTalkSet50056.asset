{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50056","backstageTalkSetId":50056,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50056-1","talkText":"鸫，生日快乐","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet50056-2","talkText":"是兰提议要送你\n可爱的花哦~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50056-3","talkText":"因为不知道选哪个好，\n所以大家每人挑选了一支！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet50056-4","talkText":"哇啊，我好开心！\n都是什么样的花呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50056-5","talkText":"我选的是雏菊！\n花语是『真正的友谊』！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet50056-6","talkText":"我选的是洋甘菊，\n听说有舒缓心情的功效","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50056-7","talkText":"小摩卡选的是丁香花\n兰，这种花的花语是~？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50056-8","talkText":"『重要的朋友』，\n你明明是查了以后才选的吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50056-9","talkText":"啊哈哈~小摩卡\n真是糊涂呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet50056-10","talkText":"最后是郁金香。\n是鸫的诞生花","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[6],"voiceId":"TalkSet50056-11","talkText":"装饰在店里或者\n自己喜欢的地方吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[10],"voiceId":"TalkSet50056-12","talkText":"嗯，谢谢！\n呵呵，好香啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}