{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50059","backstageTalkSetId":50059,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50059-1","talkText":"把那个送给薰同学\n当生日礼物没问题吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet50059-2","talkText":"育美可是把自己想象成\n薰同学来选的哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet50059-3","talkText":"我也是哦！于是\n脑海中就浮现出了那个！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet50059-4","talkText":"啊哈哈，确实是\n非常梦幻的礼物呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}