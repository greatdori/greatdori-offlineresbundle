{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet785","backstageTalkSetId":785,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet785-1","talkText":"茶道部办的茶会，已经\n定下搭哪种点心了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet785-2","talkText":"这个啊……\n搭这种怎么样呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet785-3","talkText":"哇，\n好可爱的练切啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet785-4","talkText":"好像是之前报道的那家店\n推出的招牌商品！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet785-5","talkText":"方便的话，\n待会儿我们一起去看看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}