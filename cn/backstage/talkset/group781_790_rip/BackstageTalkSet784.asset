{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet784","backstageTalkSetId":784,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet784-1","talkText":"巧克力海螺包的\n『海螺』是指什么呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet784-2","talkText":"听你这么一说……\n要不要来搜索看看？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet784-3","talkText":"唔……在意大利语中，\n好像是从号角这个词演变而来的呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet784-4","talkText":"号角啊……会不会有人\n曾经用它办过演奏会呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet784-5","talkText":"……用这个当乐器，\n未免太狂热了吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}