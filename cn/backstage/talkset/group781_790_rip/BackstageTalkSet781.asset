{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet781","backstageTalkSetId":781,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet781-1","talkText":"小育美，请问！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet781-2","talkText":"如果星星爆炸了，\n你觉得会发生什么~？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet781-3","talkText":"诶~！育美\n不想让它爆炸啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet781-4","talkText":"所以说……那个……\n答案是育美会难过！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet781-5","talkText":"啊哈哈！\n原来如此，是这样的答案啊~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}