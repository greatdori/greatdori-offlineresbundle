{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet788","backstageTalkSetId":788,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet788-1","talkText":"前段时间，我去了一趟\n有点儿远的地方拍照片","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet788-2","talkText":"这样啊……\n我可以看看你拍的照片吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet788-3","talkText":"当然可以！\n这张是清晨的公园……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet788-4","talkText":"好美……\n感觉空气很清新……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet788-5","talkText":"（就像是对即将开始的一天\n充满了期待）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet788-6","talkText":"呵呵，你很喜欢吗？\n接下来，这张是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}