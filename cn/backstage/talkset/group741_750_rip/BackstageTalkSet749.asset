{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet749","backstageTalkSetId":749,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet749-1","talkText":"在冬天骑摩托车\n不会觉得冷吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[33],"voiceId":"TalkSet749-2","talkText":"虽然冷，但是空气很清澈\n很舒服哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet749-3","talkText":"原来如此！\n会是什么感受呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet749-4","talkText":"下次我骑车带你体验吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet749-5","talkText":"真的吗！？\n哇！　太好啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}