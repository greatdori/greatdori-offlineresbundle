{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2035","backstageTalkSetId":2035,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2035-1","talkText":"真想有一天\n和大家一起合宿啊~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2035-2","talkText":"听起来很有趣的样子！\n现在就来合宿吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2035-3","talkText":"好、好像有点太快了，\n不过我确实也想试试","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2035-4","talkText":"如果这样能更有助于练习，\n那我也不介意","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2035-5","talkText":"合宿的食物就交给我吧！\n我对做饭还是很有自信的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2035-6","talkText":"虽然筑筑非常自信，\n但不知为何我很不安……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2035-7","talkText":"唔~如果小透子这么说的话，\n我就不准备你的饭了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}