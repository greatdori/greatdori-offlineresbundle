{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2037","backstageTalkSetId":2037,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2037-1","talkText":"这次真的要认真思考\n办一个能让大家情绪高涨的演唱会了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2037-2","talkText":"上次大家从中途开始\n就在开玩笑了~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2037-3","talkText":"从舞台后方\n发射激光，怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2037-4","talkText":"哦，不错呢！\n很帅！采用~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2037-5","talkText":"冒烟\n感觉也很帅呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2037-6","talkText":"这个也不错！\n采用~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[30],"voiceId":"TalkSet2037-7","talkText":"我觉得比起演出，\n还是靠演奏吸引观众更好","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[27],"voiceId":"TalkSet2037-8","talkText":"这才是最帅气的！\n瑠唯的意见也要采用！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet2037-9","talkText":"刚才的与其说是意见，\n不如说是提醒大家要注意……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}