{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2033","backstageTalkSetId":2033,"snippets":[{"talkId":1,"characterIds":[27],"voiceId":"TalkSet2033-1","talkText":"啊，对了！\n这是给大家的特产","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[26],"voiceId":"TalkSet2033-2","talkText":"谢谢，这个巧克力\n看起来很好吃呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2033-3","talkText":"啊，我知道这个！\n是一家很有名的店吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[27],"voiceId":"TalkSet2033-4","talkText":"是的，因为我周末\n去了比利时","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[26],"voiceId":"TalkSet2033-5","talkText":"是国外的特产！？\n好、好厉害……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[27],"voiceId":"TalkSet2033-6","talkText":"是吗？\n总之，大家一起吃吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet2033-7","talkText":"这个很好吃呢~\n我也很喜欢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[30],"voiceId":"TalkSet2033-8","talkText":"我下周也要去国外，\n买点什么回来吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[26],"voiceId":"TalkSet2033-9","talkText":"久违地再次感受到\n大家都是大小姐了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}