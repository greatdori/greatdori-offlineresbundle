{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2038","backstageTalkSetId":2038,"snippets":[{"talkId":1,"characterIds":[32],"voiceId":"TalkSet2038-1","talkText":"乡下送过来了一些吃的，\n请尝尝看！这是五平饼！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet2038-2","talkText":"哇！看上去好好吃！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[32],"voiceId":"TalkSet2038-3","talkText":"说是让我送给\n平时照顾我的人","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet2038-4","talkText":"所以就送给我吗！？\nLOCK，谢谢你——！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}