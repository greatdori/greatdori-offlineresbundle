{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet534","backstageTalkSetId":534,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet534-1","talkText":"小心心，你把信\n寄给圣诞老人了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet534-2","talkText":"对啊，我写了\n“成为Hello Happy的同伴吧！”","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet534-3","talkText":"圣诞老人也想让大家露出笑容，\n是我们的同志呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet534-4","talkText":"我说，花音同学。\n心的愿望……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet534-5","talkText":"呵呵，我觉得\n说不定会实现哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}