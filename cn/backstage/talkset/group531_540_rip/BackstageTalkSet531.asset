{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet531","backstageTalkSetId":531,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet531-1","talkText":"好，现在开始决定\n今年圣诞节大家的分工咯！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet531-2","talkText":"好，小摩卡想要\n负责吃的工作","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet531-3","talkText":"驳回。我和摩卡一起\n出去采购","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet531-4","talkText":"那我就装饰一下\n圣诞树之类的物件吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet531-5","talkText":"那我和小绯玛丽\n就负责做饭吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet531-6","talkText":"今年也玩个痛快吧~！\n嘿、嘿、哦~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}