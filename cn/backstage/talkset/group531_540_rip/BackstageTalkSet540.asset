{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet540","backstageTalkSetId":540,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet540-1","talkText":"生日快乐，小彩。\n这是我的礼物","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet540-2","talkText":"是发圈啊~！\n闪闪发亮呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet540-3","talkText":"嘿嘿，我觉得\n这发圈很适合彩学姐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet540-4","talkText":"因为它既可爱\n又闪闪发光♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet540-5","talkText":"嘿嘿，好害羞啊！\n谢谢你们俩啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}