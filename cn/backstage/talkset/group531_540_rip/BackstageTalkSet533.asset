{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet533","backstageTalkSetId":533,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet533-1","talkText":"大家做好\n交换礼物的准备了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet533-2","talkText":"是，我准备了\n精美的礼品！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet533-3","talkText":"我也带来了很噜♪\n的东西哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet533-4","talkText":"我现在有点担心\n选这个做礼物合不合适……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet533-5","talkText":"这种东西重要的\n是心意，所以别担心啦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet533-6","talkText":"那就开始咯……咦，\n我的礼物去哪了！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}