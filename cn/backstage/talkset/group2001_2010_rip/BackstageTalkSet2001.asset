{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2001","backstageTalkSetId":2001,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2001-1","talkText":"服装设计的灵感，\n你都是在什么时候想到的？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[27],"voiceId":"TalkSet2001-2","talkText":"去卡拉OK的时候，\n或者去拍趣味照片的时候？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[27],"voiceId":"TalkSet2001-3","talkText":"啊，还有和朋友一起\n吃可丽饼的时候！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet2001-4","talkText":"全、全都是\n玩的时候呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}