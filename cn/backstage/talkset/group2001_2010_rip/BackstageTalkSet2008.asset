{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2008","backstageTalkSetId":2008,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet2008-1","talkText":"有没有什么方法\n能在舞台上不紧张呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2008-2","talkText":"把客人当做蔬菜\n就可以了吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[26],"voiceId":"TalkSet2008-3","talkText":"原来如此……\n但是蔬菜可能不太合适……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2008-4","talkText":"啊，这么说来\n你不喜欢吃蔬菜呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}