{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet697","backstageTalkSetId":697,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet697-1","talkText":"突然好想吃\n暖呼呼的巧克力海螺包……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet697-2","talkText":"那是什么！？\n育美也好想吃吃看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet697-3","talkText":"啊，如果油炸一下，\n可能会变得更好吃！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet697-4","talkText":"刚炸好的巧克力海螺包……\n看上去很美味……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet697-5","talkText":"小里美，今天回家\n炸炸看吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}