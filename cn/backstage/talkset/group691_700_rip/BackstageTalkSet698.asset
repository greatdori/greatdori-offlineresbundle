{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet698","backstageTalkSetId":698,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet698-1","talkText":"下次似乎会推出\n名叫“冬季动物”的食品玩具~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet698-2","talkText":"那是什么？\n会有什么样的动物啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet698-3","talkText":"有北狐、北海道狸，\n还有秋田犬之类的动物呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet698-4","talkText":"姐姐估计会很开心！\n好想送给她啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet698-5","talkText":"我也很好奇，\n我们一起去买吧~？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}