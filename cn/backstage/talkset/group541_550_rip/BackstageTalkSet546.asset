{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet546","backstageTalkSetId":546,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet546-1","talkText":"快看快看！这张照片里的\n亚子超级帅吧！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet546-2","talkText":"冥界的看门狗，刻耳柏洛斯\n都为我俯首称臣！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet546-3","talkText":"这狗狗体型真大啊！\n旁边的小亚子也好可爱","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet546-4","talkText":"别、别说什么可爱，\n要夸就夸我帅气啦~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}