{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet545","backstageTalkSetId":545,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet545-1","talkText":"今年终于要结束了。\n时间过得真快啊~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet545-2","talkText":"嗯嗯！\n又多了好多纪念日呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet545-3","talkText":"希望明年能和今年一样\n快快乐乐的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet545-4","talkText":"既然这样，现在大家\n来想一想明年要做什么吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet545-5","talkText":"做明年的规划吗。\n挺好的嘛？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet545-6","talkText":"哇~想做的事情有好多，\n好难决定啊~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[4],"voiceId":"TalkSet545-7","talkText":"我懂~想做的事\n一个劲地冒出来呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[2],"voiceId":"TalkSet545-8","talkText":"我大概\n能想到一百个左右","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[1],"voiceId":"TalkSet545-9","talkText":"我也差不多！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[5],"voiceId":"TalkSet545-10","talkText":"这也实在\n太多了点吧！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}