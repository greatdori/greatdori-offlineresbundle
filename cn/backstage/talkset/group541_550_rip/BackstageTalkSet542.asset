{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet542","backstageTalkSetId":542,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet542-1","talkText":"今年马上\n就要结束了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet542-2","talkText":"是啊！那个，\n大家要不要来办一场年末聚会？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet542-3","talkText":"我赞成！亚子\n想试试黑暗火锅！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet542-4","talkText":"黑暗火锅……？\n希望起码都是些能吃的东西","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet542-5","talkText":"或许应该限制在\n火锅食材的范围内……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet542-6","talkText":"那么，大家都带些\n火锅食材过来吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet542-7","talkText":"哇，听起来\n很开心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[22],"voiceId":"TalkSet542-8","talkText":"只要准备好肉和蔬菜,\n至少不会太离谱吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[21],"voiceId":"TalkSet542-9","talkText":"是啊。\n这下就能安心了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[25],"voiceId":"TalkSet542-10","talkText":"（大家一起吃火锅……\n好期待啊……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}