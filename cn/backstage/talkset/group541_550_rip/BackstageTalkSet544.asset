{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet544","backstageTalkSetId":544,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet544-1","talkText":"差不多该给房间\n做个大扫除了~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet544-2","talkText":"啊~都到这个时节了啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet544-3","talkText":"我已经打扫干净了~\n很厉害吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet544-4","talkText":"没想到摩卡在这方面\n还挺积极的呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[10],"voiceId":"TalkSet544-5","talkText":"我这边也结束了，\n不过店铺那边还没有","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet544-6","talkText":"那我们来帮忙吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet544-7","talkText":"我赞成~鸫鸫，\n店里大扫除的时候记得告诉我们~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[10],"voiceId":"TalkSet544-8","talkText":"谢谢大家！\n我去问问妈妈！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9],"voiceId":"TalkSet544-9","talkText":"结束以后再去吃碗拉面，\n来为今年收尾吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet544-10","talkText":"不是吃荞麦面啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}