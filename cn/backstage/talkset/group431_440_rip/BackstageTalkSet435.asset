{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet435","backstageTalkSetId":435,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet435-1","talkText":"明天就是育美的生日了。\n要怎么庆祝好呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet435-2","talkText":"我为育美准备了玫瑰\n和自己写的诗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet435-3","talkText":"我打算用烟花和游行\n为她庆祝！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet435-4","talkText":"那、那么，呃……\n我怎么办才好……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet435-5","talkText":"花音同学冷静一点。\n普通地庆祝就行了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}