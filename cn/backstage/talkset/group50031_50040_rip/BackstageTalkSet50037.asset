{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50037","backstageTalkSetId":50037,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet50037-1","talkText":"明天是燐子的生日呢。\n亚子，谢谢你做了这么多","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50037-2","talkText":"诶嘿嘿，\n亚子想让燐燐开心嘛！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50037-3","talkText":"呵呵，果然拜托亚子\n是正确的选择呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet50037-4","talkText":"嗯，我很期待明天\n白金同学的反应哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}