{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50038","backstageTalkSetId":50038,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet50038-1","talkText":"白金同学，\n生日快乐","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50038-2","talkText":"今天为你准备了\n超级帅气的蛋糕哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet50038-3","talkText":"帅气的……\n蛋糕……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50038-4","talkText":"蹡蹡！你看！\n是特制蛋糕！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50038-5","talkText":"好、好棒……啊，\n难不成这根魔杖是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet50038-6","talkText":"我记得你在NFO里\n用的就是这根魔杖吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet50038-7","talkText":"是、是的……\n还原度真高呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[23],"voiceId":"TalkSet50038-8","talkText":"我说，燐子！\n把这根杖拔出来吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[25],"voiceId":"TalkSet50038-9","talkText":"好、好的……！\n嘿咻……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50038-10","talkText":"哇啊！燐燐！\n超级帅气哦！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}