{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50040","backstageTalkSetId":50040,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet50040-1","talkText":"兰！鸫鸫！\n来，茄子！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet50040-2","talkText":"哇啊，吓我一跳！\n茄、茄子……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet50040-3","talkText":"绯玛丽从刚才开始\n拍了很多张呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet50040-4","talkText":"当然了！因为实在是\n太开心了啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet50040-5","talkText":"摩卡和巴也一起来！\n好了，茄子！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet50040-6","talkText":"耶~小绯\n生快~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet50040-7","talkText":"对了，难得有这个机会，\n大家一起拍一张吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[8],"voiceId":"TalkSet50040-8","talkText":"我赞成！大家靠过来\n靠过来！好了，茄子！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[10],"voiceId":"TalkSet50040-9","talkText":"这次的礼物能让你喜欢\n真是太好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50040-10","talkText":"嗯！我会珍惜\n这个玩具相机的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}