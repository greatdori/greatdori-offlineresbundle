{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet596","backstageTalkSetId":596,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet596-1","talkText":"最近天气\n暖和了许多呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet596-2","talkText":"是的。春天到了，\n好开心啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet596-3","talkText":"天气冷的时候，\n手指就不能灵活演奏……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet596-4","talkText":"呵呵，莉莎她们\n也说了同样的话","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}