{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet599","backstageTalkSetId":599,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet599-1","talkText":"待会儿我要去\n鸫同学家店里打工","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet599-2","talkText":"你还参加了那么多社团，\n不会很辛苦吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet599-3","talkText":"和精通变身术的\n美咲同学相比，我还差得远呢……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet599-4","talkText":"咦，难道你是指的\n米歇尔吗……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}