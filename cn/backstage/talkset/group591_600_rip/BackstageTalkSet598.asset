{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet598","backstageTalkSetId":598,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet598-1","talkText":"我说啊，不觉得这块石头\n看起来很像兔子吗！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet598-2","talkText":"好、好可爱！\n一起去看看吧！马上就出发","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet598-3","talkText":"哎！？\n但这座公园在很远的地方哦！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet598-4","talkText":"哇，已经走掉了！\n惠惠，等等我~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}