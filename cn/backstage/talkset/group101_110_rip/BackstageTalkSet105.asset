{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet105","backstageTalkSetId":105,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet105-1","talkText":"然后哦，\n她好温柔地~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet105-2","talkText":"我懂我懂！\n我的姐姐也是哦~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[9],"voiceId":"TalkSet105-3","talkText":"你、你们两个\n在聊什么啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet105-4","talkText":"亚子和小日菜\n在炫耀自己的姐姐呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet105-5","talkText":"聊得超兴奋的！\n啊，太开心了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet105-6","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[9],"voiceId":"TalkSet105-7","talkText":"感、感觉\n好害羞啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[22],"voiceId":"TalkSet105-8","talkText":"是啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}