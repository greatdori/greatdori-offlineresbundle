{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet110","backstageTalkSetId":110,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet110-1","talkText":"小时候的薰学姐\n是怎样的人呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet110-2","talkText":"我、我也很想知道！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet110-3","talkText":"这个嘛……\n说来话长……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet110-4","talkText":"我有一段非常\n梦幻的幼年期哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet110-5","talkText":"学、学姐！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":6,"characterIds":[3],"voiceId":"TalkSet110-6","talkText":"薰、薰同学！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet110-7","talkText":"对吧，千圣？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet110-8","talkText":"……嗯，你说得对","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}