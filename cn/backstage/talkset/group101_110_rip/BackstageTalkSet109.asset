{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet109","backstageTalkSetId":109,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet109-1","talkText":"啊，是小巴！\n今天是练习太鼓吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet109-2","talkText":"是啊，刚好结束。\n差不多快到正式演出的日子了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet109-3","talkText":"呵呵，巴的太鼓演奏，\n可以振奋人心呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet109-4","talkText":"是的是的！\n让人心情愉悦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet109-5","talkText":"啊哈哈，那么就请你们\n期待正式演出吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}