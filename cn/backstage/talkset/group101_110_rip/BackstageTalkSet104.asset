{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet104","backstageTalkSetId":104,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet104-1","talkText":"小心心，下次放假\n你有什么安排吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet104-2","talkText":"打算出国旅游！\n和米歇尔一起去哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet104-3","talkText":"哎……\n我怎么没听说过……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet104-4","talkText":"真好呢~！\n我也想去~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet104-5","talkText":"喂，香澄！\n不要说傻话了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet104-6","talkText":"也对，\n我也没有护照呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet104-7","talkText":"我不是指这个！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":8,"characterIds":[15],"voiceId":"TalkSet104-8","talkText":"等等，心！\n刚刚那事再详细说说！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}