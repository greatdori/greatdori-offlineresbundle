{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet103","backstageTalkSetId":103,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet103-1","talkText":"啊，小心心！\n米歇尔在这里哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet103-2","talkText":"真的耶！\n米歇尔也在休息吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet103-3","talkText":"嗯、嗯，是啊~\n大家辛苦了","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet103-4","talkText":"奥泽同学，辛苦了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":1,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet103-5","talkText":"谢谢你，小有咲","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[5],"voiceId":"TalkSet103-6","talkText":"真是敬业……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}