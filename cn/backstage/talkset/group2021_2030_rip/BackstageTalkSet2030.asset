{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2030","backstageTalkSetId":2030,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2030-1","talkText":"诶嘿嘿♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[28],"voiceId":"TalkSet2030-2","talkText":"筑筑心情真好啊！\n小瑠唯，发生什么事了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[30],"voiceId":"TalkSet2030-3","talkText":"来这里的路上，\n被陌生人问路了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[29],"voiceId":"TalkSet2030-4","talkText":"是问我的！也就是说，\n我看起来很可靠呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet2030-5","talkText":"（可能是因为小瑠唯\n看起来很可怕吧……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet2030-6","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[29],"voiceId":"TalkSet2030-7","talkText":"哼哼♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet2030-8","talkText":"（不过，这事\n还是不说为妙吧）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}