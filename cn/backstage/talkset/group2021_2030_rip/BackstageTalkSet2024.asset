{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2024","backstageTalkSetId":2024,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet2024-1","talkText":"…………","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2024-2","talkText":"是什么？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet2024-3","talkText":"果然，瑠唯同学\n喜欢牛奶吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2024-4","talkText":"不算喜欢，也不算\n讨厌吧，怎么了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet2024-5","talkText":"没什么！就有这种感觉而已！\n啊哈哈……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[29],"voiceId":"TalkSet2024-6","talkText":"原来不是喝牛奶\n长高的啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[26],"voiceId":"TalkSet2024-7","talkText":"（我明白你的心情，\n小筑紫……！）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}