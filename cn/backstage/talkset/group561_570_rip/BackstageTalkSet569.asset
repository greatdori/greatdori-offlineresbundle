{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet569","backstageTalkSetId":569,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet569-1","talkText":"明天就是薰同学的\n生日了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet569-2","talkText":"礼物已经备好了，\n还需要准备什么其他的吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet569-3","talkText":"接下来只需要带着\n最棒的笑容迎接她了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet569-4","talkText":"是啊。希望能成功\n给她一个惊喜","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}