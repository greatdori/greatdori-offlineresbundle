{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet563","backstageTalkSetId":563,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet563-1","talkText":"鸫的店里\n有什么招牌点心吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet563-2","talkText":"应该是曲奇套餐吧。\n咖啡欧蕾也很好喝哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet563-3","talkText":"真棒啊！听起来\n很能让人露出笑容呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}