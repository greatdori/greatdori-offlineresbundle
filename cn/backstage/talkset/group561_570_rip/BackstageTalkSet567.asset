{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet567","backstageTalkSetId":567,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet567-1","talkText":"鸫鸫，生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet567-2","talkText":"这下我们五个人\n就同岁了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet567-3","talkText":"这是文具套装！\n在学生会用吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet567-4","talkText":"好厉害！文件夹、钢笔，\n还有夹子……有这么多！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet567-5","talkText":"还是大家一起\n一个一个挑选的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[6],"voiceId":"TalkSet567-6","talkText":"我们知道你很忙，\n但是大家都会为你加油的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet567-7","talkText":"谢谢！不管是乐队\n还是学生会，我都会加油的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}