{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet504","backstageTalkSetId":504,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet504-1","talkText":"我选的生日礼物\n怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet504-2","talkText":"虽然有点让人吃惊，\n但有咲应该会喜欢的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet504-3","talkText":"嗯。这可是一件\n超可爱的礼物呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet504-4","talkText":"好期待明天\n有咲的反应啊~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}