{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet502","backstageTalkSetId":502,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet502-1","talkText":"友希那同学！\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[25],"voiceId":"TalkSet502-2","talkText":"这个是大家一起选的……\n礼物……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet502-3","talkText":"谢谢。原来如此，\n里面装了很多东西呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet502-4","talkText":"亚子选的超帅的戒指，\n怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet502-5","talkText":"我选的是发饰哦。\n如果你用起来，我会很开心的☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet502-6","talkText":"我选的是围巾。\n天气变冷了，我觉得你会需要","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[21],"voiceId":"TalkSet502-7","talkText":"谢谢，\n每一件我都会珍惜的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}