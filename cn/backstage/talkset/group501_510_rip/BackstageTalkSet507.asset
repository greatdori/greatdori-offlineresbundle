{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet507","backstageTalkSetId":507,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet507-1","talkText":"好了，这下所有人\n都到齐了呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet507-2","talkText":"要去给小麻弥\n买礼物对吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet507-3","talkText":"我不知道该买什么，\n所以能大家一起去就放心了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet507-4","talkText":"然后，我记得小彩是\n有什么主意的吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet507-5","talkText":"嗯！那么，\n大家一起去购物吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}