{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet505","backstageTalkSetId":505,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet505-1","talkText":"有咲~！\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet505-2","talkText":"哇！\n吓我一跳……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet505-3","talkText":"营造惊喜成功了呢。\n有咲还真吓到了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet505-4","talkText":"有咲，这个给你。\n是生日礼物！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[5],"voiceId":"TalkSet505-5","talkText":"这不是迷你盆栽嘛！\n嗯，我还挺喜欢的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[4],"voiceId":"TalkSet505-6","talkText":"礼物方面的惊喜\n看来也很成功啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}