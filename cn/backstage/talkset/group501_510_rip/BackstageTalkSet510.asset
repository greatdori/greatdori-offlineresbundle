{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet510","backstageTalkSetId":510,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet510-1","talkText":"我前一阵子\n去看了灯光秀！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet510-2","talkText":"哇~好美啊！\n感觉很适合发到网上呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet510-3","talkText":"下个休息日，\n我也去看看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet510-4","talkText":"啊，那我和你一起去吧！\n还有其他好玩的地方呢~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}