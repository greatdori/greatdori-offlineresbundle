{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet501","backstageTalkSetId":501,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet501-1","talkText":"明天是凑同学的生日。\n宇田川同学，怎么了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet501-2","talkText":"嗯……我担心礼物\n不合她的心意~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet501-3","talkText":"啊，小亚子……\n你冷静一点……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[23],"voiceId":"TalkSet501-4","talkText":"不用那么担心，\n她一定会喜欢的☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet501-5","talkText":"亚子或许会\n一直紧张到明天……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}