{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet337","backstageTalkSetId":337,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet337-1","talkText":"育、育美，\n在学习……！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet337-2","talkText":"不是，有人\n落下了这本书！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet337-3","talkText":"育美只是在看书上\n有没有写名字而已！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet337-4","talkText":"太好了，\n你还是平时的那个育美","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}