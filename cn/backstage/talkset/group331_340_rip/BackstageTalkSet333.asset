{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet333","backstageTalkSetId":333,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet333-1","talkText":"薰，今天午休的时候\n你是不是在学校操场跳舞了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet333-2","talkText":"因为下一次舞台剧，\n我要扮演一个舞者","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet333-3","talkText":"为了更好地表现这个角色，\n我才跳舞的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}