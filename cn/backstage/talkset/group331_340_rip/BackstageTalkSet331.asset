{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet331","backstageTalkSetId":331,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet331-1","talkText":"其实，我写了一封信\n给米歇尔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet331-2","talkText":"想感谢她\n一直很照顾我","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet331-3","talkText":"你愿意\n帮我交给她吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet331-4","talkText":"（……怎么办，\n这封信我能打开看吗）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}