{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet328","backstageTalkSetId":328,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet328-1","talkText":"呜哎哎……怎么办才好……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet328-2","talkText":"花音，你怎么了？\n好像有什么烦恼呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet328-3","talkText":"我想去一个地方，\n但是距离很远，我怕会迷路……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet328-4","talkText":"呵呵，那就由我\n来为花音你保驾护航吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}