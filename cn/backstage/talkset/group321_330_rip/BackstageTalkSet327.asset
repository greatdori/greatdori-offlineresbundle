{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet327","backstageTalkSetId":327,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet327-1","talkText":"薰同学，你之前的舞台剧\n真的好帅哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet327-2","talkText":"很好地诠释出了\n作为主人公的猫咪的心情！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet327-3","talkText":"呵呵，看来我成功地成为了\n一只猫咪，那我就放心了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}