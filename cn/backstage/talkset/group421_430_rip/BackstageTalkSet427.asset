{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet427","backstageTalkSetId":427,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet427-1","talkText":"谢谢你，小麻弥。\n谢谢你一直以来的帮忙","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet427-2","talkText":"小事而已，\n不用谢的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet427-3","talkText":"作为回礼，要不要去喝杯茶？\n我有一个想去的地方","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet427-4","talkText":"好啊！\n请让我一起去！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}