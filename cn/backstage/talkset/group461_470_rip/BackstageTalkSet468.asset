{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet468","backstageTalkSetId":468,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet468-1","talkText":"小巴今天看起来\n也很有精神呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet468-2","talkText":"我很有精神哦。濑田学姐\n也在闪闪发亮呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet468-3","talkText":"你对这位闪闪发亮的演员\n有兴趣吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}