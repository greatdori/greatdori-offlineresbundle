{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet466","backstageTalkSetId":466,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet466-1","talkText":"小摩卡，\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet466-2","talkText":"来，这份礼物给你！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet466-3","talkText":"这股香气……\n难道……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet466-4","talkText":"是面包哦~！\n小摩卡最喜欢的就是这个吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet466-5","talkText":"我感觉\n和往常一样啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet466-6","talkText":"不，谢谢~\n既然这样，大家一起吃吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}