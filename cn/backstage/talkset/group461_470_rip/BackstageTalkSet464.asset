{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet464","backstageTalkSetId":464,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet464-1","talkText":"摩卡的生日礼物，\n那样就好了吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet464-2","talkText":"挺好的吧？\n我觉得摩卡会喜欢的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet464-3","talkText":"嗯，我能想象到\n摩卡开心的表情呢~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet464-4","talkText":"呵呵，要是她能\n喜欢就好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}