{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50014","backstageTalkSetId":50014,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50014-1","talkText":"花音同学，请你就这样\n笔直往前前","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50014-2","talkText":"呼、呼诶诶……\n是、是什么……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet50014-3","talkText":"好的，已经到了。\n可以睁开眼睛了哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet50014-4","talkText":"花音！\n生日快乐！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet50014-5","talkText":"哇啊！超大的\n水母……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet50014-6","talkText":"这其实\n是个垫子哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[11],"voiceId":"TalkSet50014-7","talkText":"我们觉得非常适合花音，\n就替你准备了这个哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet50014-8","talkText":"温柔地将人包裹住，\n这种梦幻感正和花音一样……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[13],"voiceId":"TalkSet50014-9","talkText":"好了好了，小花音学姐！\n赶快坐上去吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet50014-10","talkText":"哇啊，就像是坐在了\n真正的水母上一样……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[14],"voiceId":"TalkSet50014-11","talkText":"…………呼","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[15],"voiceId":"TalkSet50014-12","talkText":"睡、睡着了——！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}