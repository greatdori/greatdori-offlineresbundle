{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50019","backstageTalkSetId":50019,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet50019-1","talkText":"明天是小伊芙的生日！\n好期待啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet50019-2","talkText":"犹豫了好久\n到底要送她什么礼物才好","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet50019-3","talkText":"不过，烦恼了那么久\n也是值得的呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet50019-4","talkText":"小彩挑选的礼物\n真的是太可爱了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet50019-5","talkText":"太棒了！要是明天\n小伊芙能喜欢就好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}