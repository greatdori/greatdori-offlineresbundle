{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50015","backstageTalkSetId":50015,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet50015-1","talkText":"沙绫会喜欢\n这件生日礼物吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50015-2","talkText":"真想早点看到她\n戴上这个呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet50015-3","talkText":"绝对很适合沙绫的哦！\n对吧，有咲！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50015-4","talkText":"不、不要问我啊！\n不过我觉得应该合适吧……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}