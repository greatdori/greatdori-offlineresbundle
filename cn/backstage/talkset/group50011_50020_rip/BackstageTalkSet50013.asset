{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50013","backstageTalkSetId":50013,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet50013-1","talkText":"礼物的事情\n还没有和花音同学说吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet50013-2","talkText":"要是搬运的时候\n被她看到的话就糟糕了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50013-3","talkText":"可能一不小心就会说漏嘴，\n真是忐忑不安呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet50013-4","talkText":"啊，明天将会是非常\n梦幻的一天呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[11],"voiceId":"TalkSet50013-5","talkText":"我非~常期待\n看到花音的笑容哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}