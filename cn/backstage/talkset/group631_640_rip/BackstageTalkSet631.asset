{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet631","backstageTalkSetId":631,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet631-1","talkText":"咦，你的手臂\n是被晒黑了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet631-2","talkText":"和小兰她们去海边玩的时候\n不知不觉就……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet631-3","talkText":"不介意的话，\n我可以借给你修复霜哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet631-4","talkText":"千圣同学给我介绍了一款\n很管用的护肤品呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}