{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet297","backstageTalkSetId":297,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet297-1","talkText":"薰同学，你为什么\n会想要演戏剧呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet297-2","talkText":"那是因为，舞台\n在呼唤着我啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet297-3","talkText":"啊哈哈，果然\n薰同学好有趣啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}