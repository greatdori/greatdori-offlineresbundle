{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet97","backstageTalkSetId":97,"snippets":[{"talkId":1,"characterIds":[13],"voiceId":"TalkSet97-1","talkText":"小巴，你是不是\n有在打太鼓啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet97-2","talkText":"是啊，非常\n有趣哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet97-3","talkText":"嘴上还会喊『嘿呀』的，对吧，\n姐姐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet97-4","talkText":"听起来好好玩啊！\n嘿呀~！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet97-5","talkText":"嘿呀~！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet97-6","talkText":"嘿呀~！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet97-7","talkText":"等、等等……\n你们怎么了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}