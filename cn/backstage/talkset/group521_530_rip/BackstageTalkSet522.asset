{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet522","backstageTalkSetId":522,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet522-1","talkText":"冬天到了，\n就会想吃很多甜食呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet522-2","talkText":"虽然我\n不怎么喜欢甜食……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet522-3","talkText":"不过，最近好像\n确实吃了很多黑巧克力","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet522-4","talkText":"嘿嘿，我这里有黑巧克力，\n你要来点吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}