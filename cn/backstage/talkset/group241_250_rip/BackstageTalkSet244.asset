{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet244","backstageTalkSetId":244,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet244-1","talkText":"面包卖剩了……\n你们要吃吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet244-2","talkText":"谢谢。啊啊……\n多么甜美的香气啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet244-3","talkText":"呃，那个……\n这是咖喱包啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet244-4","talkText":"呵呵……就算是咖喱包\n也有甜甜的香气","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}