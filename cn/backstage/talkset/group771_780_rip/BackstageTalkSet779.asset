{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet779","backstageTalkSetId":779,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet779-1","talkText":"那个，LOCK，\n听我说、听我说~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet779-2","talkText":"嗡~！的声音和\n叮铃~的声音","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet779-3","talkText":"你觉得哪种更好？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[32],"voiceId":"TalkSet779-4","talkText":"诶？这个……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet779-5","talkText":"如果是香澄学姐弹的，\n那么两种都很好听！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet779-6","talkText":"诶嘿嘿~两种都好听吗~\n谢谢你，LOCK~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}