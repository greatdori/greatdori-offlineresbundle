{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet777","backstageTalkSetId":777,"snippets":[{"talkId":1,"characterIds":[31],"voiceId":"TalkSet777-1","talkText":"我想买一件新的皮夹克","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet777-2","talkText":"哇~！秋装很棒呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[31],"voiceId":"TalkSet777-3","talkText":"LOCK最后也还是买下了\n犹豫很久的针织衫","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[32],"voiceId":"TalkSet777-4","talkText":"是的！非常可爱，\n我最近很喜欢那件衣服","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet777-5","talkText":"嗯。前不久穿上它的时候，\n感觉很合适哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}