{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet774","backstageTalkSetId":774,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet774-1","talkText":"快看！这家咖啡厅\n开始用秋季菜单了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet774-2","talkText":"哎呀，看起来很好吃呢。\n好像是在车站附近对吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet774-3","talkText":"嗯！啊，好像还能在露台上欣赏\n最佳观赏期的枫叶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet774-4","talkText":"呵呵，那我们下次\n一起去看看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet774-5","talkText":"太棒了~！\n时间选在下周练习之前怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}