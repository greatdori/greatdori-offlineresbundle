{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet194","backstageTalkSetId":194,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet194-1","talkText":"小麻弥，吉他的音色\n感觉不太对劲","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet194-2","talkText":"我调一下\n琴颈吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet194-3","talkText":"小麻弥，\n下次上节目的剧本……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet194-4","talkText":"黄色封面的那本就是！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[20],"voiceId":"TalkSet194-5","talkText":"麻弥同学，\n你有创可贴吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[19],"voiceId":"TalkSet194-6","talkText":"包包里有！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[18],"voiceId":"TalkSet194-7","talkText":"（有小麻弥在我们身边\n真的太好了……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}