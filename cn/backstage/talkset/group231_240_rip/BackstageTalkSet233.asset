{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet233","backstageTalkSetId":233,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet233-1","talkText":"昨天吃的筑前煮，\n真的太好吃啦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[5],"voiceId":"TalkSet233-2","talkText":"啊，我昨天晚饭\n也吃了筑前煮哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet233-3","talkText":"好巧！我和有咲感觉\n在吃的方面很合拍呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}