{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet38","backstageTalkSetId":38,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet38-1","talkText":"姐姐，要不要\n和我一起去买吉他的弦线？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet38-2","talkText":"我最近，\n才刚换完","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet38-3","talkText":"哎，那就当备用！\n我们去买备用弦线吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}