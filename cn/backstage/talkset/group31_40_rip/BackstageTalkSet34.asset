{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet34","backstageTalkSetId":34,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet34-1","talkText":"看，小美咲。\n我换了待机画面","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet34-2","talkText":"啊，和之前不一样\n换成水母了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet34-3","talkText":"嘿嘿，其实这个\n是我昨天在水族馆拍的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}