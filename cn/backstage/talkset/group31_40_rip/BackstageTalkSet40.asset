{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet40","backstageTalkSetId":40,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet40-1","talkText":"麻弥，我的练习\n终于有成果了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet40-2","talkText":"难、难道说是你之前\n练习的『梦幻』吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet40-3","talkText":"是啊，你听！\n梦幻……怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet40-4","talkText":"（和之前的有什么不一样的吗\n完全分辨不出……？）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}