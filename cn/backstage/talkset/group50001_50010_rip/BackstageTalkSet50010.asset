{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50010","backstageTalkSetId":50010,"snippets":[{"talkId":1,"characterIds":[6],"voiceId":"TalkSet50010-1","talkText":"咦，好黑……\n大家都不在吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7,8,9,10],"voiceId":"TalkSet50010-2","talkText":"兰！\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet50010-3","talkText":"给你这个！满怀心意的\n绯玛丽特制布偶！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet50010-4","talkText":"谢、谢谢你，绯玛丽……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet50010-5","talkText":"今年绯玛丽\n可是干劲十足呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[10],"voiceId":"TalkSet50010-6","talkText":"她还给大家准备了\n咸饼干哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[7],"voiceId":"TalkSet50010-7","talkText":"赶快接受\n来自小绯的炽热心意吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[6],"voiceId":"TalkSet50010-8","talkText":"嗯、嗯。那个，\n也非常……谢谢大家","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet50010-9","talkText":"兰，能收到可爱的布偶\n真是太好了呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet50010-10","talkText":"诶！可爱吗！？\n太好了~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[8],"voiceId":"TalkSet50010-11","talkText":"其实，我给每个人\n都做了一个哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[8],"voiceId":"TalkSet50010-12","talkText":"把这个和护身符一起\n戴在身上吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}