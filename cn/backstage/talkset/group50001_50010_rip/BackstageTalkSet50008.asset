{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50008","backstageTalkSetId":50008,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet50008-1","talkText":"千圣同学！\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet50008-2","talkText":"我们为你准备了\n超棒的礼物哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet50008-3","talkText":"谢谢。\n是什么呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[20],"voiceId":"TalkSet50008-4","talkText":"彩同学，日菜同学！\n拜托你们了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet50008-5","talkText":"好的！\n小千圣，生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet50008-6","talkText":"你说的礼物是……\n这个红茶组合？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[19],"voiceId":"TalkSet50008-7","talkText":"是的！我们觉得\n非常适合千圣同学！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[20],"voiceId":"TalkSet50008-8","talkText":"今天请让我们\n用这个来款待你吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[16],"voiceId":"TalkSet50008-9","talkText":"我们为了今天\n练习了很久哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet50008-10","talkText":"小千圣你看好哦！\n预备，开始！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[16],"voiceId":"TalkSet50008-11","talkText":"唔哇哇！\n诶、诶嘿！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[18],"voiceId":"TalkSet50008-12","talkText":"呵呵，真是让人惊讶了。\n真的非常感谢你们","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}