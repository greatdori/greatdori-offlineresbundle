{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet456","backstageTalkSetId":456,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet456-1","talkText":"这样的天气\n变得舒适了许多呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet456-2","talkText":"确实是的。\n说真的，帮大忙了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet456-3","talkText":"对米歇尔来说\n也是适宜生活的季节","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}