{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2020","backstageTalkSetId":2020,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2020-1","talkText":"哦，和你一起拍照的，\n是筑筑的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet2020-2","talkText":"是我的妹妹们哦！\n很可爱吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2020-3","talkText":"嗯、嗯！\n真是可爱的三姐妹呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet2020-4","talkText":"（一瞬间都分不清哪个\n才是筑筑了……）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}