{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet2017","backstageTalkSetId":2017,"snippets":[{"talkId":1,"characterIds":[28],"voiceId":"TalkSet2017-1","talkText":"小瑠唯拉小提琴的时候，\n非常帅气呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[30],"voiceId":"TalkSet2017-2","talkText":"是吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet2017-3","talkText":"我也想拉拉看呢——\n啊，不过看起来很难的样子~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[30],"voiceId":"TalkSet2017-4","talkText":"我觉得，如果是你的话，\n应该很容易就能拉起来了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}