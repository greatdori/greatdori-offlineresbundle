{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet56","backstageTalkSetId":56,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet56-1","talkText":"总之，就是这么一回事","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[11],"voiceId":"TalkSet56-2","talkText":"这么一回事\n是怎么一回事！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet56-3","talkText":"总之就是这么一回事\n的意思吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet56-4","talkText":"不是很懂你在说什么，\n不过原来是这么一回事啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}