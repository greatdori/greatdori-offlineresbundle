{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet793","backstageTalkSetId":793,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet793-1","talkText":"寒冷的时候就要演出！\n对吧，友希那学姐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[21],"voiceId":"TalkSet793-2","talkText":"……这两者\n有什么关系吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[1],"voiceId":"TalkSet793-3","talkText":"当然有关系，因为演出\n可以赶走寒冷哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet793-4","talkText":"我仿佛在夏天\n也听到过类似的理由","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}