{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet762","backstageTalkSetId":762,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet762-1","talkText":"我想去花园land！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet762-2","talkText":"只要在脑海中描绘出来，\n随时都可以入园哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet762-3","talkText":"真是太美妙了！\n我想想！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet762-4","talkText":"有让人兴奋的\n过山车呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet762-5","talkText":"是卖爆米花的小店！\n那边还有巡游表演！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}