{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet766","backstageTalkSetId":766,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet766-1","talkText":"小巴，\n你在看什么？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet766-2","talkText":"在看海洋馆的相册。\n看着看着就觉得凉快起来了哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[10],"voiceId":"TalkSet766-3","talkText":"哇啊，是真的呢，\n就像置身在海里一样","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[9],"voiceId":"TalkSet766-4","talkText":"机会难得，也邀请兰她们\n一起看吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}