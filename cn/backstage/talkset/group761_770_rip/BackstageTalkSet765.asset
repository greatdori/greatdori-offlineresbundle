{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet765","backstageTalkSetId":765,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet765-1","talkText":"那个，这顶草帽\n是不是很可爱？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet765-2","talkText":"真的呢，上面有向日葵的装饰，\n很有夏天的感觉呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet765-3","talkText":"怎么办啊~\n我要不要买下来呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet765-4","talkText":"呵呵，那我们\n一起去买吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}