{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet764","backstageTalkSetId":764,"snippets":[{"talkId":1,"characterIds":[33],"voiceId":"TalkSet764-1","talkText":"哎呀，这次合奏\n真有趣啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet764-2","talkText":"是的！\n我流了一身汗！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[33],"voiceId":"TalkSet764-3","talkText":"对了，接下来\n一起去旭汤吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[33],"voiceId":"TalkSet764-4","talkText":"夏天洗完澡后\n来一瓶波子汽水，简直是再好不过了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet764-5","talkText":"好啊，\n走吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}