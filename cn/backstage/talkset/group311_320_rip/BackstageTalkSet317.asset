{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet317","backstageTalkSetId":317,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet317-1","talkText":"我忽然想到一个关于\n下一场演唱会的好主意了！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet317-2","talkText":"不愧是心呢。\n告诉我吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet317-3","talkText":"夜晚在学校的屋顶上\n和星星们一起演奏！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet317-4","talkText":"和星星一起演奏\n协奏曲……好梦幻","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}