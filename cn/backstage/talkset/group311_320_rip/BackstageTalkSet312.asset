{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet312","backstageTalkSetId":312,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet312-1","talkText":"专业的高中生鼓手……\n大和同学好厉害啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet312-2","talkText":"没、没有\n这么厉害啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet312-3","talkText":"和米歇尔同学比起来，\n我才没有……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet312-4","talkText":"不不！我才是，\n算不上什么厉害呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}