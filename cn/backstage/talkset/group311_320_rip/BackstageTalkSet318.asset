{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet318","backstageTalkSetId":318,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet318-1","talkText":"美咲否决了\n屋顶星空演唱会的想法","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet318-2","talkText":"很遗憾，那只能\n想别的方案了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet318-3","talkText":"薰想要一场\n怎样的演唱会？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet318-4","talkText":"这个嘛……\n果然还是梦幻的演唱会最好","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}