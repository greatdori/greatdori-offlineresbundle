{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet311","backstageTalkSetId":311,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet311-1","talkText":"奥泽同学，你是\n怎么做DJ练习的？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet311-2","talkText":"这个嘛……\n就是看看优秀的DJ打碟……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet311-3","talkText":"唔……我大概只做了\n一些很基础的练习而已","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet311-4","talkText":"原来如此！掌握基础技能是\n最重要的呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}