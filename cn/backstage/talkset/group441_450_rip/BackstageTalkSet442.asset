{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet442","backstageTalkSetId":442,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet442-1","talkText":"莉莎，生日快乐。\n我准备了礼物哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet442-2","talkText":"你们为我准备了耳环，颈饰等\n各种各样的礼物呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet442-3","talkText":"我们都挑选了适合\n今井同学的东西哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet442-4","talkText":"嘿嘿，亚子选的怎么样？\n帅吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet442-5","talkText":"如果你喜欢的话……\n请戴上看看……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[23],"voiceId":"TalkSet442-6","talkText":"真的非常感谢大家！\n我会好好珍惜的☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}