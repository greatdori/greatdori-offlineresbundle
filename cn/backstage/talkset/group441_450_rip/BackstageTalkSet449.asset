{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet449","backstageTalkSetId":449,"snippets":[{"talkId":1,"characterIds":[4],"voiceId":"TalkSet449-1","talkText":"哇，好漂亮的天空的照片！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet449-2","talkText":"啊，嗯。\n是我刚才拍的。","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet449-3","talkText":"秋天的天空真让人心情愉快呢\n蔚蓝又通透","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet449-4","talkText":"我懂的。我也会\n不由得看入迷了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}