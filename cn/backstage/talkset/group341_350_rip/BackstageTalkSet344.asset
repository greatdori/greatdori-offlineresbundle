{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet344","backstageTalkSetId":344,"snippets":[{"talkId":1,"characterIds":[21],"voiceId":"TalkSet344-1","talkText":"纱夜，你好早啊。\n还没到练习时间吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet344-2","talkText":"我在自主练习呢。\n那么凑同学呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[21],"voiceId":"TalkSet344-3","talkText":"呵呵，看来\n我们想到一块去了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}