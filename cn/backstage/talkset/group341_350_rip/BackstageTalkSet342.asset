{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet342","backstageTalkSetId":342,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet342-1","talkText":"奥泽同学，\n你会做羊毛毡对吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet342-2","talkText":"是啊。难道说\n燐子学姐有兴趣？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet342-3","talkText":"是、是的……但是……\n好像很难……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet342-4","talkText":"不不，你都会做衣服了，\n羊毛毡肯定易如反掌","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}