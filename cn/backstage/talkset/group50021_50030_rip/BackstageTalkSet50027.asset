{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50027","backstageTalkSetId":50027,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet50027-1","talkText":"好，这样明天的准备\n应该就没有问题问了吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet50027-2","talkText":"我刚才试着看了一下，\n非常漂亮哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet50027-3","talkText":"连育美都心动不已！\n小心心会喜欢吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet50027-4","talkText":"明天要由我们来\n让心露出笑容呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}