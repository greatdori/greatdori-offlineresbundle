{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50023","backstageTalkSetId":50023,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet50023-1","talkText":"明天终于就是\n香澄的生日了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet50023-2","talkText":"要是她能喜欢\n这个礼物就好了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet50023-3","talkText":"那个也已经准备万全了，\n好期待明天的到来呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet50023-4","talkText":"拿着那个走路\n实在是太引人瞩目了呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}