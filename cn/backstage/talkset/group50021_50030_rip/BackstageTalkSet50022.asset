{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50022","backstageTalkSetId":50022,"snippets":[{"talkId":1,"characterIds":[25],"voiceId":"TalkSet50022-1","talkText":"小亚子……\n生日快乐……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50022-2","talkText":"哇！谢谢！\n那个箱子难不成是……！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet50022-3","talkText":"全都是送给\n宇田川同学的礼物哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50022-4","talkText":"这么多吗！？\n太~~~棒了！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet50022-5","talkText":"那么！虽然很突然，\n但现在要进行问答！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[24],"voiceId":"TalkSet50022-6","talkText":"问答！？好的！\n亚子一定要全部答对！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[23],"voiceId":"TalkSet50022-7","talkText":"这些礼物\n分别是谁挑选的呢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet50022-8","talkText":"亚子，我觉得你\n一定能全都答对的哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[24],"voiceId":"TalkSet50022-9","talkText":"好、好的！亚子会加油的！\n呃，那个……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[24],"voiceId":"TalkSet50022-10","talkText":"这个NFO的布偶是\n……燐燐挑的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[25],"voiceId":"TalkSet50022-11","talkText":"嗯……小亚子……\n答对了哦……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[24],"voiceId":"TalkSet50022-12","talkText":"太棒了！保持这个感觉，\n继续答对所有问题吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}