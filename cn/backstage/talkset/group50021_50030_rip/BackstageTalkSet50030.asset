{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet50030","backstageTalkSetId":50030,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet50030-1","talkText":"……咦，总感觉\n和平常的氛围不太一样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet50030-2","talkText":"呵呵呵……欢迎来到\n暗黑盛宴……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet50030-3","talkText":"诶！？亚子？\n还有大家也……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet50030-4","talkText":"现在开始为你展示\n非比寻常的暗黑力量……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet50030-5","talkText":"桌子上什么都没有……\n把一块布盖在上面……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet50030-6","talkText":"这块布上\n没有任何机关和装置","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[24],"voiceId":"TalkSet50030-7","talkText":"把布慢慢地\n拿开之后……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[24],"voiceId":"TalkSet50030-8","talkText":"原本空无一物的桌子上\n居然凭空出现了礼物！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet50030-9","talkText":"所谓的暗黑盛宴是魔术吧！\n说来，这个是围裙啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet50030-10","talkText":"莉莎，生日快乐。\n你喜欢这个礼物吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet50030-11","talkText":"非常可爱哦！\n我会很爱惜地使用的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}