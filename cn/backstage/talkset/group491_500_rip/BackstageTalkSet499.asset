{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet499","backstageTalkSetId":499,"snippets":[{"talkId":1,"characterIds":[10],"voiceId":"TalkSet499-1","talkText":"小绯玛丽！\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[8],"voiceId":"TalkSet499-2","talkText":"哇~！\n谢谢大家！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[7],"voiceId":"TalkSet499-3","talkText":"这是温柔体贴的我们\n送你的生日礼物哦~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet499-4","talkText":"啊，这个！\n我想要的无檐帽！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[9],"voiceId":"TalkSet499-5","talkText":"之前你说过\n对它很有兴趣","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[6],"voiceId":"TalkSet499-6","talkText":"还有，这个蛋糕也是\n在绯玛丽喜欢的店买的哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[8],"voiceId":"TalkSet499-7","talkText":"全都是我喜欢的……！\n哇，谢谢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[7],"voiceId":"TalkSet499-8","talkText":"耶~\n今年也大获成功~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}