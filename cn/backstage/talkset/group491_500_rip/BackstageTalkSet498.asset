{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet498","backstageTalkSetId":498,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet498-1","talkText":"嘿嘿嘿~\n今年的准备也很完美","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet498-2","talkText":"摩卡一到绯玛丽的生日，\n就会变得兴致高昂","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet498-3","talkText":"感觉某种意义上\n她才是最期待的……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet498-4","talkText":"总、总之，小绯玛丽\n高兴就好！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}