{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet500","backstageTalkSetId":500,"snippets":[{"talkId":1,"characterIds":[3],"voiceId":"TalkSet500-1","talkText":"小绯玛丽，\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet500-2","talkText":"这是生日礼物哦。\n请收下吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet500-3","talkText":"谢谢大家！\n好漂亮的植物标本瓶啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet500-4","talkText":"我和小里美一起去买东西，\n一眼就相中了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[3],"voiceId":"TalkSet500-5","talkText":"如果你喜欢，\n那就太好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[8],"voiceId":"TalkSet500-6","talkText":"我超喜欢的~！\n我会好好珍惜的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}