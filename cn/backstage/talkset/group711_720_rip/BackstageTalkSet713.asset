{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet713","backstageTalkSetId":713,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet713-1","talkText":"寄宿于吾身的黑暗之力啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[24],"voiceId":"TalkSet713-2","talkText":"穿刺吧！\nChaotic Shot！！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet713-3","talkText":"哇，小亚子好厉害~\n接着该轮到小益木了吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet713-4","talkText":"我和花音学姐\n在扇子上画了画","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[14],"voiceId":"TalkSet713-5","talkText":"这是巧克力海螺包和水母哦♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet713-6","talkText":"唔……太可爱了，\n根本不忍心射中啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet713-7","talkText":"MASKING同学……\n不射中的话就不能算才艺了哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[33],"voiceId":"TalkSet713-8","talkText":"没办法……！\n我就豁出去了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[3],"voiceId":"TalkSet713-9","talkText":"最后是冰川学姐啊。\n靶、靶子这么小","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[22],"voiceId":"TalkSet713-10","talkText":"……『正射必中』。\n只要正确地将箭射出，就一定……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[24],"voiceId":"TalkSet713-11","talkText":"好、好厉害——纱夜同学\n超超超帅气~~！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[22],"voiceId":"TalkSet713-12","talkText":"呵呵，\n看来今年也会是很棒的一年","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}