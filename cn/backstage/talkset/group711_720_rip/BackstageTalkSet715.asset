{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet715","backstageTalkSetId":715,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet715-1","talkText":"我们是手技杂耍队。\n那、那么请看……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet715-2","talkText":"太好了——大获成功！\n这都是多亏了美咲学姐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[15],"voiceId":"TalkSet715-3","talkText":"不不，\n我什么都没做","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[10],"voiceId":"TalkSet715-4","talkText":"呵呵，虽然练习很辛苦，\n但也很开心呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[17],"voiceId":"TalkSet715-5","talkText":"锵锵！怎么样？\n我这么噜♪的新技能~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet715-6","talkText":"哈哈……除了心以外，\n居然还有人能这么轻松就做到啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet715-7","talkText":"那么~最后♪\n小真白也来试试吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[26],"voiceId":"TalkSet715-8","talkText":"好、好的……\n看、看我的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[29],"voiceId":"TalkSet715-9","talkText":"好可惜，小真白\n就只差一步了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[10],"voiceId":"TalkSet715-10","talkText":"嗯，这是你努力的成果呢。\n今年也积极地努力吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[26],"voiceId":"TalkSet715-11","talkText":"好、好的，\n我会努力的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}