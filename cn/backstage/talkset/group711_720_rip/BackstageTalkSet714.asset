{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet714","backstageTalkSetId":714,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet714-1","talkText":"各位~\n准备好了吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[32],"voiceId":"TalkSet714-2","talkText":"没问题，彩学姐。\n一起拿出干劲吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5,16,27,30,32],"voiceId":"TalkSet714-3","talkText":"祝大家\n新年快~乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet714-4","talkText":"嗯。这就是新年！\n感觉很不错吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[27],"voiceId":"TalkSet714-5","talkText":"作为纪念拍张照吧~！\n瑠唯，笑得再灿烂点~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[30],"voiceId":"TalkSet714-6","talkText":"我倒是觉得\n什么表情都无所谓","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[27],"voiceId":"TalkSet714-7","talkText":"哇~瑠唯，\n新的一年还这么顽固~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[5],"voiceId":"TalkSet714-8","talkText":"等、等等。新的一年才刚开始，\n吵架不太好吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[30],"voiceId":"TalkSet714-9","talkText":"怎么会？\n我们又没在吵架","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet714-10","talkText":"对了！我说啊，大家要不要\n写写今年的目标？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[32],"voiceId":"TalkSet714-11","talkText":"这点子不错！\n要有远大的目标！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[16],"voiceId":"TalkSet714-12","talkText":"是啊。而且\n大家也要友好相处♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}