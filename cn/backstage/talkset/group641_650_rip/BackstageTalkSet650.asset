{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet650","backstageTalkSetId":650,"snippets":[{"talkId":1,"characterIds":[14],"voiceId":"TalkSet650-1","talkText":"我明天要和小千圣\n一起去车站前的咖啡厅","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet650-2","talkText":"感兴趣的话，小纱夜也\n和我们一起去吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[22],"voiceId":"TalkSet650-3","talkText":"咖啡厅……好啊，\n请务必让我一起去","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet650-4","talkText":"我会和小彩\n还有小燐子说一声的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}