{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet222","backstageTalkSetId":222,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet222-1","talkText":"香澄她们好慢啊。\n是不是跑去哪里闲逛了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[4],"voiceId":"TalkSet222-2","talkText":"呵呵，你担心的话\n就联系一下她们吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet222-3","talkText":"才、才\n没有呢！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}