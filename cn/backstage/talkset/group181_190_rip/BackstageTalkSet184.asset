{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet184","backstageTalkSetId":184,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet184-1","talkText":"米歇尔，\n原来你在这里啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[12],"voiceId":"TalkSet184-2","talkText":"我找你好久了，小猫咪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet184-3","talkText":"但是，这次轮到小美\n不见了？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet184-4","talkText":"小美咲有急事\n先回去了","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[13],"voiceId":"TalkSet184-5","talkText":"啊！但育美有事\n想找小美啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[15],"voiceId":"TalkSet184-6","talkText":"！？","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[14],"voiceId":"TalkSet184-7","talkText":"（小美咲真辛苦啊）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}