{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet513","backstageTalkSetId":513,"snippets":[{"talkId":1,"characterIds":[7],"voiceId":"TalkSet513-1","talkText":"披萨面包、咖喱面包、\n奶汁烤菜面包~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[7],"voiceId":"TalkSet513-2","talkText":"冬天有好多\n好吃的面包呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet513-3","talkText":"啊哈哈，就算不是冬天，\n面包也一直很好吃哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet513-4","talkText":"确实是~面包\n果然好伟大啊~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}