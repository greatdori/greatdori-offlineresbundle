{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet574","backstageTalkSetId":574,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet574-1","talkText":"锵锵！\n我买了福袋哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet574-2","talkText":"哦，好哎好哎~！\n里面装了什么？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[24],"voiceId":"TalkSet574-3","talkText":"我看看……啊，是面具！\n感觉很适合友希那同学！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[21],"voiceId":"TalkSet574-4","talkText":"是、是吗……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[24],"voiceId":"TalkSet574-5","talkText":"下一个是……哦~水晶球啊~\n这个就给燐燐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[25],"voiceId":"TalkSet574-6","talkText":"谢、谢谢你，\n小亚子……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[22],"voiceId":"TalkSet574-7","talkText":"里面装的东西\n都很奇妙呢……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[25],"voiceId":"TalkSet574-8","talkText":"友希那同学……非常……\n适合你","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet574-9","talkText":"难不成\n你很中意？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet574-10","talkText":"才、才没\n那回事呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}