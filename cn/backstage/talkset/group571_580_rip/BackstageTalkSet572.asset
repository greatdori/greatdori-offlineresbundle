{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet572","backstageTalkSetId":572,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet572-1","talkText":"快看快看！我在仓库\n找到了这个！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet572-2","talkText":"哇~！好大的风筝","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet572-3","talkText":"大家一起去放风筝吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet572-4","talkText":"这么大的风筝，\n飞不飞得起来都是个问题吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[4],"voiceId":"TalkSet572-5","talkText":"确实，没有风的话，\n感觉很难飞起来呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[2],"voiceId":"TalkSet572-6","talkText":"没事。\n我们一定能做到的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[5],"voiceId":"TalkSet572-7","talkText":"你为什么那么\n有信心啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[1],"voiceId":"TalkSet572-8","talkText":"嗯嗯，肯定没问题！\nLet's go！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[4],"voiceId":"TalkSet572-9","talkText":"啊，等等。\n香澄、惠惠！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[3],"voiceId":"TalkSet572-10","talkText":"呵呵，好期待♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}