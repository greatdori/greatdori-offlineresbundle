{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet575","backstageTalkSetId":575,"snippets":[{"talkId":1,"characterIds":[17],"voiceId":"TalkSet575-1","talkText":"各位看好了！\n嘿！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[19],"voiceId":"TalkSet575-2","talkText":"哦，好厉害！\n日菜同学，太精彩了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet575-3","talkText":"这肯定能在\n综艺会场上得到热烈反响的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet575-4","talkText":"接着是小彩吧。\n加油！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[16],"voiceId":"TalkSet575-5","talkText":"嗯！我一定\n会成功的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet575-6","talkText":"我上咯！\n……看招！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[16],"voiceId":"TalkSet575-7","talkText":"啊！\n……好痛！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[19],"voiceId":"TalkSet575-8","talkText":"好可惜！\n就差一点了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[20],"voiceId":"TalkSet575-9","talkText":"一定很快就能成功了！\n俗话说，专一艺则通天下！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[16],"voiceId":"TalkSet575-10","talkText":"有道理！\n好，我再试一次！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}