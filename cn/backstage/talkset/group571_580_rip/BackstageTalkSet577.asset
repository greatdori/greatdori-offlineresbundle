{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet577","backstageTalkSetId":577,"snippets":[{"talkId":1,"characterIds":[1],"voiceId":"TalkSet577-1","talkText":"下次有机会，我们Popipa全员\n一起去野餐吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet577-2","talkText":"而且要带上乐器，\n在户外演奏！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet577-3","talkText":"可是……爵士鼓\n没办法带过去吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet577-4","talkText":"有干劲就没问题！\n大家一起搬过去吧！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}