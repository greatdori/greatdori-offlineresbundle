{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet576","backstageTalkSetId":576,"snippets":[{"talkId":1,"characterIds":[11],"voiceId":"TalkSet576-1","talkText":"这是Hello Happy的舞狮哦！\n嗷！","lipAnimation":"","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet576-2","talkText":"好厉害啊！\n我还是第一次看舞狮呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[13],"voiceId":"TalkSet576-3","talkText":"有没有坏孩子啊~？\n我要把可乐饼吃掉咯！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":4,"characterIds":[15],"voiceId":"TalkSet576-4","talkText":"不，那是生剥鬼吧。\n而且它也不会吃可乐饼","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet576-5","talkText":"祛除灾厄、带来幸福。\n啊，真梦幻啊……","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[11],"voiceId":"TalkSet576-6","talkText":"下次演出\n就用舞狮开场吧！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet576-7","talkText":"我赞成！","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[12],"voiceId":"TalkSet576-8","talkText":"啊。感觉会成为一场\n很吉祥的演出","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet576-9","talkText":"到时候就是，舞狮、\n米歇尔还有花音同学？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet576-10","talkText":"呼哎哎……\n我没信心啦……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}