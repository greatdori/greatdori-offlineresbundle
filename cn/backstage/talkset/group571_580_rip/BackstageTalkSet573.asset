{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet573","backstageTalkSetId":573,"snippets":[{"talkId":1,"characterIds":[9],"voiceId":"TalkSet573-1","talkText":"嘿咻！嘿咻！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":2,"characterIds":[10],"voiceId":"TalkSet573-2","talkText":"好！好！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":3,"characterIds":[6],"voiceId":"TalkSet573-3","talkText":"好厉害……她们俩\n相当有默契呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[7],"voiceId":"TalkSet573-4","talkText":"咖油~","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet573-5","talkText":"摩卡~要吃还是要说话，\n你选一个做啦~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[7],"voiceId":"TalkSet573-6","talkText":"那我要吃~\n饼饼好美味~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[10],"voiceId":"TalkSet573-7","talkText":"成功了！好开心啊。\n努力有成效了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[9],"voiceId":"TalkSet573-8","talkText":"下次就轮到摩卡你们了哦。\n重要的是节奏！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[7],"voiceId":"TalkSet573-9","talkText":"明~白~\n交给我吧~~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[6],"voiceId":"TalkSet573-10","talkText":"真、真的没问题吗？\n你这节奏我很担心啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}