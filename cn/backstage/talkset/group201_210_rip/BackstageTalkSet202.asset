{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet202","backstageTalkSetId":202,"snippets":[{"talkId":1,"characterIds":[2],"voiceId":"TalkSet202-1","talkText":"香澄的发型\n是怎么弄的啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[1],"voiceId":"TalkSet202-2","talkText":"惠惠也要\n弄这个发型吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[2],"voiceId":"TalkSet202-3","talkText":"不是，我想弄一个\n兔子耳朵的发型","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[1],"voiceId":"TalkSet202-4","talkText":"兔子耳朵！\n快去弄一个试试看！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}