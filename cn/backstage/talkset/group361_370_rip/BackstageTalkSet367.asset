{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet367","backstageTalkSetId":367,"snippets":[{"talkId":1,"characterIds":[23],"voiceId":"TalkSet367-1","talkText":"日菜，生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet367-2","talkText":"这是生日礼物！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet367-3","talkText":"哇，会是什么呢！\n……啊，是垂饰！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet367-4","talkText":"这个形状我好像在哪里见过……\n啊，是双子座的图案！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[23],"voiceId":"TalkSet367-5","talkText":"纱夜找了好久\n才找到的哦♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[22],"voiceId":"TalkSet367-6","talkText":"今井同学，\n这个不用说出来的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[17],"voiceId":"TalkSet367-7","talkText":"嘿嘿，谢谢！\n我会好好珍惜的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}