{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet366","backstageTalkSetId":366,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet366-1","talkText":"日菜同学，\n生日快乐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet366-2","talkText":"给，这是礼物！\n大家一起挑的哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[17],"voiceId":"TalkSet366-3","talkText":"哇~是什么？\n里面放了什么？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[19],"voiceId":"TalkSet366-4","talkText":"是天文馆的\n门票哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[18],"voiceId":"TalkSet366-5","talkText":"你和小纱夜两个人，\n一起去看吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[17],"voiceId":"TalkSet366-6","talkText":"哇！好的！\n我马上去问问她！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}