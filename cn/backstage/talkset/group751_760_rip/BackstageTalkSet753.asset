{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet753","backstageTalkSetId":753,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet753-1","talkText":"阿嚏","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet753-2","talkText":"CHU、CHU²大人！？\n难道您感冒了！？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet753-3","talkText":"才不是，只是鼻子\n有点不舒服","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet753-4","talkText":"我马上准备一锅很多葱的热火锅\n把身体暖和起来吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet753-5","talkText":"不要蔬菜。\n会让我的身体更不舒服","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}