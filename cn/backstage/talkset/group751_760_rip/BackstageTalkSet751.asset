{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet751","backstageTalkSetId":751,"snippets":[{"talkId":1,"characterIds":[29],"voiceId":"TalkSet751-1","talkText":"不久之前，我和妹妹们\n参加了附近的马拉松大赛","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet751-2","talkText":"虽然很冷\n但是我们还是完美地完成了比赛！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[29],"voiceId":"TalkSet751-3","talkText":"这是那个时候的照片哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[28],"voiceId":"TalkSet751-4","talkText":"哦哦~三姐妹牵着手\n一起冲过了终点呢～","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[28],"voiceId":"TalkSet751-5","talkText":"（分不太清……\n哪一个才是筑筑）","lipAnimation":"","fontColorType":0,"fontSizeType":0,"balloonType":2}]}}