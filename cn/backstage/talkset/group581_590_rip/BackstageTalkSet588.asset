{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet588","backstageTalkSetId":588,"snippets":[{"talkId":1,"characterIds":[12],"voiceId":"TalkSet588-1","talkText":"育美，你的头发上\n沾了花瓣哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet588-2","talkText":"咦？真的？\n帮我取下来嘛~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet588-3","talkText":"不用，维持原状就好。\n你看起来就像樱花精灵一样","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[12],"voiceId":"TalkSet588-4","talkText":"呵呵……真是梦幻啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}