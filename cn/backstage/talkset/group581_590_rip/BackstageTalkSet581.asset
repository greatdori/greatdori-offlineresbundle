{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet581","backstageTalkSetId":581,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet581-1","talkText":"嗯，这下可能\n有点麻烦了……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet581-2","talkText":"怎么了？有什么烦恼的话，\n我可以听你讲讲哦？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[8],"voiceId":"TalkSet581-3","talkText":"我买了太多春装，\n现在钱包面临巨大危机~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8],"voiceId":"TalkSet581-4","talkText":"救救我，巴~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0}]}}