{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet556","backstageTalkSetId":556,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet556-1","talkText":"今天的体育课\n好累啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet556-2","talkText":"是吗？我倒是\n没怎么觉得","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[5],"voiceId":"TalkSet556-3","talkText":"奥泽同学真厉害啊。\n体力很好呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[5],"voiceId":"TalkSet556-4","talkText":"啊，难不成是因为\n米歇尔吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet556-5","talkText":"啊，你说得有道理……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}