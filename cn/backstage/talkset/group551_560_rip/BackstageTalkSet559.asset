{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet559","backstageTalkSetId":559,"snippets":[{"talkId":1,"characterIds":[20],"voiceId":"TalkSet559-1","talkText":"你觉得，用蔬菜的花\n来插花怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[6],"voiceId":"TalkSet559-2","talkText":"蔬菜……\n这个点子挺有趣啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[20],"voiceId":"TalkSet559-3","talkText":"把花椰菜放在正中间，\n然后在周围——","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[6],"voiceId":"TalkSet559-4","talkText":"花椰菜……\n感觉和我想的不太一样","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}