{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet551","backstageTalkSetId":551,"snippets":[{"talkId":1,"characterIds":[22],"voiceId":"TalkSet551-1","talkText":"今井同学做的曲奇\n一直都很美味","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[23],"voiceId":"TalkSet551-2","talkText":"谢谢啦！不过\n我也很喜欢纱夜做的曲奇","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[23],"voiceId":"TalkSet551-3","talkText":"因为我知道\n里面蕴藏着你对大家的心意","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[22],"voiceId":"TalkSet551-4","talkText":"这、这样的话……今井同学\n不也是一样吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}