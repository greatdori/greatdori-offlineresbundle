{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet111","backstageTalkSetId":111,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet111-1","talkText":"喂，里美。\n三二一之后我们一起问吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[3],"voiceId":"TalkSet111-2","talkText":"嗯、嗯……！\n三二一……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3,8],"voiceId":"TalkSet111-3","talkText":"薰学姐为什么\n这么帅啊！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":4,"characterIds":[3],"voiceId":"TalkSet111-4","talkText":"薰同学为什么\n这么帅啊！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet111-5","talkText":"呵呵……\n这个很难一言概括……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet111-6","talkText":"硬要说的话……\n因为我很梦幻吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[3,8],"voiceId":"TalkSet111-7","talkText":"好、好帅……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[18],"voiceId":"TalkSet111-8","talkText":"你们……\n到底哪里帅啊？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}