{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet113","backstageTalkSetId":113,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet113-1","talkText":"啊，彩同学和花音同学！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[16],"voiceId":"TalkSet113-2","talkText":"咦，小巴和\n小绯玛丽，不用打工吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[14],"voiceId":"TalkSet113-3","talkText":"今天有你们两个的\n排班吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[8,9],"voiceId":"TalkSet113-4","talkText":"……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[8],"voiceId":"TalkSet113-5","talkText":"哇~！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":6,"characterIds":[9],"voiceId":"TalkSet113-6","talkText":"我忘得一干二净了！\n快跑，绯玛丽！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1},{"talkId":7,"characterIds":[8],"voiceId":"TalkSet113-7","talkText":"巴、巴，等等我~！\n别丢下我~！","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":2,"balloonType":1}]}}