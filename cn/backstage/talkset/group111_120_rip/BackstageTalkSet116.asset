{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet116","backstageTalkSetId":116,"snippets":[{"talkId":1,"characterIds":[19],"voiceId":"TalkSet116-1","talkText":"扮演米歇尔\n有什么诀窍吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[15],"voiceId":"TalkSet116-2","talkText":"诀窍……这个嘛……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[12],"voiceId":"TalkSet116-3","talkText":"你们在聊米歇尔？\n那我也要加入","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[13],"voiceId":"TalkSet116-4","talkText":"育美也要！\n因为育美最喜欢米歇尔了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[12],"voiceId":"TalkSet116-5","talkText":"我也和育美一样，\n最喜欢米歇尔","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[13],"voiceId":"TalkSet116-6","talkText":"好，那么我们来玩\n米歇尔问答大比拼吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[15],"voiceId":"TalkSet116-7","talkText":"……已经习惯\n这种气氛了呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[19],"voiceId":"TalkSet116-8","talkText":"啊哈哈……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}