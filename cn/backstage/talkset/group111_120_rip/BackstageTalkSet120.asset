{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet120","backstageTalkSetId":120,"snippets":[{"talkId":1,"characterIds":[5],"voiceId":"TalkSet120-1","talkText":"惠惠家的兔子\n还好吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[2],"voiceId":"TalkSet120-2","talkText":"嗯。大家都很好","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[3],"voiceId":"TalkSet120-3","talkText":"而且你养了20只对吧\n太厉害了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[4],"voiceId":"TalkSet120-4","talkText":"兔子们还是\n喜欢吃胡萝卜吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[2],"voiceId":"TalkSet120-5","talkText":"西兰花之类的\n也会吃哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[1],"voiceId":"TalkSet120-6","talkText":"真好啊，\n好想摸摸它们！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}