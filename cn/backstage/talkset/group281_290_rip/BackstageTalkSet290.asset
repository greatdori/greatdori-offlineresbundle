{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet290","backstageTalkSetId":290,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet290-1","talkText":"明天的行程……\n哎呀，没有安排啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[17],"voiceId":"TalkSet290-2","talkText":"最近工作那么多，\n终于可以休息一下了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[18],"voiceId":"TalkSet290-3","talkText":"是啊，虽然工作多是件好事，\n但偶尔也想休息一下呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[17],"voiceId":"TalkSet290-4","talkText":"是啊是啊！明天就尽情\n玩耍吧！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}