{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet285","backstageTalkSetId":285,"snippets":[{"talkId":1,"characterIds":[16],"voiceId":"TalkSet285-1","talkText":"我买了薯条回来~\n小花音要吃吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[14],"voiceId":"TalkSet285-2","talkText":"嗯！谢谢！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[16],"voiceId":"TalkSet285-3","talkText":"一闻到这股味儿，\n我就觉得自己在打工呢","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[14],"voiceId":"TalkSet285-4","talkText":"呵呵，我大概明白你的感受","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}