{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet705","backstageTalkSetId":705,"snippets":[{"talkId":1,"characterIds":[18],"voiceId":"TalkSet705-1","talkText":"哎呀，难道是要讨论\n有关才艺表演大会的事？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[20],"voiceId":"TalkSet705-2","talkText":"各位！\n没错，就是这件事","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[19],"voiceId":"TalkSet705-3","talkText":"表演的规模一大起来，\n准备起来也很困难吧……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[18],"voiceId":"TalkSet705-4","talkText":"确实，薰总会\n说一些没头没脑的话","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[19],"voiceId":"TalkSet705-5","talkText":"一直都是这样的吧。\n呼嘿嘿","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[16],"voiceId":"TalkSet705-6","talkText":"呵呵，大家看上去很开心~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[20],"voiceId":"TalkSet705-7","talkText":"彩同学的队伍\n进展还顺利吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[16],"voiceId":"TalkSet705-8","talkText":"前段时间大家一起彩排了~\n小日菜那里怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[17],"voiceId":"TalkSet705-9","talkText":"我们算是还在\n各自练习吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[17],"voiceId":"TalkSet705-10","talkText":"我在考虑很噜♪的\n新技能……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[19],"voiceId":"TalkSet705-11","talkText":"你再说下去，\n大家都能猜到了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[17],"voiceId":"TalkSet705-12","talkText":"啊，对哦。表演内容\n要一直保密到新年啊","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}