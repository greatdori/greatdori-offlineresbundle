{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet704","backstageTalkSetId":704,"snippets":[{"talkId":1,"characterIds":[24],"voiceId":"TalkSet704-1","talkText":"Chaotic Shot！\n纱夜同学，你觉得这个怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[22],"voiceId":"TalkSet704-2","talkText":"我说过很多遍了，\n我们不需要喊口号","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[25],"voiceId":"TalkSet704-3","talkText":"呵呵……大家是在讨论\n才艺表演大会吗……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[24],"voiceId":"TalkSet704-4","talkText":"是啊！我们的表演很厉害，\n你就好好期待吧，燐燐！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[25],"voiceId":"TalkSet704-5","talkText":"嗯……我们\n也要加油啊……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[21],"voiceId":"TalkSet704-6","talkText":"是啊。从现在开始，\n要更加努力锻炼肺活量了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[25],"voiceId":"TalkSet704-7","talkText":"不、不用……\n那里好像有提供打气筒……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[21],"voiceId":"TalkSet704-8","talkText":"哎呀，是这样吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[23],"voiceId":"TalkSet704-9","talkText":"真羡慕大家啊~队伍里面\n有自己的乐队成员~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[21],"voiceId":"TalkSet704-10","talkText":"莉莎准备的时候\n不是也很开心吗","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[23],"voiceId":"TalkSet704-11","talkText":"很开心啊☆","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[23],"voiceId":"TalkSet704-12","talkText":"我们队的表演规模特别大，\n敬请期待啦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[24],"voiceId":"TalkSet704-13","talkText":"哇，能不能快点\n到新年啊~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}