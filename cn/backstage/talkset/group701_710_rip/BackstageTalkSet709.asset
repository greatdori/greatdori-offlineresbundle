{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet709","backstageTalkSetId":709,"snippets":[{"talkId":1,"characterIds":[11,13],"voiceId":"TalkSet709-1","talkText":"耶！\n新年快乐！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":2,"characterIds":[9],"voiceId":"TalkSet709-2","talkText":"上咯~！\n嘿呀！嘿呀！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":3,"characterIds":[34,35],"voiceId":"TalkSet709-3","talkText":"哦哦~~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[34],"voiceId":"TalkSet709-4","talkText":"好，接下来就轮到我们了。\n一起加油吧♪","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[35],"voiceId":"TalkSet709-5","talkText":"果、果然\n有点太高了！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[34],"voiceId":"TalkSet709-6","talkText":"没事的♪\n垫子也准备好了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[13],"voiceId":"TalkSet709-7","talkText":"没问题的！只要拿出勇气，\n没什么是做不到的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[11],"voiceId":"TalkSet709-8","talkText":"是啊，最重要的是笑容哦。\n大家上吧~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[9,11,13],"voiceId":"TalkSet709-9","talkText":"来吧~笑容~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":2,"balloonType":0},{"talkId":10,"characterIds":[35],"voiceId":"TalkSet709-10","talkText":"Unbelievable……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}