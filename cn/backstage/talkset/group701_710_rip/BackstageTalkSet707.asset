{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet707","backstageTalkSetId":707,"snippets":[{"talkId":1,"characterIds":[26],"voiceId":"TalkSet707-1","talkText":"唔，只有我一个人\n总是做不好……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[29],"voiceId":"TalkSet707-2","talkText":"还有时间，\n只要好好练习，一定没问题的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[28],"voiceId":"TalkSet707-3","talkText":"啊，是说才艺表演大会吗~？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[26],"voiceId":"TalkSet707-4","talkText":"嗯。我手脚很笨，\n所以学起来特别困难……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[29],"voiceId":"TalkSet707-5","talkText":"学姐们也在温柔地\n为你指导，不是吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[26],"voiceId":"TalkSet707-6","talkText":"确实如此，可是……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[28],"voiceId":"TalkSet707-7","talkText":"小白，加油~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[28],"voiceId":"TalkSet707-8","talkText":"唯唯和小TOKO\n也在同一队吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[27],"voiceId":"TalkSet707-9","talkText":"对！我的彩排已经很完美了！\n瑠唯也看到了吧？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[30],"voiceId":"TalkSet707-10","talkText":"除了你忘带东西\n这件事以外","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[27],"voiceId":"TalkSet707-11","talkText":"反正事情最后也解决了，\n有什么关系嘛？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[29],"voiceId":"TalkSet707-12","talkText":"你、你们两个\n别吵了……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[28],"voiceId":"TalkSet707-13","talkText":"每支队伍看起来\n都很辛苦呢~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}