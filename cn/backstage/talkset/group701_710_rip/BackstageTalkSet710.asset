{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet710","backstageTalkSetId":710,"snippets":[{"talkId":1,"characterIds":[8],"voiceId":"TalkSet710-1","talkText":"嘿！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[18],"voiceId":"TalkSet710-2","talkText":"看招！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[4],"voiceId":"TalkSet710-3","talkText":"嘿咿","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[2],"voiceId":"TalkSet710-4","talkText":"锵~！\n小欧登场咯~","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[31],"voiceId":"TalkSet710-5","talkText":"哇……\n呵呵，好可爱","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[18],"voiceId":"TalkSet710-6","talkText":"最后是大招呢。\n你们俩加油哦","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[2,8],"voiceId":"TalkSet710-7","talkText":"要上咯~\n来吧~~！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[4],"voiceId":"TalkSet710-8","talkText":"好厉害！\n飞出来好多","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[18],"voiceId":"TalkSet710-9","talkText":"你、你们俩等一下……？\n这已经够了吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[8],"voiceId":"TalkSet710-10","talkText":"其、其实是……\n停、停不下了~~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[2],"voiceId":"TalkSet710-11","talkText":"嗯，我觉得新年\n热闹一点也不错","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[31],"voiceId":"TalkSet710-12","talkText":"呵呵，是啊。\n今年一定会收获很多的","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[8],"voiceId":"TalkSet710-13","talkText":"真是的~！别说话了，\n谁来阻止一下她们啊~~！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}