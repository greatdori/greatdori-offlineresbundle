{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet706","backstageTalkSetId":706,"snippets":[{"talkId":1,"characterIds":[15],"voiceId":"TalkSet706-1","talkText":"你们两个的才艺表演\n真的没问题吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":2,"characterIds":[13],"voiceId":"TalkSet706-2","talkText":"嗯！完全准备好了！\n对吧，小心心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[11],"voiceId":"TalkSet706-3","talkText":"美咲是在\n担心什么呢？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[11],"voiceId":"TalkSet706-4","talkText":"我会和育美一起\n让大家露出笑容的！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[15],"voiceId":"TalkSet706-5","talkText":"正因为是心和育美，\n我才会担心！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[12],"voiceId":"TalkSet706-6","talkText":"呵呵……美咲的那份\n为同伴着想的心意……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[12],"voiceId":"TalkSet706-7","talkText":"啊，太梦幻了","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[14],"voiceId":"TalkSet706-8","talkText":"呵呵……那小美咲的\n队伍进展顺利吗？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[15],"voiceId":"TalkSet706-9","talkText":"嗯，我们还行吧。\n我姑且算有经验","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[14],"voiceId":"TalkSet706-10","talkText":"有经验……？\n你们要做什么啊……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[15],"voiceId":"TalkSet706-11","talkText":"啊！不行，\n这得要保密……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[11],"voiceId":"TalkSet706-12","talkText":"一定是用笑容招来笑容的\n『微笑隐藏才艺』！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[13],"voiceId":"TalkSet706-13","talkText":"小美的微笑隐藏才艺，\n我好期待啊~~！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[12],"voiceId":"TalkSet706-14","talkText":"我也很期待\n美咲令人捧腹大笑的隐藏才艺","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[15],"voiceId":"TalkSet706-15","talkText":"你们提高难度的方式……\n也太非同寻常了吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}