{"Base":{"m_GameObject":{"m_FileID":0,"m_PathID":"0000000000000000"},"m_Enabled":1,"m_Script":{"m_FileID":0,"m_PathID":"1f51ca899d1e54c9"},"m_Name":"BackstageTalkSet708","backstageTalkSetId":708,"snippets":[{"talkId":1,"characterIds":[35],"voiceId":"TalkSet708-1","talkText":"我也要表演\n隐藏才艺吗！？Why！？","lipAnimation":"mouth_shout","fontColorType":0,"fontSizeType":0,"balloonType":1},{"talkId":2,"characterIds":[34],"voiceId":"TalkSet708-2","talkText":"能和CHU²大人在同一支队伍，\nPAREO很开心哦！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":3,"characterIds":[35],"voiceId":"TalkSet708-3","talkText":"我没说这个！\n而是觉得没有表演的必要！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":4,"characterIds":[31],"voiceId":"TalkSet708-4","talkText":"益木和LOCK的队伍\n进展怎么样？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":5,"characterIds":[32],"voiceId":"TalkSet708-5","talkText":"啊！我们队有彩学姐\n在带领我们……！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":6,"characterIds":[33],"voiceId":"TalkSet708-6","talkText":"我们队现在\n也算很顺利吧","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":7,"characterIds":[34],"voiceId":"TalkSet708-7","talkText":"那个，LAYER同学队伍的\n成员好像是……","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":8,"characterIds":[31],"voiceId":"TalkSet708-8","talkText":"嗯，我和小花在一起。\n所以练习也很快乐","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":9,"characterIds":[31],"voiceId":"TalkSet708-9","talkText":"而且\n小欧也在","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":10,"characterIds":[34],"voiceId":"TalkSet708-10","talkText":"小欧，\n就是那只……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":11,"characterIds":[31],"voiceId":"TalkSet708-11","talkText":"对的对的。\n小花养的那只——","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":12,"characterIds":[35],"voiceId":"TalkSet708-12","talkText":"Stop！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":13,"characterIds":[35],"voiceId":"TalkSet708-13","talkText":"说好了才艺表演的内容\n要保持Secret","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":14,"characterIds":[32],"voiceId":"TalkSet708-14","talkText":"CHU²同学……你其实\n很期待吧……？","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0},{"talkId":15,"characterIds":[35],"voiceId":"TalkSet708-15","talkText":"啰、啰嗦！！","lipAnimation":"mouth_normal","fontColorType":0,"fontSizeType":0,"balloonType":0}]}}