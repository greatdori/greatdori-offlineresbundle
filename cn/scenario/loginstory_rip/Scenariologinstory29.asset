renceIndex":64,"delay":3,"isWaitForSkipMode":0},{"actionType":1,"progressType":1,"referenceIndex":47,"delay":0,"isWaitForSkipMode":0}],"talkData":[{"talkCharacters":[{"characterId":32}],"windowDisplayName":"勇者洛可","body":"（呼啊，呼啊，呼啊~……\n终于来到这里了……）","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":32,"voiceId":"senkyostory4-001","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"勇者洛可","body":"（不愧是魔王军的根据地，被一股不祥的黑暗气息笼罩着。\n要是掉以轻心的话，可能会被黑暗吞噬……）","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":32,"voiceId":"senkyostory4-002","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"勇者洛可","body":"（可是……我不能害怕！\n为了拯救被魔王军掳走的珍柏公主，\n为了再次给世界带来光明，我必须前进！……唔！！）","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":32,"voiceId":"senkyostory4-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"勇者洛可","body":"唔！！魔王军这么快就来迎接我了！！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":32,"voiceId":"senkyostory4-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"？？？","body":"呼嗯~……\n竟然能避开我的魔法，不愧是传说中的勇者","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":4,"voiceId":"senkyostory4-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"勇者洛可","body":"你、你是——\n魔王军四天王之一的面点师·珊吹……！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":32,"voiceId":"senkyostory4-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"四天王珊吹","body":"呵呵，居然能走到这里，值得夸赞哦。\n但你居然不知道这是个陷阱！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"senkyostory4-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":32}],"windowDisplayName":"勇者洛可","body":"陷、陷阱！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":32,"voiceId":"senkyostory4-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":4}],"windowDisplayName":"四天王珊吹","body":"正是。也就是说，这将是你的葬身之处。\n刚才那招被你躲过去了，接下来，让你尝尝这个吧~？\n我的终极魔法——巨型面包屑裹粉机","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":4,"motionName":"nnf04","expressionName":"kime01","timingSyncValue":0}],"voices":[{"characterId":4,"voiceId":"senkyostory4-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"wi