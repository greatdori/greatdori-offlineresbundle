:0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈绪","body":"久等了！那就继续练习……\n怎么了，大家都一脸严肃的样子","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-07-042","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event257-07-043","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈绪","body":"你们为什么一起看着手机？\n让我看一下……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-07-044","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈绪","body":"……这样啊。被你们看见了啊","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-07-045","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"奈绪小姐……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event257-07-046","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈绪","body":"虽然我们找各种地方交涉过，\n但最后好像还是被强行报道了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-07-047","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"奈绪小姐，莫非你那时候\n收到的邮件……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nnf02","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event257-07-048","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈绪","body":"嗯。\n在这么重要的时期还影响到你们，真的很对不起","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"nnf04","expressionName":"sad01","timingSyncValue":0}],"voices":[{"characterId":226,"voiceId":"event257-07-049","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":226}],"windowDisplayName":"奈绪","body":"这件事说来话长……\n能让我亲口向你们解释一下吗？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":226,"motionName":"nnf01","ex