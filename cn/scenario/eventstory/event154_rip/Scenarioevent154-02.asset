ferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":221}],"windowDisplayName":"巽","body":"看你们的样子，应该是用了那个身体乳吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":221,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":221,"voiceId":"event154-02-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"伊芙","body":"为、为什么你会知道！？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event154-02-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":221}],"windowDisplayName":"巽","body":"我之前也从『超超祭典』实行委员会的人那里收到身体乳，\n不小心用了一下……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":221,"motionName":"sad02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":221,"voiceId":"event154-02-036","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"啊……那还是真是挺够呛的呢……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"event154-02-037","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":221}],"windowDi