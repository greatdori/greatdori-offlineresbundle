],"windowDisplayName":"千圣","body":"大家……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event154-06-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千圣","body":"（冷静下来想想的话，\n在工作人员把设备调整好之前，\n专业人士应该保持良好的状态才对）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf03","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event154-06-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千圣","body":"（但是，除此之外，她还要带动所有人。\n只要能让观众们露出笑容，她愿意克服一切困难。\n我们的队长……就是这样的人呢）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf01","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event154-06-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":18}],"windowDisplayName":"千圣","body":"真是的……\n在我过去之前，那边就拜托你了。小彩……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":18,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":18,"voiceId":"event154-06-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"大、大家！晚上好！\n抱歉让你们久等了……！\n我是Pastel＊Palettes的主唱，丸山彩！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"bye01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"在演出之前，呃……对、对了！\n来说说佐贺的事情吧！我是第一次来佐贺，\n有很多让我惊讶的事情……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"观众A","body":"好、好像开始闲谈了，\n果然演出还没有开始啊……？","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"观众B","body":"走吧走吧。也花太长时间了。\n我还想看祭典呢——","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":221}],"windowDisplayName":"巽","body":"……Pastel＊Palettes也只有这种程度而已吗","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":221,"motionName":"sad01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":221,"voiceId":"event154-06-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"（这样下去，大家都会走的……！\n难得他们特意来看我们的演出……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"odoodo01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"那个，接下来我准备唱歌！\n所以……请大家欣赏我们的演出，直到最后吧！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nnf02","expressionName":"serious01","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"观众A","body":"清唱……？\n也就是说，其他成员还不出场？","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"（观众们看起来还是非常不安……）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"（其他成员没有出现，他们会不安也是理所当然的。\n但是……\n我会努力抓住观众们的心，直到大家回来为止！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"（我要把我自己这一瞬间非常高兴的心情，传达给大家……！\n所以，观众们，请聆听我的歌声吧……！）","tention":0,"lipSyncMode":2,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"event154-06-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"观众A","body":"会场的气氛明明这么尴尬……\n她却满脸笑容……高兴地唱着歌","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":0}],"windowDisplayName":"观众B","body":"嗯，哪怕只有一个人，她仍然闪闪发光……\n总觉得很难把目光从她身上移开……！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[],"voices":[{"characterId":0,"voiceId":"#NAME?","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":221}],"windowDisplayName":"巽","body":"……看来，并没有『死』啊","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":221,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":221,"voiceId":"event154-06-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":1,"requirePlayEff