","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"对我来说，月之森是一个\n可以获取有益知识的地方","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event251-06-003","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":30}],"windowDisplayName":"瑠唯","body":"以前的我，为了了解拥有什么样的才能，\n靠什么才能取得第一名，满脑子只想着提升自己","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":30,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":30,"voiceId":"event251-06-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"嗯，我记得。刚开始的时候，\n唯唯就算和我们在一起，也是一副事不关己的样子呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event251-06-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":28}],"windowDisplayName":"七深","body":"但是，在一起的时间久了以后，\n你好像渐渐变得柔和起来了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":28,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":28,"voiceId":"event251-06-006","volume":1}],"speed":0,"fontSize":0,"whenFinishC