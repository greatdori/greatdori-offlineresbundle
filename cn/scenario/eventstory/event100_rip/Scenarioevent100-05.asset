racterId":320}],"windowDisplayName":"千圣","body":"算了，小薰","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":321}],"windowDisplayName":"薰","body":"诶……？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":321,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":321,"voiceId":"event100-05-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千圣","body":"我已经不在意了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nnf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千圣","body":"只要小薰、妈妈和妹妹……还有Leo……\n我最喜欢的大家，\n能理解我就足够了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":320,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":320,"voiceId":"event100-05-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":320}],"windowDisplayName":"千圣","body":"不管其他人怎么想我都不在意，\n毕竟当女演员的人，是我自己","tention":0,"lipSyncMode":1,"motionCh