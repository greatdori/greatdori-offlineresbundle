:0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":220}],"windowDisplayName":"志乃","body":"好、好的！初次见面。\n我是小金井志乃！\n请多关照！！","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":220,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":20}],"windowDisplayName":"伊芙","body":"诶？上次联合练习的时候志乃同学就在吧？\n应该不是初次见面吧……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":20,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":20,"voiceId":"event135-02-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":220}],"windowDisplayName":"志乃","body":"那、那个……\n我担心大家已经\n不记得我了！","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":220,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":220}],"windowDisplayName":"志乃","body":"如果大家已经不记得我了，我却说『好久不见』的话，\n大家岂不是会想『这是谁啊？』，\n所以我就说『初次见面』了","tention":0,"lipSyncMode":0,"motionChangeFactor":1,"motions":[{"characterId":220,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":220}],"windowDisplayName":"志乃","body":"啊，对不起！我也不知道自己在说什么！\n……诶？怎么办，总、总之！\n请多关照！！","tention":0,"lipSyncMode":0,"moti