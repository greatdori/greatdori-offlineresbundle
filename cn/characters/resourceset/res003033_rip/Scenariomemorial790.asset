haracterId":3}],"windowDisplayName":"里美","body":"不是的，前些日子和小育美她们去赏枫的时候，\n那里有手绘信体验教室，我在那里画的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev95-me1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"小里美画了什么样的画？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev95-me1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"很普通……就是枫叶。\n我体验皮艇的时候看到的枫叶非常漂亮……\n啊，那个时候我还录了视频呢，呃……找到了，就是这个","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev95-me1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呜哇……非常风雅，很美呢。\n看到画了这么漂亮的景色的手绘信，\n小百合一定也会开心的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev95-me1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"诶嘿嘿，这是我非常努力画下来的，\n能让姐姐开心就太好了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev95-me1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"她一定能明白你的心意。\n这个视频也要发给小百合吗？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev95-me1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"是的，我去那里原本就是打算拍摄视频信的。\n拍的时候，一起去的其他人还帮了我，\n我觉得拍得很棒","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev95-me1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呵呵，能看到可爱的妹妹如此开心的样子，\n小百合一定会很开心的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev95-me1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"说起来，前几天打电话的时候，姐姐也说\n给我寄了明信片。\n希望能早点收到呢~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev95-me1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"呵呵，既然是小百合寄的，\n那一定是设计很棒的明信片吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev95-me1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"嗯，所以我非常期待！\n等我收到了，也会让麻里奈小姐和\n{{userName}}看看的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev95-me1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"哇，谢谢！\n听你这么一说，连我也开始期待\n收到的明信片了呢~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev95-me1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"不过，姐妹互相写信，\n感觉好棒呢，真是让人向往","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"c