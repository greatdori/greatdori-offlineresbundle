ySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"嗯，不过没关系。\n昨天也说过了，我有重要的同伴陪在我的身旁","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev72-ep2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"只要和大家在一起，无论之后遇到什么样的事情\n我都能继续努力……因为我并不孤单","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"serious01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev72-ep2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"百合","body":"是啊，里美你并不孤单。\n你有活泼又可靠的同伴，\n我也能放下心来，专心做自己的事情了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":302,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":302,"voiceId":"ev72-ep2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"百合","body":"我现在就开始期待了，等我回来的时候\n里美你们会成长多少呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":302,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":302,"voiceId":"ev72-ep2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"嗯……我会竭尽全力去努力，\n好让姐姐回来时夸奖我的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev72-ep2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"百合","body":"我会留下几样器材和乐谱，\n喜欢的话就用吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":302,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":302,"voiceId":"ev72-ep2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"百合","body":"还有……把放在房间正中央的床\n移到边上去吧。\n大家来玩的时候会碍事的","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":302,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":302,"voiceId":"ev72-ep2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":3}],"windowDisplayName":"里美","body":"这……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":3,"motionName":"odoodo02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":3,"voiceId":"ev72-ep2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":302}],"windowDisplayName":"百合","body":"怎么了？","tention":0,"l