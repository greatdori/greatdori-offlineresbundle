indow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"真让人怀念啊，在文化节上表演的『罗密欧与朱丽叶』。\n薰同学饰演罗密欧，千圣同学饰演朱丽叶，\n那次大受好评呢！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nod01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"我也在舞台侧面观看了你们的表演，非常吸引人！\n真是一段美好的回忆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"嗯，这就证明一次次的练习没有白费","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"说到练习……在演出服做好以后，\n大家不是穿着演出服，从头到尾排练了一次吗","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"我还记得，穿着演出服的薰同学和千圣同学\n演技一下子变得更好了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"嗯，我也记得那时的感觉哦。\n穿上演出服后，就觉得自己更贴近罗密欧这个角色了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nod01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"俗话说『入戏先从外形开始』，\n这句话真是一点都没说错呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"是啊。所谓戏剧，就是要化身为并非自己的另一个人。\n因此即使饰演相同的角色，若是穿上不同的演出服，\n也会呈现出不一样的气质吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"演出服不一样，气质也会改变吗……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"你怎么了，麻弥？\n有什么让你在意的事情吗？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"啊，没有。\n我最近正好遇到了同样的情况，\n刚刚想起了这件事……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"哦……这还真是让人感兴趣，能讲给我听听吗？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"好的。平时很关照我们的节目导演\n举办了一场婚礼，然后\nPasPale的所有成员都参加了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"那位导演穿婚纱的样子\n漂亮得让人看到出神","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"呵呵，竟然能夺走我的小猫咪的心，\n真令人嫉妒","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"啊哈哈……\n然后，她平时总是穿着工作服，\n我们都没见过她盛装打扮的模样。但是……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"看到她穿婚纱的样子，我真的非常惊讶。\n只是穿上了礼服而已，\n一个人的气质竟然会发生这么大的变化","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-028","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"她明明是我们很熟悉的人，\n看起来却完全像个陌生人……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nod01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-029","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"这个例子可能有些偏差，\n但应该也算『衣服成就了角色』吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-030","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"呵呵，其实也没什么差别。\n就如同我穿上罗密欧的演出服后会更投入地表演一样，\n不管是谁，只要改变了着装，就会努力成为与之相符的自己","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nnf01","expressionName":"smile01","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-031","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"比如说……穿上优雅的长裙，\n就会产生自己是贵妇人的心境，\n一举一动都会变得高贵动人","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-032","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"如果穿上成熟的双排扣风衣，\n就会觉得自己仿佛化身为了一名刑警，\n步履也会变得自信飒爽……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-033","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":19}],"windowDisplayName":"麻弥","body":"确实，我多少能理解","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":19,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":19,"voiceId":"ev188-ep2-034","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"一套衣服就可以改变心态。\n心态的转变会自然地影响站姿、动作、气质……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2-035","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":12}],"windowDisplayName":"薰","body":"这就是服装拥有的力量……\n说是服装的魔法也不过分吧","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":12,"motionName":"nod01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":12,"voiceId":"ev188-ep2