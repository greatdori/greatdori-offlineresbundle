ices":[{"characterId":201,"voiceId":"ev109-me5-024","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":201}],"windowDisplayName":"麻里奈","body":"啊，我问你哦。\n如果有开始音乐活动的新人对你说\n『请教教我！』，你会怎么做？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":201,"motionName":"smile01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":201,"voiceId":"ev109-me5-025","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"绯玛丽","body":"诶~~！该怎么办呢！好开心！！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"shame01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"ev109-me5-026","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"绯玛丽","body":"不懂的事我都想教给她们呢。\n甚至我还会操很多心，\n然后对她们关照有加","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"ev109-me5-027","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":8}],"windowDisplayName":"绯玛丽","body":"不过，兰大概会来阻止我，\n然后对我说\n『这些事不该由绯玛丽来管』吧~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":8,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":8,"voiceId":"ev109-me5-028","volum