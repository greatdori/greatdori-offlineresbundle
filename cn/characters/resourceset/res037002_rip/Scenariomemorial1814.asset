":[{"characterId":37,"voiceId":"memorial-r-anon-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"……诶，我刚才是不是很帅气？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"kime01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"真想让Rikki也看看啊~\n我很帅气吧？诶嘿嘿嘿","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"所以，新教材我也一定会学好的！\n请期待我的表现哦","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf05","expressionName":"kime01","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"我现在感兴趣的是这本教材！\n书评看起来不错，就选这本吧……啊","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-017","volume":1}],"s