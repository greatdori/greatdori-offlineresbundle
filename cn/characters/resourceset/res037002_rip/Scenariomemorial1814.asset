"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"很厉害吗？诶嘿嘿嘿~是吧~\n我很努力的~","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"kandou01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"看演出时，也请关注一下我努力的样子哦！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"wink01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"如果是以前的我，多半连一开始买的教材都没有坚持学完，\n只是觉得自己会弹一点了，就半途而废了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":37,"voiceId":"memorial-r-anon-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":37}],"windowDisplayName":"爱音","body":"好好坚持下去。然后，迈向下一个阶段……\n所谓全力以赴，原来就是这样的呢","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":37,"motionName":"nnf05","expressionNa