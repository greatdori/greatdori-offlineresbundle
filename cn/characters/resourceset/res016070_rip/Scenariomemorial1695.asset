nceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"虽然还没有开花，\n但已经有花苞要绽放了。你看，这边也有……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-004","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"它比周围的樱花树开得晚……\n但正因为这样，我才更想为它加油……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-005","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"到入学典礼的时候，一定就全部绽放了吧……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-006","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"话说回来，我看过花女毕业典礼的留言板了！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-007","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"能得到{{userName}}\n那么美好的祝语，\n我真的很开心！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"gattsu01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-008","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"对了，我拍了留言板的纪念照……\n看，像这样放大照片的话……\n大家的留言都能看得清清楚楚哦！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-009","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"我还拍了很多别的照片……\n这张是和小千圣在校门口一起拍的照片，\n这张是和小伊芙在教学楼的走廊拍的照片！还有……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-010","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"诶？你问我拍了多少张？","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-011","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"这个啊……嗯……大概有200张？\n啊，这个文件夹里还有在CiRCLE拍的\n庆功宴照片，或许不止200张！","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"eeto01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-012","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"……呵呵，不管是哪张照片，大家的表情都很棒呢。\n有哭，有笑……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-013","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"……刚进入花女的时候，\n我根本没想到自己会以这样的心情迎接毕业典礼","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-014","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"啊，那个……我在一年级的时候还是练习生……\n当时几乎没有同学知道\n我的志向是成为偶像","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-015","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"毕竟我很少主动说\n『我的目标是成为偶像』……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nnf01","expressionName":"smile03","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-016","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"不过，成为PasPale的一员后……\n我变得能够挺起胸膛，\n说出『我是一名偶像』了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-017","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"我想，这应该不是因为我真的成为了偶像……\n而是因为和PasPale的大家度过的时光，\n让我对自己有了信心","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-018","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"而且，我在班上也交到了许多朋友……\n留下了很多快乐的回忆","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile04","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-019","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"我的高中生活真的过得很充实，\n可以说『我把想做的事情都做了！』……\n我由衷地觉得，自己能成为花女的学生真是太好了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nf05","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-020","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"所以，今后我想挺起胸膛，\n对粉丝们说出\n『我是花女的毕业生！』","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"nnf02","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-021","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"……诶？身为偶像，报出毕业学校的名字有点不合适……？\n嗯~我觉得还好吧~\n和小千圣商量一下好了","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"surprised01","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-022","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"……不过，一想到和大家关系这么好，\n却很快就要很难见到大家了，我就……\n呜呜……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motionName":"smile03","expressionName":"default","timingSyncValue":0}],"voices":[{"characterId":16,"voiceId":"ev215-me1-023","volume":1}],"speed":0,"fontSize":0,"whenFinishCloseWindow":0,"requirePlayEffect":0,"effectReferenceIdx":0,"requirePlaySound":0,"soundReferenceIdx":0,"whenStartHideWindow":0},{"talkCharacters":[{"characterId":16}],"windowDisplayName":"彩","body":"啊，手帕……不好意思……","tention":0,"lipSyncMode":1,"motionChangeFactor":1,"motions":[{"characterId":16,"motion